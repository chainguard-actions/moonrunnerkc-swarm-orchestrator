+			switch (fallbackDecision.type) {
+				case 'redirect':
+					return new Response(null, {
+						status: 302,
+						headers: { Location: fallbackDecision.pathname + url.search },
+					});
+				case 'rewrite':
+					return await state.rewrite(fallbackDecision.pathname + url.search);
+				case 'none':
+					break;
+			}
+		}
