+		font-size: 0.85em;
+	}
+
+	.form-card {
+		background: #1a1d27;
+		border: 1px solid #2a2d3a;
+		border-radius: 8px;
+		padding: 1.5rem;
+		margin-top: 1.5rem;
+	}
+
+	.field {
+		margin-bottom: 1rem;
+	}
+
+	label {
+		display: block;
+		font-size: 0.875rem;
+		color: #8b8fa3;
+		margin-bottom: 0.375rem;
+	}
+
+	input {
+		width: 100%;
+		padding: 0.5rem 0.75rem;
