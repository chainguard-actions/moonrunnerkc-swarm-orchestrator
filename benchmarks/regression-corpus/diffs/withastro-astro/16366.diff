+		font-size: 1.75rem;
+		font-weight: 700;
+		margin-bottom: 1rem;
+	}
+
+	p {
+		color: #8b8fa3;
+		line-height: 1.6;
+		margin-bottom: 1rem;
+	}
+
+	code {
+		background: #1a1d27;
+		border: 1px solid #2a2d3a;
