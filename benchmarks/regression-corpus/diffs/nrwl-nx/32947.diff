+
+describe('Maven (Simple)', () => {
+  let mavenProjectName = uniq('my-maven-project');
+
+  beforeAll(async () => {
+    createEmptyProjectDirectory(mavenProjectName);
+    await createMavenProject(mavenProjectName);
+    openInEditor();
+    runCLI('init --no-interactive');
+    runCLI(`add @nx/maven`);
+  });
+
+  afterAll(() => cleanupProject());
+
