+		if (days == 1) {
+			return `after ${days} day`;
+		} else {
+			return `after ${days} days`;
+		}
+	} else if (condition.type === "Date" && condition.date) {
+		const date = new Date(condition.date);
+		const displayDate = date.toISOString().split("T")[0];
+		return `on ${displayDate}`;
