+function sortObjectKeys<T extends Record<string, unknown>>(obj: T | undefined): T | undefined {
+  if (!obj) {
+    return obj;
+  }
+  const sortedKeys = Object.keys(obj).sort((a, b) => {
+    return a.toLowerCase().localeCompare(b.toLowerCase());
+  });
