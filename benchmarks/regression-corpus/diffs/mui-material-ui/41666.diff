+import VariantButtonGroup from '../../../../../docs/data/material/components/button-group/VariantButtonGroup.tsx';
+
+export default function ButtonGroup() {
+  return (
+    <MaterialUILayout>
+      <h1>Button-group</h1>
+      <section>
