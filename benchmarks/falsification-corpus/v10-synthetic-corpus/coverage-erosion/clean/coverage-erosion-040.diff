diff --git a/src/coverage-40.ts b/src/coverage-40.ts
--- a/src/coverage-40.ts
+++ b/src/coverage-40.ts
@@ -1,3 +1,6 @@
 export function step40(x: number): number {
+  if (x < 0) {
+    return -1;
+  }
   return x * 2;
 }
