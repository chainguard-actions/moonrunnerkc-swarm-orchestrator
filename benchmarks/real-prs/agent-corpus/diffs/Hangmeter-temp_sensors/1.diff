new file mode 100644
index 0000000..663db03
--- /dev/null
+++ b/main/Kconfig.projbuild
@@ -0,0 +1,81 @@
+menu "Temp sensors configuration"
+
+    menu "GPIO pins"
+
+        config TEMP_SENSORS_DHT_GPIO_PIN
+            int "DHT sensor GPIO pin"
+            range 0 48
+            default 10
+            help
+                GPIO pin number connected to the DHT sensor data line.
+
+        config TEMP_SENSORS_BH1750_SDA_GPIO_PIN
+            int "BH1750 I2C SDA GPIO pin"
+            range 0 48
+            default 18
+            help
+                GPIO pin number used as the I2C SDA line for the BH1750 sensor.
+
+        config TEMP_SENSORS_BH1750_SCL_GPIO_PIN
+            int "BH1750 I2C SCL GPIO pin"
+            range 0 48
+            default 19
+            help
+                GPIO pin number used as the I2C SCL line for the BH1750 sensor.
+
+        config TEMP_SENSORS_LED_RED_GPIO_PIN
+            int "Red LED GPIO pin"
+            range 0 48
+            default 3
+            help
+                GPIO pin number connected to the red status LED.
+
+        config TEMP_SENSORS_LED_GREEN_GPIO_PIN
+            int "Green LED GPIO pin"
+            range 0 48
+            default 4
+            help
+                GPIO pin number connected to the green status LED.
+
+        config TEMP_SENSORS_LED_BLUE_GPIO_PIN
+            int "Blue LED GPIO pin"
+            range 0 48
+            default 5
+            help
+                GPIO pin number connected to the blue status LED.
+
+    endmenu
+
+    menu "Wi-Fi"
+
+        config TEMP_SENSORS_WIFI_SSID
+            string "Wi-Fi SSID"
+            default "GL_AXT1800"
+            help
+                Wi-Fi network SSID used by the station interface.
+
+        config TEMP_SENSORS_WIFI_PASSWORD
+            string "Wi-Fi password"
+            default "WRHD24ERWM"
+            help
+                Wi-Fi network password used by the station interface.
+
+    endmenu
+
+    menu "MQTT"
+
+        config TEMP_SENSORS_MQTT_BROKER_URL
+            string "MQTT broker URL"
+            default "mqtt://192.168.8.126"
+            help
+                MQTT broker URI used to initialize the MQTT client.
+
+        config TEMP_SENSORS_MQTT_TOPIC
+            string "MQTT publish topic"
+            default "esp32-e6e4/env"
+            help
+                MQTT topic where environment measurements are published.
+
+    endmenu
+
+endmenu
