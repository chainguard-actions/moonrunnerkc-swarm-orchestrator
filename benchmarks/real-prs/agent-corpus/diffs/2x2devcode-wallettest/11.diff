+                                    blockHeight = detail.blockHeight,
+                                    spent = false
+                                )
+                            )
+                        }
+                    }
+                }
+                start += TX_PAGE_SIZE
+                if (page.size < TX_PAGE_SIZE) return@repeat
+            }
+        }
+        reconcileUtxos(addresses, utxoDao)
+    }
