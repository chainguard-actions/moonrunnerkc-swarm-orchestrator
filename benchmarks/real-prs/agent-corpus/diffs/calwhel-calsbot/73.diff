+async function _bulkDeleteChunk(strategyIds){
+  const r=await fetch(`/api/strategies/bulk-delete?uid=${encodeURIComponent(UID)}`,{
+    method:'POST',
+    credentials:'same-origin',
+    headers:{'Content-Type':'application/json'},
+    body:JSON.stringify({uid:UID,strategy_ids:strategyIds}),
+  });
+  let d={};
+  const raw=await r.text();
+  try{d=raw?JSON.parse(raw):{};}catch(_){d={detail:raw||`HTTP ${r.status}`};}
+  if(!r.ok){
+    const msg=typeof d.detail==='string'?d.detail:(Array.isArray(d.detail)?d.detail.map(x=>x.msg||x).join(', '):'Bulk delete failed');
+    throw new Error(msg||`HTTP ${r.status}`);
+  }
+  return d;
+}
