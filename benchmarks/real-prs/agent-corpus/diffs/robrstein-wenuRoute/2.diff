+"""Tests for HTML graph rendering."""
+
+from __future__ import annotations
+
+from wenuroute.graph import _infer_layer, _serialise_node, _truncate_label, render_html
+from wenuroute.models import NodeKind, RouteEdge, RouteGraph, RouteNode
+
+
+class TestRenderHtml:
+    def test_render_html_includes_interactive_controls(self, tmp_path):
+        graph = RouteGraph()
+        graph.add_node(
+            RouteNode(
+                id="frontend:page",
+                label="PaginaProductos",
+                kind=NodeKind.UI_ELEMENT,
+                file="src/pages/productos.jsx",
+                line=12,
+            )
+        )
+        graph.add_node(
+            RouteNode(
+                id="backend:endpoint",
+                label="GET /productos",
+                kind=NodeKind.ENDPOINT,
+                file="api/app.py",
+                line=24,
+                metadata={"framework": "flask"},
+            )
+        )
+        graph.add_node(
+            RouteNode(
+                id="db:pkg",
+                label="Pkg_productos",
+                kind=NodeKind.SQL,
+                file="db/packages.sql",
+                line=8,
+            )
+        )
+        graph.add_node(
+            RouteNode(
+                id="android:screen",
+                label="ProductosActivity",
+                kind=NodeKind.UI_ELEMENT,
+                file="android/app/src/main/java/com/example/ProductosActivity.kt",
+                line=4,
+            )
+        )
+        graph.add_edge(RouteEdge("frontend:page", "backend:endpoint", "calls"))
+        graph.add_edge(RouteEdge("backend:endpoint", "db:pkg", "query"))
+        graph.add_edge(RouteEdge("frontend:page", "android:screen", "opens"))
+
+        output = tmp_path / "graph.html"
+        render_html(graph, output)
+
+        html = output.read_text(encoding="utf-8")
+        assert 'id="searchInput"' in html
+        assert 'id="layer-Frontend"' in html
+        assert 'id="layer-Backend"' in html
+        assert 'id="layer-Android"' in html
+        assert 'id="layer-BD"' in html
+        assert 'doubleClick' in html
+        assert 'Pkg_productos' in html
+        assert '"layer": "Frontend"' in html
+        assert '"layer": "Backend"' in html
+        assert '"layer": "Android"' in html
+        assert '"layer": "BD"' in html
+
+    def test_render_html_skips_edges_with_missing_nodes(self, tmp_path):
+        graph = RouteGraph()
+        graph.add_node(
+            RouteNode(
+                id="frontend:page",
+                label="Home",
+                kind=NodeKind.UI_ELEMENT,
+                file="src/home.jsx",
+                line=1,
+            )
+        )
+        graph.add_edge(RouteEdge("frontend:page", "backend:missing", "calls"))
+        graph.add_edge(RouteEdge("backend:missing", "frontend:page", "calls"))
+
+        output = tmp_path / "graph.html"
+        render_html(graph, output)
+
+        html = output.read_text(encoding="utf-8")
+        assert "backend:missing" not in html
+        assert '"from": "frontend:page"' not in html
+        assert '"to": "frontend:page"' not in html
+
+
+class TestGraphHelpers:
+    def test_infer_layer_uses_kind_extension_and_framework(self):
+        assert _infer_layer(RouteNode(id="sql", label="SQL", kind=NodeKind.SQL, file="db/query.sql")) == "BD"
+        assert _infer_layer(
+            RouteNode(
+                id="backend",
+                label="GET /users",
+                kind=NodeKind.ENDPOINT,
+                file="server/routes.js",
+                metadata={"framework": "express"},
+            )
+        ) == "Backend"
+        assert _infer_layer(
+            RouteNode(
+                id="frontend",
+                label="Home",
+                kind=NodeKind.UI_ELEMENT,
+                file="src/pages/home.tsx",
+            )
+        ) == "Frontend"
+        assert _infer_layer(
+            RouteNode(
+                id="android",
+                label="MainActivity",
+                kind=NodeKind.UI_ELEMENT,
+                file="android/app/src/main/java/MainActivity.kt",
+            )
+        ) == "Android"
+
+    def test_truncate_label_adds_ellipsis_only_when_needed(self):
+        assert _truncate_label("Short label") == "Short label"
+        assert _truncate_label("X" * 60).endswith("...")
+        assert len(_truncate_label("X" * 60)) == 48
+
+    def test_serialise_node_includes_expected_fields(self):
+        node = RouteNode(
+            id="frontend:products",
+            label="PaginaProductos",
+            kind=NodeKind.UI_ELEMENT,
+            file="src/pages/productos.jsx",
+            line=9,
+            params=["onClick"],
+            metadata={"screen": "productos"},
+        )
+
+        payload = _serialise_node(node)
+
+        assert payload["id"] == "frontend:products"
+        assert payload["layer"] == "Frontend"
+        assert payload["kind"] == "ui_element"
+        assert payload["shape"] == "box"
+        assert payload["isKey"] is True
+        assert "paginaproductos" in payload["searchText"]
+        assert "ui_element" in payload["searchText"]
+        assert "frontend" in payload["searchText"]
+        assert "src/pages/productos.jsx" in payload["searchText"]
+        assert "onclick" in payload["searchText"]
+        assert "screen:productos" in payload["searchText"]
