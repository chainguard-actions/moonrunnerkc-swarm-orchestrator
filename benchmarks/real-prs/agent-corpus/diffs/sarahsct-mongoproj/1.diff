+  </div>
+</section>
+
+<section class="spotlight-section container" aria-labelledby="spotlight-title">
+  <div class="section-heading">
+    <p class="section-kicker">Featured records</p>
+    <h2 id="spotlight-title">A preview of national park biodiversity</h2>
+  </div>
+
+  <div class="species-grid">
+    {% for species in featured_species %}
+      <article class="species-card reveal">
+        <a class="species-image" href="{{ species_detail_url(species.slug) }}" aria-label="View {{ species.common_name }}">
+          <img src="{{ species.image_url }}" alt="{{ species.common_name }} in {{ species.park_name }}" loading="lazy">
+          <span>{{ species.category }}</span>
+        </a>
+        <div class="species-card-content">
+          <p>{{ species.park_name }}</p>
+          <h3>{{ species.common_name }}</h3>
+          <em>{{ species.scientific_name }}</em>
+          <p>{{ species.short_description }}</p>
+          <a class="text-link" href="{{ species_detail_url(species.slug) }}">View details</a>
+        </div>
+      </article>
+    {% endfor %}
+  </div>
+</section>
+{% endblock %}
