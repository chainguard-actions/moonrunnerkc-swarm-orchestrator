+    logSpy?.mockRestore();
+    warnSpy?.mockRestore();
+    errorSpy?.mockRestore();
+    exitSpy?.mockRestore();
+    logSpy = warnSpy = errorSpy = exitSpy = undefined;
+    process.chdir(originalCwd);
+    fs.rmSync(tmpDir, { recursive: true, force: true });
