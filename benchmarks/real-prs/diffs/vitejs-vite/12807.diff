+  // https://caniuse.com/?search=es2018
+  2018: ['chrome63', 'edge79', 'safari12', 'firefox58', 'opera50'],
+  // https://caniuse.com/?search=es2019
+  2019: ['chrome73', 'edge79', 'safari12.1', 'firefox64', 'opera60'],
+  // https://caniuse.com/?search=es2020
