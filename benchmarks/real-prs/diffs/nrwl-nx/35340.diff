+      { target: 'test', inputs: ['first'] },
+      { target: 'test', inputs: ['second'] },
+    ];
+    expect(
+      findBestTargetDefault(
+        'test',
+        undefined,
+        undefined,
+        undefined,
+        undefined,
+        entries
