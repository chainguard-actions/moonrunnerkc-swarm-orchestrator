+      const entries: TargetDefaultEntry[] = [
+        { plugin: '@nx/jest/plugin', cache: false },
+      ];
+      expect(
+        findBestTargetDefault(
+          'test',
+          undefined,
+          'web',
+          node('web'),
+          '@nx/vite/plugin',
+          entries
