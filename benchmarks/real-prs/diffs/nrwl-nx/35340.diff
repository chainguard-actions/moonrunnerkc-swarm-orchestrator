+
+  it('does not match when project tag is missing', () => {
+    const entries: TargetDefaultEntry[] = [
+      { target: 'test', projects: 'tag:dotnet', options: { a: 1 } },
+    ];
+    expect(
+      findBestTargetDefault(
+        'test',
+        undefined,
