+
+type RsbuildVersionMap = {
+  rsbuildVersion: string;
+  rsbuildPluginReactVersion: string;
+  rsbuildPluginVueVersion: string;
+  rsbuildPluginSassVersion: string;
+};
+
+export const latestRsbuildVersions: RsbuildVersionMap = {
