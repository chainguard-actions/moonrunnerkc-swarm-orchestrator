+{
+  "$schema": "https://json-schema.org/schema",
+  "$id": "NxReactConsumer",
+  "title": "Create a Module Federation consumer",
+  "description": "Scaffold a React Module Federation consumer. The bundler is selected at generation time; remotes are registered dynamically at runtime from an inline PROVIDERS list in src/mf.ts (no build-time remotes list).",
