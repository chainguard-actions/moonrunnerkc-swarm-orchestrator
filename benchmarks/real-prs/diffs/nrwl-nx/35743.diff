+  changes.push(
+    { type: ChangeType.Delete, start, length: end - start },
+    {
+      type: ChangeType.Insert,
+      index: start,
+      text: `${render(publicEls, TO_PUBLIC)}\n${render(
+        internalEls,
+        TO_INTERNAL
+      )}`,
+    }
+  );
