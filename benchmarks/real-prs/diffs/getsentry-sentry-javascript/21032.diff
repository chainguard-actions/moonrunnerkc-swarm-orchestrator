- */
-export async function runScriptInSandbox(
-  page: Page,
-  impl: {
-    path?: string;
-    content?: string;
-  },
-): Promise<void> {
-  try {
-    await page.addScriptTag({ path: impl.path, content: impl.content });
-  } catch {
-    // no-op
-  }
-}
-
-/**
