-                : options.envelopeType || (['event'] as EnvelopeItemType[])
-              : (['event'] as EnvelopeItemType[]);
-
-            if (envelopeTypeArray.includes(getEnvelopeType(request))) {
-              reqCount++;
-            }
-          }
-        } catch (e) {
-          reject(e);
-        }
-      }
-    };
-
-    page.on('request', requestHandler);
