+        _sentrySpan: mockSpan,
+      };
+      subs(IOREDIS_DC_CHANNEL_COMMAND).asyncEnd(data);
+
+      expect(responseHook).toHaveBeenCalledWith(mockSpan, 'mget', ['key1', 'key2', 'key3'], ['v1', 'v2', 'v3']);
