+      expect(result).toEqual({
+        name: 'hello world',
+        page: '1',
+      });
+    });
+
+    it('handles params with no value', () => {
+      const result = filterQueryParams('debug&page=1', true);
+
+      expect(result).toEqual({
+        debug: '',
+        page: '1',
+      });
+    });
+
+    it('handles duplicate params (last value wins via URLSearchParams)', () => {
