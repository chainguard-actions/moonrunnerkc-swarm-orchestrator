+	shift: 'shift',
+	'⇧': 'shift',
+	alt: 'alt',
+	option: 'alt',
+	'⌥': 'alt',
+	ctrl: 'ctrl',
+	control: 'ctrl',
+	'⌃': 'ctrl',
+	cmd: 'meta',
+	command: 'meta',
+	meta: 'meta',
+	'⌘': 'meta',
+}
+
+// Aliases for named keys. Values match the lowercased `event.key` for that key.
+const KEY_ALIASES: Record<string, string> = {
+	'⌫': 'backspace',
+	'↩': 'enter',
+	return: 'enter',
+	esc: 'escape',
+	del: 'delete',
+	ins: 'insert',
+	left: 'arrowleft',
+	right: 'arrowright',
+	up: 'arrowup',
+	down: 'arrowdown',
+	space: ' ',
