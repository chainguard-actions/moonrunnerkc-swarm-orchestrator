+function createPagePool(factory) {
+  const all = new Set();
+  const available = [];
+
+  return {
+    async acquire() {
+      const existing = available.shift();
+      if (existing) {
+        return existing;
+      }
+      const page = await factory();
+      all.add(page);
+      return page;
+    },
+    release(page) {
+      available.push(page);
+    },
+    async closeAll() {
+      const pages = Array.from(all);
+      all.clear();
+      available.length = 0;
+      await Promise.all(pages.map((page) => page.close()));
+    },
+  };
+}
+
 await main();
