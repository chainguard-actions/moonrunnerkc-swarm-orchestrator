+                [HCM]: {
+                  borderBottomColor: hcTokens.error,
+                },
+              },
+            },
+            [`&.${inputClasses.disabled}:before`]: {
+              [HCM]: {
+                borderBottomStyle: 'solid',
+                borderBottomColor: hcTokens.disabled,
+              },
+            },
+            [`&.${inputClasses.disabled}`]: {
+              [HCM]: {
