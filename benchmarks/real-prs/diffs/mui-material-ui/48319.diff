+  error: 'ActiveText',
+  selectedBackground: 'SelectedItem',
+  selectedText: 'SelectedItemText',
+  activeBackground: 'Highlight',
+  activeText: 'HighlightText',
+  buttonBorder: 'ButtonBorder',
+  buttonText: 'ButtonText',
+  canvas: 'Canvas',
