+            },
+          },
+        ],
+      },
+    },
+    MuiAutocomplete: {
+      ...c?.MuiAutocomplete,
+      styleOverrides: {
+        ...c?.MuiAutocomplete?.styleOverrides,
+        listbox: [
+          c?.MuiAutocomplete?.styleOverrides?.listbox,
+          {
+            [`& .${autocompleteClasses.option}`]: {
+              '&[aria-disabled="true"]': {
+                [HCM]: {
+                  color: hcTokens.disabled,
+                  opacity: 1,
+                },
+              },
+              [`&.${autocompleteClasses.focused}, &.${autocompleteClasses.focusVisible}`]: {
