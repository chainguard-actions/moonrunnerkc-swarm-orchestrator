+
+      expect((optionStyles['&[aria-selected="true"]'] as StyleOverride)[HCM]).to.deep.equal({
+        forcedColorAdjust: 'none',
+        color: 'ButtonText',
+        backgroundColor: 'ButtonFace',
+      });
+    });
+  });
+
+  describe('MuiCheckbox overrides', () => {
