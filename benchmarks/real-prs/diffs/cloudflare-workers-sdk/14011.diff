+		// (non-403) short-circuits before any body read or loopback call,
+		// so this adds no latency to successful requests.
+		return await maybeReportCloudflareAccessBlock(
+			response,
+			bindingName,
+			remoteProxyConnectionString,
+			loopback
+		);
