+
+export const isUnifiedProcessor = (
+	p: { name: string },
+): p is MarkdownProcessor<UnifiedResolvedOptions> => p.name === 'unified';
+
+export const isSatteriProcessor = (
+	p: { name: string },
+): p is MarkdownProcessor<SatteriResolvedOptions> => p.name === 'satteri';
