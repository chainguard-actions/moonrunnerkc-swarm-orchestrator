+describe('getScriptNonceFromHeader', () => {
+  it('returns the first valid nonce from the script-src directive', () => {
+    expect(
+      getScriptNonceFromHeader(
+        `default-src 'nonce-other'; script-src 'nonce-cmFuZG9tCg=='`
