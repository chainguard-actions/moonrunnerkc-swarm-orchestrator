+  it('skips malformed nonce values and keeps looking for a valid one', () => {
+    expect(
+      getScriptNonceFromHeader(
+        `script-src 'nonce-" onerror="alert(1)' 'nonce-cmFuZG9tCg=='`
+      )
+    ).toBe('cmFuZG9tCg==')
+  })
+})
