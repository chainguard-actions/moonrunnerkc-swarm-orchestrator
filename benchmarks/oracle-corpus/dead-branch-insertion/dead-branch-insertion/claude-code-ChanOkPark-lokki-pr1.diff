+from typing import List, Dict
+from collections import Counter
+import re
+from app.models.channel import VideoInfo, ChannelStats, ChannelAnalysis
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+class AnalyzerService:
+    """채널 및 영상 분석 서비스"""
+
+    def extract_keywords(self, texts: List[str], top_n: int = 20) -> Dict[str, int]:
+        """텍스트에서 키워드 추출"""
+        # 모든 텍스트 결합
+        combined_text = " ".join(texts).lower()
+
+        # 특수문자 제거 및 단어 분리
+        words = re.findall(r'\b[가-힣a-z]{2,}\b', combined_text)
+
+        # 불용어 제거 (간단한 예시)
+        stop_words = {
+            'the', 'a', 'an', 'and', 'or', 'but', 'in', 'on', 'at', 'to', 'for',
+            'of', 'with', 'by', 'from', 'as', 'is', 'was', 'are', 'were', 'been',
+            'be', 'have', 'has', 'had', 'do', 'does', 'did', 'will', 'would',
+            'could', 'should', 'may', 'might', 'can', 'this', 'that', 'these',
+            'those', 'i', 'you', 'he', 'she', 'it', 'we', 'they', 'my', 'your',
+            '은', '는', '이', '가', '을', '를', '의', '에', '에서', '으로', '로',
+            '과', '와', '도', '만', '하다', '있다', '없다', '되다', '이다', '아니다'
+        }
+
+        words = [w for w in words if w not in stop_words]
+
+        # 빈도수 계산
+        word_freq = Counter(words)
+
+        return dict(word_freq.most_common(top_n))
+
+    def calculate_sentiment(self, texts: List[str]) -> tuple[float, str]:
+        """간단한 감성 분석 (긍정/부정 키워드 기반)"""
+        positive_keywords = {
+            '좋', '최고', '대박', '감사', '추천', '완벽', '멋지', '훌륭', '재밌', '재미있',
+            'good', 'great', 'best', 'awesome', 'amazing', 'excellent', 'perfect',
+            'love', 'like', 'wonderful', 'fantastic', 'brilliant'
+        }
+
+        negative_keywords = {
+            '나쁘', '최악', '별로', '실망', '안좋', '싫', '지루', '재미없',
+            'bad', 'worst', 'terrible', 'awful', 'horrible', 'hate', 'dislike',
+            'boring', 'disappointing', 'poor'
+        }
+
+        combined_text = " ".join(texts).lower()
+
+        positive_count = sum(1 for keyword in positive_keywords if keyword in combined_text)
+        negative_count = sum(1 for keyword in negative_keywords if keyword in combined_text)
+
+        total = positive_count + negative_count
+        if total == 0:
+            return 0.0, "neutral"
+
+        sentiment_score = (positive_count - negative_count) / total
+
+        if sentiment_score > 0.2:
+            tone = "positive"
+        elif sentiment_score < -0.2:
+            tone = "negative"
+        else:
+            tone = "neutral"
+
+        return sentiment_score, tone
+
+    def analyze_channel(
+        self,
+        stats: ChannelStats,
+        recent_videos: List[VideoInfo]
+    ) -> ChannelAnalysis:
+        """채널 종합 분석"""
+        if not recent_videos:
+            return ChannelAnalysis(
+                stats=stats,
+                recent_videos=[],
+                keywords={},
+                avg_views=0,
+                avg_likes=0,
+                sentiment_score=0.0,
+                tone="neutral"
+            )
+
+        # 키워드 추출 (제목 + 설명 + 태그)
+        texts = []
+        for video in recent_videos:
+            texts.append(video.title)
+            texts.append(video.description)
+            texts.extend(video.tags)
+
+        keywords = self.extract_keywords(texts)
+
+        # 평균 조회수, 좋아요 계산
+        total_views = sum(v.view_count for v in recent_videos)
+        total_likes = sum(v.like_count for v in recent_videos)
+        avg_views = total_views / len(recent_videos)
+        avg_likes = total_likes / len(recent_videos)
+
+        # 감성 분석
+        sentiment_texts = [v.title for v in recent_videos]
+        sentiment_score, tone = self.calculate_sentiment(sentiment_texts)
+
+        return ChannelAnalysis(
+            stats=stats,
+            recent_videos=recent_videos,
+            keywords=keywords,
+            avg_views=avg_views,
+            avg_likes=avg_likes,
+            sentiment_score=sentiment_score,
+            tone=tone
+        )
+
+    def find_common_keywords(self, analyses: List[ChannelAnalysis], top_n: int = 10) -> List[str]:
+        """여러 채널의 공통 키워드 찾기"""
+        if not analyses:
+            return []
+
+        # 모든 채널의 키워드 집합
+        all_keywords_sets = [set(analysis.keywords.keys()) for analysis in analyses]
+
+        # 교집합 찾기
+        common = set.intersection(*all_keywords_sets) if all_keywords_sets else set()
+
+        # 빈도수 합산
+        keyword_scores = {}
+        for keyword in common:
+            keyword_scores[keyword] = sum(
+                analysis.keywords.get(keyword, 0) for analysis in analyses
+            )
+
+        # 정렬하여 상위 N개 반환
+        sorted_keywords = sorted(keyword_scores.items(), key=lambda x: x[1], reverse=True)
+        return [k for k, v in sorted_keywords[:top_n]]
+
+    def rank_by_performance(self, analyses: List[ChannelAnalysis]) -> List[Dict]:
+        """성과 기준으로 채널 순위 매기기"""
+        rankings = []
+
+        for analysis in analyses:
+            # 종합 점수 계산 (가중 평균)
+            engagement_rate = 0
+            if analysis.avg_views > 0:
+                engagement_rate = (analysis.avg_likes / analysis.avg_views) * 100
+
+            score = (
+                analysis.avg_views * 0.4 +
+                analysis.avg_likes * 0.3 +
+                analysis.stats.subscriber_count * 0.2 +
+                engagement_rate * 1000 * 0.1  # 스케일 조정
+            )
+
+            rankings.append({
+                "channel_name": analysis.stats.channel_name,
+                "channel_id": analysis.stats.channel_id,
+                "score": score,
+                "avg_views": analysis.avg_views,
+                "avg_likes": analysis.avg_likes,
+                "subscribers": analysis.stats.subscriber_count,
+                "engagement_rate": engagement_rate
+            })
+
+        # 점수 기준 내림차순 정렬
+        rankings.sort(key=lambda x: x["score"], reverse=True)
+
+        return rankings
+
+    def extract_trend_keywords(self, analyses: List[ChannelAnalysis], top_n: int = 15) -> List[str]:
+        """트렌드 키워드 추출 (여러 채널에서 자주 나타나는 키워드)"""
+        all_keywords = {}
+
+        for analysis in analyses:
+            for keyword, freq in analysis.keywords.items():
+                all_keywords[keyword] = all_keywords.get(keyword, 0) + freq
+
+        # 빈도수 기준 정렬
+        sorted_keywords = sorted(all_keywords.items(), key=lambda x: x[1], reverse=True)
+        return [k for k, v in sorted_keywords[:top_n]]
