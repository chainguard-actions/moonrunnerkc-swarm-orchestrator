+            display: block;
+        }
+    </style>
+</head>
+<body>
+    <div class="container">
+        <header>
+            <h1>📊 Lokki</h1>
+            <p class="subtitle">YouTube 트렌드 & 경쟁채널 자동 리서치</p>
+        </header>
+
+        <div class="card">
+            <div class="tabs">
+                <button class="tab active" onclick="switchTab('single')">단일 채널 분석</button>
+                <button class="tab" onclick="switchTab('compare')">채널 비교</button>
+                <button class="tab" onclick="switchTab('trending')">트렌딩</button>
+            </div>
+
+            <div id="single-tab" class="tab-content active">
+                <h2>단일 채널 분석</h2>
+                <div class="input-group">
+                    <label for="channelId">채널 ID 또는 채널명</label>
+                    <input type="text" id="channelId" placeholder="예: UCUpJs89fSBXNolQGOYKn0YQ 또는 '백종원'" />
+                </div>
+                <div class="input-group">
+                    <label for="videoCount">분석할 영상 수</label>
+                    <input type="number" id="videoCount" value="10" min="1" max="50" />
+                </div>
+                <button onclick="analyzeChannel()">분석 시작</button>
+
+                <div class="loading" id="loading-single">
+                    <p>분석 중...</p>
+                </div>
+                <div class="error" id="error-single"></div>
+                <div class="results" id="results-single"></div>
+            </div>
+
+            <div id="compare-tab" class="tab-content">
+                <h2>경쟁 채널 비교</h2>
+                <div class="input-group">
+                    <label for="compareChannels">채널 목록 (쉼표로 구분)</label>
+                    <input type="text" id="compareChannels" placeholder="예: 채널A, 채널B, 채널C" />
+                </div>
+                <div class="input-group">
+                    <label for="compareVideoCount">각 채널의 영상 수</label>
+                    <input type="number" id="compareVideoCount" value="10" min="1" max="50" />
+                </div>
+                <button onclick="compareChannels()">비교 시작</button>
+
+                <div class="loading" id="loading-compare">
+                    <p>비교 분석 중...</p>
+                </div>
+                <div class="error" id="error-compare"></div>
+                <div class="results" id="results-compare"></div>
+            </div>
+
+            <div id="trending-tab" class="tab-content">
+                <h2>트렌딩 영상</h2>
+                <div class="input-group">
+                    <label for="region">지역</label>
+                    <select id="region">
+                        <option value="KR">한국 (KR)</option>
+                        <option value="US">미국 (US)</option>
+                        <option value="JP">일본 (JP)</option>
+                        <option value="GB">영국 (GB)</option>
+                    </select>
+                </div>
+                <div class="input-group">
+                    <label for="trendingCount">조회할 영상 수</label>
+                    <input type="number" id="trendingCount" value="10" min="1" max="50" />
+                </div>
+                <button onclick="getTrending()">조회</button>
+
+                <div class="loading" id="loading-trending">
+                    <p>조회 중...</p>
+                </div>
+                <div class="error" id="error-trending"></div>
+                <div class="results" id="results-trending"></div>
+            </div>
+        </div>
+    </div>
+
+    <script>
+        function switchTab(tabName) {
+            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
+            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
+
+            event.target.classList.add('active');
+            document.getElementById(`${tabName}-tab`).classList.add('active');
+        }
+
+        async function analyzeChannel() {
+            const channelId = document.getElementById('channelId').value.trim();
+            const videoCount = document.getElementById('videoCount').value;
+
+            if (!channelId) {
+                alert('채널 ID 또는 채널명을 입력하세요.');
+                return;
+            }
+
+            const loading = document.getElementById('loading-single');
+            const error = document.getElementById('error-single');
+            const results = document.getElementById('results-single');
+
+            loading.style.display = 'block';
+            error.style.display = 'none';
+            results.innerHTML = '';
+
+            try {
+                const response = await fetch(`/api/channel/${encodeURIComponent(channelId)}?video_count=${videoCount}`);
+                const data = await response.json();
+
+                if (!response.ok) {
+                    throw new Error(data.detail || '오류가 발생했습니다.');
+                }
+
+                displayChannelAnalysis(data, results);
+            } catch (err) {
+                error.textContent = err.message;
+                error.style.display = 'block';
+            } finally {
+                loading.style.display = 'none';
+            }
+        }
+
+        async function compareChannels() {
+            const channelsInput = document.getElementById('compareChannels').value.trim();
+            const videoCount = document.getElementById('compareVideoCount').value;
+
+            if (!channelsInput) {
+                alert('채널 목록을 입력하세요.');
+                return;
+            }
+
+            const channels = channelsInput.split(',').map(c => c.trim()).filter(c => c);
+
+            if (channels.length < 2) {
+                alert('최소 2개의 채널을 입력하세요.');
+                return;
+            }
+
+            const loading = document.getElementById('loading-compare');
+            const error = document.getElementById('error-compare');
+            const results = document.getElementById('results-compare');
+
+            loading.style.display = 'block';
+            error.style.display = 'none';
+            results.innerHTML = '';
+
+            try {
+                const params = new URLSearchParams();
+                channels.forEach(ch => params.append('channels', ch));
+                params.append('video_count', videoCount);
+
+                const response = await fetch(`/api/compare?${params}`);
+                const data = await response.json();
+
+                if (!response.ok) {
+                    throw new Error(data.detail || '오류가 발생했습니다.');
+                }
+
+                displayComparison(data, results);
+            } catch (err) {
+                error.textContent = err.message;
+                error.style.display = 'block';
+            } finally {
+                loading.style.display = 'none';
+            }
+        }
+
+        async function getTrending() {
+            const region = document.getElementById('region').value;
+            const maxResults = document.getElementById('trendingCount').value;
+
+            const loading = document.getElementById('loading-trending');
+            const error = document.getElementById('error-trending');
+            const results = document.getElementById('results-trending');
+
+            loading.style.display = 'block';
+            error.style.display = 'none';
+            results.innerHTML = '';
+
+            try {
+                const response = await fetch(`/api/trending?region=${region}&max_results=${maxResults}`);
+                const data = await response.json();
+
+                if (!response.ok) {
+                    throw new Error(data.detail || '오류가 발생했습니다.');
+                }
+
+                displayTrending(data, results);
+            } catch (err) {
+                error.textContent = err.message;
+                error.style.display = 'block';
+            } finally {
+                loading.style.display = 'none';
+            }
+        }
+
+        function displayChannelAnalysis(data, container) {
+            const stats = data.stats;
+
+            container.innerHTML = `
+                <div class="result-content">
+                    <h3>${stats.channel_name}</h3>
+                    <div class="stats-grid">
+                        <div class="stat-box">
+                            <div class="stat-value">${formatNumber(stats.subscriber_count)}</div>
+                            <div class="stat-label">구독자</div>
+                        </div>
+                        <div class="stat-box">
+                            <div class="stat-value">${formatNumber(Math.round(data.avg_views))}</div>
+                            <div class="stat-label">평균 조회수</div>
+                        </div>
+                        <div class="stat-box">
+                            <div class="stat-value">${formatNumber(Math.round(data.avg_likes))}</div>
+                            <div class="stat-label">평균 좋아요</div>
+                        </div>
+                        <div class="stat-box">
+                            <div class="stat-value">${data.tone}</div>
+                            <div class="stat-label">톤</div>
+                        </div>
+                    </div>
+
+                    <h4>주요 키워드</h4>
+                    <div>
+                        ${Object.keys(data.keywords).slice(0, 15).map(k =>
+                            `<span class="keyword-tag">${k} (${data.keywords[k]})</span>`
+                        ).join('')}
+                    </div>
+
+                    <h4 style="margin-top: 20px;">최근 영상 (${data.recent_videos.length}개)</h4>
+                    <div class="channel-list">
+                        ${data.recent_videos.slice(0, 5).map(v => `
+                            <div class="channel-item">
+                                <strong>${v.title}</strong><br>
+                                <small>조회수: ${formatNumber(v.view_count)} | 좋아요: ${formatNumber(v.like_count)}</small>
+                            </div>
+                        `).join('')}
+                    </div>
+                </div>
+            `;
+        }
+
+        function displayComparison(data, container) {
+            const ranking = data.performance_ranking;
+
+            container.innerHTML = `
+                <div class="result-content">
+                    <h3>성과 순위</h3>
+                    <div class="channel-list">
+                        ${ranking.map((ch, idx) => `
+                            <div class="channel-item">
+                                <strong>${idx + 1}. ${ch.channel_name}</strong><br>
+                                <small>
+                                    평균 조회수: ${formatNumber(Math.round(ch.avg_views))} |
+                                    평균 좋아요: ${formatNumber(Math.round(ch.avg_likes))} |
+                                    구독자: ${formatNumber(ch.subscribers)} |
+                                    참여율: ${ch.engagement_rate.toFixed(2)}%
+                                </small>
+                            </div>
+                        `).join('')}
+                    </div>
+
+                    <h4 style="margin-top: 20px;">공통 키워드</h4>
+                    <div>
+                        ${data.common_keywords.map(k =>
+                            `<span class="keyword-tag">${k}</span>`
+                        ).join('')}
+                    </div>
+
+                    <h4 style="margin-top: 20px;">트렌드 키워드</h4>
+                    <div>
+                        ${data.trend_keywords.map(k =>
+                            `<span class="keyword-tag">${k}</span>`
+                        ).join('')}
+                    </div>
+                </div>
+            `;
+        }
+
+        function displayTrending(data, container) {
+            container.innerHTML = `
+                <div class="result-content">
+                    <h3>${data.region} 지역 트렌딩</h3>
+
+                    <h4>트렌딩 키워드</h4>
+                    <div>
+                        ${Object.keys(data.trending_keywords).slice(0, 15).map(k =>
+                            `<span class="keyword-tag">${k} (${data.trending_keywords[k]})</span>`
+                        ).join('')}
+                    </div>
+
+                    <h4 style="margin-top: 20px;">인기 영상</h4>
+                    <div class="channel-list">
+                        ${data.videos.map(v => `
+                            <div class="channel-item">
+                                <strong>${v.title}</strong><br>
+                                <small>조회수: ${formatNumber(v.view_count)} | 좋아요: ${formatNumber(v.like_count)}</small>
+                            </div>
+                        `).join('')}
+                    </div>
+                </div>
+            `;
+        }
+
+        function formatNumber(num) {
+            if (num >= 1000000) {
+                return (num / 1000000).toFixed(1) + 'M';
+            } else if (num >= 1000) {
+                return (num / 1000).toFixed(1) + 'K';
+            }
+            return num.toString();
+        }
+    </script>
+</body>
+</html>
