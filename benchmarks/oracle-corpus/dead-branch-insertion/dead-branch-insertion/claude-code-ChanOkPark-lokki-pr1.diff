+from fastapi import APIRouter, HTTPException, Query
+from typing import List
+from app.services.youtube_service import YouTubeService
+from app.services.research_service import ResearchService
+from app.models.channel import ChannelAnalysis, ComparisonResult
+from app.config import settings
+import logging
+
+logger = logging.getLogger(__name__)
+
+router = APIRouter()
+
+
+def get_research_service():
+    """ResearchService 인스턴스 생성"""
+    youtube_service = YouTubeService(settings.youtube_api_key)
+    return ResearchService(youtube_service)
+
+
+@router.get("/")
+async def root():
+    """API 루트"""
+    return {
+        "service": "Lokki - YouTube 트렌드 & 경쟁채널 리서치",
+        "version": "1.0.0",
+        "endpoints": {
+            "/api/channel/{identifier}": "단일 채널 분석",
+            "/api/compare": "여러 채널 비교",
+            "/api/trending": "트렌딩 영상 조회",
+            "/docs": "API 문서"
+        }
+    }
+
+
+@router.get("/api/channel/{identifier}", response_model=ChannelAnalysis)
+async def analyze_channel(
+    identifier: str,
+    video_count: int = Query(default=10, ge=1, le=50, description="분석할 최근 영상 수")
+):
+    """
+    단일 채널 분석
+
+    - **identifier**: 채널 ID (UC로 시작) 또는 채널명
+    - **video_count**: 분석할 최근 영상 수 (1-50)
+    """
+    try:
+        research_service = get_research_service()
+        result = research_service.research_channel(identifier, video_count)
+        return result
+    except ValueError as e:
+        raise HTTPException(status_code=404, detail=str(e))
+    except Exception as e:
+        logger.error(f"채널 분석 오류: {e}")
+        raise HTTPException(status_code=500, detail="채널 분석 중 오류가 발생했습니다.")
+
+
+@router.get("/api/compare", response_model=ComparisonResult)
+async def compare_channels(
+    channels: List[str] = Query(..., description="비교할 채널 ID 또는 채널명 목록"),
+    video_count: int = Query(default=10, ge=1, le=50, description="각 채널의 최근 영상 수")
+):
+    """
+    여러 채널 비교 분석
+
+    - **channels**: 비교할 채널 목록 (최소 2개)
+    - **video_count**: 각 채널의 최근 영상 수 (1-50)
+
+    예시: /api/compare?channels=채널A&channels=채널B&channels=채널C
+    """
+    if len(channels) < 2:
+        raise HTTPException(
+            status_code=400,
+            detail="최소 2개 이상의 채널이 필요합니다."
+        )
+
+    try:
+        research_service = get_research_service()
+        result = research_service.compare_channels(channels, video_count)
+        return result
+    except ValueError as e:
+        raise HTTPException(status_code=404, detail=str(e))
+    except Exception as e:
+        logger.error(f"채널 비교 오류: {e}")
+        raise HTTPException(status_code=500, detail="채널 비교 중 오류가 발생했습니다.")
+
+
+@router.get("/api/trending")
+async def get_trending(
+    region: str = Query(default="KR", description="지역 코드 (KR, US, JP 등)"),
+    max_results: int = Query(default=10, ge=1, le=50, description="조회할 영상 수")
+):
+    """
+    트렌딩 영상 조회
+
+    - **region**: 지역 코드 (KR, US, JP 등)
+    - **max_results**: 조회할 영상 수 (1-50)
+    """
+    try:
+        youtube_service = YouTubeService(settings.youtube_api_key)
+        videos = youtube_service.get_trending_videos(region, max_results)
+
+        # 키워드 추출
+        from app.services.analyzer_service import AnalyzerService
+        analyzer = AnalyzerService()
+
+        texts = []
+        for video in videos:
+            texts.append(video.title)
+            texts.extend(video.tags)
+
+        keywords = analyzer.extract_keywords(texts, top_n=20)
+
+        return {
+            "region": region,
+            "videos": videos,
+            "trending_keywords": keywords
+        }
+    except Exception as e:
+        logger.error(f"트렌딩 영상 조회 오류: {e}")
+        raise HTTPException(status_code=500, detail="트렌딩 영상 조회 중 오류가 발생했습니다.")
+
+
+@router.get("/health")
+async def health_check():
+    """헬스 체크"""
+    return {"status": "healthy"}
