+from typing import List
+from app.services.youtube_service import YouTubeService
+from app.services.analyzer_service import AnalyzerService
+from app.models.channel import ChannelAnalysis, ComparisonResult
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+class ResearchService:
+    """채널 리서치 통합 서비스"""
+
+    def __init__(self, youtube_service: YouTubeService):
+        self.youtube = youtube_service
+        self.analyzer = AnalyzerService()
+
+    def research_channel(self, channel_identifier: str, video_count: int = 10) -> ChannelAnalysis:
+        """단일 채널 리서치"""
+        # 채널 ID 확인
+        if channel_identifier.startswith("UC"):
+            channel_id = channel_identifier
+        else:
+            # 채널 검색
+            channel_id = self.youtube.search_channel(channel_identifier)
+            if not channel_id:
+                raise ValueError(f"채널을 찾을 수 없습니다: {channel_identifier}")
+
+        # 채널 통계 조회
+        stats = self.youtube.get_channel_stats(channel_id)
+        if not stats:
+            raise ValueError(f"채널 통계를 가져올 수 없습니다: {channel_id}")
+
+        # 최근 영상 조회
+        recent_videos = self.youtube.get_recent_videos(channel_id, video_count)
+
+        # 채널 분석
+        analysis = self.analyzer.analyze_channel(stats, recent_videos)
+
+        logger.info(f"채널 분석 완료: {stats.channel_name}")
+        return analysis
+
+    def compare_channels(self, channel_identifiers: List[str], video_count: int = 10) -> ComparisonResult:
+        """여러 채널 비교 분석"""
+        analyses = []
+
+        for identifier in channel_identifiers:
+            try:
+                analysis = self.research_channel(identifier, video_count)
+                analyses.append(analysis)
+            except Exception as e:
+                logger.error(f"채널 분석 실패 ({identifier}): {e}")
+                continue
+
+        if not analyses:
+            raise ValueError("분석할 채널이 없습니다.")
+
+        # 공통 키워드
+        common_keywords = self.analyzer.find_common_keywords(analyses)
+
+        # 성과 순위
+        performance_ranking = self.analyzer.rank_by_performance(analyses)
+
+        # 트렌드 키워드
+        trend_keywords = self.analyzer.extract_trend_keywords(analyses)
+
+        return ComparisonResult(
+            channels=analyses,
+            common_keywords=common_keywords,
+            performance_ranking=performance_ranking,
+            trend_keywords=trend_keywords
+        )
