-  if (revealed) {
-    for (const c of revealed) {
-      const lx = c.index % CHUNK_SIZE;
-      const ly = Math.floor(c.index / CHUNK_SIZE);
-      grid[ly][lx] = {
-        ...grid[ly][lx],
-        revealed: true,
-        isMine: c.isMine,
-        adjacentMines: c.adjacentMines,
-      };
-    }
-  }
