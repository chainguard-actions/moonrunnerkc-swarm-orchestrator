   if (!hay.trim()) return "NONE";
   for (const group of MOVERS_CATALYST_KEYWORD_GROUPS) {
     for (const kw of group.keywords) {
-      if (hay.includes(kw)) return group.type;
+      if (headlineMatchesKeyword(hay, kw)) return group.type;
     }
   }
-  return "SECTOR";
+  return "UNKNOWN";
 }
 
