+// Interface for team player data (current squad composition)
+interface TeamPlayerData {
+  playerId: number;
+  position: string;
+}
+
+// Interface for team with league data
+interface TeamWithLeague {
+  id: number;
+  leagueId: number;
+}
+
+/**
+ * Backfill TeamPlayerSnapshot rows for all teams that do not yet have a snapshot
+ * for the given round. Derives snapshots from current TeamPlayer rows.
+ *
+ * This is idempotent: teams that already have at least one snapshot for the round
+ * are skipped entirely.
+ *
+ * Call this before calculateRoundPoints to ensure all teams are scored correctly,
+ * even when managers did not submit squad changes during the round.
+ *
+ * @returns Count of teams backfilled and snapshot rows created
+ */
+export async function backfillRoundSnapshots(
+  // Using any to support both PrismaClient and transaction clients with extensions
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  prisma: any,
+  tenantId: string,
+  roundId: number
+): Promise<{ teamsBackfilled: number; snapshotsCreated: number }> {
+  // Get all teams in this tenant (need leagueId for snapshot creation)
+  const allTeams: TeamWithLeague[] = await prisma.team.findMany({
+    where: { tenantId },
+    select: { id: true, leagueId: true },
+  });
+
+  if (allTeams.length === 0) {
+    return { teamsBackfilled: 0, snapshotsCreated: 0 };
+  }
+
+  // Get the set of teamIds that already have at least one snapshot for this round
+  const existingSnapshotRows: { teamId: number }[] = await prisma.teamPlayerSnapshot.findMany({
+    where: { tenantId, roundId },
+    select: { teamId: true },
+    distinct: ['teamId'],
+  });
+
+  const teamsWithSnapshots = new Set<number>(existingSnapshotRows.map((s: { teamId: number }) => s.teamId));
+  const teamsNeedingSnapshots = allTeams.filter((t) => !teamsWithSnapshots.has(t.id));
+
+  if (teamsNeedingSnapshots.length === 0) {
+    return { teamsBackfilled: 0, snapshotsCreated: 0 };
+  }
+
+  let snapshotsCreated = 0;
+
+  for (const team of teamsNeedingSnapshots) {
+    const teamPlayers: TeamPlayerData[] = await prisma.teamPlayer.findMany({
+      where: { teamId: team.id },
+      select: { playerId: true, position: true },
+    });
+
+    if (teamPlayers.length > 0) {
+      await prisma.teamPlayerSnapshot.createMany({
+        data: teamPlayers.map((tp) => ({
+          tenantId,
+          teamId: team.id,
+          leagueId: team.leagueId,
+          roundId,
+          playerId: tp.playerId,
+          position: tp.position,
+        })),
+        skipDuplicates: true,
+      });
+      snapshotsCreated += teamPlayers.length;
+    }
+  }
+
+  return { teamsBackfilled: teamsNeedingSnapshots.length, snapshotsCreated };
+}
+
