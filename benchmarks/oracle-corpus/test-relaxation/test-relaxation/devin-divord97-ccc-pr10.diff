+	id, _ := strconv.ParseInt(chi.URLParam(r, "id"), 10, 64)
+	sess, err := h.svc.GetSession(r.Context(), id)
+	if err != nil {
+		response.Error(w, http.StatusNotFound, err.Error())
+		return
