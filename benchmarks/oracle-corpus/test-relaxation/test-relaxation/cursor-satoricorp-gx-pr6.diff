+package termstyle
+
+import (
+	"fmt"
+	"os"
+	"strings"
+
+	"charm.land/lipgloss/v2"
+	"charm.land/lipgloss/v2/table"
+	"charm.land/lipgloss/v2/tree"
+)
+
+// StackUnit is one entry in a gx stack listing.
+type StackUnit struct {
+	Index       int
+	Description string
+	Active      bool
+	Published   bool
+}
+
+// RenderStack formats stack metadata and units for terminal output.
+func RenderStack(containerName string, publishedCount int, units []StackUnit) string {
+	initTheme()
+	if len(units) == 0 {
+		return Muted("No GX stack recorded yet.")
+	}
+
+	lines := []string{
+		Section("Stack"),
+		LabelValue("Container", containerName),
+		LabelValue("Units", fmt.Sprintf("%d total, %d published", len(units), publishedCount)),
+		"",
+	}
+
+	if !Enabled() {
+		for _, unit := range units {
+			lines = append(lines, plainStackLine(unit))
+		}
+		return strings.Join(lines, "\n")
+	}
+
+	dark := lipgloss.HasDarkBackground(os.Stdin, os.Stdout)
+	ld := lipgloss.LightDark(dark)
+	borderColor := ld(lipgloss.Color("#5B3FD9"), lipgloss.Color(colorAccent))
+
+	root := tree.Root(containerName).
+		Enumerator(tree.RoundedEnumerator).
+		EnumeratorStyle(lipgloss.NewStyle().Foreground(borderColor)).
+		RootStyle(styleSection).
+		ItemStyle(styleValue)
+
+	for _, unit := range units {
+		label := stackUnitLabel(unit)
+		if unit.Active {
+			root = root.Child(styleActive.Render(label))
+		} else {
+			root = root.Child(label)
+		}
+	}
+	lines = append(lines, Render(root.String()))
+	return strings.Join(lines, "\n")
+}
+
+func plainStackLine(unit StackUnit) string {
+	marker := " "
+	if unit.Active {
+		marker = "*"
+	}
+	line := fmt.Sprintf("  %s %d. %s", marker, unit.Index, unit.Description)
+	tags := stackTags(unit)
+	if len(tags) > 0 {
+		line += "  [" + strings.Join(tags, ", ") + "]"
+	}
+	return line
+}
+
+func stackUnitLabel(unit StackUnit) string {
+	prefix := fmt.Sprintf("%d. %s", unit.Index, unit.Description)
+	tags := stackTags(unit)
+	if len(tags) == 0 {
+		return prefix
+	}
+	tagText := strings.Join(tags, ", ")
+	if !Enabled() {
+		return prefix + "  [" + tagText + "]"
+	}
+	return Render(
+		lipgloss.JoinHorizontal(
+			lipgloss.Bottom,
+			styleValue.Render(prefix),
+			"  ",
+			styleTag.Render("["+tagText+"]"),
+		),
+	)
+}
+
+func stackTags(unit StackUnit) []string {
+	var tags []string
+	if unit.Published {
+		tags = append(tags, "published")
+	}
+	if unit.Active {
+		tags = append(tags, "active")
+	}
+	return tags
+}
+
+// DoctorRow is one health-check line for gx doctor.
+type DoctorRow struct {
+	Check  string
+	Status string
+}
+
+// RenderDoctorTable formats doctor checks as a bordered table.
+func RenderDoctorTable(rows []DoctorRow) string {
+	initTheme()
+	if len(rows) == 0 {
+		return ""
+	}
+	if !Enabled() {
+		var lines []string
+		for _, row := range rows {
+			lines = append(lines, row.Check+"  "+row.Status)
+		}
+		return strings.Join(lines, "\n")
+	}
+
+	dark := lipgloss.HasDarkBackground(os.Stdin, os.Stdout)
+	ld := lipgloss.LightDark(dark)
+	borderColor := ld(lipgloss.Color("#5B3FD9"), lipgloss.Color(colorAccent))
+
+	headerStyle := lipgloss.NewStyle().Bold(true).Foreground(borderColor).Padding(0, 1)
+	checkStyle := lipgloss.NewStyle().Foreground(ld(lipgloss.Color("#333"), lipgloss.Color(colorText))).Padding(0, 1)
+	cellStyle := lipgloss.NewStyle().Padding(0, 1)
+
+	tableRows := make([][]string, len(rows))
+	for i, row := range rows {
+		tableRows[i] = []string{row.Check, row.Status}
+	}
+
+	t := table.New().
+		Border(lipgloss.RoundedBorder()).
+		BorderStyle(lipgloss.NewStyle().Foreground(borderColor)).
+		Headers("CHECK", "STATUS").
+		Rows(tableRows...).
+		StyleFunc(func(row, col int) lipgloss.Style {
+			if row == table.HeaderRow {
+				return headerStyle
+			}
+			if col == 0 {
+				return checkStyle
+			}
+			dataRow := row - 1
+			if dataRow < 0 || dataRow >= len(tableRows) {
+				return cellStyle
+			}
+			status := tableRows[dataRow][1]
+			switch {
+			case strings.HasPrefix(status, "ok"):
+				return cellStyle.Inherit(styleOK)
+			case strings.HasPrefix(status, "warn"):
+				return cellStyle.Inherit(styleWarn)
+			default:
+				return cellStyle.Inherit(styleValue)
+			}
+		})
+
+	return Render(t.String())
+}
diff --git a/internal/termstyle/theme.go b/internal/termstyle/theme.go
new file mode 100644
index 0000000..340a1bc
--- /dev/null
+++ b/internal/termstyle/theme.go
@@ -0,0 +1,221 @@
+package termstyle
+
+import (
+	"os"
+	"strings"
+	"sync"
+
+	"charm.land/lipgloss/v2"
+)
+
+// gx palette — Charm-adjacent purple accent with clear status colors.
+const (
+	colorAccent   = "#7D56F4"
+	colorAccentHi = "#BD93F9"
+	colorOK       = "#50FA7B"
+	colorWarn     = "#FFB86C"
+	colorErr      = "#FF5555"
+	colorMuted    = "#6272A4"
+	colorText     = "#F8F8F2"
+	colorTextDim  = "#BFBFBF"
+)
+
+var (
+	initOnce sync.Once
+
+	// Semantic styles (initialized in initTheme).
+	styleDanger  lipgloss.Style
+	styleSuccess lipgloss.Style
+	styleSection lipgloss.Style
+	styleCommand lipgloss.Style
+	styleMuted   lipgloss.Style
+	styleAccent  lipgloss.Style
+	styleValue   lipgloss.Style
+	styleHint    lipgloss.Style
+	styleOK      lipgloss.Style
+	styleWarn    lipgloss.Style
+	styleActive  lipgloss.Style
+	styleTag     lipgloss.Style
+	styleURL     lipgloss.Style
+
+	labelWidth = 16
+)
+
+func initTheme() {
+	initOnce.Do(func() {
+		dark := true
+		if Enabled() {
+			dark = lipgloss.HasDarkBackground(os.Stdin, os.Stdout)
+		}
+		ld := lipgloss.LightDark(dark)
+
+		accent := ld(lipgloss.Color("#5B3FD9"), lipgloss.Color(colorAccent))
+		accentHi := ld(lipgloss.Color("#5B3FD9"), lipgloss.Color(colorAccentHi))
+		ok := ld(lipgloss.Color("#1B7A3D"), lipgloss.Color(colorOK))
+		warn := ld(lipgloss.Color("#9A5B12"), lipgloss.Color(colorWarn))
+		err := ld(lipgloss.Color("#C62828"), lipgloss.Color(colorErr))
+		muted := ld(lipgloss.Color("#6B6B6B"), lipgloss.Color(colorMuted))
+		text := ld(lipgloss.Color("#1A1A1A"), lipgloss.Color(colorText))
+		textDim := ld(lipgloss.Color("#4A4A4A"), lipgloss.Color(colorTextDim))
+
+		styleDanger = lipgloss.NewStyle().Bold(true).Foreground(err)
+		styleSuccess = lipgloss.NewStyle().Bold(true).Foreground(ok)
+		styleSection = lipgloss.NewStyle().Bold(true).Foreground(accentHi)
+		styleCommand = lipgloss.NewStyle().Bold(true).Foreground(accent)
+		styleMuted = lipgloss.NewStyle().Foreground(muted)
+		styleAccent = lipgloss.NewStyle().Bold(true).Foreground(accentHi)
+		styleValue = lipgloss.NewStyle().Foreground(text)
+		styleHint = lipgloss.NewStyle().Foreground(muted).Italic(true)
+		styleOK = lipgloss.NewStyle().Foreground(ok)
+		styleWarn = lipgloss.NewStyle().Foreground(warn)
+		styleActive = lipgloss.NewStyle().Bold(true).Foreground(accentHi)
+		styleTag = lipgloss.NewStyle().Foreground(textDim)
+		styleURL = lipgloss.NewStyle().Foreground(accentHi).Underline(true)
+	})
+}
+
+// Enabled reports whether gx should emit color and styled output.
+func Enabled() bool {
+	if os.Getenv("NO_COLOR") != "" {
+		return false
+	}
+	if strings.EqualFold(os.Getenv("TERM"), "dumb") {
+		return false
+	}
+	return true
+}
+
+func paint(style lipgloss.Style, text string) string {
+	initTheme()
+	if text == "" || !Enabled() {
+		return text
+	}
+	return Render(style.Render(text))
+}
+
+// Render applies lipgloss downsampling when writing styled strings to variables.
+func Render(s string) string {
+	initTheme()
+	if !Enabled() || s == "" {
+		return s
+	}
+	return lipgloss.Sprint(s)
+}
+
+func Danger(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleDanger, text)
+}
+
+func Success(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleSuccess, text)
+}
+
+func Section(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleSection, text)
+}
+
+func Command(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleCommand, text)
+}
+
+func Muted(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleMuted, text)
+}
+
+func Accent(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleAccent, text)
+}
+
+func Hint(text string) string {
+	initTheme()
+	if text == "" {
+		return text
+	}
+	return paint(styleHint, text)
+}
+
+// LabelValue renders a fixed-width label with a value.
+func LabelValue(label, value string) string {
+	initTheme()
+	if !Enabled() {
+		return label + " " + value
+	}
+	lbl := styleCommand.Width(labelWidth).Render(label)
+	val := styleValue.Render(value)
+	return Render(lipgloss.JoinHorizontal(lipgloss.Top, lbl, " ", val))
+}
+
+// FormatStatus styles values that use gx ok:/warn: conventions.
+func FormatStatus(value string) string {
+	initTheme()
+	if !Enabled() {
+		return value
+	}
+	trimmed := strings.TrimSpace(value)
+	switch {
+	case strings.HasPrefix(trimmed, "ok:"):
+		return paint(styleOK, trimmed)
+	case strings.HasPrefix(trimmed, "warn:"):
+		return paint(styleWarn, trimmed)
+	case trimmed == "ok" || trimmed == "updated":
+		return paint(styleOK, trimmed)
+	default:
+		return paint(styleValue, value)
+	}
+}
+
+// LabelStatus is LabelValue with status coloring on the value.
+func LabelStatus(label, value string) string {
+	initTheme()
+	if !Enabled() {
+		return label + " " + value
+	}
+	lbl := styleCommand.Width(labelWidth).Render(label)
+	val := FormatStatus(value)
+	return Render(lipgloss.JoinHorizontal(lipgloss.Top, lbl, " ", val))
+}
+
+// Hyperlink renders a terminal hyperlink when supported.
+func Hyperlink(url, text string) string {
+	initTheme()
+	if text == "" {
+		text = url
+	}
+	if !Enabled() || url == "" {
+		return text
+	}
+	return paint(styleURL.Hyperlink(url), text)
+}
+
+// PromptLabel styles interactive prompt labels (gx init, modify).
+func PromptLabel(text string) string {
+	initTheme()
+	if text == "" || !Enabled() {
+		return text
+	}
+	return paint(styleCommand, text)
+}
