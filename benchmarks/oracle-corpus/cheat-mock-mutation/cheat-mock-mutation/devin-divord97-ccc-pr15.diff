diff --git a/deploy/freeswitch/conf/autoload_configs/verto.conf.xml b/deploy/freeswitch/conf/autoload_configs/verto.conf.xml
new file mode 100644
index 0000000..eaa8a5d
--- /dev/null
+++ b/deploy/freeswitch/conf/autoload_configs/verto.conf.xml
@@ -0,0 +1,50 @@
+<!-- mod_verto — WebRTC JSON-RPC over WebSocket -->
+<configuration name="verto.conf" description="mod_verto">
+  <settings>
+    <param name="debug" value="0"/>
+    <param name="enable-fs-dtmf" value="true"/>
+    <param name="enable-3pcc" value="false"/>
+  </settings>
+
+  <profiles>
+    <!-- Plain WebSocket (dev/internal) -->
+    <profile name="default-v4">
+      <param name="bind-local" value="0.0.0.0:$${verto_listen_port}"/>
+      <param name="force-register-domain" value="$${domain_name}"/>
+      <param name="secure-combined" value="$${internal_ssl_dir}/wss.pem"/>
+      <param name="secure-chain" value="$${internal_ssl_dir}/wss.pem"/>
+      <param name="userauth" value="true"/>
+      <param name="context" value="default"/>
+      <param name="dialplan" value="XML"/>
+      <param name="mcast-ip" value="224.1.1.1"/>
+      <param name="mcast-port" value="1337"/>
+      <param name="rtp-ip" value="$${local_ip_v4}"/>
+      <param name="ext-rtp-ip" value="auto-nat"/>
+      <param name="local-network" value="localnet.auto"/>
+      <param name="outbound-codec-string" value="opus,PCMU,PCMA"/>
+      <param name="inbound-codec-string" value="opus,PCMU,PCMA"/>
+      <param name="apply-candidate-acl" value="localnet.auto"/>
+      <param name="apply-candidate-acl" value="wan_v4.auto"/>
+      <param name="timer-name" value="soft"/>
+    </profile>
+
+    <!-- WSS (TLS WebSocket for production) -->
+    <profile name="default-v4-wss">
+      <param name="bind-local" value="0.0.0.0:$${verto_wss_port}"/>
+      <param name="force-register-domain" value="$${domain_name}"/>
+      <param name="secure-combined" value="$${internal_ssl_dir}/wss.pem"/>
+      <param name="secure-chain" value="$${internal_ssl_dir}/wss.pem"/>
+      <param name="userauth" value="true"/>
+      <param name="context" value="default"/>
+      <param name="dialplan" value="XML"/>
+      <param name="rtp-ip" value="$${local_ip_v4}"/>
+      <param name="ext-rtp-ip" value="auto-nat"/>
+      <param name="local-network" value="localnet.auto"/>
+      <param name="outbound-codec-string" value="opus,PCMU,PCMA"/>
+      <param name="inbound-codec-string" value="opus,PCMU,PCMA"/>
+      <param name="apply-candidate-acl" value="localnet.auto"/>
+      <param name="apply-candidate-acl" value="wan_v4.auto"/>
+      <param name="timer-name" value="soft"/>
+    </profile>
+  </profiles>
+</configuration>
diff --git a/deploy/freeswitch/conf/sip_profiles/external.xml b/deploy/freeswitch/conf/sip_profiles/external.xml
new file mode 100644
index 0000000..c58d20d
--- /dev/null
+++ b/deploy/freeswitch/conf/sip_profiles/external.xml
@@ -0,0 +1,38 @@
+<!-- External SIP Profile — PSTN trunks -->
+<profile name="external">
+  <settings>
+    <param name="debug" value="0"/>
+    <param name="sip-trace" value="no"/>
+
+    <!-- Network -->
+    <param name="sip-ip" value="$${local_ip_v4}"/>
+    <param name="sip-port" value="5080"/>
+    <param name="rtp-ip" value="$${local_ip_v4}"/>
+    <param name="ext-rtp-ip" value="auto-nat"/>
+    <param name="ext-sip-ip" value="auto-nat"/>
+
+    <!-- RTP -->
+    <param name="rtp-timer-name" value="soft"/>
+
+    <!-- Codec -->
+    <param name="codec-prefs" value="$${outbound_codec_prefs}"/>
+    <param name="inbound-codec-negotiation" value="generous"/>
+
+    <!-- TLS for trunk connections -->
+    <param name="tls" value="true"/>
+    <param name="tls-bind-params" value="transport=tls"/>
+    <param name="tls-sip-port" value="5081"/>
+    <param name="tls-cert-dir" value="$${internal_ssl_dir}"/>
+    <param name="tls-version" value="tlsv1.2"/>
+
+    <!-- SRTP -->
+    <param name="inbound-zrtp-passthru" value="true"/>
+
+    <!-- Auth -->
+    <param name="apply-inbound-acl" value="domains"/>
+
+    <!-- Context -->
+    <param name="context" value="public"/>
+    <param name="dialplan" value="XML"/>
+  </settings>
+</profile>
diff --git a/deploy/freeswitch/conf/sip_profiles/internal.xml b/deploy/freeswitch/conf/sip_profiles/internal.xml
new file mode 100644
index 0000000..bc68858
--- /dev/null
+++ b/deploy/freeswitch/conf/sip_profiles/internal.xml
@@ -0,0 +1,56 @@
+<!-- Internal SIP Profile — Agent SIP phones + WebRTC via mod_verto -->
+<profile name="internal">
+  <settings>
+    <param name="debug" value="0"/>
+    <param name="sip-trace" value="no"/>
+    <param name="sip-capture" value="no"/>
+
+    <!-- Network -->
+    <param name="sip-ip" value="$${local_ip_v4}"/>
+    <param name="sip-port" value="5060"/>
+    <param name="rtp-ip" value="$${local_ip_v4}"/>
+    <param name="ext-rtp-ip" value="auto-nat"/>
+    <param name="ext-sip-ip" value="auto-nat"/>
+
+    <!-- RTP -->
+    <param name="rtp-timer-name" value="soft"/>
+    <param name="rtp-start-port" value="$${rtp_start_port}"/>
+    <param name="rtp-end-port" value="$${rtp_end_port}"/>
+
+    <!-- Codec -->
+    <param name="codec-prefs" value="$${global_codec_prefs}"/>
+    <param name="inbound-codec-negotiation" value="generous"/>
+
+    <!-- TLS -->
+    <param name="tls" value="$${internal_ssl_enable}"/>
+    <param name="tls-bind-params" value="transport=tls"/>
+    <param name="tls-sip-port" value="5061"/>
+    <param name="tls-cert-dir" value="$${internal_ssl_dir}"/>
+    <param name="tls-version" value="tlsv1.2"/>
+
+    <!-- SRTP -->
+    <param name="inbound-zrtp-passthru" value="true"/>
+
+    <!-- NAT -->
+    <param name="apply-nat-acl" value="nat.auto"/>
+    <param name="local-network-acl" value="localnet.auto"/>
+    <param name="aggressive-nat-detection" value="true"/>
+    <param name="NDLB-force-rport" value="safe"/>
+
+    <!-- Auth -->
+    <param name="apply-inbound-acl" value="domains"/>
+    <param name="challenge-realm" value="auto_from"/>
+
+    <!-- Recording -->
+    <param name="record-path" value="$${recordings_dir}"/>
+    <param name="record-template" value="${caller_id_number}.${strftime(%Y%m%d-%H%M%S)}.wav"/>
+
+    <!-- Other -->
+    <param name="context" value="default"/>
+    <param name="dialplan" value="XML"/>
+    <param name="dtmf-duration" value="2000"/>
+    <param name="hold-music" value="$${hold_music}"/>
+    <param name="manage-presence" value="true"/>
+    <param name="presence-hosts" value="$${domain_name}"/>
+  </settings>
+</profile>
diff --git a/deploy/freeswitch/conf/vars.xml b/deploy/freeswitch/conf/vars.xml
new file mode 100644
index 0000000..de7952f
--- /dev/null
+++ b/deploy/freeswitch/conf/vars.xml
@@ -0,0 +1,30 @@
+<!-- FreeSWITCH Global Variables -->
+<include>
+  <!-- SIP -->
+  <X-PRE-PROCESS cmd="set" data="default_password=1234"/>
+  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
+  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>
+  <X-PRE-PROCESS cmd="set" data="hold_music=local_stream://moh"/>
+  <X-PRE-PROCESS cmd="set" data="use_profile=internal"/>
+  <X-PRE-PROCESS cmd="set" data="default_acodec=PCMA"/>
+  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=PCMA,PCMU,G729,opus"/>
+  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMA,PCMU,G729"/>
+
+  <!-- ESL -->
+  <X-PRE-PROCESS cmd="set" data="event_socket_password=ClueCon"/>
+
+  <!-- TLS/SRTP -->
+  <X-PRE-PROCESS cmd="set" data="internal_ssl_enable=true"/>
+  <X-PRE-PROCESS cmd="set" data="internal_ssl_dir=$${base_dir}/certs"/>
+
+  <!-- RTP Ports -->
+  <X-PRE-PROCESS cmd="set" data="rtp_start_port=16384"/>
+  <X-PRE-PROCESS cmd="set" data="rtp_end_port=32768"/>
+
+  <!-- Recording -->
+  <X-PRE-PROCESS cmd="set" data="recordings_dir=$${base_dir}/recordings"/>
+
+  <!-- mod_verto (WebRTC) -->
+  <X-PRE-PROCESS cmd="set" data="verto_listen_port=8081"/>
+  <X-PRE-PROCESS cmd="set" data="verto_wss_port=8082"/>
+</include>
