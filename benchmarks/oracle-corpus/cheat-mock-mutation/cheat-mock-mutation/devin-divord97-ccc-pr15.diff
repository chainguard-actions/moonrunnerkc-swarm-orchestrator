+-- Helper: Generate RANGE partition clauses by month.
+-- Each partition stores rows WHERE created_at < 'YYYY-MM-01'.
+
+-- ─── 1. calls ───
+ALTER TABLE calls PARTITION BY RANGE (TO_DAYS(created_at)) (
+    PARTITION p2024_01 VALUES LESS THAN (TO_DAYS('2024-02-01')),
+    PARTITION p2024_02 VALUES LESS THAN (TO_DAYS('2024-03-01')),
+    PARTITION p2024_03 VALUES LESS THAN (TO_DAYS('2024-04-01')),
