+++ b/src/utils/placesApi.js
@@ -0,0 +1,122 @@
+/**
+ * Google Places API (New) — Nearby Search for competitor laundromats.
+ *
+ * The Places API (New) supports CORS from browser requests.
+ * Users need a free API key from console.cloud.google.com with
+ * the "Places API (New)" product enabled.
+ *
+ * Geocoding (ZIP → lat/lng) uses the free Zippopotam.us API
+ * — no key required.
+ */
+
+const MILE_TO_METERS = 1609.344;
+
+// ─── Geocoding ────────────────────────────────────────────────────────────────
+
+/**
+ * Convert a US ZIP code to {lat, lng} using the free Zippopotam.us API.
+ * No API key required.
+ */
+export async function geocodeZip(zip) {
+  const clean = String(zip).trim().replace(/\D/g, '').slice(0, 5).padStart(5, '0');
+  const res = await fetch(`https://api.zippopotam.us/us/${clean}`);
+  if (!res.ok) throw new Error(`Could not geocode ZIP ${clean}. Verify the ZIP is a valid US ZIP code.`);
+  const data = await res.json();
+  const place = data.places?.[0];
+  if (!place) throw new Error(`No coordinates found for ZIP ${clean}.`);
+  return {
+    lat: parseFloat(place.latitude),
+    lng: parseFloat(place.longitude),
+    city: place['place name'],
+    state: place['state abbreviation'],
+  };
+}
+
+// ─── Places Nearby Search ─────────────────────────────────────────────────────
+
+/**
+ * Search for laundromats near {lat, lng} within radiusMiles using the
+ * Google Places API (New).
+ *
+ * Returns an array of place objects:
+ *   { name, displayName, types, rating, userRatingCount, location }
+ */
+export async function searchNearbyLaundromats(lat, lng, radiusMiles, apiKey) {
+  if (!apiKey) throw new Error('Google Maps API key is required for competitor search.');
+
+  const radiusMeters = radiusMiles * MILE_TO_METERS;
+
+  const body = {
+    includedTypes: ['laundry'],
+    maxResultCount: 20,
+    locationRestriction: {
+      circle: {
+        center: { latitude: lat, longitude: lng },
+        radius: radiusMeters,
+      },
+    },
+  };
+
+  const res = await fetch('https://places.googleapis.com/v1/places:searchNearby', {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json',
+      'X-Goog-Api-Key': apiKey,
+      'X-Goog-FieldMask': 'places.displayName,places.types,places.rating,places.userRatingCount,places.location,places.primaryType',
+    },
+    body: JSON.stringify(body),
+  });
+
+  if (!res.ok) {
+    const err = await res.json().catch(() => ({}));
+    const msg = err?.error?.message || `Places API error ${res.status}`;
+    if (res.status === 403 || res.status === 401) {
+      throw new Error(`Invalid or unauthorized API key. Make sure "Places API (New)" is enabled in your Google Cloud project. Details: ${msg}`);
+    }
+    throw new Error(`Google Places API error: ${msg}`);
+  }
+
+  const data = await res.json();
+  const places = data.places || [];
+
+  // Filter to only laundry-type results (exclude dry cleaners etc.)
+  const laundromats = places.filter(p => {
+    const name = (p.displayName?.text || '').toLowerCase();
+    const types = p.types || [];
+    // Include if primary type is laundry, or name contains laundromat/laundry/coin/wash
+    return (
+      types.includes('laundry') ||
+      name.includes('laundromat') ||
+      name.includes('coin laundry') ||
+      name.includes('wash') ||
+      name.includes('laundry')
+    );
+  });
+
+  return {
+    all: places,
+    laundromats,
+    count: laundromats.length,
+    rawCount: places.length,
+  };
+}
+
+/**
+ * Full flow: geocode ZIP → search nearby → return count + details.
+ * Pass existing lat/lng to skip geocoding.
+ */
+export async function fetchCompetitorCount({ zip, lat, lng, radiusMiles, googleApiKey }) {
+  let coords = { lat: parseFloat(lat), lng: parseFloat(lng) };
+
+  // Geocode if coordinates not provided
+  if (!coords.lat || !coords.lng || isNaN(coords.lat) || isNaN(coords.lng)) {
+    coords = await geocodeZip(zip);
+  }
+
+  const result = await searchNearbyLaundromats(coords.lat, coords.lng, radiusMiles, googleApiKey);
+
+  return {
+    ...result,
+    coords,
+  };
+}
