diff --git a/app/api/outbound/email/route.ts b/app/api/outbound/email/route.ts
new file mode 100644
index 0000000..d9861f7
--- /dev/null
+++ b/app/api/outbound/email/route.ts
@@ -0,0 +1,48 @@
+import { auth } from "@clerk/nextjs/server";
+import { NextResponse } from "next/server";
+import { sendProspectEmail } from "@/lib/email/resend";
+import { createSupabaseAdmin } from "@/lib/supabase/admin";
+import { outboundEmailSchema } from "@/lib/validators";
+
+export const runtime = "nodejs";
+
+export async function POST(req: Request) {
+  const { userId } = await auth();
+  if (!userId) {
+    return NextResponse.json({ error: "Non authentifié." }, { status: 401 });
+  }
+
+  const body = await req.json().catch(() => null);
+  const parsed = outboundEmailSchema.safeParse(body);
+  if (!parsed.success) {
+    return NextResponse.json({ error: "Payload invalide." }, { status: 400 });
+  }
+
+  const { prospectId, to, subject, body: htmlBody } = parsed.data;
+  const sb = createSupabaseAdmin();
+
+  const { data: prospect, error: pe } = await sb
+    .from("prospects")
+    .select("id")
+    .eq("id", prospectId)
+    .eq("clerk_user_id", userId)
+    .maybeSingle();
+
+  if (pe || !prospect) {
+    return NextResponse.json({ error: "Prospect introuvable." }, { status: 404 });
+  }
+
+  try {
+    const result = await sendProspectEmail({
+      clerkUserId: userId,
+      prospectId,
+      to,
+      subject,
+      bodyHtml: htmlBody,
+    });
+    return NextResponse.json({ success: true, messageId: result.id });
+  } catch (e) {
+    const message = e instanceof Error ? e.message : "Erreur d'envoi";
+    return NextResponse.json({ error: message }, { status: 500 });
+  }
+}
