diff --git a/supabase/migrations/20260531120000_rls_outbound_logs.sql b/supabase/migrations/20260531120000_rls_outbound_logs.sql
new file mode 100644
index 0000000..8f339be
--- /dev/null
+++ b/supabase/migrations/20260531120000_rls_outbound_logs.sql
@@ -0,0 +1,123 @@
+-- RLS (Clerk JWT via intégration Supabase : claim `sub` = `user_...` = clerk_user_id)
+-- Le client service_role continue de bypasser RLS côté Next.js.
+-- Voir docs/security-rls.md pour le template JWT Clerk « supabase ».
+
+-- Journal envois email (Resend / pipeline)
+create table if not exists public.outbound_logs (
+  id uuid primary key default gen_random_uuid(),
+  clerk_user_id text not null,
+  prospect_id uuid references public.prospects (id) on delete set null,
+  type text not null default 'email',
+  status text not null,
+  response text,
+  created_at timestamptz not null default now()
+);
+
+create index if not exists outbound_logs_clerk_created_idx
+  on public.outbound_logs (clerk_user_id, created_at desc);
+
+-- --- RLS : user_settings ---
+alter table public.user_settings enable row level security;
+
+create policy user_settings_select_own on public.user_settings
+  for select to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy user_settings_insert_own on public.user_settings
+  for insert to authenticated with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy user_settings_update_own on public.user_settings
+  for update to authenticated
+  using (clerk_user_id = (auth.jwt() ->> 'sub'))
+  with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+-- --- RLS : campaigns ---
+alter table public.campaigns enable row level security;
+
+create policy campaigns_select_own on public.campaigns
+  for select to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy campaigns_insert_own on public.campaigns
+  for insert to authenticated with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy campaigns_update_own on public.campaigns
+  for update to authenticated
+  using (clerk_user_id = (auth.jwt() ->> 'sub'))
+  with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy campaigns_delete_own on public.campaigns
+  for delete to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+-- --- RLS : prospects ---
+alter table public.prospects enable row level security;
+
+create policy prospects_select_own on public.prospects
+  for select to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy prospects_insert_own on public.prospects
+  for insert to authenticated with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy prospects_update_own on public.prospects
+  for update to authenticated
+  using (clerk_user_id = (auth.jwt() ->> 'sub'))
+  with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy prospects_delete_own on public.prospects
+  for delete to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+-- --- RLS : message_feedbacks ---
+alter table public.message_feedbacks enable row level security;
+
+create policy message_feedbacks_select_own on public.message_feedbacks
+  for select to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy message_feedbacks_insert_own on public.message_feedbacks
+  for insert to authenticated with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy message_feedbacks_update_own on public.message_feedbacks
+  for update to authenticated
+  using (clerk_user_id = (auth.jwt() ->> 'sub'))
+  with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy message_feedbacks_delete_own on public.message_feedbacks
+  for delete to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+-- --- RLS : agent_logs ---
+alter table public.agent_logs enable row level security;
+
+create policy agent_logs_select_own on public.agent_logs
+  for select to authenticated using (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+create policy agent_logs_insert_own on public.agent_logs
+  for insert to authenticated with check (clerk_user_id = (auth.jwt() ->> 'sub'));
+
+-- --- RLS : agent_blueprints ---
+alter table public.agent_blueprints enable row level security;
