+/**
+ * Sources de prospects : IA (défaut) ou Apollo quand `APOLLO_API_KEY` est défini.
+ * Apollo renvoie souvent moins de lignes que demandé ; en cas d’échec ou liste vide, l’API `/api/ai/prospects` retombe sur la génération IA.
+ */
+
+export type ProspectSource = "ai" | "apollo";
+
+export type AiProspectRow = {
+  name: string;
+  company: string;
+  needSummary: string;
+  linkedinHandle: string;
+};
+
+function slugFromLinkedinUrl(url: string | null | undefined): string {
+  if (!url || typeof url !== "string") return "";
+  const m = url.match(/linkedin\.com\/in\/([^/?#]+)/i);
+  return m?.[1]?.replace(/\/$/, "") ?? "";
+}
+
+/**
+ * Recherche Apollo (`mixed_people/search`). Retourne [] si clé absente, erreur HTTP, ou parsing impossible.
+ */
+export async function fetchApolloProspects(
+  niche: string,
+  count: number,
+): Promise<AiProspectRow[]> {
+  const apiKey = process.env.APOLLO_API_KEY?.trim();
+  if (!apiKey) return [];
+
+  const perPage = Math.min(Math.max(count, 1), 50);
+  const res = await fetch("https://api.apollo.io/api/v1/mixed_people/search", {
+    method: "POST",
+    headers: {
+      "Content-Type": "application/json",
+      "Cache-Control": "no-cache",
+      "X-Api-Key": apiKey,
+    },
+    body: JSON.stringify({
+      q_keywords: niche,
+      page: 1,
+      per_page: perPage,
+    }),
+  });
+
+  if (!res.ok) {
+    console.error("Apollo mixed_people/search", res.status, await res.text().catch(() => ""));
+    return [];
+  }
+
+  const data = (await res.json()) as {
+    people?: Array<{
+      first_name?: string | null;
+      last_name?: string | null;
+      title?: string | null;
+      linkedin_url?: string | null;
+      organization?: { name?: string | null } | null;
+    }>;
+  };
+
+  const people = Array.isArray(data.people) ? data.people : [];
+  const out: AiProspectRow[] = [];
+
+  for (const p of people) {
+    if (out.length >= count) break;
+    const first = (p.first_name ?? "").trim();
+    const last = (p.last_name ?? "").trim();
+    const name = `${first} ${last}`.trim() || "Contact";
+    const company = (p.organization?.name ?? "").trim() || "Organisation inconnue";
+    const needSummary = (p.title ?? "").trim() || `Rôle ciblé — ${niche}`;
+    const linkedinHandle = slugFromLinkedinUrl(p.linkedin_url ?? undefined);
+    out.push({
+      name,
+      company,
+      needSummary,
+      linkedinHandle: linkedinHandle || "a-completer",
+    });
+  }
+
+  return out;
+}
