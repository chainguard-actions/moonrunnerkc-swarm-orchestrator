+import { Resend } from "resend";
+import { createSupabaseAdmin } from "@/lib/supabase/admin";
+
+export type SendProspectEmailParams = {
+  clerkUserId: string;
+  prospectId: string;
+  to: string;
+  subject: string;
+  /** HTML ou texte brut (Resend accepte html) */
+  bodyHtml: string;
+};
+
+/**
+ * Envoie un email via Resend et trace dans `outbound_logs`.
+ * Requiert `RESEND_API_KEY` et de préférence `RESEND_FROM_EMAIL` (domaine vérifié chez Resend).
+ */
+export async function sendProspectEmail(params: SendProspectEmailParams): Promise<{ id: string | null }> {
+  const apiKey = process.env.RESEND_API_KEY?.trim();
+  if (!apiKey) {
+    throw new Error(
+      "RESEND_API_KEY manquant. Ajoute la clé dans les variables d'environnement pour activer l'envoi.",
+    );
+  }
+
+  const from =
+    process.env.RESEND_FROM_EMAIL?.trim() ||
+    "Gold Monster <onboarding@resend.dev>";
+
+  const resend = new Resend(apiKey);
+  const { data, error } = await resend.emails.send({
+    from,
+    to: params.to,
+    subject: params.subject,
+    html: params.bodyHtml,
+  });
+
+  const sb = createSupabaseAdmin();
+  if (error) {
+    await sb.from("outbound_logs").insert({
+      clerk_user_id: params.clerkUserId,
+      prospect_id: params.prospectId,
+      type: "email",
+      status: "error",
+      response: error.message,
+    });
+    throw new Error(error.message);
+  }
+
+  await sb.from("outbound_logs").insert({
+    clerk_user_id: params.clerkUserId,
+    prospect_id: params.prospectId,
+    type: "email",
+    status: "sent",
+    response: data?.id ?? null,
+  });
+
+  return { id: data?.id ?? null };
+}
