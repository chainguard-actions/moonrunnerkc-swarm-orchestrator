@@ -0,0 +1,28 @@
+import { auth } from "@clerk/nextjs/server";
+import { createClient, type SupabaseClient } from "@supabase/supabase-js";
+
+/**
+ * Client Supabase avec le JWT Clerk (template `supabase`).
+ * Les politiques RLS (`clerk_user_id` = `sub`) s’appliquent.
+ * Réservé au serveur (Route Handlers / Server Components) — ne pas exposer la clé anon autrement que via `NEXT_PUBLIC_*`.
+ */
+export async function createSupabaseWithClerkJwt(): Promise<SupabaseClient> {
+  const url = process.env.NEXT_PUBLIC_SUPABASE_URL;
+  const anon = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;
+  if (!url || !anon) {
+    throw new Error(
+      "NEXT_PUBLIC_SUPABASE_URL ou NEXT_PUBLIC_SUPABASE_ANON_KEY manquant — requis pour le client JWT.",
+    );
+  }
+  const { getToken } = await auth();
+  const token = await getToken({ template: "supabase" });
+  if (!token) {
+    throw new Error(
+      "Jeton Clerk (template « supabase ») indisponible. Configure le template JWT dans Clerk.",
+    );
+  }
+  return createClient(url, anon, {
+    auth: { persistSession: false, autoRefreshToken: false },
+    global: { headers: { Authorization: `Bearer ${token}` } },
+  });
+}
