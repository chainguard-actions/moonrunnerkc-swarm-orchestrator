+        providerDebug: {
+          timedOut: true,
+          providersTried: [],
+          envReady: buildSoldEnvReadySnapshot()
+        }
+      };
+    }
+
+    const data = winner?.data || {};
+    return {
+      ...data,
+      providerDebug: {
+        ...(data.providerDebug || {}),
+        timedOut: false,
+        envReady: data.providerDebug?.envReady || buildSoldEnvReadySnapshot()
+      }
+    };
+  } catch (err) {
+    return {
+      items: [],
+      total: 0,
+      warnings: [serializeErrorValue(err)],
+      providerDebug: {
+        timedOut: false,
+        error: serializeErrorValue(err),
+        providersTried: [],
+        envReady: buildSoldEnvReadySnapshot()
+      }
+    };
+  } finally {
+    if (timer) clearTimeout(timer);
+  }
