diff --git a/src/lib/scroll-to-hash.ts b/src/lib/scroll-to-hash.ts
new file mode 100644
index 0000000..d78105d
--- /dev/null
+++ b/src/lib/scroll-to-hash.ts
@@ -0,0 +1,81 @@
+const DEFAULT_HEADER_OFFSET = 88;
+
+export function parseHashPath(path: string): { basePath: string; hash: string } {
+  const hashIndex = path.indexOf("#");
+  if (hashIndex === -1) {
+    return { basePath: path, hash: "" };
+  }
+
+  return {
+    basePath: path.slice(0, hashIndex) || "/",
+    hash: path.slice(hashIndex),
+  };
+}
+
+export function navigateToHashPath(
+  path: string,
+  pathname: string,
+  router: { push: (href: string) => void },
+): void {
+  const { basePath, hash } = parseHashPath(path);
+
+  if (hash && pathname === basePath) {
+    window.history.pushState(null, "", path);
+    scrollToHashWithRetry(hash);
+    return;
+  }
+
+  router.push(path);
+}
+
+export function scrollToHashSection(
+  hash: string,
+  options?: { behavior?: ScrollBehavior; offset?: number },
+): boolean {
+  const id = hash.replace(/^#/, "");
+  if (!id) return false;
+
+  const element = document.getElementById(id);
+  if (!element) return false;
+
+  const offset = options?.offset ?? DEFAULT_HEADER_OFFSET;
+  const top =
+    element.getBoundingClientRect().top + window.scrollY - offset;
+
+  window.scrollTo({
+    top: Math.max(0, top),
+    behavior: options?.behavior ?? "smooth",
+  });
+
+  return true;
+}
+
+export function scrollToHashWithRetry(
+  hash: string,
+  options?: {
+    behavior?: ScrollBehavior;
+    offset?: number;
+    maxAttempts?: number;
+    intervalMs?: number;
+  },
+): () => void {
+  const maxAttempts = options?.maxAttempts ?? 12;
+  const intervalMs = options?.intervalMs ?? 100;
+  let attempts = 0;
+  let timeoutId: ReturnType<typeof setTimeout> | undefined;
+
+  const tryScroll = () => {
+    attempts += 1;
+    if (scrollToHashSection(hash, options)) return;
+
+    if (attempts < maxAttempts) {
+      timeoutId = setTimeout(tryScroll, intervalMs);
+    }
+  };
+
+  tryScroll();
+
+  return () => {
+    if (timeoutId) clearTimeout(timeoutId);
+  };
+}
