+  },
+  {
+    href: "/campaigns",
+    title: "Campagnes & meta-agent",
+    icon: Zap,
+    description:
+      "Suivre les campagnes, lancer le meta-agent (blueprints / sous-agents) et consulter les journaux d’audit.",
+    cta: "Ouvrir les campagnes",
+  },
+  {
+    href: "/settings",
+    title: "Réglages",
+    icon: Settings,
+    description:
+      "Lien Stripe, montant de proposition par défaut et rappel des variables d’environnement (Clerk, Supabase, OpenRouter, crons).",
+    cta: "Ouvrir les réglages",
+  },
+] as const;
+
+export default function CapacitesPage() {
+  return (
+    <div className="space-y-10">
+      <div>
+        <h1 className="text-2xl font-black tracking-tight sm:text-3xl">Capacités du cockpit</h1>
+        <p className="mt-2 max-w-2xl text-sm text-muted-foreground">
+          Tout ce que tu peux faire dans l’app est regroupé ici avec des liens directs. Les sections « Prospects »
+          utilisent des ancres (<code className="text-xs text-amber-200/90">#…</code>) pour te poser au bon endroit
+          sur la page.
+        </p>
+      </div>
+
+      <div className="grid gap-4 sm:grid-cols-2">
+        {zones.map(({ href, hash, title, icon: Icon, description, cta }) => (
+          <Card key={href} className="border-white/10 bg-white/[0.03]">
+            <CardHeader>
+              <div className="flex items-start gap-3">
+                <span className="flex size-10 shrink-0 items-center justify-center rounded-lg bg-amber-500/15 text-amber-300">
+                  <Icon className="size-5" />
+                </span>
+                <div>
+                  <CardTitle className="text-lg">{title}</CardTitle>
+                  <CardDescription className="mt-1 text-muted-foreground">{description}</CardDescription>
+                </div>
+              </div>
+            </CardHeader>
+            <CardContent>
+              <Link
+                href={`${href}${hash ?? ""}`}
+                className={cn(
+                  buttonVariants({ variant: "outline", size: "sm" }),
+                  "border-amber-500/40 text-amber-200 hover:bg-amber-500/10 hover:text-amber-100",
+                )}
+              >
+                {cta}
+                <ArrowRight className="ml-2 size-4" />
+              </Link>
+            </CardContent>
+          </Card>
+        ))}
+      </div>
+
+      <Card className="border-white/10 bg-white/[0.03]">
+        <CardHeader>
+          <CardTitle className="text-base">En arrière-plan (sans page dédiée)</CardTitle>
+          <CardDescription className="text-muted-foreground">
+            Ces briques tournent côté serveur ou via des crons — tu les configures dans Vercel / Supabase.
+          </CardDescription>
+        </CardHeader>
+        <CardContent className="space-y-2 text-sm text-muted-foreground">
+          <p>
+            <span className="font-medium text-foreground">Relances IA</span> — cron sur{" "}
+            <code className="text-xs text-amber-200/90">/api/ai/follow-up</code> (prospects contactés sans activité).
+          </p>
+          <p>
+            <span className="font-medium text-foreground">Stripe</span> — webhook checkout pour marquer un deal quand
+            un paiement est confirmé (lien de paiement dans les réglages).
+          </p>
+          <p>
+            <span className="font-medium text-foreground">Quotas IA</span> — compteur consommé par les routes{" "}
+            <code className="text-xs text-amber-200/90">/api/ai/*</code>.
+          </p>
+        </CardContent>
+      </Card>
+    </div>
+  );
+}
