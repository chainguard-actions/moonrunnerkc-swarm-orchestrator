+  },
+  {
+    href: "/prospects",
+    hash: "#generer-prospects",
+    title: "Prospects",
+    icon: Target,
+    description:
+      "Générer des profils, rédiger les messages LinkedIn + email, mémoire des corrections et pipeline (statuts, deals).",
