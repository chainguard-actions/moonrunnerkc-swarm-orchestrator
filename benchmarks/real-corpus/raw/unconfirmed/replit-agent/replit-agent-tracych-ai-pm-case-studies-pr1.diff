+      { t: 'Implement changes incrementally', done: false },
+      { t: 'Write or update tests', done: false },
+      { t: 'Run lint, typecheck, and tests', done: false },
+      { t: 'Open PR with summary and verification notes', done: false },
+    ],
+    files: [],
+    transcript: [
+      { role: 'user', ts: timestamp(), body: task },
+      { role: 'assistant', ts: timestamp(1), thought: 'Let me start by exploring the repo to understand the existing patterns.' },
+      { role: 'tool', ts: timestamp(2), tool: 'Glob', arg: '**/*.{ts,tsx,js,jsx}', result: 'scanning workspace...' },
+    ],
+    terminal: [
+      { type: 'info', text: '→ Spawning agent on ' + repo + '...' },
+      { type: 'cmd', text: '$ git checkout -b agent/' + newId.toLowerCase() },
+      { type: 'out', text: "Switched to a new branch 'agent/" + newId.toLowerCase() + "'" },
+    ],
+    pr: null,
+  };
+
+  AGENTS.unshift(newAgent);
+  modal.classList.remove('open');
+  document.getElementById('m-task').value = '';
+  toast(`Dispatched ${newId} on ${repo}`);
+  renderCards();
+  setTimeout(() => selectAgent(newId), 200);
+});
+
+function timestamp(offset = 0) {
+  const d = new Date(Date.now() + offset * 1000);
+  return d.toTimeString().slice(0, 8);
+}
+
+// keyboard: esc closes detail/modal
+document.addEventListener('keydown', e => {
+  if (e.key === 'Escape') {
+    if (modal.classList.contains('open')) modal.classList.remove('open');
+    else if (state.selectedId) closeDetail();
+  }
+});
+
+/* =========================================================================
+   BOOT
+   ========================================================================= */
+
+renderCards();
+state.tickHandle = setInterval(tick, 1800);
+
+// auto-open the most interesting card after a beat
+setTimeout(() => {
+  selectAgent('TASK-4125'); // the flaky test one — has rich transcript
+  // tour hint
+  const tour = document.getElementById('tour');
+  tour.style.display = 'flex';
+  tour.addEventListener('click', () => tour.style.display = 'none');
+  setTimeout(() => tour.style.display = 'none', 8000);
+}, 1200);
+
+</script>
+</body>
+</html>
