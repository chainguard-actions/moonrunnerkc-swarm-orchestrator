+    }
+    if (m.role === 'tool') {
+      return `<div class="msg">
+        <div class="msg-role"><span class="tag" style="color:var(--violet);">tool</span><span class="ts">${m.ts}</span></div>
+        <div class="msg-tool-call">
+          <span class="tool-name">${m.tool}</span>(<span class="tool-arg">${escapeHtml(m.arg)}</span>)
