+<script>
+/* ---- theme toggle ---- */
+(function(){
+  var root = document.documentElement;
+  var btn = document.getElementById('themeBtn');
+  var icon = document.getElementById('themeIcon');
+  var sun = '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>';
+  var moon = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
+  function setIcon(){ icon.innerHTML = (root.getAttribute('data-theme')==='dark') ? moon : sun; }
+  setIcon();
+  btn.addEventListener('click', function(){
+    var next = (root.getAttribute('data-theme')==='dark') ? 'light' : 'dark';
+    root.setAttribute('data-theme', next);
+    setIcon();
+    try{ localStorage.setItem('cc-theme', next); }catch(e){}
+  });
+  try{
+    var saved = localStorage.getItem('cc-theme');
+    if(saved){ root.setAttribute('data-theme', saved); setIcon(); }
+  }catch(e){}
+})();
+
+/* ---- intersection-observer driven fade-ins + bar grow ---- */
+(function(){
+  if(!('IntersectionObserver' in window)){
+    document.querySelectorAll('.fade-up,.ice-bar').forEach(function(el){ el.classList.add('is-in'); });
+    return;
+  }
+  var io = new IntersectionObserver(function(entries){
+    entries.forEach(function(e){
+      if(e.isIntersecting){
+        e.target.classList.add('is-in');
+        io.unobserve(e.target);
+      }
+    });
+  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
+  document.querySelectorAll('.fade-up, .ice-bar').forEach(function(el){ io.observe(el); });
+})();
+</script>
