index 0000000..877b744
--- /dev/null
+++ b/web/src/machines/notificationMachine.ts
@@ -0,0 +1,125 @@
+/**
+ * notificationMachine — The single source of truth for all toasts / snackbars.
+ *
+ * Any machine or component sends PUSH_TOAST. This machine queues them,
+ * auto-dismisses after a delay, and handles manual dismissal.
+ *
+ * States
+ * ──────
+ *  idle ⟷ showing (queue never empties → stays in showing)
+ *
+ * Context holds the full queue. Each toast has its own dismiss timer
+ * managed via XState's `after` in a spawned actor per notification.
+ */
+
+import { setup, assign, sendSelf } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export type ToastVariant = 'success' | 'error' | 'info' | 'warning'
+
+export interface Toast {
+  id:        string
+  message:   string
+  variant:   ToastVariant
+  /** ms before auto-dismiss — defaults to 3500 */
+  duration?: number
+}
+
+export interface NotificationContext {
+  queue: Toast[]
+}
+
+export type NotificationEvent =
+  | { type: 'PUSH_TOAST'; toast: Omit<Toast, 'id'> }
+  | { type: 'DISMISS_TOAST'; id: string }
+  | { type: 'DISMISS_ALL' }
+  | { type: '_AUTO_DISMISS'; id: string }
+
+const AUTO_DISMISS_DEFAULT = 3_500
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const notificationMachine = setup({
+  types: {
+    context: {} as NotificationContext,
+    events:  {} as NotificationEvent,
+  },
+  actions: {
+    addToast: assign({
+      queue: ({ context, event }) => {
+        if (event.type !== 'PUSH_TOAST') return context.queue
+        const id = `toast_${Date.now()}_${Math.random().toString(36).slice(2, 7)}`
+        return [...context.queue, { ...event.toast, id }]
+      },
+    }),
+    removeToast: assign({
+      queue: ({ context, event }) => {
+        const id = event.type === 'DISMISS_TOAST' || event.type === '_AUTO_DISMISS'
+          ? event.id
+          : null
+        if (!id) return context.queue
+        return context.queue.filter((t) => t.id !== id)
+      },
+    }),
+    clearAll: assign({ queue: [] }),
+
+    /** Schedule auto-dismiss for the most recently added toast. */
+    scheduleAutoDismiss: sendSelf(({ context, event }) => {
+      if (event.type !== 'PUSH_TOAST') return { type: '_AUTO_DISMISS', id: '' }
+      const toast = context.queue.at(-1)
+      const delay = event.toast.duration ?? AUTO_DISMISS_DEFAULT
+      return new Promise<NotificationEvent>((resolve) =>
+        setTimeout(
+          () => resolve({ type: '_AUTO_DISMISS', id: toast?.id ?? '' }),
+          delay,
+        )
+      ) as unknown as NotificationEvent
+    }),
+  },
+}).createMachine({
+  id:      'notifications',
+  initial: 'idle',
+  context: { queue: [] },
+
+  states: {
+    idle: {
+      on: {
+        PUSH_TOAST: {
+          target:  'showing',
+          actions: ['addToast', 'scheduleAutoDismiss'],
+        },
+      },
+    },
+
+    showing: {
+      on: {
+        PUSH_TOAST: {
+          actions: ['addToast', 'scheduleAutoDismiss'],
+        },
+        DISMISS_TOAST: {
+          actions: 'removeToast',
+        },
+        _AUTO_DISMISS: [
+          {
+            guard:   ({ context, event }) =>
+              event.type === '_AUTO_DISMISS' && context.queue.length <= 1,
+            target:  'idle',
+            actions: 'removeToast',
+          },
+          {
+            actions: 'removeToast',
+          },
+        ],
+        DISMISS_ALL: {
+          target:  'idle',
+          actions: 'clearAll',
+        },
+      },
+    },
+  },
+})
