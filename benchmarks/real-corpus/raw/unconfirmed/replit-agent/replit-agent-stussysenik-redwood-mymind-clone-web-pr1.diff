+/**
+ * machines/index — Central export for all XState machines.
+ *
+ * Architecture:
+ *   graphMachine        — graph data/renderer/simulation lifecycle
+ *   animationMachine    — all animated state transitions
+ *   notificationMachine — toast queue with auto-dismiss
+ *   cardOperationMachine — archive/delete/restore + optimistic UI
+ *   clusterMachine      — cluster selection → save flow
+ *   filterMachine       — debounced edge-weight filter
+ *   modalMachine        — generic open/close with animation guard
+ *
+ * Rule: components SEND EVENTS. They never own the logic.
+ */
+
+export { graphMachine, GRAPH_PHASE_LABELS } from './graphMachine'
+export type { GraphMachineContext, GraphMachineEvent } from './graphMachine'
+
+export {
+  createAnimationMachine,
+  graphCanvasAnimMachine,
+  detailPanelAnimMachine,
+  modalOverlayAnimMachine,
+  loadingOverlayAnimMachine,
+} from './animationMachine'
+export type { AnimationVariant, AnimationMachineContext } from './animationMachine'
+
+export { notificationMachine } from './notificationMachine'
+export type { Toast, ToastVariant, NotificationContext } from './notificationMachine'
+
+export { cardOperationMachine } from './cardOperationMachine'
+export type { CardOperation, CardOperationContext } from './cardOperationMachine'
+
+export { clusterMachine } from './clusterMachine'
+export type { ClusterMachineContext } from './clusterMachine'
+
+export { filterMachine } from './filterMachine'
+export type { FilterMachineContext } from './filterMachine'
+
+export {
+  createModalMachine,
+  cardDetailModalMachine,
+  settingsModalMachine,
+  addModalMachine,
+  clusterSheetMachine,
+} from './modalMachine'
