+  const handleNodeClick = useCallback((node: FGNode) => {
+    if (focusedNodeId === node.id) {
+      haptic('medium')
+      modalSend({ type: 'OPEN', payload: node.id })
+      return
+    }
+    haptic('light')
+    setFocusedNodeId(node.id)
+    const fg = fgRef.current
+    if (fg) { fg.centerAt(node.x, node.y, 600); fg.zoom(isMobile ? 2 : 2.5, 600) }
+  }, [focusedNodeId, isMobile, setFocusedNodeId, modalSend])
+
+  const closeFocus = useCallback(() => {
+    setFocusedNodeId(null)
+    const fg = fgRef.current
+    if (fg) { fg.centerAt(0, 0, 600); fg.zoom(1, 600) }
+  }, [setFocusedNodeId])
+
+  const handleBackgroundClick = useCallback(() => { if (focusedNodeId) closeFocus() }, [focusedNodeId, closeFocus])
+  const handleZoom = useCallback(({ k }: { k: number }) => { currentZoomRef.current = k }, [])
+  const handleNodeClickById = useCallback((id: string) => { const node = graphData.nodes.find((n) => n.id === id); if (node) handleNodeClick(node) }, [graphData.nodes, handleNodeClick])
+  const handleNodeHoverById = useCallback((node: GraphNode | null) => { handleNodeHover(node, null) }, [handleNodeHover])
+
+  useEffect(() => {
+    function onKeyDown(e: KeyboardEvent) {
+      if (e.key === 'Escape') {
+        if (modalState.matches('open')) { modalSend({ type: 'CLOSE' }) }
+        else if (focusedNodeId) { closeFocus() }
+      }
+    }
+    window.addEventListener('keydown', onKeyDown)
+    return () => window.removeEventListener('keydown', onKeyDown)
+  }, [focusedNodeId, modalState, modalSend, closeFocus])
+
+  // ── Filter events → filterMachine ─────────────────────────────────────────────
+  const handleMinWeightChange = useCallback((weight: number) => {
+    filterSend({ type: 'SET_WEIGHT', weight })
+    // Also notify graphMachine that filtering happened (no re-simulate needed)
+    graphSend({ type: 'FILTER_CHANGED' })
+  }, [filterSend, graphSend])
+
+  const handleReset = useCallback(() => {
+    filterSend({ type: 'RESET' })
+    setFocusedNodeId(null)
+  }, [filterSend, setFocusedNodeId])
+
+  // ── Canvas rendering (display only — no logic) ────────────────────────────────
+  const showLabels   = dimensions.width > 400
+  const showInitials = true
+
+  const nodeCanvasObject = useCallback((node: FGNode, ctx: CanvasRenderingContext2D) => {
+    const x = node.x ?? 0; const y = node.y ?? 0
+    const canvas = ctx.canvas; const transform = ctx.getTransform()
+    const screenX = x * transform.a + transform.e
+    const screenY = y * transform.d + transform.f
+    const pad = 60
+    if (screenX < -pad || screenX > canvas.width + pad || screenY < -pad || screenY > canvas.height + pad) return
+
+    const connections = node.connections ?? 0
+    const color = node.color ?? '#6B7280'
+    const type  = node.type  ?? 'article'
+    const isOrphan   = !connectedNodeIds.has(node.id)
+    const isHovered  = hoveredNode?.id === node.id
+    const isFocused  = focusedNodeId === node.id
+    const isNeighbor = focusedNeighbors?.has(node.id) ?? false
+    const inFocusMode = focusedNodeId !== null
+
+    if (isOrphan && !isHovered) {
+      ctx.beginPath(); ctx.arc(x, y, 6, 0, 2 * Math.PI)
+      ctx.setLineDash([2, 2])
+      ctx.strokeStyle = color; ctx.globalAlpha = inFocusMode ? 0.12 : 0.35; ctx.lineWidth = 1.25; ctx.stroke()
+      ctx.setLineDash([]); ctx.globalAlpha = 1
+      if (showInitials) {
+        ctx.font = FONT_ORPHAN_INITIAL; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'
+        ctx.fillStyle = color; ctx.globalAlpha = inFocusMode ? 0.14 : 0.28
+        ctx.fillText(TYPE_INITIALS[type] || '?', x, y); ctx.globalAlpha = 1
+      }
+      return
+    }
+
+    const radius = Math.sqrt(Math.max(1, connections)) * 4 + 5
+    let alpha: number
+    if (inFocusMode) { alpha = (isFocused || isNeighbor) ? 1 : DIM_ALPHA }
+    else { alpha = 0.35 + (connections / maxConnections) * 0.65 }
+    if (isHovered) alpha = 1
+
+    if (isHovered || isFocused) {
+      ctx.beginPath(); ctx.arc(x, y, radius + 6, 0, 2 * Math.PI)
+      ctx.fillStyle = color + '22'; ctx.fill()
+    }
+    ctx.beginPath(); ctx.arc(x, y, radius, 0, 2 * Math.PI)
+    ctx.globalAlpha = alpha; ctx.fillStyle = color; ctx.fill(); ctx.globalAlpha = 1
+
+    if (showInitials) {
+      const initial = TYPE_INITIALS[type] || '?'
+      const initialSize = Math.max(8, radius * 0.75)
+      ctx.font = `700 ${initialSize}px Inter, system-ui, sans-serif`
+      ctx.textAlign = 'center'; ctx.textBaseline = 'middle'
+      ctx.fillStyle = '#FFFFFF'; ctx.globalAlpha = alpha * 0.9
+      ctx.fillText(initial, x, y); ctx.globalAlpha = 1
+    }
+
+    if (showLabels) {
+      const title = node.title
+      const showLabel = !inFocusMode || isFocused || isNeighbor || isHovered
+      if (title && showLabel && alpha > DIM_ALPHA) {
+        const prominent = isHovered || isFocused
+        const dark = darkModeRef.current
+        ctx.font = prominent ? FONT_LABEL_PROMINENT : FONT_LABEL_NORMAL
+        ctx.textAlign = 'center'; ctx.textBaseline = 'top'
+        ctx.fillStyle = prominent ? (dark ? '#F5EFE5' : '#2D2D2D') : (dark ? '#A8A098' : '#5A5A5A')
+        ctx.globalAlpha = prominent ? 1 : Math.max(0.5, alpha * 0.9)
+        ctx.fillText(prominent ? truncate(title, 36) : truncate(title, 20), x, y + radius + 3)
+        ctx.globalAlpha = 1
+      }
+    }
+  }, [hoveredNode, focusedNodeId, focusedNeighbors, maxConnections, connectedNodeIds, darkModeRef, showInitials, showLabels])
+
+  const linkCanvasObject = useCallback((link: FGLink, ctx: CanvasRenderingContext2D) => {
+    const src = link.source; const tgt = link.target
+    if (!src || !tgt || src.x == null || tgt.x == null) return
+    const srcId = src.id ?? src; const tgtId = tgt.id ?? tgt
+    const inFocusMode    = focusedNodeId !== null
+    const isFocusedLink  = inFocusMode && (srcId === focusedNodeId || tgtId === focusedNodeId)
+    const weight = link.weight ?? 1
+    const t = 0.15 + (weight / maxWeight) * 0.45
+    let edgeAlpha = t
+    if (inFocusMode && !isFocusedLink) edgeAlpha = DIM_ALPHA * 0.5
+    if (isFocusedLink) edgeAlpha = Math.max(t, 0.5)
+
+    const sx = src.x; const sy = src.y; const tx = tgt.x; const ty = tgt.y
+    const canvas = ctx.canvas; const transform = ctx.getTransform()
+    const pad = 20
+    const ssx = sx * transform.a + transform.e; const ssy = sy * transform.d + transform.f
+    const tsx = tx * transform.a + transform.e; const tsy = ty * transform.d + transform.f
+    if ((ssx < -pad && tsx < -pad) || (ssx > canvas.width + pad && tsx > canvas.width + pad) ||
+        (ssy < -pad && tsy < -pad) || (ssy > canvas.height + pad && tsy > canvas.height + pad)) return
+
+    const mx = (sx + tx) / 2; const my = (sy + ty) / 2
+    const dx = tx - sx; const dy = ty - sy
+    const cpx = mx - dy * 0.15; const cpy = my + dx * 0.15
+
+    ctx.beginPath(); ctx.moveTo(sx, sy); ctx.quadraticCurveTo(cpx, cpy, tx, ty)
+    ctx.strokeStyle = isFocusedLink ? '#8B7355' : EDGE_COLOR
+    ctx.globalAlpha = edgeAlpha
+    ctx.lineWidth = isFocusedLink ? Math.max(1.5, weight * 1) : Math.max(0.5, weight * 0.8)
+    ctx.stroke(); ctx.globalAlpha = 1
+
+    const sharedTags = link.sharedTags
+    if (isFocusedLink && sharedTags && sharedTags.length > 0) {
+      const lx = (mx + cpx) / 2; const ly = (my + cpy) / 2
+      const label = sharedTags.slice(0, 3).join(', ')
+      ctx.font = FONT_TAG_LABEL; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'
+      const dark = darkModeRef.current
+      const pw = ctx.measureText(label).width + 8; const ph = 14
+      ctx.fillStyle = dark ? '#1A1A2E' : '#F7F6F3'; ctx.globalAlpha = 0.9
+      ctx.beginPath(); drawRoundedRect(ctx, lx - pw / 2, ly - ph / 2, pw, ph, 4); ctx.fill()
+      ctx.fillStyle = dark ? '#C4B5A0' : '#6B5D4F'; ctx.globalAlpha = 1; ctx.fillText(label, lx, ly)
+    }
+  }, [focusedNodeId, maxWeight, darkModeRef])
+
+  // ── Focused head item for detail panel ────────────────────────────────────────
+  const focusedHeadItem: ConnectionItem | null = focusedNodeId ? {
+    id: focusedNodeId,
+    title: neighborIndex.titleMap[focusedNodeId] || 'Untitled',
+    type:  neighborIndex.typeMap[focusedNodeId]  || 'article',
+    color: neighborIndex.colorMap[focusedNodeId] || '#6B7280',
+    sharedTags: [],
+    weight: focusedConnections.length,
+  } : null
+
+  const isReady = dimensions.width > 10 && dimensions.height > 10
+
+  // =============================================================================
+  // RENDER
+  // =============================================================================
+
+  return (
+    <div
+      ref={containerRef}
+      style={{
+        width: '100%', height: '100%',
+        position: 'absolute', top: 0, left: 0, right: 0, bottom: 0,
+        touchAction: viewMode === 'list' ? 'auto' : (isMobile ? 'manipulation' : 'none'),
+      }}
+    >
+      {/* ── Top-right chrome ──────────────────────────────────────────────────
+           Flex row, wraps down on very narrow viewports so the two controls
+           never overlap each other. max-w keeps it from pushing into the
+           filter panel zone on small screens. z-50 sits above the filter (z-40). */}
+      <div className="absolute right-3 top-3 z-50 flex flex-wrap items-center justify-end gap-2 max-w-[calc(100%-1.5rem)]">
+        {viewMode === 'graph' && (
+          <GraphDimensionToggle value={localDimension} onChange={handleDimensionChange} />
+        )}
+        <ViewModeToggle
+          value={viewMode}
+          onChange={setViewMode}
+          ariaLabel="Graph page view"
+          options={[
+            { value: 'graph', label: 'Graph', icon: <Network className="h-4 w-4" /> },
+            { value: 'list',  label: 'List',  icon: <Rows3   className="h-4 w-4" /> },
+          ]}
+        />
+      </div>
+
+      {/* ── Ordered loading overlay — driven by graphMachine ── */}
+      {showLoadingOverlay && viewMode === 'graph' && (
+        <GraphLoadingStage
+          phase={graphPhase}
+          nodeCount={graphState.context.nodeCount}
+          edgeCount={graphState.context.edgeCount}
+        />
+      )}
+
+      {/* ── No edges hint ─────────────────────────────────────────────────────
+           Placed at bottom-left on mobile (above the Clusters button) so it
+           doesn't conflict with the top-right chrome or the filter panel.
+           On sm+ it sits top-left below the header chrome row. */}
+      {viewMode === 'graph' && graphSettled && graphData.links.length === 0 && (
+        <div
+          className="absolute left-4 bottom-20 sm:bottom-auto sm:top-20 z-40 max-w-[280px] rounded-2xl px-3.5 py-3 text-xs"
+          style={{ backgroundColor: 'var(--surface-floating)', border: '1px solid var(--border-subtle)', boxShadow: 'var(--shadow-sm)', color: 'var(--foreground-muted)' }}
+        >
+          No shared-tag edges yet. The graph still renders every card, and list
+          view stays available as a denser fallback while tags improve.
+        </div>
+      )}
+
+      {/* ── Main content area ── */}
+      {viewMode === 'list' ? (
+        <GraphListView nodes={graphData.nodes} links={graphData.links} onCardOpen={(id) => modalSend({ type: 'OPEN', payload: id })} />
+
+      ) : effectiveRenderer === 'webgl' ? (
+        <Suspense fallback={<div className="flex items-center justify-center w-full h-full"><Loader2 className="h-8 w-8 animate-spin text-[var(--accent-primary)]" /></div>}>
+          <WebGLGraphRenderer
+            nodes={graphData.nodes} links={graphData.links}
+            dimensions={dimensions} focusedNodeId={focusedNodeId}
+            minWeight={minWeight} darkMode={darkModeRef.current}
+            onNodeClick={handleNodeClickById} onNodeHover={handleNodeHoverById}
+            onEngineStop={handleEngineStop} neighborSetsByNode={neighborSetsByNode}
+          />
+        </Suspense>
+
+      ) : effectiveRenderer === 'three' ? (
+        <Suspense fallback={<div className="flex items-center justify-center w-full h-full"><Loader2 className="h-8 w-8 animate-spin text-[var(--accent-primary)]" /></div>}>
+          <ThreeGraphRenderer
+            // eslint-disable-next-line @typescript-eslint/no-explicit-any
+            ref={threeRendererRef as any}
+            nodes={graphData.nodes} links={graphData.links}
+            dimensions={dimensions} focusedNodeId={focusedNodeId}
+            minWeight={minWeight} darkMode={darkModeRef.current}
+            onNodeClick={handleNodeClickById} onNodeHover={handleNodeHoverById}
+            onEngineStop={handleEngineStop} initialTilt={localDimension === '3d' ? 0.5 : 0}
+            onLongPressNode={handleLongPressNode}
+          />
+        </Suspense>
+
+      ) : !isReady || !rendererComponent ? null : (
+        /* Canvas renderer — visible only after graphMachine reaches "settled" */
+        <div
+          className="absolute inset-0"
+          style={{
+            opacity:       graphSettled ? 1 : 0,
+            transition:    graphSettled ? 'opacity 320ms ease' : 'none',
+            pointerEvents: graphSettled ? 'auto' : 'none',
+          }}
+        >
+          {/* eslint-disable-next-line @typescript-eslint/no-explicit-any */}
+          {(() => { const ForceGraphCanvas = rendererComponent as ComponentType<any>; return (
+            <ForceGraphCanvas
+              ref={fgRef}
+              graphData={graphData}
+              width={dimensions.width} height={dimensions.height}
+              nodeCanvasObject={nodeCanvasObject}
+              nodePointerAreaPaint={(node: FGNode, color: string, ctx: CanvasRenderingContext2D) => {
+                const isOrphan = !connectedNodeIds.has(node.id)
+                const radius = isOrphan ? 8 : Math.sqrt(Math.max(1, node.connections ?? 1)) * 4 + 8
+                ctx.beginPath(); ctx.arc(node.x ?? 0, node.y ?? 0, radius, 0, 2 * Math.PI)
+                ctx.fillStyle = color; ctx.fill()
+              }}
+              linkCanvasObject={linkCanvasObject}
+              linkPointerAreaPaint={() => {}}
+              enableNodeDrag={isMobile}
+              enableZoomInteraction={true}
+              enablePanInteraction={true}
+              onNodeHover={handleNodeHover}
+              onNodeClick={handleNodeClick}
+              onBackgroundClick={handleBackgroundClick}
+              onZoom={handleZoom}
+              onEngineStop={handleEngineStop}
+              backgroundColor="#00000000"
+              cooldownTicks={hasCachedLayout.current ? 20 : (isMobile ? 100 : 180)}
+              d3AlphaDecay={hasCachedLayout.current ? 0.1 : (isMobile ? 0.04 : 0.012)}
+              d3VelocityDecay={0.3}
+            />
+          )})()}
+        </div>
+      )}
+
+      {/* ── Filter panel ──────────────────────────────────────────────────────
+           Sits in the same top-3 row as the chrome but occupies the LEFT
+           zone only.  `right-[252px]` leaves a gap for the chrome controls
+           (2×44px buttons + 8px gap + 2×12px margins ≈ 240px) plus breathing
+           room.  pointer-events-none on the wrapper so only the pill itself
+           is interactive. z-40 keeps it below the z-50 chrome. */}
+      {viewMode === 'graph' && graphSettled && (
+        <div className="absolute left-0 right-[252px] top-3 z-40 flex items-center justify-center pointer-events-none">
+          <GraphFilterPanel
+            minWeight={minWeight}
+            onMinWeightChange={handleMinWeightChange}
+            nodeCount={graphData.nodes.length}
+            edgeCount={graphData.links.length}
+            orphanCount={Math.max(0, orphanCount)}
+            onReset={handleReset}
+          />
+        </div>
+      )}
+
+      {/* ── Clusters button ── */}
+      {viewMode === 'graph' && graphSettled && (
+        <button
+          onClick={() => setClusterListSheetOpen(true)}
+          className="absolute bottom-6 left-4 z-40 flex items-center gap-1.5 sm:bottom-16 px-3 py-2 rounded-full text-sm font-medium select-none bg-[var(--surface-floating)] border border-[var(--border-subtle)] shadow-[var(--shadow-sm)] text-[var(--foreground-muted)] hover:text-[var(--foreground)] hover:bg-[var(--surface-hover)] transition-colors"
+        >
+          <Layers className="h-4 w-4" /> Clusters
+        </button>
+      )}
+
+      {/* ── Graph detail panel ── */}
+      {focusedHeadItem && (
+        <GraphDetailPanel
+          headItem={focusedHeadItem}
+          connections={focusedConnections}
+          onClose={closeFocus}
+          onCardClick={(id) => modalSend({ type: 'OPEN', payload: id })}
+          isMobile={isMobile}
+        />
+      )}
+
+      {/* ── Tooltip ── */}
+      {hoveredNode && tooltipPos && !isMobile && (
+        <GraphTooltip
+          node={hoveredNode}
+          position={tooltipPos}
+          connectedNames={connectedNames}
+        />
+      )}
+
+      {/* ── Card detail modal ── */}
+      {selectedCardId && (
+        <CardDetailModal
+          card={selectedCard}
+          loading={cardLoading}
+          onClose={() => modalSend({ type: 'CLOSE' })}
+          onArchive={handleArchive}
+          onDelete={handleDelete}
+          onRestore={handleRestore}
+        />
+      )}
+
+      {/* ── Cluster sheets ── */}
+      <ClusterSheet
+        open={clusterSheetOpen}
+        onClose={() => { setClusterSheetOpen(false); clearClusterSelection() }}
+        onSave={handleClusterSave}
+        saving={clusterSaving}
+        error={clusterError}
+        nodeCount={selectedClusterNodeIds.size}
+      />
+      <ClusterListSheet
+        open={clusterListSheetOpen}
+        onClose={() => setClusterListSheetOpen(false)}
+        onClusterSelect={handleClusterRestore}
+      />
+    </div>
+  )
 }
diff --git a/web/src/components/GraphDimensionToggle/GraphDimensionToggle.test.tsx b/web/src/components/GraphDimensionToggle/GraphDimensionToggle.test.tsx
new file mode 100644
index 0000000..6a27be5
--- /dev/null
+++ b/web/src/components/GraphDimensionToggle/GraphDimensionToggle.test.tsx
@@ -0,0 +1,109 @@
+/**
+ * GraphDimensionToggle — Design-system enforcement tests
+ *
+ * Touch-target spec: every interactive element must be ≥ 44 × 44 px (WCAG 2.5.5
+ * and Apple HIG). This file verifies that inline styles encode the correct
+ * minWidth / minHeight values so the constraint can never silently regress.
+ */
+
+import userEvent from '@testing-library/user-event'
+
+import { render, screen } from '@redwoodjs/testing/web'
+
+import { GraphDimensionToggle } from './GraphDimensionToggle'
+
+const noop = jest.fn()
+
+describe('GraphDimensionToggle — touch-target enforcement (≥ 44 px)', () => {
+  it('every radio button has minWidth ≥ 44 and minHeight ≥ 44', () => {
+    render(<GraphDimensionToggle value="2d" onChange={noop} />)
+    const buttons = screen.getAllByRole('radio')
+    expect(buttons).toHaveLength(2)
+
+    buttons.forEach((btn) => {
+      const el = btn as HTMLButtonElement
+      // Inline styles are the source of truth here — Tailwind purge can't
+      // remove inline style values, so they are a reliable regression guard.
+      expect(Number(el.style.minWidth)).toBeGreaterThanOrEqual(44)
+      expect(Number(el.style.minHeight)).toBeGreaterThanOrEqual(44)
+    })
+  })
+
+  it('3D button has minWidth ≥ 44 and minHeight ≥ 44', () => {
+    render(<GraphDimensionToggle value="3d" onChange={noop} />)
+    const buttons = screen.getAllByRole('radio')
+    buttons.forEach((btn) => {
+      const el = btn as HTMLButtonElement
+      expect(Number(el.style.minWidth)).toBeGreaterThanOrEqual(44)
+      expect(Number(el.style.minHeight)).toBeGreaterThanOrEqual(44)
+    })
+  })
+})
+
+describe('GraphDimensionToggle — colour tokens', () => {
+  it('uses CSS variables for active colour, not hardcoded hex', () => {
+    render(<GraphDimensionToggle value="2d" onChange={noop} />)
+    const [btn2d] = screen.getAllByRole('radio')
+    const el = btn2d as HTMLButtonElement
+    expect(el.style.color).toBe('var(--foreground)')
+    expect(el.style.color).not.toMatch(/^#/)
+  })
+
+  it('inactive button uses var(--foreground-muted)', () => {
+    render(<GraphDimensionToggle value="2d" onChange={noop} />)
+    const [, btn3d] = screen.getAllByRole('radio')
+    const el = btn3d as HTMLButtonElement
+    expect(el.style.color).toBe('var(--foreground-muted)')
+  })
+
+  it('container uses var(--surface-floating) background', () => {
+    const { container } = render(<GraphDimensionToggle value="2d" onChange={noop} />)
+    const group = container.firstChild as HTMLElement
+    expect(group.style.backgroundColor).toBe('var(--surface-floating)')
+  })
+})
+
+describe('GraphDimensionToggle — ARIA semantics', () => {
+  it('wraps buttons in a radiogroup with a descriptive label', () => {
+    render(<GraphDimensionToggle value="2d" onChange={noop} />)
+    expect(screen.getByRole('radiogroup', { name: /graph dimensionality/i })).toBeInTheDocument()
+  })
+
+  it('marks the active option as aria-checked=true, inactive as false', () => {
+    render(<GraphDimensionToggle value="3d" onChange={noop} />)
+    const [btn2d, btn3d] = screen.getAllByRole('radio')
+    expect(btn2d).toHaveAttribute('aria-checked', 'false')
+    expect(btn3d).toHaveAttribute('aria-checked', 'true')
+  })
+})
+
+describe('GraphDimensionToggle — interaction', () => {
+  // The component sets a 200 ms timeout after each click to prevent
+  // double-mount flicker. Use fake timers so tests don't hang.
+  beforeEach(() => jest.useFakeTimers())
+  afterEach(() => jest.useRealTimers())
+
+  it('calls onChange with the other dimension when clicked', async () => {
+    const user = userEvent.setup({ advanceTimers: jest.advanceTimersByTime })
+    const onChange = jest.fn()
+    render(<GraphDimensionToggle value="2d" onChange={onChange} />)
+    await user.click(screen.getByRole('radio', { name: '3D' }))
+    expect(onChange).toHaveBeenCalledWith('3d')
+  })
+
+  it('does not call onChange when the active option is clicked again', async () => {
+    const user = userEvent.setup({ advanceTimers: jest.advanceTimersByTime })
+    const onChange = jest.fn()
+    render(<GraphDimensionToggle value="2d" onChange={onChange} />)
+    await user.click(screen.getByRole('radio', { name: '2D' }))
+    expect(onChange).not.toHaveBeenCalled()
+  })
+
+  it('does not call onChange when disabled', async () => {
+    const user = userEvent.setup({ advanceTimers: jest.advanceTimersByTime })
+    const onChange = jest.fn()
+    render(<GraphDimensionToggle value="2d" onChange={onChange} disabled />)
+    await user.click(screen.getByRole('radio', { name: '3D' }))
+    expect(onChange).not.toHaveBeenCalled()
+  })
+})
diff --git a/web/src/components/GraphFilterPanel/GraphFilterPanel.test.tsx b/web/src/components/GraphFilterPanel/GraphFilterPanel.test.tsx
