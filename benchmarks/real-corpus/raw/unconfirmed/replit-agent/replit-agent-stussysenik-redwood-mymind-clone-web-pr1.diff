index 0000000..7caea14
--- /dev/null
+++ b/web/src/components/GraphFilterPanel/GraphFilterPanel.test.tsx
@@ -0,0 +1,168 @@
+/**
+ * GraphFilterPanel — Design-system & spacing enforcement tests
+ *
+ * These tests enforce the layout contract documented in the design spec:
+ *   • The filter pill is always positioned at top-[60px], clearing the
+ *     top-3 chrome row (≈ 12px + 44px = 56px) on every breakpoint.
+ *   • All colours come from CSS custom properties, never hardcoded hex.
+ *   • Interactive controls (slider, reset) carry accessible labels.
+ *   • The pill sits at z-index 40 so it draws above the graph canvas (z-10)
+ *     but below modals and the global FAB (z-50+).
+ */
+
+import { render, screen } from '@redwoodjs/testing/web'
+
+import { GraphFilterPanel } from './GraphFilterPanel'
+
+const defaultProps = {
+  minWeight: 1,
+  onMinWeightChange: jest.fn(),
+  nodeCount: 120,
+  edgeCount: 380,
+  orphanCount: 0,
+  onReset: jest.fn(),
+}
+
+// ── Positioning contract ────────────────────────────────────────────────────
+//
+// GraphFilterPanel is now a self-contained pill with no absolute positioning.
+// Its parent in GraphClient is:
+//   <div className="absolute left-0 right-[252px] top-3 z-40 … pointer-events-none">
+//     <GraphFilterPanel … />
+//   </div>
+//
+// This ensures the pill is always centred in the LEFT zone of the top chrome
+// row, never overlapping the right-side controls (GraphDimensionToggle +
+// ViewModeToggle), which occupy the right-[252px] zone at z-50.
+//
+// Tests here verify what the component itself renders; layout/z-index tests
+// live at the GraphClient level.
+
+describe('GraphFilterPanel — layout contract (self-contained pill)', () => {
+  it('renders a rounded-full pill shape', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    expect(pill.className).toMatch(/rounded-full/)
+  })
+
+  it('does NOT apply any absolute/fixed self-positioning classes', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    // Positioning is owned by the GraphClient wrapper — pill is flow-level.
+    expect(pill.className).not.toMatch(/\babsolute\b/)
+    expect(pill.className).not.toMatch(/\bfixed\b/)
+    expect(pill.className).not.toMatch(/left-1\/2/)
+    expect(pill.className).not.toMatch(/-translate-x-1\/2/)
+  })
+
+  it('does NOT own z-index — that belongs to the GraphClient wrapper', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    expect(pill.className).not.toMatch(/\bz-\d+\b/)
+  })
+
+  it('pointer-events are auto so clicks reach the controls', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    // The GraphClient wrapper sets pointer-events-none; the pill re-enables them.
+    expect(pill.style.pointerEvents).toBe('auto')
+  })
+})
+
+// ── CSS-variable–only colours ──────────────────────────────────────────────
+//
+// jsdom (used by Jest/JSDOM) silently drops inline-style properties whose
+// value is an unresolvable CSS custom property (e.g. `var(--surface-floating)`).
+// We therefore test:
+//   (a) properties jsdom DOES preserve (e.g. box-shadow — also a var, but jsdom
+//       keeps it as the raw string when set via the React style prop)
+//   (b) that no hardcoded hex appears anywhere in the raw style attribute.
+//
+// A complementary ESLint rule (`no-restricted-syntax` on hex-color literals
+// inside JSX style props) enforces this at lint time across the whole codebase.
+
+describe('GraphFilterPanel — no hardcoded colours', () => {
+  it('uses a CSS variable for box-shadow (var(--shadow-sm))', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    const rawStyle = pill.getAttribute('style') ?? ''
+    // jsdom preserves var() references for box-shadow
+    expect(rawStyle).toContain('var(--shadow-sm)')
+  })
+
+  it('has no hardcoded hex colour in any inline style on the pill', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    const pill = container.firstChild as HTMLElement
+    const rawStyle = pill.getAttribute('style') ?? ''
+    expect(rawStyle).not.toMatch(/#[0-9a-fA-F]{3,8}/)
+  })
+
+  it('stats text uses var(--foreground-muted) not a hardcoded colour', () => {
+    const { container } = render(<GraphFilterPanel {...defaultProps} />)
+    // The stats group has `style={{ color: 'var(--foreground-muted)' }}`
+    // Check that no element inside uses a hardcoded colour for `color`.
+    const allStyled = container.querySelectorAll('[style]')
+    allStyled.forEach((el) => {
+      const raw = el.getAttribute('style') ?? ''
+      expect(raw).not.toMatch(/\bcolor:\s*#[0-9a-fA-F]{3,8}/)
+    })
+  })
+})
+
+// ── Accessibility ──────────────────────────────────────────────────────────
+
+describe('GraphFilterPanel — accessibility', () => {
+  it('exposes a group with a descriptive aria-label for graph stats', () => {
+    render(<GraphFilterPanel {...defaultProps} nodeCount={120} edgeCount={380} />)
+    expect(
+      screen.getByRole('group', { name: /graph contents: 120 nodes, 380 links/i })
+    ).toBeInTheDocument()
+  })
+
+  it('the range slider has a descriptive aria-label', () => {
+    render(<GraphFilterPanel {...defaultProps} minWeight={1} />)
+    expect(
+      screen.getByRole('slider', {
+        name: /hide connections with fewer than 1 shared tag/i,
+      })
+    ).toBeInTheDocument()
+  })
+
+  it('the range slider uses plural "tags" when minWeight > 1', () => {
+    render(<GraphFilterPanel {...defaultProps} minWeight={3} />)
+    expect(
+      screen.getByRole('slider', {
+        name: /hide connections with fewer than 3 shared tags/i,
+      })
+    ).toBeInTheDocument()
+  })
+
+  it('reset button has aria-label and only renders when minWeight > 1', () => {
+    const { rerender } = render(<GraphFilterPanel {...defaultProps} minWeight={1} />)
+    expect(screen.queryByRole('button', { name: /reset connection filter/i })).not.toBeInTheDocument()
+
+    rerender(<GraphFilterPanel {...defaultProps} minWeight={2} />)
+    expect(screen.getByRole('button', { name: /reset connection filter/i })).toBeInTheDocument()
+  })
+})
+
+// ── Live counters ──────────────────────────────────────────────────────────
+
+describe('GraphFilterPanel — aria-live counters', () => {
+  it('renders node/edge counts as live regions so screen readers re-announce on change', () => {
+    const { container } = render(
+      <GraphFilterPanel {...defaultProps} nodeCount={50} edgeCount={100} />
+    )
+    const live = container.querySelectorAll('[aria-live="polite"]')
+    // At least nodeCount + edgeCount = 2 live spans (possibly more for orphan)
+    expect(live.length).toBeGreaterThanOrEqual(2)
+  })
+
+  it('shows isolated count when orphanCount > 0, hidden when 0', () => {
+    const { rerender } = render(<GraphFilterPanel {...defaultProps} orphanCount={0} />)
+    expect(screen.queryByText(/isolated/i)).not.toBeInTheDocument()
+
+    rerender(<GraphFilterPanel {...defaultProps} orphanCount={12} />)
+    expect(screen.getAllByText(/isolated/i).length).toBeGreaterThanOrEqual(1)
+  })
+})
