+/**
+ * Jotai atoms — global state primitives for the graph view.
+ *
+ * Rule: atoms hold raw data or simple derived values only.
+ * Complex async logic lives in XState machines, NOT here.
+ * Components read atoms and send events to machines — never
+ * compute business logic inside a component.
+ */
+
+import { atom } from 'jotai'
+import { atomWithStorage } from 'jotai/utils'
+
+import type { RendererBackend, GraphDimension } from 'src/lib/graph-renderer-types'
+
+// ---------------------------------------------------------------------------
+// GRAPH FILTER STATE
+// ---------------------------------------------------------------------------
+
+/** Minimum shared-tag weight for an edge to be shown. */
+export const minWeightAtom = atom<number>(1)
+
+/** Whether the filter panel is expanded on mobile. */
+export const filterPanelOpenAtom = atom<boolean>(false)
+
+// ---------------------------------------------------------------------------
+// GRAPH VIEW MODE
+// ---------------------------------------------------------------------------
+
+export type GraphViewMode = 'graph' | 'list'
+
+/** Persisted across sessions. Falls back to 'graph'. */
+export const graphViewModeAtom = atomWithStorage<GraphViewMode>(
+  'byoa_graph_view_mode',
+  'graph'
+)
+
+// ---------------------------------------------------------------------------
+// GRAPH DIMENSION + RENDERER — persisted preferences
+// ---------------------------------------------------------------------------
+
+export const graphDimensionAtom = atomWithStorage<GraphDimension>(
+  'byoa_graph_dimension',
+  '2d'
+)
+
+export const graphRendererAtom = atomWithStorage<RendererBackend>(
+  'byoa_graph_renderer',
+  'canvas'
+)
+
+// ---------------------------------------------------------------------------
+// FOCUS / SELECTION STATE
+// ---------------------------------------------------------------------------
+
+/** Currently focused node ID (single-click on a graph node). */
+export const focusedNodeIdAtom = atom<string | null>(null)
+
+/** Card detail modal — the card ID being viewed. */
+export const selectedCardIdAtom = atom<string | null>(null)
+
+// ---------------------------------------------------------------------------
+// CLUSTER UI
+// ---------------------------------------------------------------------------
+
+export const clusterSheetOpenAtom = atom<boolean>(false)
+export const clusterListSheetOpenAtom = atom<boolean>(false)
+
+/** Node IDs in the current in-progress cluster selection. */
+export const clusterSelectedNodeIdsAtom = atom<Set<string>>(new Set<string>())
+
+// ---------------------------------------------------------------------------
+// DARK MODE — read from media query once, updated via event
+// ---------------------------------------------------------------------------
+
+const _darkModeBase = atom<boolean>(
+  typeof window !== 'undefined'
+    ? window.matchMedia?.('(prefers-color-scheme: dark)').matches ?? false
+    : false
+)
+
+export const darkModeAtom = atom(
+  (get) => get(_darkModeBase),
+  (_get, set, next: boolean) => set(_darkModeBase, next)
+)
+
+// ---------------------------------------------------------------------------
+// APP-WIDE UI ATOMS
+// ---------------------------------------------------------------------------
+
+/** Global toast queue — machines write, Toast component reads. */
+export type ToastEntry = {
+  id: string
+  message: string
+  variant: 'success' | 'error' | 'info' | 'warning'
+}
+
+export const toastQueueAtom = atom<ToastEntry[]>([])
