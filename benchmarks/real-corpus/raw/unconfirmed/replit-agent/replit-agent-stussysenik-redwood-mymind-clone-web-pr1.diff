@@ -0,0 +1,103 @@
+/**
+ * AuthContext — wraps the XState authMachine and exposes auth state +
+ * actions to the rest of the app.
+ *
+ * Usage:
+ *   const { state, signIn, signOut, token } = useAuth()
+ */
+
+import React, { createContext, useContext, useEffect, useRef } from 'react'
+import * as SecureStore from 'expo-secure-store'
+import { useActor } from '@xstate/react'
+import { createActor } from 'xstate'
+
+import { authMachine, type AuthContext as AuthCtx } from '@/lib/authMachine'
+
+const SESSION_KEY = 'byoa_session'
+
+interface StoredSession {
+  token: string
+  userId: string
+  email: string
+}
+
+interface AuthContextValue {
+  isLoading: boolean
+  isAuthenticated: boolean
+  token: string | null
+  userId: string | null
+  email: string | null
+  error: string | null
+  signIn: (email: string, password: string) => Promise<void>
+  signOut: () => Promise<void>
+}
+
+const AuthContext = createContext<AuthContextValue | null>(null)
+
+export function AuthProvider({ children }: { children: React.ReactNode }) {
+  const actorRef = useRef(createActor(authMachine).start())
+  const [state, send] = useActor(actorRef.current)
+
+  useEffect(() => {
+    send({ type: 'CHECK' })
+    SecureStore.getItemAsync(SESSION_KEY)
+      .then((raw) => {
+        if (!raw) { send({ type: 'NO_SESSION' }); return }
+        const session: StoredSession = JSON.parse(raw)
+        send({ type: 'SESSION_FOUND', ...session })
+      })
+      .catch(() => send({ type: 'NO_SESSION' }))
+  }, [])
+
+  const signIn = async (email: string, password: string) => {
+    send({ type: 'SIGN_IN', email, password })
+    try {
+      const res = await fetch(
+        `${process.env.EXPO_PUBLIC_API_URL ?? 'http://localhost:5000'}/.redwood/functions/auth`,
+        {
+          method: 'POST',
+          headers: { 'Content-Type': 'application/json' },
+          body: JSON.stringify({ method: 'login', type: 'emailPassword', email, password }),
+        }
+      )
+      if (!res.ok) throw new Error('Sign-in failed')
+      const { currentUser, token } = await res.json()
+      const session: StoredSession = {
+        token: token ?? currentUser?.token ?? '',
+        userId: currentUser?.id ?? '',
+        email: currentUser?.email ?? email,
+      }
+      await SecureStore.setItemAsync(SESSION_KEY, JSON.stringify(session))
+      send({ type: 'SIGN_IN_SUCCESS', ...session })
+    } catch (err: unknown) {
+      const message = err instanceof Error ? err.message : 'Unknown error'
+      send({ type: 'SIGN_IN_ERROR', message })
+    }
+  }
+
+  const signOut = async () => {
+    send({ type: 'SIGN_OUT' })
+    await SecureStore.deleteItemAsync(SESSION_KEY).catch(() => null)
+    send({ type: 'SIGN_OUT_DONE' })
+  }
+
+  const ctx = state.context as AuthCtx
+  const value: AuthContextValue = {
+    isLoading: state.matches('checking') || state.matches('idle'),
+    isAuthenticated: state.matches('authenticated'),
+    token: ctx.token,
+    userId: ctx.userId,
+    email: ctx.email,
+    error: ctx.error,
+    signIn,
+    signOut,
+  }
+
+  return <AuthContext.Provider value={value}>{children}</AuthContext.Provider>
+}
+
+export function useAuth(): AuthContextValue {
+  const ctx = useContext(AuthContext)
+  if (!ctx) throw new Error('useAuth must be used inside <AuthProvider>')
+  return ctx
+}
