index 0000000..9e27ada
--- /dev/null
+++ b/mobile/lib/graphql.ts
@@ -0,0 +1,105 @@
+/**
+ * GraphQL client for the BYOA RedwoodJS backend.
+ *
+ * The API URL is read from EXPO_PUBLIC_API_URL (set in mobile/.env).
+ * During development this should point to your Replit dev URL:
+ *   EXPO_PUBLIC_API_URL=https://<your-repl>.riker.replit.dev
+ *
+ * The RedwoodJS GraphQL endpoint is always at <API_URL>/.redwood/functions/graphql
+ */
+
+const API_BASE = process.env.EXPO_PUBLIC_API_URL ?? 'http://localhost:5000'
+export const GRAPHQL_ENDPOINT = `${API_BASE}/.redwood/functions/graphql`
+
+interface GraphQLResponse<T> {
+  data?: T
+  errors?: Array<{ message: string; locations?: unknown; path?: unknown }>
+}
+
+/**
+ * Low-level GraphQL fetch.  For authenticated requests, pass the Supabase
+ * session token via the `authToken` argument — it is forwarded in the
+ * Authorization header that RedwoodJS's auth decoder expects.
+ */
+export async function gqlRequest<T>(
+  query: string,
+  variables?: Record<string, unknown>,
+  authToken?: string | null
+): Promise<T> {
+  const headers: Record<string, string> = {
+    'Content-Type': 'application/json',
+  }
+  if (authToken) {
+    headers['Authorization'] = `Bearer ${authToken}`
+  }
+
+  const res = await fetch(GRAPHQL_ENDPOINT, {
+    method: 'POST',
+    headers,
+    body: JSON.stringify({ query, variables }),
+  })
+
+  if (!res.ok) {
+    throw new Error(`GraphQL HTTP error: ${res.status} ${res.statusText}`)
+  }
+
+  const json: GraphQLResponse<T> = await res.json()
+
+  if (json.errors && json.errors.length > 0) {
+    throw new Error(json.errors.map((e) => e.message).join('\n'))
+  }
+
+  if (!json.data) {
+    throw new Error('GraphQL response contained no data')
+  }
+
+  return json.data
+}
+
+// ── Query fragments ────────────────────────────────────────────────────────
+
+export const CARD_FRAGMENT = /* GraphQL */ `
+  fragment CardFields on Card {
+    id
+    title
+    type
+    imageUrl
+    tags
+    connections
+    createdAt
+  }
+`
+
+// ── Queries ────────────────────────────────────────────────────────────────
+
+export const GET_CARDS_QUERY = /* GraphQL */ `
+  ${CARD_FRAGMENT}
+  query MobileCardsQuery($limit: Int, $offset: Int) {
+    cards(limit: $limit, offset: $offset) {
+      ...CardFields
+    }
+  }
+`
+
+export const GET_GRAPH_DATA_QUERY = /* GraphQL */ `
+  query MobileGraphDataQuery($graphId: String!) {
+    graph(id: $graphId) {
+      id
+      dimension
+      nodes {
+        id
+        title
+        type
+        imageUrl
+        tags
+        connections
+      }
+      links {
+        source
+        target
+        sharedTags
+        weight
+      }
+    }
+  }
+`
