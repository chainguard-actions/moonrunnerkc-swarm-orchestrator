index 0000000..aec0b9e
--- /dev/null
+++ b/web/src/machines/modalMachine.ts
@@ -0,0 +1,114 @@
+/**
+ * modalMachine — Generic open/close with animation guard.
+ *
+ * Prevents the "unmount during animation" bug.
+ * The component must call ANIMATION_DONE when its CSS transition ends.
+ * Until then, the DOM node stays mounted but is animating out.
+ *
+ * States
+ * ──────
+ *  closed → opening → open → closing → closed
+ *
+ * Usage
+ * ──────
+ *  const [state, send] = useMachine(modalMachine)
+ *  send({ type: 'OPEN' })
+ *  // In onTransitionEnd: send({ type: 'ANIMATION_DONE' })
+ */
+
+import { setup, assign } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export interface ModalMachineContext {
+  /** Arbitrary data passed when opening — e.g. the card ID being viewed */
+  payload: unknown
+}
+
+export type ModalMachineEvent =
+  | { type: 'OPEN';           payload?: unknown }
+  | { type: 'CLOSE' }
+  | { type: 'ANIMATION_DONE' }
+
+// ---------------------------------------------------------------------------
+// MACHINE FACTORY
+// ---------------------------------------------------------------------------
+
+/**
+ * Create a modal machine with configurable animation duration.
+ * Each modal gets its own isolated machine instance.
+ */
+export const createModalMachine = (animDurationMs = 240) =>
+  setup({
+    types: {
+      context: {} as ModalMachineContext,
+      events:  {} as ModalMachineEvent,
+    },
+    delays: {
+      ANIM_DURATION: animDurationMs,
+    },
+    actions: {
+      storePayload: assign({
+        payload: ({ event }) =>
+          event.type === 'OPEN' ? (event.payload ?? null) : null,
+      }),
+      clearPayload: assign({ payload: null }),
+    },
+  }).createMachine({
+    id:      'modal',
+    initial: 'closed',
+    context: { payload: null },
+
+    states: {
+      closed: {
+        on: {
+          OPEN: { target: 'opening', actions: 'storePayload' },
+        },
+      },
+
+      opening: {
+        /** Auto-advance if animation_done fires before timeout. */
+        after: {
+          ANIM_DURATION: 'open',
+        },
+        on: {
+          ANIMATION_DONE: 'open',
+          CLOSE:          'closed', // cancelled before it opened
+        },
+      },
+
+      open: {
+        on: {
+          CLOSE: 'closing',
+          /** Allow re-opening with a different payload without closing first. */
+          OPEN:  { actions: 'storePayload' },
+        },
+      },
+
+      closing: {
+        after: {
+          ANIM_DURATION: { target: 'closed', actions: 'clearPayload' },
+        },
+        on: {
+          ANIMATION_DONE: { target: 'closed', actions: 'clearPayload' },
+          /** Cancelled close — re-open immediately. */
+          OPEN:           { target: 'open', actions: 'storePayload' },
+        },
+      },
+    },
+  })
+
+// ---------------------------------------------------------------------------
+// PRE-BUILT INSTANCES
+// ---------------------------------------------------------------------------
+
+/** Card detail modal (slides in from right, 280ms) */
+export const cardDetailModalMachine = createModalMachine(280)
+/** Settings modal (fade, 200ms) */
+export const settingsModalMachine   = createModalMachine(200)
+/** Add capture modal (slide up, 320ms) */
+export const addModalMachine        = createModalMachine(320)
+/** Cluster sheet (slides up, 300ms) */
+export const clusterSheetMachine    = createModalMachine(300)
diff --git a/web/src/machines/notificationMachine.ts b/web/src/machines/notificationMachine.ts
