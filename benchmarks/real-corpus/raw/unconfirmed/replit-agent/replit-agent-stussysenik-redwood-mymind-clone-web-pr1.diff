+/**
+ * App-wide Jotai atoms — theme, auth UI, navigation state.
+ *
+ * These are the global atoms that any component can read without
+ * prop drilling. XState machines write to these; components only read.
+ */
+
+import { atom } from 'jotai'
+import { atomWithStorage } from 'jotai/utils'
+
+// ---------------------------------------------------------------------------
+// THEME
+// ---------------------------------------------------------------------------
+
+export type ThemeName =
+  | 'default'
+  | 'brutalist'
+  | 'glassmorphism'
+  | 'muji'
+  | 'nasa'
+  | 'neubrutalism'
+  | 'nord'
+  | 'retro-terminal'
+
+export const activeThemeAtom = atomWithStorage<ThemeName>('byoa_theme', 'default')
+
+// ---------------------------------------------------------------------------
+// SIDEBAR / NAVIGATION
+// ---------------------------------------------------------------------------
+
+export const sidebarOpenAtom = atom<boolean>(false)
+
+// ---------------------------------------------------------------------------
+// ADD MODAL
+// ---------------------------------------------------------------------------
+
+export const addModalOpenAtom = atom<boolean>(false)
+export const addModalUrlAtom = atom<string>('')
+
+// ---------------------------------------------------------------------------
+// SEARCH
+// ---------------------------------------------------------------------------
+
+export const searchQueryAtom = atom<string>('')
+export const searchActiveAtom = atom<boolean>(false)
+
+// ---------------------------------------------------------------------------
+// SETTINGS MODAL
+// ---------------------------------------------------------------------------
+
+export const settingsModalOpenAtom = atom<boolean>(false)
+
+// ---------------------------------------------------------------------------
+// LOCAL AI
+// ---------------------------------------------------------------------------
+
+export const localAIEnabledAtom = atomWithStorage<boolean>('byoa_local_ai', false)
+
+// ---------------------------------------------------------------------------
+// DERIVED: is ANY modal open? (for scroll-lock, backdrop, etc.)
+// ---------------------------------------------------------------------------
+
+export const anyModalOpenAtom = atom((get) =>
+  get(addModalOpenAtom) || get(settingsModalOpenAtom)
