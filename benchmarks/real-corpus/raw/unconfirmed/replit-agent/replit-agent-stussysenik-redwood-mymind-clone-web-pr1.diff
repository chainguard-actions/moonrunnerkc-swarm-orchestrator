diff --git a/mobile/app/(tabs)/_layout.tsx b/mobile/app/(tabs)/_layout.tsx
new file mode 100644
index 0000000..e8bb147
--- /dev/null
+++ b/mobile/app/(tabs)/_layout.tsx
@@ -0,0 +1,53 @@
+import { Tabs } from 'expo-router'
+import { Platform } from 'react-native'
+import { Ionicons } from '@expo/vector-icons'
+
+import { useColors } from '@/hooks/useColors'
+
+export default function TabsLayout() {
+  const colors = useColors()
+
+  return (
+    <Tabs
+      screenOptions={{
+        headerShown: false,
+        tabBarStyle: {
+          backgroundColor: colors.background,
+          borderTopColor: colors.border,
+          height: Platform.OS === 'web' ? 84 : undefined,
+        },
+        tabBarActiveTintColor: colors.accentPrimary,
+        tabBarInactiveTintColor: colors.foregroundMuted,
+        tabBarShowLabel: false,
+      }}
+    >
+      <Tabs.Screen
+        name="feed"
+        options={{
+          tabBarIcon: ({ color, size }) => (
+            <Ionicons name="layers-outline" size={size} color={color} />
+          ),
+          tabBarAccessibilityLabel: 'Feed',
+        }}
+      />
+      <Tabs.Screen
+        name="graph"
+        options={{
+          tabBarIcon: ({ color, size }) => (
+            <Ionicons name="git-network-outline" size={size} color={color} />
+          ),
+          tabBarAccessibilityLabel: 'Graph',
+        }}
+      />
+      <Tabs.Screen
+        name="settings"
+        options={{
+          tabBarIcon: ({ color, size }) => (
+            <Ionicons name="person-outline" size={size} color={color} />
+          ),
+          tabBarAccessibilityLabel: 'Profile',
+        }}
+      />
+    </Tabs>
+  )
+}
diff --git a/mobile/app/(tabs)/feed.tsx b/mobile/app/(tabs)/feed.tsx
new file mode 100644
index 0000000..d37e1c4
--- /dev/null
+++ b/mobile/app/(tabs)/feed.tsx
@@ -0,0 +1,220 @@
+/**
+ * Feed — card list from the BYOA graph.
+ * Fetches cards from the RedwoodJS GraphQL API via React Query.
+ */
+
+import {
+  FlatList,
+  View,
+  Text,
+  Image,
+  TouchableOpacity,
+  ActivityIndicator,
+  RefreshControl,
+  StyleSheet,
+} from 'react-native'
+import { useSafeAreaInsets } from 'react-native-safe-area-context'
+import { useQuery } from '@tanstack/react-query'
+import * as Haptics from 'expo-haptics'
+
+import { useAuth } from '@/contexts/AuthContext'
+import { useColors } from '@/hooks/useColors'
+import { gqlRequest, GET_CARDS_QUERY } from '@/lib/graphql'
+
+interface Card {
+  id: string
+  title: string
+  type: string
+  imageUrl: string | null
+  tags: string[]
+  connections: number
+  createdAt: string
+}
+
+interface CardsData {
+  cards: Card[]
+}
+
+const TAG_COLORS: Record<string, string> = {
+  green: '#007A3D',
+  red: '#CC0000',
+  blue: '#0055FF',
+  orange: '#CC6600',
+  purple: '#6633CC',
+  pink: '#CC0066',
+  cyan: '#007799',
+  amber: '#CC8800',
+}
+
+function tagColor(tag: string) {
+  const keys = Object.keys(TAG_COLORS)
+  return TAG_COLORS[keys[tag.length % keys.length]] ?? '#0055FF'
+}
+
+export default function FeedScreen() {
+  const insets = useSafeAreaInsets()
+  const colors = useColors()
+  const { token } = useAuth()
+
+  const { data, isLoading, isError, refetch, isFetching } = useQuery<CardsData>({
+    queryKey: ['cards'],
+    queryFn: () => gqlRequest<CardsData>(GET_CARDS_QUERY, { limit: 40, offset: 0 }, token),
+  })
+
+  const cards = data?.cards ?? []
+
+  const s = styles(colors, insets)
+
+  if (isLoading) {
+    return (
+      <View style={[s.root, s.center]}>
+        <ActivityIndicator color={colors.accentPrimary} />
+      </View>
+    )
+  }
+
+  if (isError) {
+    return (
+      <View style={[s.root, s.center]}>
+        <Text style={s.emptyText}>Couldn't load cards.</Text>
+        <TouchableOpacity style={s.retryBtn} onPress={() => refetch()}>
+          <Text style={s.retryText}>Retry</Text>
+        </TouchableOpacity>
+      </View>
+    )
+  }
+
+  return (
+    <FlatList
+      style={s.root}
+      contentContainerStyle={s.list}
+      data={cards}
+      keyExtractor={(item) => item.id}
+      scrollEnabled={!!cards.length}
+      showsVerticalScrollIndicator={false}
+      refreshControl={
+        <RefreshControl
+          refreshing={isFetching && !isLoading}
+          onRefresh={refetch}
+          tintColor={colors.accentPrimary}
+        />
+      }
+      ListEmptyComponent={
+        <View style={s.center}>
+          <Text style={s.emptyText}>No cards yet.</Text>
+        </View>
+      }
+      renderItem={({ item }) => <CardRow card={item} colors={colors} />}
+    />
+  )
+}
+
+function CardRow({
+  card,
+  colors,
+}: {
+  card: Card
+  colors: ReturnType<typeof useColors>
+}) {
+  const s = cardStyles(colors)
+
+  const handlePress = async () => {
+    await Haptics.selectionAsync()
+  }
+
+  return (
+    <TouchableOpacity style={s.row} onPress={handlePress} activeOpacity={0.7}>
+      {card.imageUrl ? (
+        <Image source={{ uri: card.imageUrl }} style={s.thumb} resizeMode="cover" />
+      ) : (
+        <View style={[s.thumb, s.thumbPlaceholder]}>
+          <Text style={s.thumbType}>{card.type[0]?.toUpperCase() ?? '?'}</Text>
+        </View>
+      )}
+
+      <View style={s.body}>
+        <Text style={s.title} numberOfLines={2}>
+          {card.title}
+        </Text>
+
+        <View style={s.tags}>
+          {card.tags.slice(0, 3).map((tag) => (
+            <View key={tag} style={[s.tag, { borderColor: tagColor(tag) }]}>
+              <Text style={[s.tagText, { color: tagColor(tag) }]}>{tag}</Text>
+            </View>
+          ))}
+          {card.tags.length > 3 && (
+            <Text style={s.moreText}>+{card.tags.length - 3}</Text>
+          )}
+        </View>
+      </View>
+
+      <Text style={s.connections}>{card.connections}</Text>
+    </TouchableOpacity>
+  )
+}
+
+const styles = (
+  colors: ReturnType<typeof useColors>,
+  insets: ReturnType<typeof useSafeAreaInsets>
+) =>
+  StyleSheet.create({
+    root: { flex: 1, backgroundColor: colors.background },
+    list: {
+      paddingTop: insets.top + 16,
+      paddingBottom: insets.bottom + 16,
+      paddingHorizontal: 16,
+      gap: 8,
+    },
+    center: { flex: 1, alignItems: 'center', justifyContent: 'center' },
+    emptyText: { fontSize: 15, color: colors.foregroundMuted },
+    retryBtn: {
+      marginTop: 12,
+      paddingHorizontal: 20,
+      paddingVertical: 10,
+      borderRadius: 8,
+      backgroundColor: colors.accentPrimary,
+    },
+    retryText: { color: '#fff', fontSize: 14, fontWeight: '600' },
+  })
+
+const cardStyles = (colors: ReturnType<typeof useColors>) =>
+  StyleSheet.create({
+    row: {
+      flexDirection: 'row',
+      alignItems: 'center',
+      backgroundColor: colors.backgroundSecondary,
+      borderRadius: 12,
+      padding: 12,
+      gap: 12,
+      minHeight: 72,
+    },
+    thumb: {
+      width: 48,
+      height: 48,
+      borderRadius: 8,
+      flexShrink: 0,
+    },
+    thumbPlaceholder: {
+      backgroundColor: colors.accentLight,
+      alignItems: 'center',
+      justifyContent: 'center',
+    },
+    thumbType: {
+      fontSize: 18,
+      fontWeight: '700',
+      color: colors.accentPrimary,
+    },
+    body: { flex: 1, gap: 6 },
+    title: { fontSize: 14, fontWeight: '600', color: colors.foreground, lineHeight: 20 },
+    tags: { flexDirection: 'row', flexWrap: 'wrap', gap: 4 },
+    tag: {
+      borderWidth: 1,
+      borderRadius: 4,
+      paddingHorizontal: 6,
+      paddingVertical: 2,
+    },
+    tagText: { fontSize: 10, fontWeight: '500' },
+    moreText: { fontSize: 10, color: colors.foregroundSubtle, alignSelf: 'center' },
+    connections: { fontSize: 13, color: colors.foregroundMuted, fontWeight: '500' },
