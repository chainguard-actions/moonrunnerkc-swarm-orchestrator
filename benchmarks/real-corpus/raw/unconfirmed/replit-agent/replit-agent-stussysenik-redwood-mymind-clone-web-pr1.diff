+/**
+ * GraphKernel — Pure ReScript logic kernel.
+ *
+ * All functions are pure (no side-effects, no mutations).
+ * React / XState call into here. This module never calls back.
+ *
+ * Compiled to ES6 modules (.bs.js) by the ReScript 12 compiler.
+ * TypeScript imports the generated .bs.js files directly.
+ */
+
+open! RescriptCore
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+type nodeId = string
+
+type graphNode = {
+  id: nodeId,
+  title: option<string>,
+  connectionCount: int,
+  nodeType: string,
+  tags: array<string>,
+}
+
+type graphLink = {
+  source: nodeId,
+  target: nodeId,
+  sharedTags: array<string>,
+  weight: int,
+}
+
+type graphData = {
+  nodes: array<graphNode>,
+  links: array<graphLink>,
+}
+
+type neighbourIndex = {
+  adjacency: dict<array<nodeId>>,
+  titleMap: dict<string>,
+  typeMap: dict<string>,
+}
+
+type graphStats = {
+  nodeCount: int,
+  edgeCount: int,
+  orphanCount: int,
+  maxWeight: int,
+  maxConnections: int,
+}
+
+// ---------------------------------------------------------------------------
+// EDGE BUDGET — prune weak edges when the graph is too dense
+// ---------------------------------------------------------------------------
+
+let edgeBudget = 4000
+
+/** Filter links by minimum weight threshold. Pure. */
+let filterLinksByWeight = (links: array<graphLink>, minWeight: int): array<graphLink> =>
+  links->Array.filter(l => l.weight >= minWeight)
+
+/** Keep only the top-weighted links up to the budget cap. Pure. */
+let applyEdgeBudget = (links: array<graphLink>): array<graphLink> => {
+  if links->Array.length <= edgeBudget {
+    links
+  } else {
+    let sorted = links->Array.copy
+    // sort descending by weight (sort mutates a copy)
+    sorted->Array.sort((a, b) =>
+      if b.weight > a.weight { 1.0 }
+      else if b.weight < a.weight { -1.0 }
+      else { 0.0 }
+    )
+    sorted->Array.slice(~start=0, ~end=edgeBudget)
+  }
+}
+
+/** Compose filter + budget in one pass. */
+let pruneLinks = (links: array<graphLink>, minWeight: int): array<graphLink> =>
+  links->filterLinksByWeight(minWeight)->applyEdgeBudget
+
+// ---------------------------------------------------------------------------
+// CONNECTED NODE SET
+// ---------------------------------------------------------------------------
+
+/** Returns a Set (as a dict<bool>) of node IDs that have at least one edge. */
+let connectedNodeSet = (links: array<graphLink>): dict<bool> => {
+  let seen: dict<bool> = Dict.make()
+  links->Array.forEach(l => {
+    seen->Dict.set(l.source, true)
+    seen->Dict.set(l.target, true)
+  })
+  seen
+}
+
+// ---------------------------------------------------------------------------
+// NEIGHBOUR INDEX — O(1) adjacency lookup
+// ---------------------------------------------------------------------------
+
+let buildNeighbourIndex = (nodes: array<graphNode>, links: array<graphLink>): neighbourIndex => {
+  let adjacency: dict<array<nodeId>> = Dict.make()
+  let titleMap: dict<string> = Dict.make()
+  let typeMap: dict<string> = Dict.make()
+
+  nodes->Array.forEach(n => {
+    titleMap->Dict.set(n.id, n.title->Option.getOr("Untitled"))
+    typeMap->Dict.set(n.id, n.nodeType)
+    adjacency->Dict.set(n.id, [])
+  })
+
+  links->Array.forEach(l => {
+    let srcArr = adjacency->Dict.get(l.source)->Option.getOr([])
+    let tgtArr = adjacency->Dict.get(l.target)->Option.getOr([])
+    adjacency->Dict.set(l.source, srcArr->Array.concat([l.target]))
+    adjacency->Dict.set(l.target, tgtArr->Array.concat([l.source]))
+  })
+
+  {adjacency, titleMap, typeMap}
+}
+
+/** Get neighbour IDs for a node. Returns [] if node is unknown. */
+let getNeighbours = (idx: neighbourIndex, id: nodeId): array<nodeId> =>
+  idx.adjacency->Dict.get(id)->Option.getOr([])
+
+// ---------------------------------------------------------------------------
+// LAYOUT CACHE KEY — djb2 hash over sorted node IDs
+// ---------------------------------------------------------------------------
+
+let layoutCachePrefix = "byoa_gl_v1_"
+
+/**
+ * Produce a stable cache key from a set of node IDs.
+ * Invalidated automatically when the graph topology changes.
+ */
+let layoutCacheKey = (nodeIds: array<nodeId>): string => {
+  let sorted = nodeIds->Array.copy
+  sorted->Array.sort(String.compare)
+  let joined = sorted->Array.join("\x00")
+  let h = ref(5381)
+  let len = joined->String.length
+  for i in 0 to len - 1 {
+    let code = joined->String.charCodeAt(i)->Float.toInt
+    let shifted = Int.Bitwise.lsl(h.contents, 5)
+    let sum = shifted + h.contents + code
+    h := Int.Bitwise.land(sum, 0x7fffffff)
+  }
+  let abs = h.contents < 0 ? -h.contents : h.contents
+  layoutCachePrefix ++ abs->Int.toString
+}
+
+// ---------------------------------------------------------------------------
+// GRAPH STATS
+// ---------------------------------------------------------------------------
+
+let computeStats = (nodes: array<graphNode>, activeLinks: array<graphLink>): graphStats => {
+  let connected = connectedNodeSet(activeLinks)
+  let connectedCount = connected->Dict.keysToArray->Array.length
+  let orphanCount = nodes->Array.length - connectedCount
+
+  let maxWeight = activeLinks->Array.reduce(0, (acc, l) =>
+    l.weight > acc ? l.weight : acc
+  )
+  let maxConnections = nodes->Array.reduce(0, (acc, n) =>
+    n.connectionCount > acc ? n.connectionCount : acc
+  )
+
+  {
+    nodeCount:      nodes->Array.length,
+    edgeCount:      activeLinks->Array.length,
+    orphanCount:    orphanCount < 0 ? 0 : orphanCount,
+    maxWeight:      maxWeight < 1 ? 1 : maxWeight,
+    maxConnections: maxConnections < 1 ? 1 : maxConnections,
+  }
+}
