+/**
+ * Graph — full-screen WebView embedding the BYOA web graph.
+ *
+ * The web app already has a production-quality Three.js / Canvas graph
+ * renderer with quaternion trackball, compass rose, and filter panel.
+ * Rather than rebuilding that in React Native on day 1, we embed it in a
+ * WebView and communicate with it via postMessage.
+ *
+ * Native graph (Three.js via expo-gl) is the long-term goal and is tracked
+ * in the roadmap.  This screen bridges the gap.
+ */
+
+import { Platform, View, Text, StyleSheet } from 'react-native'
+import { WebView } from 'react-native-webview'
+import { useSafeAreaInsets } from 'react-native-safe-area-context'
+
+import { useColors } from '@/hooks/useColors'
+
+const WEB_GRAPH_URL = process.env.EXPO_PUBLIC_API_URL
+  ? `${process.env.EXPO_PUBLIC_API_URL}/graph`
+  : 'http://localhost:5000/graph'
+
+export default function GraphScreen() {
+  const insets = useSafeAreaInsets()
+  const colors = useColors()
+
+  if (Platform.OS === 'web') {
+    return (
+      <View style={[styles.root, { paddingTop: insets.top }]}>
+        <Text style={{ color: colors.foregroundMuted, textAlign: 'center', marginTop: 40 }}>
+          Graph view is available in the native app.
+        </Text>
+      </View>
+    )
+  }
+
+  return (
+    <View style={[styles.root, { paddingTop: insets.top }]}>
+      <WebView
+        source={{ uri: WEB_GRAPH_URL }}
+        style={styles.webview}
+        allowsBackForwardNavigationGestures
+        allowsInlineMediaPlayback
+        mediaPlaybackRequiresUserAction={false}
+      />
+    </View>
+  )
+}
+
+const styles = StyleSheet.create({
+  root: { flex: 1, backgroundColor: '#000' },
+  webview: { flex: 1 },
+})
