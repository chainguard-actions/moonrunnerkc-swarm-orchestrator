+/**
+ * GraphLoadingStage — Ordered, labelled loading overlay for the graph view.
+ *
+ * Driven entirely by the graphMachine state — no local state here.
+ * Follows the "Semantics of Waiting" pattern:
+ *   1. Acknowledge  (0–50ms)   — immediate visual pop
+ *   2. Intent       (50–200ms) — transition shows direction
+ *   3. Disclosure   (200ms+)   — exact pipeline stage label
+ *   4. Resolution              — cross-fade to the settled graph
+ *
+ * This component is mounted/unmounted by the animationMachine,
+ * never by a raw boolean.
+ */
+
+import { useEffect, useRef } from 'react'
+
+import { GRAPH_PHASE_LABELS } from 'src/machines/graphMachine'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+interface GraphLoadingStageProps {
+  /** Current graphMachine state value */
+  phase: keyof typeof GRAPH_PHASE_LABELS | string
+  nodeCount?: number
+  edgeCount?: number
+  /** Called when the fade-out transition ends — lets animationMachine advance */
+  onTransitionEnd?: () => void
+  /** If true, overlay is animating out */
+  concealing?: boolean
+}
+
+// ---------------------------------------------------------------------------
+// PHASE CONFIG — what to show per machine state
+// ---------------------------------------------------------------------------
+
+const PHASE_CONFIG: Record<string, {
+  label:        string
+  sublabel?:    string
+  showSpinner:  boolean
+  showProgress: boolean
+  progressStep: number   // 0–4 filled segments out of 4
+}> = {
+  idle: {
+    label:        'Initialising…',
+    showSpinner:  true,
+    showProgress: false,
+    progressStep: 0,
+  },
+  awaitingData: {
+    label:        'Loading your cards…',
+    sublabel:     'Fetching from the server',
+    showSpinner:  true,
+    showProgress: true,
+    progressStep: 1,
+  },
+  loadingRenderer: {
+    label:        'Preparing the renderer…',
+    sublabel:     'Loading the graph engine',
+    showSpinner:  true,
+    showProgress: true,
+    progressStep: 2,
+  },
+  simulating: {
+    label:        'Laying out connections…',
+    sublabel:     'Running the force simulation',
+    showSpinner:  true,
+    showProgress: true,
+    progressStep: 3,
+  },
+  settled: {
+    label:        'Ready',
+    showSpinner:  false,
+    showProgress: true,
+    progressStep: 4,
+  },
+  error: {
+    label:        'Something went wrong',
+    showSpinner:  false,
+    showProgress: false,
+    progressStep: 0,
+  },
+}
+
+const TOTAL_STEPS = 4
+
+// ---------------------------------------------------------------------------
+// COMPONENT
+// ---------------------------------------------------------------------------
+
+export function GraphLoadingStage({
+  phase,
+  nodeCount,
+  edgeCount,
+  onTransitionEnd,
+  concealing = false,
+}: GraphLoadingStageProps) {
+  const config  = PHASE_CONFIG[phase] ?? PHASE_CONFIG['idle']
+  const overlayRef = useRef<HTMLDivElement>(null)
+
+  // Wire CSS transition end → animationMachine ANIMATION_DONE
+  useEffect(() => {
+    const el = overlayRef.current
+    if (!el || !onTransitionEnd) return
+    const handler = () => onTransitionEnd()
+    el.addEventListener('transitionend', handler, { once: true })
+    return () => el.removeEventListener('transitionend', handler)
+  }, [onTransitionEnd])
+
+  const statsLabel =
+    nodeCount != null && edgeCount != null && nodeCount > 0
+      ? `${nodeCount} cards · ${edgeCount} connections`
+      : null
+
+  return (
+    <div
+      ref={overlayRef}
+      aria-live="polite"
+      aria-label={`Graph loading: ${config.label}`}
+      className="pointer-events-none absolute inset-0 z-30 flex flex-col items-center justify-center gap-6"
+      style={{
+        backgroundColor: 'var(--background)',
+        opacity:          concealing ? 0 : 1,
+        transition:       'opacity 320ms ease',
+      }}
+    >
+      {/* ── Spinner / Checkmark ── */}
+      <div className="relative flex items-center justify-center">
+        {config.showSpinner ? (
+          <>
+            {/* Outer ring — slow pulse */}
+            <div
+              className="absolute rounded-full animate-ping"
+              style={{
+                width:           52,
+                height:          52,
+                border:          '1px solid var(--accent-primary)',
+                opacity:         0.2,
+                animationDuration: '2s',
+              }}
+            />
+            {/* Inner spinning arc */}
+            <svg
+              width={36}
+              height={36}
+              viewBox="0 0 36 36"
+              className="animate-spin"
+              style={{ animationDuration: '1.1s' }}
+            >
+              <circle
+                cx={18} cy={18} r={15}
+                fill="none"
+                stroke="var(--border-subtle)"
+                strokeWidth={2}
+              />
+              <circle
+                cx={18} cy={18} r={15}
+                fill="none"
+                stroke="var(--accent-primary)"
+                strokeWidth={2}
+                strokeDasharray="60 40"
+                strokeLinecap="round"
+              />
+            </svg>
+          </>
+        ) : (
+          /* Checkmark for settled state */
+          <svg width={36} height={36} viewBox="0 0 36 36">
+            <circle
+              cx={18} cy={18} r={15}
+              fill="none"
+              stroke="var(--accent-primary)"
+              strokeWidth={2}
+              opacity={0.3}
+            />
+            <path
+              d="M11 18l5 5 9-9"
+              fill="none"
+              stroke="var(--accent-primary)"
+              strokeWidth={2.5}
+              strokeLinecap="round"
+              strokeLinejoin="round"
+            />
+          </svg>
+        )}
+      </div>
+
+      {/* ── Label ── */}
+      <div className="flex flex-col items-center gap-1 text-center">
+        <p
+          className="text-sm font-semibold tabular-nums"
+          style={{ color: 'var(--foreground)' }}
+        >
+          {config.label}
+        </p>
+        {config.sublabel && (
+          <p
+            className="text-xs"
+            style={{ color: 'var(--foreground-muted)' }}
+          >
+            {config.sublabel}
+          </p>
+        )}
+        {statsLabel && (
+          <p
+            className="text-[11px] font-mono mt-0.5"
+            style={{ color: 'var(--foreground-muted)', opacity: 0.7 }}
+          >
+            {statsLabel}
+          </p>
+        )}
+      </div>
+
+      {/* ── Provenance progress bar — each segment = one real pipeline stage ── */}
+      {config.showProgress && (
+        <div className="flex items-center gap-1.5" role="progressbar" aria-valuenow={config.progressStep} aria-valuemax={TOTAL_STEPS}>
+          {Array.from({ length: TOTAL_STEPS }).map((_, i) => {
+            const filled  = i < config.progressStep
+            const current = i === config.progressStep - 1
+            return (
+              <div
+                key={i}
+                style={{
+                  width:           current ? 28 : 20,
+                  height:          4,
+                  borderRadius:    99,
+                  backgroundColor: filled
+                    ? 'var(--accent-primary)'
+                    : 'var(--border-subtle)',
+                  opacity:         filled ? (current ? 1 : 0.5) : 0.25,
+                  transition:      'all 300ms ease',
+                }}
+              />
+            )
+          })}
+        </div>
+      )}
+
+      {/* ── Stage labels below bar ── */}
+      {config.showProgress && (
+        <div className="flex items-center gap-4">
+          {['Cards', 'Engine', 'Layout', 'Done'].map((stageName, i) => (
+            <span
+              key={stageName}
+              className="text-[10px] font-mono"
+              style={{
+                color:   i < config.progressStep ? 'var(--accent-primary)' : 'var(--foreground-muted)',
+                opacity: i < config.progressStep ? 0.8 : 0.35,
+                transition: 'color 300ms ease, opacity 300ms ease',
+              }}
+            >
+              {stageName}
+            </span>
+          ))}
+        </div>
+      )}
+    </div>
+  )
+}
