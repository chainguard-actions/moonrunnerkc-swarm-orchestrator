+import { useColorScheme } from 'react-native'
+
+import { Colors } from '@/constants/colors'
+
+/**
+ * Returns the active colour palette depending on the system colour scheme.
+ * Components should never reference Colors directly — always go through this
+ * hook so that dark-mode overrides are applied automatically.
+ */
+export function useColors() {
+  const scheme = useColorScheme()
+  const dark = scheme === 'dark'
+
+  return {
+    background: dark ? Colors.dark.background : Colors.background,
+    backgroundSecondary: dark ? Colors.dark.backgroundSecondary : Colors.backgroundSecondary,
+    backgroundElevated: dark ? Colors.dark.backgroundElevated : Colors.backgroundElevated,
+    foreground: dark ? Colors.dark.foreground : Colors.foreground,
+    foregroundMuted: dark ? Colors.dark.foregroundMuted : Colors.foregroundMuted,
+    foregroundSubtle: dark ? Colors.dark.foregroundSubtle : Colors.foregroundSubtle,
+    border: dark ? Colors.dark.border : Colors.border,
+    borderHover: dark ? Colors.dark.borderHover : Colors.borderHover,
+    // Accents don't change between modes
+    accentPrimary: Colors.accentPrimary,
+    accentLight: Colors.accentLight,
+    tagGreen: Colors.tagGreen,
+    tagRed: Colors.tagRed,
+    tagBlue: Colors.tagBlue,
+    tagOrange: Colors.tagOrange,
+    tagPurple: Colors.tagPurple,
+    tagPink: Colors.tagPink,
+    tagCyan: Colors.tagCyan,
+    tagAmber: Colors.tagAmber,
+    success: Colors.success,
+    warning: Colors.warning,
+    error: Colors.error,
+    isDark: dark,
+  }
+}
