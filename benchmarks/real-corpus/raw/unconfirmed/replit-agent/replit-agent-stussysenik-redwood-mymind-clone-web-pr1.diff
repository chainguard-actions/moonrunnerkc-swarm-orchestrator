diff --git a/web/src/machines/animationMachine.ts b/web/src/machines/animationMachine.ts
new file mode 100644
index 0000000..3951237
--- /dev/null
+++ b/web/src/machines/animationMachine.ts
@@ -0,0 +1,135 @@
+/**
+ * animationMachine — Owns every animated state transition in the app.
+ *
+ * Nothing animates without going through this machine.
+ * Components fire SHOW/HIDE — the machine decides the intermediate
+ * states (revealing, concealing) and when the animation is complete.
+ *
+ * This prevents the classic React bug: "I set opacity:0, forgot to
+ * wait for transition, then unmounted immediately."
+ *
+ * States
+ * ──────
+ *  hidden → revealing → visible → concealing → hidden
+ */
+
+import { setup, assign } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export type AnimationVariant =
+  | 'fade'
+  | 'slideUp'
+  | 'slideRight'
+  | 'scale'
+  | 'crossFade'
+
+export interface AnimationMachineContext {
+  variant:       AnimationVariant
+  durationMs:    number
+  /** Optional label used by loading overlays */
+  currentLabel:  string
+  nextLabel:     string
+}
+
+export type AnimationMachineEvent =
+  | { type: 'SHOW'; label?: string }
+  | { type: 'HIDE' }
+  | { type: 'SET_LABEL'; label: string }
+  | { type: 'TRANSITION_DONE' }
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const createAnimationMachine = (
+  variant:    AnimationVariant = 'fade',
+  durationMs: number           = 320,
+) =>
+  setup({
+    types: {
+      context: {} as AnimationMachineContext,
+      events:  {} as AnimationMachineEvent,
+    },
+    delays: {
+      ANIM_DURATION: durationMs,
+    },
+  }).createMachine({
+    id:      `animation_${variant}`,
+    initial: 'hidden',
+    context: {
+      variant,
+      durationMs,
+      currentLabel: '',
+      nextLabel:    '',
+    },
+
+    states: {
+      hidden: {
+        on: {
+          SHOW: {
+            target:  'revealing',
+            actions: assign({
+              currentLabel: ({ event }) => event.label ?? '',
+            }),
+          },
+        },
+      },
+
+      revealing: {
+        after: {
+          ANIM_DURATION: 'visible',
+        },
+        on: {
+          HIDE:           'hidden',
+          TRANSITION_DONE:'visible',
+        },
+      },
+
+      visible: {
+        on: {
+          HIDE:      'concealing',
+          SET_LABEL: {
+            target:  'transitioning',
+            actions: assign({
+              nextLabel: ({ event }) => event.label,
+            }),
+          },
+        },
+      },
+
+      /** Cross-fade between two labels without fully hiding. */
+      transitioning: {
+        after: {
+          ANIM_DURATION: {
+            target:  'visible',
+            actions: assign({
+              currentLabel: ({ context }) => context.nextLabel,
+              nextLabel:    '',
+            }),
+          },
+        },
+      },
+
+      concealing: {
+        after: {
+          ANIM_DURATION: 'hidden',
+        },
+        on: {
+          SHOW:           'revealing',
+          TRANSITION_DONE:'hidden',
+        },
+      },
+    },
+  })
+
+/** Pre-built instance for the graph canvas reveal */
+export const graphCanvasAnimMachine   = createAnimationMachine('crossFade', 320)
+/** Pre-built instance for the detail panel slide-in */
+export const detailPanelAnimMachine   = createAnimationMachine('slideRight', 280)
+/** Pre-built instance for modal overlays */
+export const modalOverlayAnimMachine  = createAnimationMachine('fade', 200)
+/** Pre-built instance for the loading stage overlay */
+export const loadingOverlayAnimMachine = createAnimationMachine('fade', 240)
diff --git a/web/src/machines/cardOperationMachine.ts b/web/src/machines/cardOperationMachine.ts
new file mode 100644
index 0000000..8884b5e
--- /dev/null
+++ b/web/src/machines/cardOperationMachine.ts
@@ -0,0 +1,124 @@
+/**
+ * cardOperationMachine — Manages archive / delete / restore with optimistic UI.
+ *
+ * The machine applies the optimistic state change immediately (idle → operating),
+ * then awaits server confirmation. On failure it reverts and sends an error
+ * toast via the notification machine.
+ *
+ * States
+ * ──────
+ *  idle → operating → success → idle
+ *               ↘ reverting → idle
+ */
+
+import { setup, assign, fromPromise } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export type CardOperation = 'archive' | 'unarchive' | 'delete'
+
+export interface CardOperationContext {
+  cardId:    string | null
+  operation: CardOperation | null
+  error:     string | null
+}
+
+export type CardOperationEvent =
+  | { type: 'ARCHIVE';   cardId: string; execute: () => Promise<void> }
+  | { type: 'UNARCHIVE'; cardId: string; execute: () => Promise<void> }
+  | { type: 'DELETE';    cardId: string; execute: () => Promise<void> }
+  | { type: 'CONFIRM_SUCCESS' }
+  | { type: 'CONFIRM_FAILURE'; error: string }
+  | { type: 'RESET' }
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const cardOperationMachine = setup({
+  types: {
+    context: {} as CardOperationContext,
+    events:  {} as CardOperationEvent,
+    input:   {} as { onSuccess?: (cardId: string, op: CardOperation) => void
+                     onError?:   (cardId: string, op: CardOperation, error: string) => void },
+  },
+
+  actors: {
+    executeOperation: fromPromise<void, { execute: () => Promise<void> }>(
+      async ({ input }) => {
+        await input.execute()
+      },
+    ),
+  },
+
+  actions: {
+    setOperation: assign({
+      cardId:    ({ event }) => {
+        if ('cardId' in event) return event.cardId
+        return null
+      },
+      operation: ({ event }) => {
+        if (event.type === 'ARCHIVE')   return 'archive'
+        if (event.type === 'UNARCHIVE') return 'unarchive'
+        if (event.type === 'DELETE')    return 'delete'
+        return null
+      },
+      error: null,
+    }),
+    setError: assign({
+      error: ({ event }) =>
+        event.type === 'CONFIRM_FAILURE' ? event.error : null,
+    }),
+    clearContext: assign({
+      cardId: null, operation: null, error: null,
+    }),
+  },
+}).createMachine({
+  id:      'cardOperation',
+  initial: 'idle',
+  context: { cardId: null, operation: null, error: null },
+
+  states: {
+    idle: {
+      on: {
+        ARCHIVE:   { target: 'operating', actions: 'setOperation' },
+        UNARCHIVE: { target: 'operating', actions: 'setOperation' },
+        DELETE:    { target: 'operating', actions: 'setOperation' },
+      },
+    },
+
+    operating: {
+      invoke: {
+        src:   'executeOperation',
+        input: ({ event }) => ({
+          execute: ('execute' in event ? event.execute : async () => {}) as () => Promise<void>,
+        }),
+        onDone:  'success',
+        onError: {
+          target:  'reverting',
+          actions: assign({
+            error: ({ event }) => String((event as { error: unknown }).error),
+          }),
+        },
+      },
+    },
+
+    success: {
+      after: {
+        100: { target: 'idle', actions: 'clearContext' },
+      },
+    },
+
+    reverting: {
+      /** Give the UI a moment to show the error before resetting. */
+      after: {
+        2_000: { target: 'idle', actions: 'clearContext' },
+      },
+      on: {
+        RESET: { target: 'idle', actions: 'clearContext' },
+      },
+    },
+  },
+})
diff --git a/web/src/machines/clusterMachine.ts b/web/src/machines/clusterMachine.ts
new file mode 100644
index 0000000..4dc54e2
--- /dev/null
+++ b/web/src/machines/clusterMachine.ts
@@ -0,0 +1,168 @@
+/**
+ * clusterMachine — Manages the cluster selection → save flow.
+ *
+ * Long-press a node → machine starts flood-fill selection.
+ * User names the cluster → machine saves it to the server.
+ * On success → clears selection, closes sheet.
+ * On failure → surfaces error, keeps sheet open for retry.
+ *
+ * States
+ * ──────
+ *  idle → selecting → confirming → saving → saved → idle
+ *                            ↘ error → confirming (retry)
+ */
+
+import { setup, assign, fromPromise } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export interface ClusterMachineContext {
+  seedNodeId:      string | null
+  selectedNodeIds: Set<string>
+  name:            string
+  note:            string
+  error:           string | null
+  savedClusterId:  string | null
+}
+
+export type ClusterMachineEvent =
+  | { type: 'START_SELECTION'; seedNodeId: string; floodFillIds: Set<string> }
+  | { type: 'TOGGLE_NODE'; nodeId: string }
+  | { type: 'OPEN_SHEET' }
+  | { type: 'SET_NAME'; name: string }
+  | { type: 'SET_NOTE'; note: string }
+  | { type: 'SAVE'; execute: (name: string, note: string, nodeIds: string[]) => Promise<string> }
+  | { type: 'CANCEL' }
+  | { type: 'RETRY' }
+  | { type: 'RESTORE_CLUSTER'; nodeIds: Set<string> }
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const clusterMachine = setup({
+  types: {
+    context: {} as ClusterMachineContext,
+    events:  {} as ClusterMachineEvent,
+  },
+
+  actors: {
+    saveCluster: fromPromise<string, {
+      name:    string
+      note:    string
+      nodeIds: string[]
+      execute: (name: string, note: string, nodeIds: string[]) => Promise<string>
+    }>(async ({ input }) => {
+      return input.execute(input.name, input.note, input.nodeIds)
+    }),
+  },
+
+  actions: {
+    startFloodFill: assign({
+      seedNodeId:      ({ event }) => event.type === 'START_SELECTION' ? event.seedNodeId : null,
+      selectedNodeIds: ({ event }) => event.type === 'START_SELECTION' ? event.floodFillIds : new Set<string>(),
+    }),
+    toggleNode: assign({
+      selectedNodeIds: ({ context, event }) => {
+        if (event.type !== 'TOGGLE_NODE') return context.selectedNodeIds
+        const next = new Set(context.selectedNodeIds)
+        if (next.has(event.nodeId)) {
+          next.delete(event.nodeId)
+        } else {
+          next.add(event.nodeId)
+        }
+        return next
+      },
+    }),
+    setName:  assign({ name:  ({ event }) => event.type === 'SET_NAME' ? event.name : '' }),
+    setNote:  assign({ note:  ({ event }) => event.type === 'SET_NOTE' ? event.note : '' }),
+    setError: assign({ error: ({ event }) => (event as { error?: string }).error ?? 'Unknown error' }),
+    clearAll: assign({
+      seedNodeId: null, selectedNodeIds: new Set<string>(),
+      name: '', note: '', error: null, savedClusterId: null,
+    }),
+    setSavedId: assign({
+      savedClusterId: ({ event }) => (event as { output?: string }).output ?? null,
+    }),
+    restoreSelection: assign({
+      selectedNodeIds: ({ event }) =>
+        event.type === 'RESTORE_CLUSTER' ? event.nodeIds : new Set<string>(),
+    }),
+  },
+}).createMachine({
+  id:      'cluster',
+  initial: 'idle',
+  context: {
+    seedNodeId:      null,
+    selectedNodeIds: new Set<string>(),
+    name:            '',
+    note:            '',
+    error:           null,
+    savedClusterId:  null,
+  },
+
+  states: {
+    idle: {
+      on: {
+        START_SELECTION: { target: 'selecting',   actions: 'startFloodFill' },
+        RESTORE_CLUSTER: { target: 'selecting',   actions: 'restoreSelection' },
+      },
+    },
+
+    selecting: {
+      on: {
+        TOGGLE_NODE: { actions: 'toggleNode' },
+        OPEN_SHEET:  'confirming',
+        CANCEL:      { target: 'idle', actions: 'clearAll' },
+      },
+    },
+
+    confirming: {
+      on: {
+        SET_NAME: { actions: 'setName' },
+        SET_NOTE: { actions: 'setNote' },
+        SAVE: {
+          target: 'saving',
+          guard:  ({ context }) => context.name.trim().length > 0,
+        },
+        CANCEL: { target: 'idle', actions: 'clearAll' },
+      },
+    },
+
+    saving: {
+      invoke: {
+        src:   'saveCluster',
+        input: ({ context, event }) => ({
+          name:    context.name.trim(),
+          note:    context.note.trim(),
+          nodeIds: Array.from(context.selectedNodeIds),
+          execute: (event as { execute?: (n: string, no: string, ids: string[]) => Promise<string> }).execute
+            ?? (() => Promise.resolve('')),
+        }),
+        onDone:  {
+          target:  'saved',
+          actions: 'setSavedId',
+        },
+        onError: {
+          target:  'error',
+          actions: 'setError',
+        },
+      },
+    },
+
+    saved: {
+      after: {
+        500: { target: 'idle', actions: 'clearAll' },
+      },
+    },
+
+    error: {
+      on: {
+        RETRY:  'confirming',
+        CANCEL: { target: 'idle', actions: 'clearAll' },
+      },
+    },
+  },
+})
diff --git a/web/src/machines/filterMachine.ts b/web/src/machines/filterMachine.ts
new file mode 100644
index 0000000..f372ac7
--- /dev/null
+++ b/web/src/machines/filterMachine.ts
@@ -0,0 +1,94 @@
+/**
+ * filterMachine — Debounced edge-weight filter for the graph.
+ *
+ * The slider fires SET_WEIGHT on every input event (very fast).
+ * This machine debounces those into a single APPLY after 150ms of
+ * silence — so the heavy graphData recalculation only runs once
+ * per gesture, not once per pixel of slider movement.
+ *
+ * States
+ * ──────
+ *  idle → pending (debouncing) → idle
+ */
+
+import { setup, assign } from 'xstate'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export interface FilterMachineContext {
+  pendingWeight: number
+  appliedWeight: number
+  minBound:      number
+  maxBound:      number
+}
+
+export type FilterMachineEvent =
+  | { type: 'SET_WEIGHT'; weight: number }
+  | { type: 'RESET' }
+  | { type: 'SET_BOUNDS'; min: number; max: number }
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const filterMachine = setup({
+  types: {
+    context: {} as FilterMachineContext,
+    events:  {} as FilterMachineEvent,
+  },
+  delays: {
+    DEBOUNCE: 150,
+  },
+  actions: {
+    setPending: assign({
+      pendingWeight: ({ event }) =>
+        event.type === 'SET_WEIGHT' ? event.weight : 1,
+    }),
+    applyPending: assign({
+      appliedWeight: ({ context }) => context.pendingWeight,
+    }),
+    reset: assign({
+      pendingWeight: 1,
+      appliedWeight: 1,
+    }),
+    setBounds: assign({
+      minBound: ({ event }) => event.type === 'SET_BOUNDS' ? event.min : 1,
+      maxBound: ({ event }) => event.type === 'SET_BOUNDS' ? event.max : 5,
+    }),
+  },
+}).createMachine({
+  id:      'filter',
+  initial: 'idle',
+  context: {
+    pendingWeight: 1,
+    appliedWeight: 1,
+    minBound:      1,
+    maxBound:      5,
+  },
+
+  states: {
+    idle: {
+      on: {
+        SET_WEIGHT: { target: 'pending', actions: 'setPending' },
+        RESET:      { actions: 'reset' },
+        SET_BOUNDS: { actions: 'setBounds' },
+      },
+    },
+
+    pending: {
+      on: {
+        /** New slider input resets the debounce timer. */
+        SET_WEIGHT: { target: 'pending', actions: 'setPending', reenter: true },
+        RESET:      { target: 'idle',    actions: 'reset' },
+      },
+      after: {
+        DEBOUNCE: {
+          target:  'idle',
+          actions: 'applyPending',
+        },
+      },
+    },
+  },
+})
diff --git a/web/src/machines/graphMachine.ts b/web/src/machines/graphMachine.ts
new file mode 100644
index 0000000..8388db7
--- /dev/null
+++ b/web/src/machines/graphMachine.ts
@@ -0,0 +1,170 @@
+/**
+ * graphMachine — Orchestrates the full graph loading lifecycle.
+ *
+ * Components NEVER manage graph load state. They send events here.
+ * The machine decides what happens next — renderer loading, simulation
+ * settle, timeouts, errors, refetch. All sequenced and explicit.
+ *
+ * States
+ * ──────
+ *  idle → awaitingData → loadingRenderer → simulating → settled
+ *                    ↘ error ↗
+ */
+
+import { setup, assign, fromPromise, type ActorLogicFrom } from 'xstate'
+import type { ComponentType } from 'react'
+
+// ---------------------------------------------------------------------------
+// TYPES
+// ---------------------------------------------------------------------------
+
+export interface GraphMachineContext {
+  nodeCount: number
+  edgeCount: number
+  /** Loaded ForceGraph2D renderer component — null until ready */
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  rendererComponent: ComponentType<any> | null
+  error: string | null
+  /** How many times we've retried after a renderer error */
+  retryCount: number
+}
+
+export type GraphMachineEvent =
+  | { type: 'DATA_READY'; nodeCount: number; edgeCount: number }
+  | { type: 'DATA_EMPTY' }
+  | { type: 'ENGINE_STOPPED' }
+  | { type: 'SETTLE_TIMEOUT' }
+  | { type: 'RETRY' }
+  | { type: 'REFETCH' }
+  | { type: 'FILTER_CHANGED' }
+
+// Phase labels shown to the user in the loading overlay
+export const GRAPH_PHASE_LABELS: Record<string, string> = {
+  idle:            'Initialising…',
+  awaitingData:    'Loading your cards…',
+  loadingRenderer: 'Preparing the renderer…',
+  simulating:      'Laying out connections…',
+  settled:         'Ready',
+  error:           'Something went wrong',
+}
+
+// ---------------------------------------------------------------------------
+// MACHINE
+// ---------------------------------------------------------------------------
+
+export const graphMachine = setup({
+  types: {
+    context: {} as GraphMachineContext,
+    events:  {} as GraphMachineEvent,
+  },
+
+  actors: {
+    /** Dynamically import the heavy ForceGraph2D renderer bundle. */
+    loadRenderer: fromPromise(async () => {
+      const mod = await import('react-force-graph-2d')
+      // eslint-disable-next-line @typescript-eslint/no-explicit-any
+      const Renderer = (mod.default as ComponentType<any> | undefined)
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        ?? ((mod as unknown as { ForceGraph2D?: ComponentType<any> }).ForceGraph2D ?? null)
+      if (!Renderer) throw new Error('ForceGraph2D export not found in react-force-graph-2d')
+      return Renderer
+    }),
+  },
+
+  guards: {
+    hasNodes:       ({ event }) => event.type === 'DATA_READY' && event.nodeCount > 0,
+    canRetry:       ({ context }) => context.retryCount < 3,
+  },
+
+  actions: {
+    clearError:     assign({ error: null }),
+    incrementRetry: assign({ retryCount: ({ context }) => context.retryCount + 1 }),
+    resetRetry:     assign({ retryCount: 0 }),
+  },
+
+  delays: {
+    SETTLE_TIMEOUT: 8_000,
+  },
+}).createMachine({
+  id: 'graph',
+  initial: 'idle',
+  context: {
+    nodeCount:         0,
+    edgeCount:         0,
+    rendererComponent: null,
+    error:             null,
+    retryCount:        0,
+  },
+
+  states: {
+    idle: {
+      on: {
+        DATA_READY:  { target: 'loadingRenderer', actions: assign({ nodeCount: ({ event }) => event.nodeCount, edgeCount: ({ event }) => event.edgeCount }) },
+        DATA_EMPTY:  'settled', // empty graph is still "done"
+      },
+    },
+
+    awaitingData: {
+      // Used when the cell is in its Loading phase — GraphCell sends DATA_READY once Success fires.
+      on: {
+        DATA_READY: {
+          target:  'loadingRenderer',
+          actions: assign({
+            nodeCount: ({ event }) => event.nodeCount,
+            edgeCount: ({ event }) => event.edgeCount,
+          }),
+        },
+        DATA_EMPTY: 'settled',
+      },
+    },
+
+    loadingRenderer: {
+      entry: assign({ error: null }),
+      invoke: {
+        src:    'loadRenderer',
+        onDone: {
+          target:  'simulating',
+          actions: assign({ rendererComponent: ({ event }) => event.output }),
+        },
+        onError: {
+          target:  'error',
+          actions: assign({ error: ({ event }) => String((event as { error: unknown }).error) }),
+        },
+      },
+    },
+
+    simulating: {
+      after: {
+        SETTLE_TIMEOUT: { target: 'settled' },
+      },
+      on: {
+        ENGINE_STOPPED:  'settled',
+        SETTLE_TIMEOUT:  'settled',
+      },
+    },
+
+    settled: {
+      on: {
+        REFETCH:        { target: 'awaitingData', actions: 'resetRetry' },
+        FILTER_CHANGED: 'settled', // stays settled — filtering is instant client-side
+      },
+    },
+
+    error: {
+      on: {
+        RETRY: [
+          {
+            guard:   'canRetry',
+            target:  'loadingRenderer',
+            actions: ['incrementRetry', 'clearError'],
+          },
+          {
+            target: 'error', // stay — max retries reached
+          },
+        ],
+      },
+    },
+  },
+})
+
+export type GraphMachineLogic = ActorLogicFrom<typeof graphMachine>
