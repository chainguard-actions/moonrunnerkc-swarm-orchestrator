+/**
+ * kernel/index — TypeScript bridge to the compiled ReScript kernel.
+ *
+ * Import ONLY from this file — never import the .bs.js directly
+ * from application code. This insulates the rest of the codebase
+ * from the generated output path and lets us swap the kernel
+ * implementation without touching 50 files.
+ *
+ * All functions here are pure — no side effects, no React, no XState.
+ */
+
+// Re-export the compiled ReScript functions with typed wrappers.
+// The .bs.js file is the real runtime; this file just gives TS consumers
+// a clean, typed surface.
+
+import {
+  pruneLinks        as _pruneLinks,
+  buildNeighbourIndex as _buildNeighbourIndex,
+  connectedNodeSet  as _connectedNodeSet,
+  layoutCacheKey    as _layoutCacheKey,
+  computeStats      as _computeStats,
+  getNeighbours     as _getNeighbours,
+} from './GraphKernel.bs.js'
+
+// ---------------------------------------------------------------------------
+// TYPES (mirrored from GraphKernel.res — keep in sync)
+// ---------------------------------------------------------------------------
+
+export interface KernelGraphNode {
+  id: string
+  title: string | null | undefined
+  connectionCount: number
+  nodeType: string
+  tags: string[]
+}
+
+export interface KernelGraphLink {
+  source: string
+  target: string
+  sharedTags: string[]
+  weight: number
+}
+
+export interface KernelNeighbourIndex {
+  adjacency: Record<string, string[]>
+  titleMap:  Record<string, string>
+  typeMap:   Record<string, string>
+}
+
+export interface KernelGraphStats {
+  nodeCount:      number
+  edgeCount:      number
+  orphanCount:    number
+  maxWeight:      number
+  maxConnections: number
+}
+
+// ---------------------------------------------------------------------------
+// TYPED WRAPPERS
+// ---------------------------------------------------------------------------
+
+/**
+ * Filter links by min weight then apply the 4 000-edge budget.
+ * Returns a new array — no mutation.
+ */
+export function pruneLinks(
+  links:     KernelGraphLink[],
+  minWeight: number,
+): KernelGraphLink[] {
+  return _pruneLinks(links, minWeight) as KernelGraphLink[]
+}
+
+/**
+ * Build O(1) neighbour index from nodes + links.
+ * Also caches node titles and types to avoid repeated lookups.
+ */
+export function buildNeighbourIndex(
+  nodes: KernelGraphNode[],
+  links: KernelGraphLink[],
+): KernelNeighbourIndex {
+  return _buildNeighbourIndex(nodes, links) as KernelNeighbourIndex
+}
+
+/**
+ * Returns a dict<boolean> of node IDs that participate in at least one edge.
+ */
+export function connectedNodeSet(
+  links: KernelGraphLink[],
+): Record<string, boolean> {
+  return _connectedNodeSet(links) as Record<string, boolean>
+}
+
+/**
+ * Stable layout cache key from sorted node IDs.
+ * Changes whenever nodes are added or removed.
+ */
+export function layoutCacheKey(nodeIds: string[]): string {
+  return _layoutCacheKey(nodeIds) as string
+}
+
+/**
+ * Compute aggregate graph statistics in a single pass.
+ */
+export function computeStats(
+  nodes:       KernelGraphNode[],
+  activeLinks: KernelGraphLink[],
+): KernelGraphStats {
+  return _computeStats(nodes, activeLinks) as KernelGraphStats
+}
+
+/**
+ * Look up the direct neighbours of a node by ID.
+ * Returns [] if the node is unknown.
+ */
+export function getNeighbours(
+  idx: KernelNeighbourIndex,
+  id:  string,
+): string[] {
+  return _getNeighbours(idx, id) as string[]
+}
