+++ b/mobile/lib/authMachine.ts
@@ -0,0 +1,109 @@
+/**
+ * XState auth machine for BYOA mobile.
+ *
+ * States:
+ *   idle        → checking persisted session
+ *   checking    → loading session from SecureStore
+ *   unauthenticated → no valid session; show login
+ *   authenticating  → sign-in request in flight
+ *   authenticated   → session valid; normal app flow
+ *   signingOut      → sign-out request in flight
+ *
+ * The machine is the single source of truth for auth state; components
+ * observe it via the @xstate/react `useActor` hook.
+ */
+
+import { createMachine, assign } from 'xstate'
+
+export interface AuthContext {
+  token: string | null
+  userId: string | null
+  email: string | null
+  error: string | null
+}
+
+export type AuthEvent =
+  | { type: 'CHECK' }
+  | { type: 'SESSION_FOUND'; token: string; userId: string; email: string }
+  | { type: 'NO_SESSION' }
+  | { type: 'SIGN_IN'; email: string; password: string }
+  | { type: 'SIGN_IN_SUCCESS'; token: string; userId: string; email: string }
+  | { type: 'SIGN_IN_ERROR'; message: string }
+  | { type: 'SIGN_OUT' }
+  | { type: 'SIGN_OUT_DONE' }
+
+export const authMachine = createMachine({
+  id: 'auth',
+  initial: 'idle',
+  context: {
+    token: null,
+    userId: null,
+    email: null,
+    error: null,
+  } satisfies AuthContext,
+
+  states: {
+    idle: {
+      on: {
+        CHECK: 'checking',
+      },
+    },
+
+    checking: {
+      on: {
+        SESSION_FOUND: {
+          target: 'authenticated',
+          actions: assign({
+            token: ({ event }) => (event as Extract<AuthEvent, { type: 'SESSION_FOUND' }>).token,
+            userId: ({ event }) => (event as Extract<AuthEvent, { type: 'SESSION_FOUND' }>).userId,
+            email: ({ event }) => (event as Extract<AuthEvent, { type: 'SESSION_FOUND' }>).email,
+            error: () => null,
+          }),
+        },
+        NO_SESSION: 'unauthenticated',
+      },
+    },
+
+    unauthenticated: {
+      entry: assign({ token: () => null, userId: () => null, error: () => null }),
+      on: {
+        SIGN_IN: 'authenticating',
+      },
+    },
+
+    authenticating: {
+      on: {
+        SIGN_IN_SUCCESS: {
+          target: 'authenticated',
+          actions: assign({
+            token: ({ event }) => (event as Extract<AuthEvent, { type: 'SIGN_IN_SUCCESS' }>).token,
+            userId: ({ event }) => (event as Extract<AuthEvent, { type: 'SIGN_IN_SUCCESS' }>).userId,
+            email: ({ event }) => (event as Extract<AuthEvent, { type: 'SIGN_IN_SUCCESS' }>).email,
+            error: () => null,
+          }),
+        },
+        SIGN_IN_ERROR: {
+          target: 'unauthenticated',
+          actions: assign({
+            error: ({ event }) => (event as Extract<AuthEvent, { type: 'SIGN_IN_ERROR' }>).message,
+          }),
+        },
+      },
+    },
+
+    authenticated: {
+      on: {
+        SIGN_OUT: 'signingOut',
+      },
+    },
+
+    signingOut: {
+      on: {
+        SIGN_OUT_DONE: {
+          target: 'unauthenticated',
+          actions: assign({ token: () => null, userId: () => null, email: () => null }),
+        },
+      },
+    },
+  },
+})
