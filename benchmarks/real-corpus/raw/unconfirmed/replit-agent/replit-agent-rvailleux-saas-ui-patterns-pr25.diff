+<!doctype html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <style>
+    * { box-sizing: border-box; margin: 0; padding: 0; }
+    body {
+      font-family: system-ui, -apple-system, sans-serif;
+      background: #0f0f1a;
+      color: #e2e8f0;
+      height: 100vh;
+      overflow: hidden;
+      font-size: 13px;
+      display: flex;
+      flex-direction: column;
+      padding: 20px;
+    }
+    .scenario-selector {
+      display: flex;
+      gap: 12px;
+      margin-bottom: 20px;
+      padding-bottom: 16px;
+      border-bottom: 1px solid #2a2a55;
+    }
+    .scenario-btn {
+      padding: 10px 16px;
+      background: #1a1a2e;
+      border: 1px solid #2a2a55;
+      border-radius: 8px;
+      color: #94a3b8;
+      cursor: pointer;
+      font-size: 12px;
+      transition: all 0.2s;
+    }
+    .scenario-btn:hover { border-color: #3b82f6; color: #fff; }
+    .scenario-btn.active { background: #3b82f6; border-color: #3b82f6; color: white; }
+    .demo-area {
+      flex: 1;
+      display: flex;
+      flex-direction: column;
+      gap: 16px;
+    }
+    .agent-panel {
+      background: #1a1a2e;
+      border-radius: 12px;
+      padding: 16px;
+      border: 1px solid #2a2a55;
+    }
+    .agent-header {
+      display: flex;
+      align-items: center;
+      gap: 12px;
+      margin-bottom: 12px;
+    }
+    .agent-avatar {
+      width: 36px;
+      height: 36px;
+      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
+      border-radius: 50%;
+      display: flex;
+      align-items: center;
+      justify-content: center;
+      font-size: 16px;
+    }
+    .agent-info { flex: 1; }
+    .agent-name { font-weight: 500; }
+    .agent-status { font-size: 11px; color: #64748b; }
+    .status-badge {
+      padding: 4px 10px;
+      border-radius: 12px;
+      font-size: 11px;
+      font-weight: 500;
+    }
+    .status-running { background: #1e3a5f; color: #3b82f6; }
+    .status-paused { background: #fef3c7; color: #92400e; }
+    .agent-log {
+      background: #151528;
+      border-radius: 8px;
+      padding: 12px;
+      font-family: monospace;
+      font-size: 12px;
+      max-height: 120px;
+      overflow-y: auto;
+    }
+    .log-entry { margin-bottom: 6px; color: #94a3b8; }
+    .log-entry:last-child { margin-bottom: 0; }
+    .escalation-card {
+      background: #fef3c7;
+      border: 2px solid #f59e0b;
+      border-radius: 12px;
+      padding: 20px;
+      color: #92400e;
+      animation: attentionPulse 2s infinite;
+    }
+    @keyframes attentionPulse {
+      0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
+      50% { box-shadow: 0 0 0 8px rgba(245, 158, 11, 0); }
+    }
+    .escalation-header {
+      display: flex;
+      align-items: center;
+      gap: 12px;
+      margin-bottom: 12px;
+    }
+    .escalation-icon {
+      width: 40px;
+      height: 40px;
+      background: #f59e0b;
+      border-radius: 50%;
+      display: flex;
+      align-items: center;
+      justify-content: center;
+      font-size: 20px;
+    }
+    .escalation-title { font-size: 16px; font-weight: 600; }
+    .escalation-reason {
+      background: rgba(0,0,0,0.05);
+      padding: 12px;
+      border-radius: 8px;
+      margin-bottom: 16px;
+    }
+    .escalation-reason-title { font-weight: 500; margin-bottom: 4px; }
+    .escalation-reason-text { font-size: 12px; opacity: 0.8; }
+    .context-box {
+      background: rgba(0,0,0,0.05);
+      padding: 12px;
+      border-radius: 8px;
+      margin-bottom: 16px;
+    }
+    .context-title { font-size: 11px; font-weight: 500; margin-bottom: 8px; text-transform: uppercase; }
+    .context-item {
+      display: flex;
+      justify-content: space-between;
+      font-size: 12px;
+      margin-bottom: 4px;
+    }
+    .context-label { opacity: 0.7; }
+    .escalation-actions {
+      display: flex;
+      gap: 12px;
+    }
+    .btn {
+      flex: 1;
+      padding: 10px 16px;
+      border-radius: 8px;
+      border: none;
+      font-size: 13px;
+      font-weight: 500;
+      cursor: pointer;
+      transition: all 0.2s;
+    }
+    .btn-approve {
+      background: #22c55e;
+      color: white;
+    }
+    .btn-approve:hover { background: #16a34a; }
+    .btn-modify {
+      background: rgba(0,0,0,0.1);
+      color: #92400e;
+    }
+    .btn-reject {
+      background: #ef4444;
+      color: white;
+    }
+    .hidden { display: none !important; }
+  </style>
+</head>
+<body>
+  <div class="scenario-selector">
+    <button class="scenario-btn active" onclick="setScenario('confidence')">Low Confidence</button>
+    <button class="scenario-btn" onclick="setScenario('authorization')">Authorization Required</button>
+    <button class="scenario-btn" onclick="setScenario('conflict')">Conflict Detected</button>
+  </div>
+
+  <div class="demo-area">
+    <div class="agent-panel">
+      <div class="agent-header">
+        <div class="agent-avatar">🤖</div>
+        <div class="agent-info">
+          <div class="agent-name">Deployment Agent</div>
+          <div class="agent-status">Waiting for human input...</div>
+        </div>
+        <span class="status-badge status-paused">⏸ Paused</span>
+      </div>
+      <div class="agent-log" id="agentLog">
+        <div class="log-entry">[14:32:01] Analyzing deployment requirements...</div>
+        <div class="log-entry">[14:32:05] Checking environment variables...</div>
+        <div class="log-entry">[14:32:08] ⚠️ Escalation triggered: Confidence below threshold</div>
+        <div class="log-entry">[14:32:08] ⏸ Paused, awaiting human decision...</div>
+      </div>
+    </div>
+
+    <div class="escalation-card" id="escalationCard">
+      <div class="escalation-header">
+        <div class="escalation-icon">⚠️</div>
+        <div class="escalation-title">Human Review Required</div>
+      </div>
+
+      <div class="escalation-reason">
+        <div class="escalation-reason-title">Trigger: Low Confidence</div>
+        <div class="escalation-reason-text" id="escalationReason">The agent is unsure about the database migration plan (confidence: 65%). This requires your expertise.</div>
+      </div>
+
+      <div class="context-box">
+        <div class="context-title">Context</div>
+        <div class="context-item">
+          <span class="context-label">Action</span>
+          <span>Deploy v2.4.0 to production</span>
+        </div>
+        <div class="context-item">
+          <span class="context-label">Risk Level</span>
+          <span id="riskLevel">Medium</span>
+        </div>
+        <div class="context-item">
+          <span class="context-label">Estimated Impact</span>
+          <span id="impactLevel">~500 users affected</span>
+        </div>
+        <div class="context-item">
+          <span class="context-label">Confidence Score</span>
+          <span id="confidenceScore">65%</span>
+        </div>
+      </div>
+
+      <div class="escalation-actions">
+        <button class="btn btn-approve" onclick="handleDecision('approve')">✓ Approve</button>
+        <button class="btn btn-modify" onclick="handleDecision('modify')">✎ Modify</button>
+        <button class="btn btn-reject" onclick="handleDecision('reject')">✕ Reject</button>
+      </div>
+    </div>
+  </div>
+
+  <script>
+    const scenarios = {
+      confidence: {
+        reason: "The agent is unsure about the database migration plan (confidence: 65%). This requires your expertise.",
+        risk: "Medium",
+        impact: "~500 users affected",
+        score: "65%",
+        log: [
+          "[14:32:01] Analyzing deployment requirements...",
+          "[14:32:05] Checking environment variables...",
+          "[14:32:08] ⚠️ Escalation triggered: Confidence below threshold",
+          "[14:32:08] ⏸ Paused, awaiting human decision..."
+        ]
+      },
+      authorization: {
+        reason: "This action requires explicit authorization: Deleting production database records.",
+        risk: "High",
+        impact: "Irreversible data loss",
+        score: "Authorization required",
+        log: [
+          "[14:32:01] Scanning for obsolete records...",
+          "[14:32:03] Found 1,247 records to archive",
+          "[14:32:05] ⚠️ Escalation triggered: Authorization boundary",
+          "[14:32:05] ⏸ Paused, awaiting human approval..."
+        ]
+      },
+      conflict: {
+        reason: "Detected conflicting requirements: 'Minimize cost' vs 'Maximize performance'.",
+        risk: "Medium",
+        impact: "Trade-off decision needed",
+        score: "Conflict detected",
+        log: [
+          "[14:32:01] Optimizing resource allocation...",
+          "[14:32:04] Analyzing constraints...",
+          "[14:32:07] ⚠️ Escalation triggered: Conflicting requirements",
+          "[14:32:07] ⏸ Paused, awaiting human resolution..."
+        ]
+      }
+    };
+
+    function setScenario(type) {
+      document.querySelectorAll('.scenario-btn').forEach(btn => btn.classList.remove('active'));
+      event.target.classList.add('active');
+
+      const s = scenarios[type];
+      document.getElementById('escalationReason').textContent = s.reason;
+      document.getElementById('riskLevel').textContent = s.risk;
+      document.getElementById('impactLevel').textContent = s.impact;
+      document.getElementById('confidenceScore').textContent = s.score;
+
+      const logEl = document.getElementById('agentLog');
+      logEl.innerHTML = s.log.map(entry => `<div class="log-entry">${entry}</div>`).join('');
+    }
+
+    function handleDecision(decision) {
+      const messages = {
+        approve: "✓ Approved! Agent resuming...",
+        modify: "✎ Opening modification interface...",
+        reject: "✕ Rejected. Agent will explore alternatives."
+      };
+      alert(messages[decision]);
+    }
+  </script>
+</body>
+</html>
