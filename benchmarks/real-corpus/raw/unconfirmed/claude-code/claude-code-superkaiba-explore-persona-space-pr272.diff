+        "primary_thesis": False,  # filled below
+    }
+    verdicts["primary_thesis"] = bool(
+        verdicts["preflight_AvE_pass"]
+        and verdicts["H1_jt_decreasing"]
+        and verdicts["H1_glm_factor_primary"]
+        and verdicts["H1_glm_aux_BCE_partials_out"]
+        and verdicts["H2_any"]
