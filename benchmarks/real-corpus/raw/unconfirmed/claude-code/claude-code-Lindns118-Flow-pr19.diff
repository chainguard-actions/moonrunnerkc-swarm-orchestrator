+        var q = window.location.search;
+        if (q && q.indexOf('?p=') === 0) {
+          var params = {};
+          q.slice(1).split('&').forEach(function (s) {
+            var p = s.indexOf('=');
+            params[s.slice(0, p)] = decodeURIComponent(s.slice(p + 1));
+          });
+          if (params.p !== undefined) {
+            window.history.replaceState(
+              null, null,
+              '/Flow/' + params.p + (params.h || '')
+            );
+          }
+        }
+      })();
+    </script>
