+<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8" />
+  <title>flow</title>
+  <script>
+    // GitHub Pages SPA redirect: preserve the path for React Router
+    var l = window.location;
+    l.replace(
+      l.protocol + '//' + l.hostname + (l.port ? ':' + l.port : '') +
+      l.pathname.split('/').slice(0, 2).join('/') +
+      '/?p=' + encodeURIComponent(l.pathname.split('/').slice(2).join('/')) +
+      (l.hash ? '&h=' + encodeURIComponent(l.hash) : '')
+    );
+  </script>
+</head>
+</html>
