+  // lines to end in \r, \n, or \r\n, so adjacent line endings may be mixed.
+  for (let i = 0; i < buffer.length; i++) {
+    const firstEnd = findLineEndingEnd(buffer, i);
+    if (firstEnd === -1) {
+      continue;
+    }
