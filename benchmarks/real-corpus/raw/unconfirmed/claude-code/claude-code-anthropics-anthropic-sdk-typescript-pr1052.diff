+
+  test('throws when iterated twice', async () => {
+    const { client } = makeFake({ streams: [[TERMINATED]] });
+    const runner = new SessionToolRunner('s', { client, tools: [], maxIdleMs: 0 });
+    for await (const _ of runner) {
