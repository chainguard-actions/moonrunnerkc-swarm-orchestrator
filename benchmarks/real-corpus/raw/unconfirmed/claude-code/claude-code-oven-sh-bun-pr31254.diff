-            @field(backing, field),
-            &@field(tracking, field),
-            d,
-            cp,
-        );
-    } else {
-        @field(data, field) = try .init(
-            allocator,
-            @field(backing, field),
-            &@field(tracking, field),
-            d,
-        );
-    }
-}
