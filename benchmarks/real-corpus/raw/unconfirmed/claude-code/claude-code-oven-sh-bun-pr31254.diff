-//         const KIND: ListContainerType;
-//     }
-//
-// impl'd by `Vec<T>`, `Vec<T>`,
-// `bun_collections::SmallList<T, N>`. Callers bound on `T: ListContainer`.
-
-// TODO(port): `Tagged(U, T)` — re-synthesize a `union` with a new tag type
