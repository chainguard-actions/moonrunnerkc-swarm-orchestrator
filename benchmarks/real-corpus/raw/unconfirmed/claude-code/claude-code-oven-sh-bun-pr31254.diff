-fn testGetActualComputedGraphemeBreak(cp1: u21, cp2: u21, state: *BreakState) bool {
-    const gb1 = get(.grapheme_break, cp1);
-    const gb2 = get(.grapheme_break, cp2);
-    return computeGraphemeBreak(gb1, gb2, state);
-}
