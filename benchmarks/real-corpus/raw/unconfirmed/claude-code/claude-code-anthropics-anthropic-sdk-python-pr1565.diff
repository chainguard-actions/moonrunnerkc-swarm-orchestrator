+@pytest.mark.asyncio()
+async def test_until_done_drives_runner_to_completion() -> None:
+    """``until_done()`` (renamed from ``run()`` to match ``BetaToolRunner`` and
+    avoid colliding with ``EnvironmentWorker.run``'s forever-loop) drives the
