+    if (tokens.includes(p)) return canonical[p] || p;
+  }
+  return null;
+}
+
+function parseTypeBullet(bullet) {
+  // - **Display** (family, weight 300, italic, clamp(...), line-height 1): purpose
+  const m = bullet.match(/^\*\*(.+?)\*\*\s*\(([^)]+)\):\s*(.*)$/);
