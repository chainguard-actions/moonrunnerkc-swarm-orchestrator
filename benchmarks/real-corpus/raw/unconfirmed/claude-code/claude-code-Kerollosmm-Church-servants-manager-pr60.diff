+                  ),
+                  validator: (value) => value == null || value.trim().isEmpty
+                      ? 'هذا الحقل مطلوب'
+                      : null,
+                ),
+                AppSpacing.gapMd,
+                DropdownButtonFormField<EducationStage>(
+                  initialValue: _selectedStage,
+                  decoration: const InputDecoration(
+                    labelText: 'المرحلة الدراسية',
+                    prefixIcon: Icon(Icons.school),
