+      expect(find.text('Error Title'), findsOneWidget);
+      expect(find.text('Something went wrong'), findsOneWidget);
+      expect(find.byIcon(Icons.error_outline), findsOneWidget);
+    });
+
+    testWidgets('shows retry button and calls onRetry', (
