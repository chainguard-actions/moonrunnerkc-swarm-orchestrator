@@ -0,0 +1,77 @@
+//! AI tab evaluator (stub).
+//!
+//! Blocked on a user-configured AI provider + prompt slots (1..100).
+//! Until the provider configuration + prompt pipeline ships this
+//! evaluator emits no findings; registering it keeps the tab catalog
+//! aligned with the 33-tab registry and gives the evaluator pipeline a
+//! zero-cost code path instead of silently dropping URLs through an
+//! unmatched tab.
+
+use sf_core::crawl::CrawlUrl;
+use sf_core::tab::TabKey;
+
+use crate::{EvalContext, Evaluator, Finding};
+
+pub struct AiEvaluator;
+
+impl Evaluator for AiEvaluator {
+    fn tab(&self) -> TabKey {
+        TabKey::Ai
+    }
+
+    fn evaluate(&self, _url: &CrawlUrl, _ctx: &EvalContext) -> Vec<Finding> {
+        Vec::new()
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use chrono::Utc;
+    use sf_core::config::CrawlConfig;
+    use sf_core::crawl::{ContentType, CrawlUrl};
+    use sf_core::id::{CrawlId, CrawlUrlId};
+
+    fn page() -> CrawlUrl {
+        CrawlUrl {
+            id: CrawlUrlId::new(),
+            crawl_id: CrawlId::new(),
+            url: "https://example.com/".to_string(),
+            url_hash: "h".to_string(),
+            content_type: ContentType::Html,
+            status_code: Some(200),
+            is_internal: true,
+            depth: 0,
+            title: None,
+            title_length: None,
+            title_pixel_width: None,
+            meta_description: None,
+            meta_description_length: None,
+            meta_description_pixel_width: None,
+            h1_first: None,
+            h1_count: 0,
+            h2_first: None,
+            h2_count: 0,
+            word_count: None,
+            response_time_ms: None,
+            content_length: None,
+            redirect_url: None,
+            canonical_url: None,
+            meta_robots: None,
+            crawled_at: Some(Utc::now()),
+        }
+    }
+
+    #[test]
+    fn ai_emits_nothing() {
+        let cfg = CrawlConfig::default();
+        let ctx = EvalContext {
+            config: &cfg,
+            html: None,
+            parsed: None,
+        };
+        let evaluator = AiEvaluator;
+        assert_eq!(evaluator.tab(), TabKey::Ai);
+        assert!(evaluator.evaluate(&page(), &ctx).is_empty());
+    }
+}
