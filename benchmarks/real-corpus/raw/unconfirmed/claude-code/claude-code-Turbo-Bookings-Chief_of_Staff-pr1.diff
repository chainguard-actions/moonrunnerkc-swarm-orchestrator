+2.4 On approval
+	•	Insert projects row
+	•	Insert tasks rows for each milestone, linked via project_id
+	•	Apply depends_on array on each task
+	•	Send dispatches per Phase 2 logic — but only for milestones with no unmet dependencies
+	•	Schedule downstream milestone dispatches to fire automatically when their dependencies complete
+	•	Project surfaces in Projects tab as 'active'
+
+3. Dependency-Aware Dispatch
+In Phase 2, every captured task gets dispatched immediately. In Phase 5, tasks tied to a project respect dependencies.
+3.1 Dispatch eligibility
+A task with project_id and depends_on is dispatched only when ALL tasks in depends_on are 'complete'.
+3.2 Sequenced dispatch flow
+	•	Project created with 5 milestones (M1, M2, M3, M4, M5)
+	•	M1 has no dependencies → dispatched immediately
+	•	M2 depends on [M1], M3 depends on [M1], M4 depends on [M2, M3], M5 depends on [M4] → all wait
+	•	Team member completes M1, replies 'done', task status → complete
+	•	Trigger fires: re-evaluate downstream dependencies
+	•	M2 and M3 are now eligible → dispatched (in parallel since no inter-dependency between them)
+	•	M4 still waits because both M2 and M3 must complete first
+	•	Continue until all milestones complete → project status → complete
+3.3 What happens when a milestone slips
+	•	Phase 4 chase logic still applies at the milestone level (nudges, escalation)
+	•	Phase 5 adds project-level: if a milestone slips significantly, the project's risk_level may auto-elevate
+	•	Downstream milestones whose dependencies are slipping get a 'blocked-upstream' indicator
+	•	Selmen can manually unblock a downstream milestone ("start it anyway") if priorities shift
+3.4 Pseudocode for dependency check
+async function checkDispatchEligibility(task) {
+  if (!task.depends_on || task.depends_on.length === 0) {
+    return { eligible: true };
+  }
+
+  const dependencies = await db.select()
+    .from(tasks)
+    .where(inArray(tasks.id, task.depends_on));
+
+  const allComplete = dependencies.every(d => d.status === 'complete');
+  if (allComplete) return { eligible: true };
+
+  const blockers = dependencies.filter(d => d.status !== 'complete');
+  return {
+    eligible: false,
+    blocking: blockers.map(b => ({ id: b.id, title: b.title, status: b.status }))
+  };
+}
+
+// Called whenever any task transitions to 'complete'
+async function onTaskComplete(completedTask) {
+  if (!completedTask.project_id) return;
+
+  const downstreamTasks = await db.select()
+    .from(tasks)
+    .where(and(
+      eq(tasks.project_id, completedTask.project_id),
+      eq(tasks.status, 'captured')   // only those not yet dispatched
+    ));
+
+  for (const t of downstreamTasks) {
+    if (t.depends_on?.includes(completedTask.id)) {
+      const check = await checkDispatchEligibility(t);
+      if (check.eligible) {
+        await dispatchTask(t);
+      }
+    }
+  }
+
+  // Also check if project is now complete
+  await reevaluateProjectStatus(completedTask.project_id);
+}
