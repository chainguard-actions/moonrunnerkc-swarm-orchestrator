+# auto-generate it on first run). .env is gitignored — never commit it.
+
+# =============================================================================
+# REQUIRED — host identity (wsl-up.sh fills these in automatically)
+# =============================================================================
+
+# Your WSL username — also becomes the container username and the homebase
+# folder name (/home/$HOST_USER inside the container).
+HOST_USER=hwieland
+
+# Your WSL numeric uid/gid — the container's user is remapped to these so
+# files created inside the bind mount are owned by you on the host.
+HOST_UID=1000
+HOST_GID=1000
+
+# Absolute path to your WSL home directory on the host. This entire
+# directory is bind-mounted as /home/$HOST_USER inside the container
+# ("homebase" — the single source of persistent state).
+HOST_HOME=/home/hwieland
+
+
+# =============================================================================
+# OPTIONAL — future extension points (uncomment and fill in as needed)
+# =============================================================================
+
+# GitHub Personal Access Token. Only used if you opt into the --use-pat
+# fallback in fnba-bootstrap/first-time-setup.sh. The default git auth
+# strategy is SSH via your homebase ~/.ssh — leave this empty for that.
+# GH_TOKEN=
+
+# Atlassian (Jira / Confluence). The bootstrap wires the community
+# Atlassian remote MCP, which uses OAuth on first use — no token needed
+# here. These vars only matter if you ever bring back the legacy
+# PAT-based jira-mcp-server.
+# JIRA_BASE_URL=https://fnba.atlassian.net
+# JIRA_EMAIL=
+# JIRA_API_TOKEN=
