+
+    PFN_vkDestroyDebugUtilsMessengerEXT pfnDestroy = reinterpret_cast<PFN_vkDestroyDebugUtilsMessengerEXT>(
+        vkGetInstanceProcAddr( g_vkInstance, "vkDestroyDebugUtilsMessengerEXT" ));
+    if ( pfnDestroy )
