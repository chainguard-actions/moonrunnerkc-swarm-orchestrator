+VkPhysicalDeviceFeatures GetRequiredDeviceFeatures()
+{
+    VkPhysicalDeviceFeatures features = {};
+    features.samplerAnisotropy = VK_TRUE;
+    features.fillModeNonSolid = VK_TRUE;
+    features.wideLines = VK_TRUE;
+    return features;
