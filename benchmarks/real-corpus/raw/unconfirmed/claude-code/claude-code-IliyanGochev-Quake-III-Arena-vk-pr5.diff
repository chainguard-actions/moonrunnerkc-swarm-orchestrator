+    vkCmdPipelineBarrier( cmd, VK_PIPELINE_STAGE_ALL_GRAPHICS_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                           0, 0, nullptr, 0, nullptr, 1, &barrier );
+
+    VkBufferImageCopy copyRegion = {};
