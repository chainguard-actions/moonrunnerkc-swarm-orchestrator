diff --git a/src/ScmService.ts b/src/ScmService.ts
new file mode 100644
index 0000000..34729ed
--- /dev/null
+++ b/src/ScmService.ts
@@ -0,0 +1,51 @@
+import type {
+  RemoteGitProviderAdapter,
+  PullRequest,
+  PullRequestParams,
+  MergeParams,
+  PullRequestMergability,
+} from './remoteGitProvider';
+import { GitHubProviderAdapter } from './GitHubProviderAdapter';
+import { GitLabProviderAdapter } from './GitLabProviderAdapter';
+import { BitBucketProviderAdapter } from './BitBucketProviderAdapter';
+
+export type ProviderKey = 'github' | 'gitlab' | 'bitbucket';
+
+function createAdapter(providerKey: ProviderKey, baseUrl: string): RemoteGitProviderAdapter {
+  switch (providerKey) {
+    case 'github':    return new GitHubProviderAdapter(baseUrl);
+    case 'gitlab':    return new GitLabProviderAdapter(baseUrl);
+    case 'bitbucket': return new BitBucketProviderAdapter(baseUrl);
+  }
+}
+
+export class ScmService {
+  private readonly adapter: RemoteGitProviderAdapter;
+
+  constructor(private readonly providerKey: ProviderKey, baseUrl: string) {
+    this.adapter = createAdapter(providerKey, baseUrl);
+  }
+
+  getProviderKey(): ProviderKey {
+    return this.providerKey;
+  }
+
+  getBaseUrl(): string {
+    return this.adapter.getBaseUrl();
+  }
+
+  async createPullRequest(params: PullRequestParams): Promise<PullRequest> {
+    return this.adapter.createPullRequest(params);
+  }
+
+  async mergePullRequest(params: MergeParams): Promise<void> {
+    return this.adapter.mergePullRequest(params);
+  }
+
+  async getPullRequestMergability(
+    pullRequestId: string | number,
+    repository: string,
+  ): Promise<PullRequestMergability> {
+    return this.adapter.getPullRequestMergability(pullRequestId, repository);
+  }
+}
