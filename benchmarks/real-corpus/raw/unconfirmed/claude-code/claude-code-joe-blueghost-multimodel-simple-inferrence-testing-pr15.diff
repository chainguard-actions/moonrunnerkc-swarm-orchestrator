+#root {
+  text-align: left;
+  width: 100%;
+  max-width: 100%;
+  border-inline: none;
+}
+
+.editor {
+  display: flex;
+  flex-direction: column;
+  min-height: 100svh;
+  font-family: var(--mono);
+}
+
+/* Header */
+
+.editor-header {
+  padding: 12px 20px;
+  border-bottom: 1px solid var(--border);
+  display: flex;
+  align-items: center;
+  gap: 20px;
+  flex-wrap: wrap;
+}
+
+.editor-title {
+  font-size: 14px;
+  font-weight: 600;
+  color: var(--text-h);
+  white-space: nowrap;
+}
+
+.provider-row {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+
+.provider-row label {
+  font-size: 12px;
+  color: var(--text);
+}
+
+.provider-row select,
+.url-input {
+  font-family: var(--mono);
+  font-size: 12px;
+  padding: 4px 8px;
+  border-radius: 4px;
+  border: 1px solid var(--border);
+  background: var(--bg);
+  color: var(--text-h);
+}
+
+.url-input {
+  width: 260px;
+}
+
+/* Body */
+
+.editor-body {
+  display: flex;
+  flex: 1;
+}
+
+/* File tree */
+
+.file-tree {
+  width: 250px;
+  flex-shrink: 0;
+  border-right: 1px solid var(--border);
+  padding: 16px;
+}
+
+.file-tree ul {
+  list-style: none;
+  padding: 0;
+  margin: 8px 0 0;
+  display: flex;
+  flex-direction: column;
+  gap: 3px;
+}
+
+.file-entry {
+  display: flex;
+  align-items: center;
+  gap: 7px;
+}
+
+.section-label {
+  font-size: 11px;
+  font-weight: 600;
+  text-transform: uppercase;
+  letter-spacing: 0.07em;
+  color: var(--text);
+}
+
+.count {
+  background: var(--accent-bg);
+  color: var(--accent);
+  border-radius: 10px;
+  padding: 1px 6px;
+  font-size: 10px;
+}
+
+.badge {
+  width: 15px;
+  height: 15px;
+  border-radius: 3px;
+  font-size: 9px;
+  font-weight: 700;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+
+.badge-m { background: rgba(234, 179, 8, 0.15); color: #a16207; }
+.badge-a { background: rgba(34, 197, 94, 0.15); color: #15803d; }
+.badge-d { background: rgba(239, 68, 68, 0.15); color: #b91c1c; }
+
+@media (prefers-color-scheme: dark) {
+  .badge-m { background: rgba(234, 179, 8, 0.2); color: #fbbf24; }
+  .badge-a { background: rgba(34, 197, 94, 0.2); color: #4ade80; }
+  .badge-d { background: rgba(239, 68, 68, 0.2); color: #f87171; }
+}
+
+.file-path {
+  font-size: 12px;
+  color: var(--text-h);
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+/* PR panel */
+
+.pr-panel {
+  flex: 1;
+  padding: 20px 28px;
+  display: flex;
+  flex-direction: column;
+  gap: 18px;
+  min-width: 0;
+}
+
+.form-grid {
+  display: grid;
+  grid-template-columns: 90px 1fr;
+  gap: 7px 10px;
+  align-items: center;
+  max-width: 560px;
+}
+
+.form-grid label {
+  font-size: 12px;
+  color: var(--text);
+  text-align: right;
+}
+
+.form-grid input,
+.form-grid textarea {
+  font-family: var(--mono);
+  font-size: 12px;
+  padding: 5px 8px;
+  border-radius: 4px;
+  border: 1px solid var(--border);
+  background: var(--bg);
+  color: var(--text-h);
+  resize: vertical;
+  width: 100%;
+  box-sizing: border-box;
+}
+
+.form-grid input:focus,
+.form-grid textarea:focus {
+  outline: 2px solid var(--accent);
+  outline-offset: -1px;
+  border-color: transparent;
+}
+
+/* Actions */
+
+.actions {
+  display: flex;
+  gap: 8px;
+}
+
+.actions button {
+  font-family: var(--mono);
+  font-size: 12px;
+  padding: 6px 13px;
+  border-radius: 5px;
+  border: 1px solid var(--border);
+  background: var(--social-bg);
+  color: var(--text-h);
+  cursor: pointer;
+  transition: background 0.15s;
+}
+
+.actions button:first-child {
+  background: var(--accent-bg);
+  border-color: var(--accent-border);
+  color: var(--accent);
+}
+
+.actions button:hover:not(:disabled) {
+  background: var(--code-bg);
+}
+
+.actions button:disabled {
+  opacity: 0.35;
+  cursor: not-allowed;
+}
+
+/* PR info */
+
+.pr-info {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 9px 13px;
+  background: var(--accent-bg);
+  border: 1px solid var(--accent-border);
+  border-radius: 5px;
+  max-width: 560px;
+}
+
+.pr-id {
+  font-size: 12px;
+  font-weight: 600;
+  color: var(--accent);
+  white-space: nowrap;
+}
+
+.pr-url {
+  font-size: 12px;
+  color: var(--accent);
+  text-decoration: none;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.pr-url:hover { text-decoration: underline; }
+
+/* Log */
+
+.log {
+  list-style: none;
+  padding: 0;
+  margin: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 3px;
+  max-width: 560px;
+}
+
+.log li {
+  font-size: 12px;
+  color: var(--text);
+  padding: 4px 10px;
+  background: var(--code-bg);
+  border-radius: 4px;
+  border-left: 2px solid var(--accent-border);
+}
