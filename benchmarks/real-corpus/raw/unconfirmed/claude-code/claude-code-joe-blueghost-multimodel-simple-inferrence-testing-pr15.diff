@@ -0,0 +1,161 @@
+import { useState } from 'react'
+import { ScmService } from './ScmService'
+import './App.css'
+
+const CHANGED_FILES = [
+  { status: 'M', path: 'src/remoteGitProvider.ts' },
+  { status: 'A', path: 'src/GitHubProviderAdapter.ts' },
+  { status: 'A', path: 'src/GitLabProviderAdapter.ts' },
+  { status: 'A', path: 'src/BitBucketProviderAdapter.ts' },
+  { status: 'A', path: 'src/ScmService.ts' },
+]
+
+const DEFAULT_URLS = {
+  github: 'https://github.com',
+  gitlab: 'https://gitlab.com',
+  bitbucket: 'https://bitbucket.org',
+}
+
+export default function App() {
+  const [provider, setProvider] = useState('github')
+  const [baseUrl, setBaseUrl] = useState(DEFAULT_URLS.github)
+  const [title, setTitle] = useState('feat: add SCM adapters')
+  const [description, setDescription] = useState('')
+  const [sourceBranch, setSourceBranch] = useState('feature/scm-adapters')
+  const [targetBranch, setTargetBranch] = useState('main')
+  const [repository, setRepository] = useState('my-org/my-repo')
+  const [pr, setPr] = useState(null)
+  const [log, setLog] = useState([])
+  const [busy, setBusy] = useState(false)
+
+  const addLog = (msg) => setLog((prev) => [msg, ...prev])
+  const service = () => new ScmService(provider, baseUrl)
+
+  const onProviderChange = (e) => {
+    const p = e.target.value
+    setProvider(p)
+    setBaseUrl(DEFAULT_URLS[p])
+    setPr(null)
+    setLog([])
+  }
+
+  const handleCreate = async () => {
+    setBusy(true)
+    const result = await service().createPullRequest({
+      title,
+      description,
+      sourceBranch,
+      targetBranch,
+      repository,
+    })
+    setPr(result)
+    addLog(`Created PR #${result.id} → ${result.url}`)
+    setBusy(false)
+  }
+
+  const handleMerge = async () => {
+    setBusy(true)
+    await service().mergePullRequest({ pullRequestId: pr.id, repository })
+    addLog(`Merged PR #${pr.id}`)
+    setBusy(false)
+  }
+
+  const handleMergability = async () => {
+    setBusy(true)
+    const result = await service().getPullRequestMergability(pr.id, repository)
+    addLog(`Mergability: ${result.status}${result.reason ? ` — ${result.reason}` : ''}`)
+    setBusy(false)
+  }
+
+  return (
+    <div className="editor">
+      <header className="editor-header">
+        <span className="editor-title">Git Changes Editor</span>
+        <div className="provider-row">
+          <label htmlFor="provider">Provider</label>
+          <select id="provider" value={provider} onChange={onProviderChange}>
+            <option value="github">GitHub</option>
+            <option value="gitlab">GitLab</option>
+            <option value="bitbucket">Bitbucket</option>
+          </select>
+          <input
+            className="url-input"
+            value={baseUrl}
+            onChange={(e) => setBaseUrl(e.target.value)}
+            aria-label="Base URL"
+          />
+        </div>
+      </header>
+
+      <div className="editor-body">
+        <aside className="file-tree">
+          <div className="section-label">
+            Changed <span className="count">{CHANGED_FILES.length}</span>
+          </div>
+          <ul>
+            {CHANGED_FILES.map((f) => (
+              <li key={f.path} className="file-entry">
+                <span className={`badge badge-${f.status.toLowerCase()}`}>{f.status}</span>
+                <span className="file-path">{f.path}</span>
+              </li>
+            ))}
+          </ul>
+        </aside>
+
+        <main className="pr-panel">
+          <div className="section-label">Pull Request</div>
+
+          <div className="form-grid">
+            <label>Title</label>
+            <input value={title} onChange={(e) => setTitle(e.target.value)} />
+
+            <label>Description</label>
+            <textarea
+              value={description}
+              onChange={(e) => setDescription(e.target.value)}
+              rows={2}
+            />
+
+            <label>Source</label>
+            <input value={sourceBranch} onChange={(e) => setSourceBranch(e.target.value)} />
+
+            <label>Target</label>
+            <input value={targetBranch} onChange={(e) => setTargetBranch(e.target.value)} />
+
+            <label>Repository</label>
+            <input value={repository} onChange={(e) => setRepository(e.target.value)} />
+          </div>
+
+          <div className="actions">
+            <button onClick={handleCreate} disabled={busy || !title}>
+              Create PR
+            </button>
+            <button onClick={handleMerge} disabled={busy || !pr}>
+              Merge PR
+            </button>
+            <button onClick={handleMergability} disabled={busy || !pr}>
+              Get Mergability
+            </button>
+          </div>
+
+          {pr && (
+            <div className="pr-info">
+              <span className="pr-id">PR #{pr.id}</span>
+              <a className="pr-url" href={pr.url} target="_blank" rel="noreferrer">
+                {pr.url}
+              </a>
+            </div>
+          )}
+
+          {log.length > 0 && (
+            <ul className="log">
+              {log.map((entry, i) => (
+                <li key={i}>{entry}</li>
+              ))}
+            </ul>
+          )}
+        </main>
+      </div>
+    </div>
+  )
+}
