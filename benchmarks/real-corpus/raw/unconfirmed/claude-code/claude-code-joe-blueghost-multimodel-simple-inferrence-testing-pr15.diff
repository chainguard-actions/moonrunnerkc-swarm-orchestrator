diff --git a/src/remoteGitProvider.ts b/src/remoteGitProvider.ts
new file mode 100644
index 0000000..fb51370
--- /dev/null
+++ b/src/remoteGitProvider.ts
@@ -0,0 +1,44 @@
+export interface PullRequestParams {
+  title: string;
+  description?: string;
+  sourceBranch: string;
+  targetBranch: string;
+  repository: string;
+}
+
+export interface PullRequest {
+  id: string | number;
+  title: string;
+  sourceBranch: string;
+  targetBranch: string;
+  url: string;
+}
+
+export type MergeStrategy = 'merge' | 'squash' | 'rebase';
+
+export interface MergeParams {
+  pullRequestId: string | number;
+  repository: string;
+  strategy?: MergeStrategy;
+}
+
+export type MergabilityStatus = 'mergeable' | 'conflicts' | 'pending' | 'unknown';
+
+export interface PullRequestMergability {
+  status: MergabilityStatus;
+  reason?: string;
+}
+
+/**
+ * Service for communicating with a remote Git provider.
+ * Implementations must accept a base URL for the remote host via their constructor.
+ */
+export interface RemoteGitProviderAdapter {
+  getBaseUrl(): string;
+  createPullRequest(params: PullRequestParams): Promise<PullRequest>;
+  mergePullRequest(params: MergeParams): Promise<void>;
+  getPullRequestMergability(
+    pullRequestId: string | number,
+    repository: string,
+  ): Promise<PullRequestMergability>;
+}
