-          email: targetData.email ?? '',
-          group: targetData.groupId ?? null,
-          classId: targetData.assignedTeamId ?? null,
-          phone: null,
-          isArchived: false,
-          role: 'student',
-          createdAt: new Date(),
-          updatedAt: new Date(),
-        });
