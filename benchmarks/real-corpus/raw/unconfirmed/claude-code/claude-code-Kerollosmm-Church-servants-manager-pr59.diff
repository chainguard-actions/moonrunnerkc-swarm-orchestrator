-    if (oldRole === 'servant' && newRole !== 'servant') {
-      tx.update(targetRef, {
-        assignedTeamIds: null,
-        assignedTeamId: null,
-        groupId: null,
-      });
-    }
-
-    if (oldRole !== 'servant' && newRole === 'servant') {
-      tx.update(targetRef, {
-        assignedTeamIds: [],
-      });
-    }
-
-    if (newRole === 'student') {
-      const studentDocRef = adminDb.collection(STUDENTS_COLLECTION).doc(targetUid);
