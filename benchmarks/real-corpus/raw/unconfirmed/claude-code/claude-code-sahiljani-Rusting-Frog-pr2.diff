+
+### Data flow
+
+```
+crawl-worker fetches URL
+  ├─► parser.rs extracts body text (existing)
+  │     └─► flesch::compute(text) → ReadabilityStats
+  │           └─► writes readability_score + bucket to crawl_urls row
+  └─► evaluators run
+        └─► content.rs reads readability_score, fires bucket filter keys
+              └─► findings table populated
+                    └─► API exposes readability fields + filter hits
+                          └─► UI shows score badge in Content tab
+                                └─► Playwright asserts score visible
+```
+
+### Algorithm (Rust)
+
+```rust
+// crates/evaluators/src/flesch.rs
+pub struct ReadabilityStats {
+    pub score: f64,         // 0.0 .. 100.0
+    pub bucket: ReadabilityBucket,
+    pub total_sentences: usize,
+    pub avg_words_per_sentence: f64,
+}
+
+pub fn compute(text: &str) -> Option<ReadabilityStats> {
+    let sentences = split_sentences(text);
+    if sentences.is_empty() { return None; }
+    let words: Vec<&str> = sentences.iter().flat_map(|s| split_words(s)).collect();
+    if words.is_empty() { return None; }
+    let syllables: usize = words.iter().map(|w| count_syllables(w)).sum();
+
+    let avg_sent_len = words.len() as f64 / sentences.len() as f64;
+    let avg_syll_per_word = syllables as f64 / words.len() as f64;
+    let raw = 206.835 - 1.015 * avg_sent_len - 84.6 * avg_syll_per_word;
+    let score = raw.clamp(0.0, 100.0);
+
+    Some(ReadabilityStats {
+        score,
+        bucket: bucket_of(score),
+        total_sentences: sentences.len(),
+        avg_words_per_sentence: avg_sent_len,
+    })
+}
+
+fn bucket_of(score: f64) -> ReadabilityBucket {
+    match score {
+        s if s < 30.0 => ReadabilityBucket::VeryHard,
+        s if s < 50.0 => ReadabilityBucket::Hard,
+        s if s < 60.0 => ReadabilityBucket::FairlyHard,
+        s if s < 70.0 => ReadabilityBucket::Normal,
+        s if s < 80.0 => ReadabilityBucket::FairlyEasy,
+        s if s < 90.0 => ReadabilityBucket::Easy,
+        _             => ReadabilityBucket::VeryEasy,
+    }
+}
+```
+
+`count_syllables` uses the standard vowel-group heuristic with silent-e adjustment. No external crate needed.
+
+### Edge cases
+
+- Empty text → `None` returned, no field updated
+- Single-sentence text → still computes (avg_sent_len = word_count)
+- Non-English text → still computes, but score has no meaning. Future: gate on `<html lang="en*">`. Out of scope for 2.1.
+- Pages with code blocks / tables → those are text too; SF doesn't strip them, neither do we
+
