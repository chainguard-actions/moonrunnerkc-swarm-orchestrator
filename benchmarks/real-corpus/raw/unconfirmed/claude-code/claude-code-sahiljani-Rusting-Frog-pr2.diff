+```typescript
+import { APIRequestContext, expect } from '@playwright/test';
+
+export interface CreatedCrawl {
+  projectId: string;
+  crawlId: string;
+}
+
+export async function createProjectAndCrawl(
+  api: APIRequestContext,
+  token: string,
+  opts: { name: string; seedUrl: string; maxPages: number },
+): Promise<CreatedCrawl> {
+  const auth = { headers: { Authorization: `Bearer ${token}` } };
+
+  const proj = await api.post('/v1/projects', {
+    ...auth,
+    data: {
+      name: opts.name,
+      config: { max_pages: opts.maxPages, crawl: { obey_robots: true } },
+    },
+  });
+  expect(proj.ok(), `project create: ${await proj.text()}`).toBeTruthy();
+  const projectId = (await proj.json()).id as string;
+
+  const crawl = await api.post(`/v1/crawls`, {
+    ...auth,
+    data: { project_id: projectId, seed_urls: [opts.seedUrl] },
+  });
+  expect(crawl.ok(), `crawl create: ${await crawl.text()}`).toBeTruthy();
+  const crawlId = (await crawl.json()).id as string;
+
+  return { projectId, crawlId };
+}
+
+export async function pollCrawlCompleted(
+  api: APIRequestContext,
+  token: string,
+  crawlId: string,
+  opts: { timeoutMs: number; pollIntervalMs?: number } = { timeoutMs: 5 * 60_000 },
+): Promise<void> {
+  const auth = { headers: { Authorization: `Bearer ${token}` } };
+  const poll = opts.pollIntervalMs ?? 5_000;
+  const deadline = Date.now() + opts.timeoutMs;
+
+  while (Date.now() < deadline) {
+    const res = await api.get(`/v1/crawls/${crawlId}`, auth);
+    expect(res.ok(), `poll: ${await res.text()}`).toBeTruthy();
+    const status = (await res.json()).status as string;
+    if (status === 'completed') return;
+    if (status === 'failed') throw new Error(`crawl ${crawlId} failed`);
+    await new Promise((r) => setTimeout(r, poll));
+  }
+  throw new Error(`crawl ${crawlId} did not complete within ${opts.timeoutMs}ms`);
+}
+
+export async function firstUrlMatching(
+  api: APIRequestContext,
+  token: string,
+  crawlId: string,
+  needle: string,
+): Promise<{ id: string; url: string; readability_score: number | null; readability_bucket: string | null }> {
+  const auth = { headers: { Authorization: `Bearer ${token}` } };
+  const res = await api.get(`/v1/crawls/${crawlId}/urls?q=${encodeURIComponent(needle)}&limit=10`, auth);
+  expect(res.ok()).toBeTruthy();
+  const rows = (await res.json()).data as Array<any>;
+  if (rows.length === 0) throw new Error(`no URL matched ${needle}`);
+  return rows[0];
+}
+```
