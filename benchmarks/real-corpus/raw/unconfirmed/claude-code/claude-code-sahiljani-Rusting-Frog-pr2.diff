+import { Page, APIRequestContext, request } from '@playwright/test';
+
+export async function mintDevToken(api: APIRequestContext): Promise<string> {
+  // Endpoint matches crates/api/src/routes/dev.rs (SF_DEV_MODE=1)
+  const res = await api.post('/v1/dev/token', { data: {} });
+  if (!res.ok()) {
+    throw new Error(`dev token mint failed: ${res.status()} ${await res.text()}`);
+  }
+  const body = await res.json();
+  return body.token as string;
+}
+
+/**
+ * Seed localStorage with the dev token so the UI's authedFetch finds it.
+ * Mirrors the storage keys defined in UI/src/api.ts.
+ */
+export async function primeAuth(page: Page, token: string): Promise<void> {
+  const exp = Math.floor(Date.now() / 1000) + 60 * 60; // 1h
+  await page.addInitScript(
+    ({ token, exp }) => {
+      localStorage.setItem('sf-clone.jwt', token);
+      localStorage.setItem('sf-clone.jwt.exp', String(exp));
+    },
+    { token, exp },
+  );
+}
+```
