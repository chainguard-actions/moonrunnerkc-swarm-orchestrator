+        path: '/v1/messages/count_tokens?beta=true',
+        method: 'post',
+        headers: { 'anthropic-beta': 'effort-2025-11-24' },
+        body: { model: 'claude-haiku-4-5', messages: [] },
+      } as FinalRequestOptions);
