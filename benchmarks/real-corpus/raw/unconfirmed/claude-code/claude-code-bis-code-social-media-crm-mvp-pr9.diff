+export function suggestedTaskProgress(piece: Piece, stage: StageId): { done: number; total: number } {
+  const tasks = piece.tasksByStage[stage].filter((t) => t.suggestedKey);
+  return { done: tasks.filter((t) => getEffectiveTaskStatus(piece, t) === 'done').length, total: tasks.length };
+}
