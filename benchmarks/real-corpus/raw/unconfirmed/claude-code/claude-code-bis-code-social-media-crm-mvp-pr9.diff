diff --git a/src/data/workspace-invites-store.ts b/src/data/workspace-invites-store.ts
--- /dev/null
+++ b/src/data/workspace-invites-store.ts
@@ -0,0 +1,178 @@
+// Workspace invites store — persists workspace invitations in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+//
+// Real email delivery is deferred to the backend brainstorm.
+// Invites surface as in-app tokens (copyable URL) for now.
+
+import { useEffect, useState } from 'react';
+import type { WorkspaceInvite, Role } from '../types/saas';
+import { createAccountWorkspace } from './account-workspaces-store';
+import { getAccount } from './account-store';
+
+const KEY = 'workspace-invites-store:v1';
+
+interface WorkspaceInvitesState {
+  invites: WorkspaceInvite[];
+}
+
+const EMPTY: WorkspaceInvitesState = { invites: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let invitesCache: WorkspaceInvitesState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadInvitesState(): WorkspaceInvitesState {
+  if (invitesCache !== null) return invitesCache;
+  if (typeof localStorage === 'undefined') {
+    invitesCache = { ...EMPTY };
+    return invitesCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    invitesCache = { ...EMPTY };
+    return invitesCache;
+  }
+  try {
+    invitesCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<WorkspaceInvitesState>) };
+    return invitesCache;
+  } catch {
+    invitesCache = { ...EMPTY };
+    return invitesCache;
+  }
+}
+
+function saveInvitesState(next: WorkspaceInvitesState): void {
+  invitesCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    invitesCache = null;
+    console.warn('[workspace-invites-store] localStorage write failed:', err);
+  }
+}
+
+function mutateInvitesState(
+  fn: (current: WorkspaceInvitesState) => WorkspaceInvitesState,
+): WorkspaceInvitesState {
+  const current = loadInvitesState();
+  const next = fn(current);
+  saveInvitesState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+function genToken(): string {
+  // Uses the Web Crypto API — cryptographically secure in all modern browsers.
+  return 'inv-' + crypto.randomUUID();
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+/**
+ * Create a workspace invite. Returns the generated invite token.
+ * clientId must be set when invitedRole === 'Sponsor'.
+ */
+export function createInvite(
+  workspaceId: string,
+  invitedEmail: string,
+  invitedRole: Role,
+  clientId: string | undefined,
+  invitedByAccountId: string,
+): string {
+  const token = genToken();
+  const invite: WorkspaceInvite = {
+    id: genId('invite'),
+    workspaceId,
+    invitedEmail: invitedEmail.trim().toLowerCase(),
+    invitedRole,
+    ...(clientId ? { clientId } : {}),
+    invitedByAccountId,
+    status: 'pending',
+    token,
+    createdAt: Date.now(),
+  };
+  mutateInvitesState((s) => ({ ...s, invites: [...s.invites, invite] }));
+  return token;
+}
+
+/**
+ * Accept a pending invite. Creates an AccountWorkspace for the accepting account.
+ * Returns the created AccountWorkspace id, or null if the token is invalid/expired
+ * or the accepting account's email does not match the invited email.
+ *
+ * The status transition and the email ownership check are performed atomically
+ * inside a single mutateInvitesState call to prevent TOCTOU races where two
+ * concurrent accepts could both pass the pending check and create duplicate AWs.
+ */
+export function acceptInvite(token: string, accountId: string): WorkspaceInvite | null {
+  // Load the accepting account to compare email — invite ownership gate
+  const account = getAccount(accountId);
+  if (!account) return null;
+
+  // Use an array so TypeScript doesn't narrow the mutable variable to `never`
+  // inside the closure (TS control-flow analysis would otherwise treat the
+  // initial `null` assignment as the only possible value at the call-site).
+  const claimed: WorkspaceInvite[] = [];
+  mutateInvitesState((s) => {
+    const invite = s.invites.find(
+      (i) => i.token === token && i.status === 'pending',
+    );
+    if (!invite) return s;
+    // Email ownership check: case-insensitive compare
+    if (invite.invitedEmail.toLowerCase() !== account.email.toLowerCase()) {
+      return s; // no claim — invite is for a different email
+    }
+    claimed.push(invite);
+    return {
+      ...s,
+      invites: s.invites.map((i) =>
+        i.id === invite.id ? { ...i, status: 'accepted' } : i,
+      ),
+    };
+  });
+  const claimedInvite = claimed[0] ?? null;
+  if (!claimedInvite) return null;
+  // Now safely create the AW; the invite is already marked accepted atomically
+  createAccountWorkspace(accountId, claimedInvite.workspaceId, claimedInvite.invitedRole, claimedInvite.clientId);
+  return claimedInvite;
+}
+
+export function revokeInvite(id: string): void {
+  mutateInvitesState((s) => ({
+    ...s,
+    invites: s.invites.map((i) => (i.id === id ? { ...i, status: 'revoked' } : i)),
+  }));
+}
+
+export function listPendingInvites(workspaceId: string): WorkspaceInvite[] {
+  return loadInvitesState().invites.filter(
+    (i) => i.workspaceId === workspaceId && i.status === 'pending',
+  );
+}
+
+export function getInviteByToken(token: string): WorkspaceInvite | null {
+  return loadInvitesState().invites.find((i) => i.token === token) ?? null;
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useWorkspaceInvitesStore(): WorkspaceInvitesState {
+  const [snapshot, setSnapshot] = useState<WorkspaceInvitesState>(() => loadInvitesState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadInvitesState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
