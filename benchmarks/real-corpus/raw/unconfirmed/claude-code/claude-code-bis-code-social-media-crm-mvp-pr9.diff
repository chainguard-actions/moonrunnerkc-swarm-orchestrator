--- /dev/null
+++ b/src/data/share-tokens-store.ts
@@ -0,0 +1,133 @@
+// Share tokens store — persists client recap/billing share tokens in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+//
+// Tokens are cryptographically random UUIDs prefixed with the type ('recap-' or 'bill-').
+// Default expiry is 30 days from creation if expiresAt is not provided.
+
+import { useEffect, useState } from 'react';
+import type { ShareToken } from '../types/saas';
+
+const KEY = 'share-tokens-store:v1';
+const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
+
+interface ShareTokensState {
+  tokens: ShareToken[];
+}
+
+const EMPTY: ShareTokensState = { tokens: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let tokenCache: ShareTokensState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadTokensState(): ShareTokensState {
+  if (tokenCache !== null) return tokenCache;
+  if (typeof localStorage === 'undefined') {
+    tokenCache = { ...EMPTY };
+    return tokenCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    tokenCache = { ...EMPTY };
+    return tokenCache;
+  }
+  try {
+    tokenCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<ShareTokensState>) };
+    return tokenCache;
+  } catch {
+    tokenCache = { ...EMPTY };
+    return tokenCache;
+  }
+}
+
+function saveTokensState(next: ShareTokensState): void {
+  tokenCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    tokenCache = null;
+    console.warn('[share-tokens-store] localStorage write failed:', err);
+  }
+}
+
+function mutateTokensState(
+  fn: (current: ShareTokensState) => ShareTokensState,
+): ShareTokensState {
+  const current = loadTokensState();
+  const next = fn(current);
+  saveTokensState(next);
+  return next;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+/**
+ * Create a share token for a client.
+ * Token is prefixed 'recap-' or 'bill-' depending on type.
+ * Defaults to a 30-day expiry if expiresAt is not provided.
+ */
+export function createShareToken(
+  type: 'recap' | 'billing',
+  clientId: string,
+  expiresAt?: number,
+): ShareToken {
+  const prefix = type === 'recap' ? 'recap-' : 'bill-';
+  const shareToken: ShareToken = {
+    token: prefix + crypto.randomUUID(),
+    type,
+    clientId,
+    expiresAt: expiresAt ?? Date.now() + THIRTY_DAYS_MS,
+  };
+  mutateTokensState((s) => ({ ...s, tokens: [...s.tokens, shareToken] }));
+  return shareToken;
+}
+
+/**
+ * Find a share token by its token string.
+ * Returns null if not found, revoked (no expiresAt? still valid), or expired.
+ */
+export function findShareToken(token: string): ShareToken | null {
+  const found = loadTokensState().tokens.find((t) => t.token === token);
+  if (!found) return null;
+  // Check expiry
+  if (found.expiresAt !== undefined && found.expiresAt < Date.now()) return null;
+  return found;
+}
+
+/**
+ * Revoke (delete) a share token by its token string.
+ */
+export function revokeShareToken(token: string): void {
+  mutateTokensState((s) => ({
+    ...s,
+    tokens: s.tokens.filter((t) => t.token !== token),
+  }));
+}
+
+/**
+ * List all share tokens for a given client (including expired ones — let the UI
+ * decide whether to show them).
+ */
+export function listShareTokensForClient(clientId: string): ShareToken[] {
+  return loadTokensState().tokens.filter((t) => t.clientId === clientId);
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useShareTokensStore(): ShareTokensState {
+  const [snapshot, setSnapshot] = useState<ShareTokensState>(() => loadTokensState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadTokensState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
