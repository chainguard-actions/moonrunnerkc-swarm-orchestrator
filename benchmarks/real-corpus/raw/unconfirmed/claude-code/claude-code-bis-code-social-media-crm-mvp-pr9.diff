+++ b/src/components/production/HoursSpentField.tsx
@@ -0,0 +1,58 @@
+import { setStageHours } from '../../data/production-store';
+import type { Piece, StageId } from '../../types/production';
+import { STAGE_LABEL } from '../../types/production';
+
+/**
+ * HoursSpentField — inline label + number input recording hours spent on a
+ * given pipeline stage. Piece-level metadata, NOT a task — renders without
+ * card chrome so it doesn't visually merge with the LEFT panel's FieldCards.
+ *
+ * Designed to sit in a thin strip right under the StageTabs row.
+ */
+export function HoursSpentField({ piece, stage }: { piece: Piece; stage: StageId }) {
+  const stored = piece.hoursPerStage?.[stage];
+  const displayValue = stored !== undefined ? String(stored) : '';
+
+  return (
+    <div
+      style={{
+        display: 'inline-flex',
+        alignItems: 'center',
+        gap: 8,
+        fontSize: 12,
+        color: 'var(--muted)',
+      }}
+    >
+      <span>Time spent on {STAGE_LABEL[stage]}</span>
+      <input
+        type="number"
+        min={0}
+        step={0.25}
+        placeholder="0"
+        value={displayValue}
+        onChange={(e) => {
+          const raw = e.target.value;
+          if (raw === '') {
+            setStageHours(piece.id, stage, undefined);
+          } else {
+            const parsed = parseFloat(raw);
+            if (!Number.isNaN(parsed) && parsed >= 0) {
+              setStageHours(piece.id, stage, parsed);
+            }
+          }
+        }}
+        style={{
+          width: 70,
+          padding: '4px 8px',
+          border: '1px solid var(--line)',
+          borderRadius: 6,
+          fontSize: 12,
+          background: 'transparent',
+          color: 'var(--ink)',
+        }}
+        aria-label={`Hours spent on ${STAGE_LABEL[stage]}`}
+      />
+      <span>h</span>
+    </div>
+  );
+}
