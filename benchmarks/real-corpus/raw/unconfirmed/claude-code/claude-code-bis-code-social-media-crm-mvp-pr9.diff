+## Task 1: Jurisdiction registry module
+
+**Files:**
+- Create: `src/data/jurisdictions.ts`
+
+- [ ] **Step 1: Create the registry module**
+
+```ts
+// src/data/jurisdictions.ts
+// Jurisdiction = a workspace's operating country/market. Orthogonal to the
+// per-user UI language. Set once at onboarding, immutable thereafter.
+// Adding a country = adding one entry here + its feature configs.
+import type { Workspace } from '../types/saas';
+import type { Language } from './user-prefs-store';
+
+export type Jurisdiction = 'SA' | 'INTL'; // extensible: 'GB' | 'AE' | 'US' later
+
+export interface JurisdictionConfig {
+  code: Jurisdiction;
+  label: { en: string; ar: string };
+  defaultCurrency: 'SAR' | 'USD' | 'EUR';
+  defaultVatRate: number; // decimal, e.g. 0.15
+  suggestedLanguage: Language; // a hint seeded once at onboarding — never a lock
+  taxIdLabel: { en: string; ar: string };
+  features: { zatca: boolean };
+}
+
+export const JURISDICTIONS: Record<Jurisdiction, JurisdictionConfig> = {
+  SA: {
+    code: 'SA',
+    label: { en: 'Saudi Arabia', ar: 'المملكة العربية السعودية' },
+    defaultCurrency: 'SAR',
+    defaultVatRate: 0.15,
+    suggestedLanguage: 'ar',
+    taxIdLabel: { en: 'VAT number', ar: 'الرقم الضريبي' },
+    features: { zatca: true },
+  },
+  INTL: {
+    code: 'INTL',
+    label: { en: 'International', ar: 'دولي' },
+    defaultCurrency: 'USD',
+    defaultVatRate: 0,
+    suggestedLanguage: 'en',
+    taxIdLabel: { en: 'Tax ID', ar: 'الرقم الضريبي' },
+    features: { zatca: false },
+  },
+};
+
+/** The config for a workspace, falling back to INTL for records that predate
+ *  the jurisdiction field (defensive — the v2 migration backfills these). */
+export function jurisdictionOf(ws: Pick<Workspace, 'jurisdiction'> | null | undefined): JurisdictionConfig {
+  const code = ws?.jurisdiction;
+  return (code && JURISDICTIONS[code]) || JURISDICTIONS.INTL;
+}
+
+export function hasFeature(
+  ws: Pick<Workspace, 'jurisdiction'> | null | undefined,
+  feature: keyof JurisdictionConfig['features'],
+): boolean {
+  return jurisdictionOf(ws).features[feature];
+}
+```
+
+> Note: this references `Workspace.jurisdiction`, which Task 3 adds. Implement Task 1 and Task 3 before running `tsc`; commit Task 1 without a build gate (it is consumed starting in Task 3). Alternatively reorder locally — but the code is correct as written once Task 3 lands.
+
