+      {/* Platforms picker — always visible regardless of active stage */}
+      <div style={{ display: 'flex', alignItems: 'center', gap: 10, padding: '0 0 4px', marginTop: 8 }}>
+        <span style={{ fontSize: 11, fontWeight: 600, color: 'var(--muted)', textTransform: 'uppercase', letterSpacing: 0.4, flexShrink: 0 }}>
+          Platforms
+        </span>
+        <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap', flex: 1 }}>
+          {(Object.keys(PLATFORM_LABEL) as Platform[]).map((p) => {
+            const active = piece.stageData.brainstorm.platforms.includes(p);
+            return (
+              <button
+                key={p}
+                onClick={() =>
+                  setBrainstormPlatforms(
+                    piece.id,
+                    active
+                      ? piece.stageData.brainstorm.platforms.filter((x) => x !== p)
+                      : [...piece.stageData.brainstorm.platforms, p],
+                  )
+                }
+                style={{
+                  padding: isMobile ? '7px 10px' : '3px 10px',
+                  fontSize: 12,
+                  borderRadius: 999,
+                  border: '1px solid ' + (active ? 'var(--ink)' : 'var(--line)'),
+                  background: active ? 'var(--ink)' : 'transparent',
+                  color: active ? '#fff' : 'var(--ink)',
+                  cursor: 'pointer',
+                  fontWeight: active ? 600 : 400,
+                  transition: 'all 120ms',
+                }}
+              >
+                {PLATFORM_LABEL[p]}
+              </button>
+            );
+          })}
+        </div>
+        <TotalHours piece={piece} />
+      </div>
+      <div style={{ marginTop: 12 }}>
+        <StageTabs piece={piece} active={shownStage} onSelect={setActiveStage} />
+      </div>
+      {/* Thin strip — per-stage hours-spent metadata, NOT a task.
+          Rendered between the stage tabs and the LEFT/RIGHT panels so it's
+          visually separated from the FieldCards in the LEFT panel. */}
+      <div style={{ marginTop: 10, display: 'flex', justifyContent: 'flex-end' }}>
+        <HoursSpentField piece={piece} stage={shownStage} />
+      </div>
+      <div style={{ marginTop: 12, flex: 1, minHeight: 0, overflowY: 'auto' }}>
+        <StageBody piece={piece} stage={shownStage} />
+      </div>
+      {advanceOpen && nextStage && (
+        <AdvanceModal
+          piece={piece}
+          nextStage={nextStage}
+          incompleteTasks={incompleteSuggested}
+          onConfirm={handleConfirmAdvance}
+          onCancel={() => setAdvanceOpen(false)}
+        />
+      )}
+    </div>
+  );
+}
+
+function TotalHours({ piece }: { piece: Piece }) {
+  const total = Object.values(piece.hoursPerStage ?? {}).reduce(
+    (sum, n) => sum + (n ?? 0),
+    0,
+  );
+  if (total <= 0) return null;
+  return (
+    <span
+      style={{
+        fontSize: 12,
+        color: 'var(--muted)',
+        whiteSpace: 'nowrap',
+        flexShrink: 0,
+      }}
+    >
+      Total: {total}h
+    </span>
+  );
+}
+
+function StageBody({ piece, stage }: { piece: Piece; stage: StageId }) {
+  switch (stage) {
+    case 'brainstorm':
+      return <StageBrainstorm piece={piece} />;
+    case 'preproduction':
+      return <StagePreProduction piece={piece} />;
+    case 'production':
+      return <StageProduction piece={piece} />;
+    case 'postproduction':
+      return <StagePostProduction piece={piece} />;
+    case 'publish':
+      return <StagePublish piece={piece} />;
+    default:
+      return (
+        <div style={{ color: 'var(--muted)', fontSize: 13 }}>
+          <strong>{STAGE_LABEL[stage]}</strong> content coming in the next task.
+        </div>
+      );
+  }
+}
