diff --git a/src/settings/RoleSwitcherDevTool.tsx b/src/settings/RoleSwitcherDevTool.tsx
--- /dev/null
+++ b/src/settings/RoleSwitcherDevTool.tsx
@@ -0,0 +1,168 @@
+// RoleSwitcherDevTool — DEV ONLY affordance inside Settings → Dev tools.
+//
+// Visibility is controlled by the DEV_TOOLS_ENABLED boolean flag in
+// Settings.tsx — NOT by role/permission. This is deliberate: gating it on
+// MANAGE_USERS made the panel disappear the instant you fake-switched to a
+// non-Administrator role, leaving no way to switch back.
+// Lets a demo user fake-switch role for demoing different role views without
+// going through the full invite ceremony for each test account.
+//
+// NOTE: This component will be REMOVED when real backend auth lands.
+// The _devSetCurrentAWRole action it calls violates the immutable-role invariant
+// intentionally; it is only safe in a localStorage-only demo build.
+
+import { useState } from 'react';
+import { useSession } from '../data/session-store';
+import { _devSetCurrentAWRole, getAccountWorkspace } from '../data/account-workspaces-store';
+import { toast } from '../components/ToastHost';
+import type { Role } from '../types/saas';
+
+const SAAS_ROLES: Role[] = [
+  'Administrator',
+  'PM',
+  'Production',
+  'Marketing',
+  'Creator',
+  'Sponsor',
+];
+
+export function RoleSwitcherDevTool() {
+  const session = useSession();
+  return <RoleSwitcherInner session={session} />;
+}
+
+interface InnerProps {
+  session: { currentAccountWorkspaceId: string | null };
+}
+
+function RoleSwitcherInner({ session }: InnerProps) {
+  const currentAW = session.currentAccountWorkspaceId
+    ? getAccountWorkspace(session.currentAccountWorkspaceId)
+    : null;
+
+  const [selectedRole, setSelectedRole] = useState<Role>(
+    (currentAW?.role as Role) ?? 'Administrator',
+  );
+
+  if (!currentAW) {
+    return (
+      <div style={{ fontSize: 13, color: 'var(--ink-3)' }}>
+        No active workspace session.
+      </div>
+    );
+  }
+
+  function handleSwitch() {
+    if (!currentAW) return;
+    _devSetCurrentAWRole(currentAW.id, selectedRole);
+    toast({
+      message: `[Dev] Role switched to ${selectedRole}`,
+      kind: 'info',
+      detail: 'This is a dev-only shortcut. Role is normally immutable.',
+    });
+  }
+
+  return (
+    <div style={{ display: 'flex', flexDirection: 'column', gap: 16, maxWidth: 400 }}>
+      {/* Warning banner */}
+      <div
+        style={{
+          padding: '10px 14px',
+          borderRadius: 8,
+          background: '#fff7ed',
+          border: '1px solid #fed7aa',
+          fontSize: 12,
+          color: '#9a3412',
+          lineHeight: 1.5,
+        }}
+      >
+        <strong>Dev tool only.</strong> This bypasses the immutable-role invariant
+        for demo purposes. Will be removed when real backend auth lands.
+      </div>
+
+      <div>
+        <div
+          style={{
+            fontSize: 11,
+            fontWeight: 600,
+            letterSpacing: '0.08em',
+            textTransform: 'uppercase',
+            color: 'var(--ink-3)',
+            marginBottom: 6,
+          }}
+        >
+          Current role
+        </div>
+        <span
+          style={{
+            fontSize: 12,
+            fontWeight: 700,
+            padding: '3px 10px',
+            borderRadius: 99,
+            background: 'var(--green-soft, #dcfce7)',
+            color: 'var(--green, #16a34a)',
+          }}
+        >
+          {currentAW.role}
+        </span>
+      </div>
+
+      <div>
+        <div
+          style={{
+            fontSize: 11,
+            fontWeight: 600,
+            letterSpacing: '0.08em',
+            textTransform: 'uppercase',
+            color: 'var(--ink-3)',
+            marginBottom: 6,
+          }}
+        >
+          Switch to
+        </div>
+        <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
+          {SAAS_ROLES.map((role) => (
+            <button
+              key={role}
+              type="button"
+              onClick={() => setSelectedRole(role)}
+              style={{
+                padding: '5px 12px',
+                borderRadius: 99,
+                fontSize: 12,
+                fontWeight: 600,
+                border: selectedRole === role ? '2px solid var(--green)' : '1px solid var(--line)',
+                background: selectedRole === role ? 'var(--green-soft, #dcfce7)' : 'var(--surface)',
+                color: selectedRole === role ? 'var(--green, #16a34a)' : 'var(--ink-2)',
+                cursor: 'pointer',
+                transition: 'all 0.1s',
+              }}
+            >
+              {role}
+            </button>
+          ))}
+        </div>
+      </div>
+
+      <div>
+        <button
+          type="button"
+          onClick={handleSwitch}
+          disabled={selectedRole === currentAW.role}
+          style={{
+            padding: '8px 20px',
+            borderRadius: 8,
+            fontSize: 13,
+            fontWeight: 600,
+            background: selectedRole === currentAW.role ? 'var(--surface-2)' : 'var(--green)',
+            color: selectedRole === currentAW.role ? 'var(--ink-3)' : '#fff',
+            border: 'none',
+            cursor: selectedRole === currentAW.role ? 'default' : 'pointer',
+          }}
+        >
+          Switch role
+        </button>
+      </div>
+    </div>
+  );
+}
diff --git a/src/settings/TeamRolesSection.tsx b/src/settings/TeamRolesSection.tsx
--- /dev/null
+++ b/src/settings/TeamRolesSection.tsx
@@ -0,0 +1,342 @@
+// TeamRolesSection — Settings → Team & Roles tab.
+//
+// Lists all AccountWorkspaces for the current workspace grouped by account
+// (a single account with 2+ AWs on this workspace appears as one row with
+// multiple role badges). Shows pending invites below the accepted members.
+//
+// Visible only to users with MANAGE_USERS capability (effectively Administrator-
+// only per the permission matrix).
+
+import { useState } from 'react';
+import { useSession } from '../data/session-store';
+import { getAccountWorkspace, listAccountWorkspacesForWorkspace, revokeAccountWorkspace, useAccountWorkspacesStore } from '../data/account-workspaces-store';
+import { getAccount } from '../data/account-store';
+import { listPendingInvites, revokeInvite, useWorkspaceInvitesStore } from '../data/workspace-invites-store';
+import { WorkspaceInviteModal } from './WorkspaceInviteModal';
+import type { AccountWorkspace } from '../types/saas';
+
+const ROLE_COLOR: Record<string, string> = {
+  Administrator: 'var(--green)',
+  PM: '#7c6af7',
+  Production: '#e88c30',
+  Marketing: '#e84393',
+  Creator: '#1a9cd0',
+  Sponsor: '#8b5cf6',
+};
+
+function RoleBadge({ role }: { role: string }) {
+  const color = ROLE_COLOR[role] ?? 'var(--ink-3)';
+  return (
+    <span
+      style={{
+        display: 'inline-block',
+        padding: '2px 8px',
+        borderRadius: 4,
+        fontSize: 11,
+        fontWeight: 600,
+        background: color + '22',
+        color,
+        border: `1px solid ${color}44`,
+      }}
+    >
+      {role}
+    </span>
+  );
+}
+
+function formatDate(ts: number): string {
+  return new Date(ts).toLocaleDateString('en-US', {
+    year: 'numeric',
+    month: 'short',
+    day: 'numeric',
+  });
+}
+
+export function TeamRolesSection() {
+  const session = useSession();
+  // Subscribe to store changes so revoke/invite updates re-render this component.
+  useAccountWorkspacesStore();
+  useWorkspaceInvitesStore();
+
+  const [inviteOpen, setInviteOpen] = useState(false);
+
+  const currentAW = session.currentAccountWorkspaceId
+    ? getAccountWorkspace(session.currentAccountWorkspaceId)
+    : null;
+  const workspaceId = currentAW?.workspaceId ?? null;
+
+  if (!workspaceId) {
+    return (
+      <div style={{ color: 'var(--ink-3)', fontSize: 13 }}>
+        No active workspace selected.
+      </div>
+    );
+  }
+
+  const allAWs = listAccountWorkspacesForWorkspace(workspaceId);
+  const pendingInvites = listPendingInvites(workspaceId);
+
+  // Group AWs by accountId — one account may hold multiple AWs (multi-hat).
+  const byAccount = new Map<string, AccountWorkspace[]>();
+  for (const aw of allAWs) {
+    const existing = byAccount.get(aw.accountId) ?? [];
+    existing.push(aw);
+    byAccount.set(aw.accountId, existing);
+  }
+
+  function handleRevoke(awId: string) {
+    if (!window.confirm('Revoke this membership? The account will lose access immediately.')) return;
+    revokeAccountWorkspace(awId);
+  }
+
+  const isCurrentAW = (awId: string) => awId === session.currentAccountWorkspaceId;
+
+  return (
+    <div
+      style={{
+        display: 'flex',
+        flexDirection: 'column',
+        gap: 20,
+      }}
+    >
+      {/* Header */}
+      <div
+        style={{
+          display: 'flex',
+          alignItems: 'center',
+          justifyContent: 'space-between',
+        }}
+      >
+        <div>
+          <div
+            style={{
+              fontSize: 11,
+              fontWeight: 600,
+              letterSpacing: '0.08em',
+              textTransform: 'uppercase',
+              color: 'var(--ink-3)',
+              marginBottom: 2,
+            }}
+          >
+            Team & Roles
+          </div>
+          <div style={{ fontSize: 14, fontWeight: 600, color: 'var(--ink)' }}>
+            {allAWs.length} member{allAWs.length !== 1 ? 's' : ''}{pendingInvites.length > 0 ? ` · ${pendingInvites.length} invite${pendingInvites.length !== 1 ? 's' : ''} pending` : ''}
+          </div>
+        </div>
+        <button
+          onClick={() => setInviteOpen(true)}
+          style={{
+            display: 'flex',
+            alignItems: 'center',
+            gap: 6,
+            padding: '8px 14px',
+            background: 'var(--green)',
+            color: '#fff',
+            border: 'none',
+            borderRadius: 8,
+            fontSize: 13,
+            fontWeight: 600,
+            cursor: 'pointer',
+          }}
+        >
+          + Invite member
+        </button>
+      </div>
+
+      {/* Members table */}
+      <div
+        style={{
+          border: '1px solid var(--line)',
+          borderRadius: 8,
+          overflow: 'hidden',
+        }}
+      >
+        {/* Horizontal-scroll wrapper so the Actions column doesn't push the
+            page off-screen on narrow viewports. Cycle 2 finding C2-W-6. */}
+        <div style={{ overflowX: 'auto', WebkitOverflowScrolling: 'touch' }}>
+        <table
+          style={{
+            width: '100%',
+            borderCollapse: 'collapse',
+            fontSize: 13,
+          }}
+        >
+          <thead>
+            <tr
+              style={{
+                background: 'var(--surface-2, var(--surface))',
+                borderBottom: '1px solid var(--line)',
+              }}
+            >
+              <th style={{ padding: '10px 16px', textAlign: 'left', fontWeight: 600, color: 'var(--ink-2)', fontSize: 11 }}>Account</th>
+              <th style={{ padding: '10px 16px', textAlign: 'left', fontWeight: 600, color: 'var(--ink-2)', fontSize: 11 }}>Role(s)</th>
+              <th style={{ padding: '10px 16px', textAlign: 'left', fontWeight: 600, color: 'var(--ink-2)', fontSize: 11 }}>Joined</th>
+              <th style={{ padding: '10px 16px', textAlign: 'left', fontWeight: 600, color: 'var(--ink-2)', fontSize: 11 }}>Actions</th>
+            </tr>
+          </thead>
+          <tbody>
+            {Array.from(byAccount.entries()).map(([accountId, aws]) => {
+              const account = getAccount(accountId);
+              const displayName = account?.name ?? 'Unknown';
+              const displayEmail = account?.email ?? accountId;
+              const earliestAW = [...aws].sort((a, b) => a.createdAt - b.createdAt)[0];
+
+              return (
+                <tr
+                  key={accountId}
+                  style={{ borderBottom: '1px solid var(--line)' }}
+                >
+                  <td style={{ padding: '12px 16px' }}>
+                    <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
+                      <div
+                        style={{
+                          width: 32,
+                          height: 32,
+                          borderRadius: '50%',
+                          background: 'var(--green)',
+                          color: '#fff',
+                          display: 'flex',
+                          alignItems: 'center',
+                          justifyContent: 'center',
+                          fontSize: 12,
+                          fontWeight: 600,
+                          flexShrink: 0,
+                        }}
+                      >
+                        {displayName.split(' ').map((x) => x[0]).slice(0, 2).join('')}
+                      </div>
+                      <div>
+                        <div style={{ fontWeight: 500, color: 'var(--ink)' }}>{displayName}</div>
+                        <div style={{ fontSize: 11, color: 'var(--ink-3)' }}>{displayEmail}</div>
+                      </div>
+                    </div>
+                  </td>
+                  <td style={{ padding: '12px 16px' }}>
+                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: 4 }}>
+                      {aws.map((aw) => (
+                        <RoleBadge key={aw.id} role={aw.role} />
+                      ))}
+                    </div>
+                  </td>
+                  <td style={{ padding: '12px 16px', color: 'var(--ink-3)' }}>
+                    {formatDate(earliestAW.createdAt)}
+                  </td>
+                  <td style={{ padding: '12px 16px' }}>
+                    <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
+                      {aws.map((aw) => (
+                        <button
+                          key={aw.id}
+                          onClick={() => handleRevoke(aw.id)}
+                          disabled={isCurrentAW(aw.id)}
+                          title={isCurrentAW(aw.id) ? 'Cannot revoke your own active session' : `Revoke ${aw.role} access`}
+                          style={{
+                            padding: '4px 10px',
+                            background: 'transparent',
+                            border: '1px solid var(--line-2)',
+                            borderRadius: 6,
+                            fontSize: 12,
+                            color: isCurrentAW(aw.id) ? 'var(--ink-3)' : 'var(--danger)',
+                            cursor: isCurrentAW(aw.id) ? 'not-allowed' : 'pointer',
+                            opacity: isCurrentAW(aw.id) ? 0.5 : 1,
+                          }}
+                        >
+                          Revoke {aw.role}
+                        </button>
+                      ))}
+                    </div>
+                  </td>
+                </tr>
+              );
+            })}
+            {allAWs.length === 0 && (
+              <tr>
+                <td
+                  colSpan={4}
+                  style={{ padding: '24px 16px', textAlign: 'center', color: 'var(--ink-3)', fontSize: 13 }}
+                >
+                  No members yet. Invite your first team member.
+                </td>
+              </tr>
+            )}
+          </tbody>
+        </table>
+        </div>
+      </div>
+
+      {/* Pending invites */}
+      {pendingInvites.length > 0 && (
+        <div>
+          <div
+            style={{
+              fontSize: 11,
+              fontWeight: 600,
+              letterSpacing: '0.08em',
+              textTransform: 'uppercase',
+              color: 'var(--ink-3)',
+              marginBottom: 10,
+            }}
+          >
+            Pending Invites
+          </div>
+          <div
+            style={{
+              border: '1px solid var(--line)',
+              borderRadius: 8,
+              overflow: 'hidden',
+            }}
+          >
+            {pendingInvites.map((invite, idx) => (
+              <div
+                key={invite.id}
+                style={{
+                  display: 'flex',
+                  alignItems: 'center',
+                  gap: 12,
+                  padding: '10px 16px',
+                  borderBottom: idx < pendingInvites.length - 1 ? '1px solid var(--line)' : 'none',
+                  fontSize: 13,
+                }}
+              >
+                <div style={{ flex: 1 }}>
+                  <span style={{ color: 'var(--ink)' }}>{invite.invitedEmail}</span>
+                  <span style={{ color: 'var(--ink-3)', marginLeft: 8 }}>·</span>
+                  <span style={{ marginLeft: 8 }}>
+                    <RoleBadge role={invite.invitedRole} />
+                  </span>
+                </div>
+                <div style={{ fontSize: 11, color: 'var(--ink-3)' }}>
+                  Sent {formatDate(invite.createdAt)}
+                </div>
+                <button
+                  onClick={() => {
+                    if (!window.confirm('Revoke this invite?')) return;
+                    revokeInvite(invite.id);
+                  }}
+                  style={{
+                    padding: '4px 10px',
+                    background: 'transparent',
+                    border: '1px solid var(--line-2)',
+                    borderRadius: 6,
+                    fontSize: 12,
+                    color: 'var(--ink-3)',
+                    cursor: 'pointer',
+                  }}
+                >
+                  Revoke invite
+                </button>
+              </div>
+            ))}
+          </div>
+        </div>
+      )}
+
+      {inviteOpen && (
+        <WorkspaceInviteModal
+          workspaceId={workspaceId}
+          onClose={() => setInviteOpen(false)}
+        />
+      )}
+    </div>
+  );
+}
