+            })}
+          </ul>
+        )}
+      </section>
+
+      {/* Pieces placeholder */}
+      <section>
+        <SectionHeading>Recent Pieces</SectionHeading>
+        <EmptyHint>
+          Recent pieces will appear here once piece-client tagging ships.
+        </EmptyHint>
+      </section>
+    </div>
+  );
+}
+
+// ─── BillingContent ──────────────────────────────────────────────────────────
+
+function BillingContent({ clientName }: { clientName: string }) {
+  return (
+    <div style={{ display: 'flex', flexDirection: 'column', gap: 24 }}>
+      <section>
+        <SectionHeading>Billing Summary</SectionHeading>
