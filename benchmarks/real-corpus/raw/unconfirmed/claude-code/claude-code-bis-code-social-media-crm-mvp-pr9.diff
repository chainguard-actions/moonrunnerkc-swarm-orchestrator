+          );
+        })}
+      </div>
+
+      <div style={{ display: 'flex', gap: '8px', marginTop: '20px' }}>
+        <button type="button" onClick={onBack} style={{ ...ghostBtnStyle, flex: '0 0 auto' }}>
+          ← Back
+        </button>
+        <button type="button" onClick={onNext} style={primaryBtnStyle}>
+          Continue →
+        </button>
+      </div>
+    </div>
