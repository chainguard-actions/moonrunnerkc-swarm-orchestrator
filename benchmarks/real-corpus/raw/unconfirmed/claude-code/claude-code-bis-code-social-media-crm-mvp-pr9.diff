+import { updatePieceStageData } from '../../data/production-store';
+import type { Piece, Platform, PostProductionData } from '../../types/production';
+import { PLATFORM_LABEL } from '../../types/production';
+import { FieldCard } from './FieldCard';
+import { StageWorkspace } from './StageWorkspace';
+import { UserTasksSection } from './UserTasksSection';
+
+const EDIT_STEPS: { key: keyof PostProductionData['editChecklist']; label: string }[] = [
+  { key: 'roughCut', label: 'Rough cut' },
+  { key: 'audio', label: 'Audio cleanup' },
+  { key: 'color', label: 'Color' },
+  { key: 'captionsOnScreen', label: 'Captions / text-on-screen' },
+  { key: 'music', label: 'Music' },
+  { key: 'finalCut', label: 'Final cut' },
+];
+
+export function StagePostProduction({ piece }: { piece: Piece }) {
+  const data = piece.stageData.postproduction;
+  const selectedPlatforms = piece.stageData.brainstorm.platforms;
+
+  const toggleEditStep = (key: keyof PostProductionData['editChecklist']) => {
+    updatePieceStageData(piece.id, 'postproduction', {
+      editChecklist: { ...data.editChecklist, [key]: !data.editChecklist[key] },
+    });
+  };
+
+  const updateCaption = (platform: Platform, text: string) => {
+    updatePieceStageData(piece.id, 'postproduction', {
+      captionsPerPlatform: { ...data.captionsPerPlatform, [platform]: text },
+    });
+  };
+
+  return (
+    <StageWorkspace piece={piece} stage="postproduction">
+      <FieldCard label="Edit checklist">
+        <div style={{ display: 'flex', flexWrap: 'wrap', gap: 12 }}>
+          {EDIT_STEPS.map((s) => (
+            <label key={s.key} style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 13 }}>
+              <input
+                type="checkbox"
+                checked={data.editChecklist[s.key]}
+                onChange={() => toggleEditStep(s.key)}
+              />
+              {s.label}
+            </label>
+          ))}
+        </div>
+      </FieldCard>
+
+      <FieldCard label="On-screen hook text">
+        <input
+          type="text"
+          value={data.hookOnScreen}
+          onChange={(e) => updatePieceStageData(piece.id, 'postproduction', { hookOnScreen: e.target.value })}
+          placeholder="What appears as text over the first frame…"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+        />
+      </FieldCard>
+
+      {/* "Caption draft" matches the system task name sys.postproduction.caption-draft */}
+      <FieldCard label="Caption draft">
+        {selectedPlatforms.length === 0 ? (
+          <div style={{ fontSize: 13, color: 'var(--muted)' }}>
+            No platforms selected yet — go to Brainstorm to pick TikTok / Reels / Shorts.
+          </div>
+        ) : (
+          <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
+            {selectedPlatforms.map((p) => (
+              <label key={p} style={{ fontSize: 12, color: 'var(--muted)' }}>
+                {PLATFORM_LABEL[p]}
+                <textarea
+                  value={data.captionsPerPlatform[p] ?? ''}
+                  onChange={(e) => updateCaption(p, e.target.value)}
+                  rows={3}
+                  placeholder={`Caption for ${PLATFORM_LABEL[p]}…`}
+                  style={{ width: '100%', marginTop: 4, padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+                />
+              </label>
+            ))}
+          </div>
+        )}
+      </FieldCard>
+
+      <FieldCard label="Hashtags">
+        <input
+          type="text"
+          value={data.hashtags}
+          onChange={(e) => updatePieceStageData(piece.id, 'postproduction', { hashtags: e.target.value })}
+          placeholder="#fyp #productivity #morningroutine"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+        />
+      </FieldCard>
+
+      <FieldCard label="Music credits">
+        <input
+          type="text"
+          value={data.musicCredits}
+          onChange={(e) => updatePieceStageData(piece.id, 'postproduction', { musicCredits: e.target.value })}
+          placeholder="Track name + artist + link"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+        />
+      </FieldCard>
+
+      {/* "Editing notes" matches the system task name sys.postproduction.editing-notes (maps to reviewComments).
+          Review link is kept as a separate card for the external collaborator link. */}
+      <FieldCard label="Editing notes">
+        <textarea
+          value={data.reviewComments}
+          onChange={(e) => updatePieceStageData(piece.id, 'postproduction', { reviewComments: e.target.value })}
+          rows={3}
+          placeholder="Notes from collaborator feedback — paste here for now."
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+        />
+      </FieldCard>
+
+      {/* Inline-comment collaborator review is deferred to v2. For now, paste an external Frame.io/Drive/Vimeo link. */}
+      <FieldCard label="Review link">
+        <input
+          type="url"
+          value={data.reviewExternalLink}
+          onChange={(e) => updatePieceStageData(piece.id, 'postproduction', { reviewExternalLink: e.target.value })}
+          placeholder="Paste Frame.io / Drive / Vimeo link"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+        />
+      </FieldCard>
+      <UserTasksSection piece={piece} stage="postproduction" />
+    </StageWorkspace>
+  );
+}
diff --git a/src/components/production/StagePreProduction.tsx b/src/components/production/StagePreProduction.tsx
--- /dev/null
+++ b/src/components/production/StagePreProduction.tsx
@@ -0,0 +1,128 @@
+import { useState } from 'react';
+import {
+  addShot,
+  deleteShot,
+  updatePieceStageData,
+  updateShot,
+} from '../../data/production-store';
+import type { Piece } from '../../types/production';
+import { FieldCard } from './FieldCard';
+import { StageWorkspace } from './StageWorkspace';
+import { UserTasksSection } from './UserTasksSection';
+import { useIsMobile } from '../../data/route-buckets';
+
+export function StagePreProduction({ piece }: { piece: Piece }) {
+  const data = piece.stageData.preproduction;
+  const [newShot, setNewShot] = useState('');
+  const isMobile = useIsMobile();
+
+  // PreProductionData.references and .storyboardImageDataUrls are intentionally
+  // not rendered here — deferred to v2 per the spec.
+  return (
+    <StageWorkspace piece={piece} stage="preproduction">
+      {/* "Production notes" matches the system task name sys.preproduction.production-notes */}
+      <FieldCard label="Production notes">
+        <textarea
+          value={data.script}
+          onChange={(e) => updatePieceStageData(piece.id, 'preproduction', { script: e.target.value })}
+          rows={10}
+          placeholder="Beat-by-beat outline, full script, or scratch notes…"
+          style={{ width: '100%', padding: '10px 12px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical', fontSize: 13 }}
+        />
+      </FieldCard>
+
+      {/* "Shot list" matches the system task name sys.preproduction.shot-list */}
+      <FieldCard label="Shot list">
+        <ul style={{ listStyle: 'none', padding: 0, margin: 0, display: 'flex', flexDirection: 'column', gap: 6 }}>
+          {data.shotList.map((shot, idx) => (
+            <li key={shot.id} style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 13 }}>
+              <span style={{ width: 22, color: 'var(--muted)', textAlign: 'right' }}>{idx + 1}.</span>
+              <input
+                type="text"
+                value={shot.description}
+                onChange={(e) => updateShot(piece.id, shot.id, { description: e.target.value })}
+                style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--line)', borderRadius: 6 }}
+              />
+              <button
+                onClick={() => deleteShot(piece.id, shot.id)}
+                title="Delete shot"
+                aria-label="Delete shot"
+                style={{ background: 'transparent', border: 'none', color: 'var(--muted)', cursor: 'pointer', fontSize: 16 }}
+              >
+                ×
+              </button>
+            </li>
+          ))}
+          <li key="new-shot-input" style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
+            <span style={{ width: 22 }} />
+            <input
+              type="text"
+              value={newShot}
+              onChange={(e) => setNewShot(e.target.value)}
+              onKeyDown={(e) => {
+                if (e.key === 'Enter' && newShot.trim()) {
+                  addShot(piece.id, newShot);
+                  setNewShot('');
+                }
+              }}
+              placeholder="Add a shot — press Enter"
+              style={{ flex: 1, padding: '6px 8px', border: '1px dashed var(--line)', borderRadius: 6, fontSize: 13 }}
+            />
+          </li>
+        </ul>
+      </FieldCard>
+
+      <FieldCard label="Logistics">
+        <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : '1fr 1fr 1fr', gap: 12 }}>
+          <LabeledInput label="Location" value={data.logisticsLocation} onChange={(v) => updatePieceStageData(piece.id, 'preproduction', { logisticsLocation: v })} />
+          <LabeledInput label="Props" value={data.logisticsProps} onChange={(v) => updatePieceStageData(piece.id, 'preproduction', { logisticsProps: v })} />
+          <LabeledInput label="Wardrobe" value={data.logisticsWardrobe} onChange={(v) => updatePieceStageData(piece.id, 'preproduction', { logisticsWardrobe: v })} />
+        </div>
+      </FieldCard>
+
+      <FieldCard label="Shoot date">
+        <input
+          type="date"
+          value={data.shootDate ?? ''}
+          onChange={(e) => updatePieceStageData(piece.id, 'preproduction', { shootDate: e.target.value || undefined })}
+          style={{ padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+        />
+      </FieldCard>
+
+      {/* Collaborator notifications (magic-link / email / accounts) deferred to v2 — only name + role captured here. */}
+      <FieldCard label="Collaborator">
+        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
+          <LabeledInput label="Name" value={data.collaboratorName} onChange={(v) => updatePieceStageData(piece.id, 'preproduction', { collaboratorName: v })} />
+          <LabeledInput label="Role" value={data.collaboratorRole} onChange={(v) => updatePieceStageData(piece.id, 'preproduction', { collaboratorRole: v })} placeholder="editor, camera, voice-over…" />
+        </div>
+      </FieldCard>
+      <UserTasksSection piece={piece} stage="preproduction" />
+    </StageWorkspace>
+  );
+}
+
+function LabeledInput({
+  label,
+  value,
+  onChange,
+  placeholder,
+}: {
+  label: string;
+  value: string;
+  onChange: (v: string) => void;
+  placeholder?: string;
+}) {
+  return (
+    <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+      {label}
+      <input
+        type="text"
+        value={value}
+        onChange={(e) => onChange(e.target.value)}
+        placeholder={placeholder}
+        style={{ width: '100%', marginTop: 4, padding: '6px 8px', border: '1px solid var(--line)', borderRadius: 6 }}
+      />
+    </label>
+  );
+}
+
diff --git a/src/components/production/StageProduction.tsx b/src/components/production/StageProduction.tsx
--- /dev/null
+++ b/src/components/production/StageProduction.tsx
@@ -0,0 +1,99 @@
+import { updatePieceStageData, updateShot } from '../../data/production-store';
+import type { Piece } from '../../types/production';
+import { FieldCard } from './FieldCard';
+import { StageWorkspace } from './StageWorkspace';
+import { UserTasksSection } from './UserTasksSection';
+
+export function StageProduction({ piece }: { piece: Piece }) {
+  const shots = piece.stageData.preproduction.shotList;
+  const data = piece.stageData.production;
+  const capturedCount = shots.filter((s) => s.captured).length;
+  const reshootCount = shots.filter((s) => s.reshootReason).length;
+  const allCapturedOrFlagged =
+    shots.length > 0 && shots.every((s) => s.captured || s.reshootReason);
+
+  return (
+    <StageWorkspace piece={piece} stage="production">
+      <FieldCard label="Shot list (live)">
+        {shots.length === 0 ? (
+          <div style={{ fontSize: 13, color: 'var(--muted)' }}>
+            No shots yet. Go back to Pre-production to add them.
+          </div>
+        ) : (
+          <ul style={{ listStyle: 'none', padding: 0, margin: 0, display: 'flex', flexDirection: 'column', gap: 6 }}>
+            {shots.map((shot, idx) => (
+              <li key={shot.id} style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 13 }}>
+                <input
+                  type="checkbox"
+                  checked={shot.captured}
+                  onChange={(e) => updateShot(piece.id, shot.id, { captured: e.target.checked })}
+                  aria-label={`Mark shot ${idx + 1} captured`}
+                />
+                <span style={{ width: 22, color: 'var(--muted)', textAlign: 'right' }}>{idx + 1}.</span>
+                <span
+                  style={{
+                    flex: 1,
+                    textDecoration: shot.captured ? 'line-through' : 'none',
+                    color: shot.captured ? 'var(--muted)' : 'inherit',
+                  }}
+                >
+                  {shot.description || '(empty)'}
+                </span>
+                <input
+                  type="text"
+                  value={shot.reshootReason ?? ''}
+                  onChange={(e) =>
+                    updateShot(piece.id, shot.id, { reshootReason: e.target.value || undefined })
+                  }
+                  placeholder="reshoot reason?"
+                  aria-label={`Reshoot reason for shot ${idx + 1}`}
+                  style={{ width: 160, padding: '4px 6px', border: '1px solid var(--line)', borderRadius: 4, fontSize: 12, color: 'var(--red, #c33)' }}
+                />
+              </li>
+            ))}
+          </ul>
+        )}
+        <div style={{ fontSize: 11, color: 'var(--muted)', marginTop: 6 }}>
+          {capturedCount} of {shots.length} captured
+          {reshootCount > 0 && ` · ${reshootCount} need reshoot`}
+        </div>
+      </FieldCard>
+
+      {/* "Footage notes" matches the system task name sys.production.footage-notes */}
+      <FieldCard label="Footage notes">
+        <textarea
+          value={data.setNotes}
+          onChange={(e) => updatePieceStageData(piece.id, 'production', { setNotes: e.target.value })}
+          rows={6}
+          placeholder="What happened on set — keepers, problems, surprises…"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+        />
+      </FieldCard>
+
+      <FieldCard label="Shoot done">
+        <label style={{ display: 'inline-flex', alignItems: 'center', gap: 8, fontSize: 13 }}>
+          <input
+            type="checkbox"
+            checked={data.shootDone}
+            onChange={(e) =>
+              updatePieceStageData(piece.id, 'production', {
+                shootDone: e.target.checked,
+                shootDoneAt: e.target.checked ? new Date().toISOString() : undefined,
+              })
+            }
+          />
+          <span>
+            Mark shoot as done
+            {data.shootDoneAt && ` (${new Date(data.shootDoneAt).toLocaleString()})`}
+          </span>
+          {!data.shootDone && allCapturedOrFlagged && (
+            <span style={{ fontSize: 11, color: 'var(--green, #2a7)' }}>
+              (all shots captured or flagged — ready to mark done)
+            </span>
+          )}
+        </label>
+      </FieldCard>
+      <UserTasksSection piece={piece} stage="production" />
+    </StageWorkspace>
+  );
+}
diff --git a/src/components/production/StagePublish.tsx b/src/components/production/StagePublish.tsx
--- /dev/null
+++ b/src/components/production/StagePublish.tsx
@@ -0,0 +1,110 @@
+import { useEffect } from 'react';
+import {
+  syncPublishScheduleFromPlatforms,
+  updatePublishRow,
+  useProductionStore,
+} from '../../data/production-store';
+import type { Piece } from '../../types/production';
+import { PLATFORM_LABEL } from '../../types/production';
+import { FieldCard } from './FieldCard';
+import { StageWorkspace } from './StageWorkspace';
+import { UserTasksSection } from './UserTasksSection';
+import { useIsMobile } from '../../data/route-buckets';
+
+export function StagePublish({ piece }: { piece: Piece }) {
+  const [state] = useProductionStore();
+  const current = state.pieces.find((p) => p.id === piece.id) ?? piece;
+  const schedule = current.stageData.publish.schedule;
+  const platformsKey = current.stageData.brainstorm.platforms.join(',');
+  const isMobile = useIsMobile();
+
+  // Re-sync rows on platforms-change — covers pieces that pre-date the
+  // setBrainstormPlatforms atomic action (Task 5). No-op when the schedule
+  // is already in sync, but still writes to localStorage on every mount.
+  useEffect(() => {
+    syncPublishScheduleFromPlatforms(piece.id);
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [platformsKey]);
+
+  return (
+    <StageWorkspace piece={piece} stage="publish">
+      {/* "Schedule" matches the system task name sys.publish.schedule.
+          The Posted toggles inside each row also drive sys.publish.all-posted — no separate card needed. */}
+      <FieldCard label="Schedule">
+        {schedule.length === 0 ? (
+          <div style={{ fontSize: 13, color: 'var(--muted)' }}>
+            No platforms selected — go to Brainstorm and pick TikTok / Reels / Shorts.
+          </div>
+        ) : (
+          <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
+            {schedule.map((row) => (
+              <div
+                key={row.platform}
+                style={{
+                  border: '1px solid var(--line)',
+                  borderRadius: 8,
+                  padding: 14,
+                  display: 'grid',
+                  // Stack on mobile: datetime-local has a ~170px native min-width
+                  // that overflows the auto-sized "Posted" column at narrow widths.
+                  gridTemplateColumns: isMobile ? '1fr' : '120px 1fr auto',
+                  gap: 12,
+                  alignItems: isMobile ? 'start' : 'center',
+                }}
+              >
+                <div style={{ fontWeight: 600, fontSize: 13 }}>{PLATFORM_LABEL[row.platform]}</div>
+                <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+                  Scheduled time
+                  <input
+                    type="datetime-local"
+                    value={row.scheduledAt ? row.scheduledAt.slice(0, 16) : ''}
+                    onChange={(e) =>
+                      updatePublishRow(piece.id, row.platform, {
+                        scheduledAt: e.target.value ? new Date(e.target.value).toISOString() : undefined,
+                      })
+                    }
+                    style={{ display: 'block', marginTop: 4, padding: '6px 8px', border: '1px solid var(--line)', borderRadius: 6 }}
+                  />
+                </label>
+                <label style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 13 }}>
+                  <input
+                    type="checkbox"
+                    checked={row.posted}
+                    onChange={(e) =>
+                      updatePublishRow(piece.id, row.platform, {
+                        posted: e.target.checked,
+                        postedAt: e.target.checked ? new Date().toISOString() : undefined,
+                      })
+                    }
+                  />
+                  Posted
+                  {row.postedAt && (
+                    <span style={{ fontSize: 11, color: 'var(--muted)', marginInlineStart: 6 }}>
+                      {new Date(row.postedAt).toLocaleString()}
+                    </span>
+                  )}
+                </label>
+              </div>
+            ))}
+            {current.doneAt && (
+              <div
+                style={{
+                  padding: 12,
+                  background: 'var(--green-bg, #e8f7ef)',
+                  border: '1px solid var(--green, #2a7)',
+                  color: 'var(--green, #2a7)',
+                  borderRadius: 8,
+                  fontWeight: 600,
+                  fontSize: 13,
+                }}
+              >
+                ✓ All platforms posted — piece complete ({new Date(current.doneAt).toLocaleString()})
+              </div>
+            )}
+          </div>
+        )}
+      </FieldCard>
+      <UserTasksSection piece={piece} stage="publish" />
+    </StageWorkspace>
+  );
+}
diff --git a/src/components/production/StageTabs.tsx b/src/components/production/StageTabs.tsx
--- /dev/null
+++ b/src/components/production/StageTabs.tsx
@@ -0,0 +1,63 @@
+import type { Piece, StageId } from '../../types/production';
+import { STAGE_LABEL, STAGE_ORDER } from '../../types/production';
+import { suggestedTaskProgress } from '../../data/production-store';
+
+export function StageTabs({
+  piece,
+  active,
+  onSelect,
+}: {
+  piece: Piece;
+  active: StageId;
+  onSelect: (stage: StageId) => void;
+}) {
+  const currentIdx = STAGE_ORDER.indexOf(piece.currentStage);
+  return (
+    <div style={{ display: 'flex', borderBottom: '1px solid var(--line)', overflowX: 'auto' }}>
+      {STAGE_ORDER.map((stage, idx) => {
+        const { done, total } = suggestedTaskProgress(piece, stage);
+        const isCurrent = stage === piece.currentStage;
+        const isPast = idx < currentIdx;
+        const isFuture = idx > currentIdx;
+        const isActive = stage === active;
+        return (
+          <button
+            key={stage}
+            onClick={() => onSelect(stage)}
+            style={{
+              padding: '12px 16px',
+              border: 'none',
+              borderBottom: isActive ? '2px solid var(--ink)' : '2px solid transparent',
+              background: 'transparent',
+              cursor: 'pointer',
+              fontSize: 13,
+              fontWeight: isActive ? 600 : 500,
+              color: isFuture ? 'var(--muted)' : 'var(--ink)',
+              display: 'flex',
+              alignItems: 'center',
+              gap: 6,
+              whiteSpace: 'nowrap',
+            }}
+          >
+            <span>{STAGE_LABEL[stage]}</span>
+            {isPast && <span style={{ color: 'var(--green, #2a7)' }}>✓</span>}
+            {isCurrent && total > 0 && (
+              <span
+                style={{
+                  fontSize: 11,
+                  background: done === total ? 'var(--green, #2a7)' : 'var(--line)',
+                  color: done === total ? '#fff' : 'inherit',
+                  padding: '1px 6px',
+                  borderRadius: 4,
+                  fontWeight: 600,
+                }}
+              >
+                {done}/{total}
+              </span>
+            )}
+          </button>
+        );
+      })}
+    </div>
+  );
+}
