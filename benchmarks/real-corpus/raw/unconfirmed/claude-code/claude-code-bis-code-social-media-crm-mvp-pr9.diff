+
+/**
+ * React hook — returns workspace-filtered ProductionState.
+ * Only pieces whose workspaceId matches the current workspace are returned.
+ * If currentWorkspaceId() is null (not logged in / migration not run yet),
+ * an empty pieces array is returned so screens degrade gracefully.
+ */
+export function useProductionStore(): [
+  ProductionState,
+  (fn: (current: ProductionState) => ProductionState) => void,
+] {
+  // Re-render both on production-store changes AND on session changes (workspace switch).
+  const [snapshot, setSnapshot] = useState<ProductionState>(() => {
+    const full = loadProduction();
+    const wsId = currentWorkspaceId();
+    if (!wsId) return { ...full, pieces: [], vault: [] };
+    return {
+      ...full,
+      pieces: full.pieces.filter((p) => !p.workspaceId || p.workspaceId === wsId),
+      vault: full.vault.filter((v) => !v.workspaceId || v.workspaceId === wsId),
+    };
+  });
+
+  useEffect(() => {
+    // rebuild derives filtered view from both stores — re-runs on any
+    // production-store mutation OR on a session workspace switch.
+    const rebuild = () => {
+      const full = loadProduction();
+      const wsId = currentWorkspaceId();
+      if (!wsId) {
+        setSnapshot({ ...full, pieces: [], vault: [] });
+      } else {
+        setSnapshot({
+          ...full,
+          pieces: full.pieces.filter((p) => !p.workspaceId || p.workspaceId === wsId),
+          vault: full.vault.filter((v) => !v.workspaceId || v.workspaceId === wsId),
+        });
+      }
+    };
+    listeners.add(rebuild);
+    const unsubSession = subscribeSession(rebuild);
+    return () => {
+      listeners.delete(rebuild);
+      unsubSession();
+    };
+  }, []);
+
+  return [snapshot, (mutator) => mutateProduction(mutator)];
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+/**
+ * Snapshot the current workspace task library into a fresh tasksByStage record.
+ * Each stage's tasks are copied from the matching TaskDefinition entries.
+ * Falls back to emptyTasksByStage() when no workspaceId is available (shouldn't happen).
+ */
+function snapshotTasksForWorkspace(workspaceId: string): Piece['tasksByStage'] {
+  const out = {} as Piece['tasksByStage'];
+  for (const stage of STAGE_ORDER) {
+    const defs = listTaskDefsForStage(workspaceId, stage);
+    out[stage] = defs.map((def) => ({
+      id: genId('task'),
+      title: def.name,
+      suggestedKey: def.id,
+      status: 'todo' as TaskStatus,
+    }));
+  }
+  return out;
+}
