--- /dev/null
+++ b/src/data/session-store.ts
@@ -0,0 +1,128 @@
+// Session store — tracks which Account and AccountWorkspace is currently active.
+// Pattern mirrors production-store.ts: listeners Set + subscribe + notify.
+// No external state library.
+
+import { useEffect, useState } from 'react';
+import type { Session } from '../types/saas';
+
+const KEY = 'session-store:v1';
+
+const EMPTY_SESSION: Session = {
+  currentAccountId: null,
+  currentAccountWorkspaceId: null,
+};
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads on hot paths.
+let sessionCache: Session | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadSession(): Session {
+  if (sessionCache !== null) return sessionCache;
+  if (typeof localStorage === 'undefined') {
+    sessionCache = { ...EMPTY_SESSION };
+    return sessionCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    sessionCache = { ...EMPTY_SESSION };
+    return sessionCache;
+  }
+  try {
+    sessionCache = { ...EMPTY_SESSION, ...(JSON.parse(raw) as Partial<Session>) };
+    return sessionCache;
+  } catch {
+    sessionCache = { ...EMPTY_SESSION };
+    return sessionCache;
+  }
+}
+
+function saveSession(next: Session): void {
+  sessionCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    sessionCache = null;
+    console.warn('[session-store] localStorage write failed:', err);
+  }
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+/**
+ * Set the active account + workspace membership. Called after login or invite-accept.
+ * Pass null for accountWorkspaceId when the account exists but onboarding hasn't
+ * completed yet (e.g. right after /register, before the org+workspace wizard runs).
+ */
+export function login(accountId: string, accountWorkspaceId: string | null): void {
+  saveSession({ currentAccountId: accountId, currentAccountWorkspaceId: accountWorkspaceId });
+}
+
+/** Clear the session entirely. */
+export function logout(): void {
+  saveSession({ currentAccountId: null, currentAccountWorkspaceId: null });
+}
+
+/**
+ * Switch to a different AccountWorkspace for the SAME account.
+ * The accountId is preserved; only the workspace membership changes.
+ */
+export function switchAccountWorkspace(awId: string): void {
+  const current = loadSession();
+  saveSession({ ...current, currentAccountWorkspaceId: awId });
+}
+
+// ─── Derived reads ────────────────────────────────────────────────────────────
+
+/** Raw session state — use the hook in React components. */
+export function getSession(): Session {
+  return loadSession();
+}
+
+/**
+ * Returns the current AccountWorkspace id, or null if not logged in.
+ * Import-safe for use outside React (e.g. in store actions).
+ */
+export function getCurrentAccountWorkspaceId(): string | null {
+  return loadSession().currentAccountWorkspaceId;
+}
+
+/**
+ * Returns the current Account id, or null if not logged in.
+ * Import-safe for use outside React.
+ */
+export function getCurrentAccountId(): string | null {
+  return loadSession().currentAccountId;
+}
+
+// ─── External subscription ───────────────────────────────────────────────────
+
+/**
+ * Subscribe to session-store changes from outside React (e.g. production-store hook).
+ * Returns an unsubscribe function.
+ */
+export function subscribeSession(fn: () => void): () => void {
+  listeners.add(fn);
+  return () => {
+    listeners.delete(fn);
+  };
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useSession(): Session {
+  const [snapshot, setSnapshot] = useState<Session>(() => loadSession());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadSession());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
