-
-export function Index() {
-  // ALL hooks must run unconditionally before any early return — otherwise
-  // the hook count flips when isMobileViewport changes and React throws #310
-  // ("Rendered more hooks than during the previous render").
-  const isMobileViewport = useIsMobile();
-  const [activePage, setActivePage] = useState(1);
-
-  useEffect(() => {
-    if (isMobileViewport) return;
-    const observer = new IntersectionObserver(
-      (entries) => {
-        for (const entry of entries) {
-          if (entry.isIntersecting) {
-            const n = Number(entry.target.getAttribute('data-page')) || 1;
-            setActivePage(n);
-          }
-        }
-      },
-      { threshold: 0.5 },
-    );
-    document.querySelectorAll('.proposal-page').forEach((el) => observer.observe(el));
-    return () => observer.disconnect();
-  }, [isMobileViewport]);
-
-  if (isMobileViewport) {
-    return <MobileFallback variant="proposal" />;
-  }
-
-  const handlePrint = () => {
-    document.body.classList.add('printing-proposal');
-    const cleanup = () => {
-      document.body.classList.remove('printing-proposal');
-      window.removeEventListener('afterprint', cleanup);
-    };
-    window.addEventListener('afterprint', cleanup);
-    // Defer so the class lands and styles recompute before the dialog opens.
-    setTimeout(() => window.print(), 50);
-  };
-
-  // The /proposal route is locked to English regardless of the user's
-  // language preference — the bid deliverable is still being authored in
