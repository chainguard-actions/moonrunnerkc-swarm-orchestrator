--- /dev/null
+++ b/src/data/account-store.ts
@@ -0,0 +1,146 @@
+// Account store — persists user accounts in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+//
+// SECURITY NOTE: passwordHash is stored as plain text (not hashed).
+// This is intentional for Phase 3a — we are mocking auth in localStorage.
+// Real cryptographic hashing ships with the backend brainstorm.
+
+import { useEffect, useState } from 'react';
+import type { Account } from '../types/saas';
+
+const KEY = 'account-store:v1';
+
+interface AccountState {
+  accounts: Account[];
+}
+
+const EMPTY: AccountState = { accounts: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage.getItem + JSON.parse on
+// hot paths like TeamRolesSection where getAccount is called per row in a map loop.
+let accountCache: AccountState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadAccountState(): AccountState {
+  if (accountCache !== null) return accountCache;
+  if (typeof localStorage === 'undefined') {
+    accountCache = { ...EMPTY };
+    return accountCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    accountCache = { ...EMPTY };
+    return accountCache;
+  }
+  try {
+    accountCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<AccountState>) };
+    return accountCache;
+  } catch {
+    accountCache = { ...EMPTY };
+    return accountCache;
+  }
+}
+
+function saveAccountState(next: AccountState): void {
+  accountCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    accountCache = null;
+    console.warn('[account-store] localStorage write failed:', err);
+  }
+}
+
+function mutateAccountState(fn: (current: AccountState) => AccountState): AccountState {
+  const current = loadAccountState();
+  const next = fn(current);
+  saveAccountState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Mock password helper ─────────────────────────────────────────────────────
+// MOCK ONLY: stores password as-is. Not cryptographically safe.
+function mockHash(password: string): string {
+  return password;
+}
+
+function mockVerify(password: string, storedHash: string): boolean {
+  return password === storedHash;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function createAccount(name: string, email: string, password: string): Account {
+  const account: Account = {
+    id: genId('acct'),
+    name: name.trim(),
+    email: email.trim().toLowerCase(),
+    // MOCK: password stored plain. See file-level note.
+    passwordHash: mockHash(password),
+  };
+  mutateAccountState((s) => ({ ...s, accounts: [...s.accounts, account] }));
+  return account;
+}
+
+export function findAccountByEmail(email: string): Account | null {
+  return (
+    loadAccountState().accounts.find(
+      (a) => a.email.toLowerCase() === email.trim().toLowerCase(),
+    ) ?? null
+  );
+}
+
+/**
+ * Verify a password against the stored mock hash.
+ * Returns the Account on success, null on failure.
+ */
+export function verifyPassword(email: string, password: string): Account | null {
+  const account = findAccountByEmail(email);
+  if (!account) return null;
+  if (!mockVerify(password, account.passwordHash)) return null;
+  return account;
+}
+
+export function getAccount(id: string): Account | null {
+  return loadAccountState().accounts.find((a) => a.id === id) ?? null;
+}
+
+/**
+ * Update mutable account fields (name, email).
+ * passwordHash is intentionally not updatable here — a dedicated change-password
+ * flow would handle that separately.
+ */
+export function updateAccount(id: string, partial: Pick<Partial<Account>, 'name' | 'email'>): Account | null {
+  const existing = getAccount(id);
+  if (!existing) return null;
+  const updated: Account = { ...existing, ...partial };
+  mutateAccountState((s) => ({
+    ...s,
+    accounts: s.accounts.map((a) => (a.id === id ? updated : a)),
+  }));
+  return updated;
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useAccountStore(): AccountState {
+  const [snapshot, setSnapshot] = useState<AccountState>(() => loadAccountState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadAccountState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
diff --git a/src/data/account-workspaces-store.ts b/src/data/account-workspaces-store.ts
--- /dev/null
+++ b/src/data/account-workspaces-store.ts
@@ -0,0 +1,170 @@
+// AccountWorkspaces store — persists workspace memberships (AccountWorkspace) in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+//
+// IMPORTANT: role is IMMUTABLE. There is intentionally NO setAccountWorkspaceRole action.
+// To change a role: revokeAccountWorkspace the existing AW, then createAccountWorkspace with the new role.
+
+import { useEffect, useState } from 'react';
+import type { AccountWorkspace, Role } from '../types/saas';
+import { getSession, logout } from './session-store';
+
+const KEY = 'account-workspaces-store:v1';
+
+interface AccountWorkspacesState {
+  accountWorkspaces: AccountWorkspace[];
+}
+
+const EMPTY: AccountWorkspacesState = { accountWorkspaces: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids localStorage.getItem + JSON.parse on each useCan() call.
+// Invalidated on every saveAWState(); updated to the new value on successful writes.
+let awCache: AccountWorkspacesState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadAWState(): AccountWorkspacesState {
+  if (awCache !== null) return awCache;
+  if (typeof localStorage === 'undefined') {
+    awCache = { ...EMPTY };
+    return awCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    awCache = { ...EMPTY };
+    return awCache;
+  }
+  try {
+    awCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<AccountWorkspacesState>) };
+    return awCache;
+  } catch {
+    awCache = { ...EMPTY };
+    return awCache;
+  }
+}
+
+function saveAWState(next: AccountWorkspacesState): void {
+  awCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    awCache = null;
+    console.warn('[account-workspaces-store] localStorage write failed:', err);
+  }
+}
+
+function mutateAWState(
+  fn: (current: AccountWorkspacesState) => AccountWorkspacesState,
+): AccountWorkspacesState {
+  const current = loadAWState();
+  const next = fn(current);
+  saveAWState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+/**
+ * Create a new AccountWorkspace linking an account to a workspace with a given role.
+ * Role is set at creation time and is IMMUTABLE.
+ * clientId must be provided when role === 'Sponsor' to link to the specific Client.
+ */
+export function createAccountWorkspace(
+  accountId: string,
+  workspaceId: string,
+  role: Role,
+  clientId?: string,
+): AccountWorkspace {
+  // Invariant: the first AccountWorkspace created for a workspace MUST be Administrator.
+  // Subsequent memberships (invites, etc.) can have any role.
+  const existingAWsForWorkspace = listAccountWorkspacesForWorkspace(workspaceId);
+  if (existingAWsForWorkspace.length === 0 && role !== 'Administrator') {
+    throw new Error(
+      `[account-workspaces-store] First AccountWorkspace for workspace ${workspaceId} must have role 'Administrator', got '${role}'`,
+    );
+  }
+
+  const aw: AccountWorkspace = {
+    id: genId('aw'),
+    accountId,
+    workspaceId,
+    role,
+    ...(clientId ? { clientId } : {}),
+    createdAt: Date.now(),
+  };
+  mutateAWState((s) => ({ ...s, accountWorkspaces: [...s.accountWorkspaces, aw] }));
+  return aw;
+}
+
+/**
+ * Revoke an AccountWorkspace by removing it entirely.
+ * The account loses its membership in this workspace under this role.
+ * If the current session points at the revoked AW, the session is cleared (logout).
+ */
+export function revokeAccountWorkspace(awId: string): void {
+  mutateAWState((s) => ({
+    ...s,
+    accountWorkspaces: s.accountWorkspaces.filter((aw) => aw.id !== awId),
+  }));
+  // Clear session if the active AW was just revoked — prevents a dangling session
+  // pointing at a non-existent AccountWorkspace.
+  if (getSession().currentAccountWorkspaceId === awId) {
+    logout();
+  }
+}
+
+export function getAccountWorkspace(awId: string): AccountWorkspace | null {
+  return loadAWState().accountWorkspaces.find((aw) => aw.id === awId) ?? null;
+}
+
+export function listAccountWorkspacesForAccount(accountId: string): AccountWorkspace[] {
+  return loadAWState().accountWorkspaces.filter((aw) => aw.accountId === accountId);
+}
+
+export function listAccountWorkspacesForWorkspace(workspaceId: string): AccountWorkspace[] {
+  return loadAWState().accountWorkspaces.filter((aw) => aw.workspaceId === workspaceId);
+}
+
+// ─── DEV ONLY ────────────────────────────────────────────────────────────────
+
+/**
+ * DEV ONLY — mutates the current AW's role in localStorage without going
+ * through the immutable-role invariant.
+ *
+ * This is a shortcut for demoing different role views without inviting
+ * multiple test accounts. WILL BE REMOVED when real backend auth lands
+ * and the immutable-role invariant is enforced server-side.
+ *
+ * Callers are responsible for ensuring this is only reachable from
+ * admin-gated UI (gated by useCan('MANAGE_USERS')).
+ */
+export function _devSetCurrentAWRole(awId: string, role: Role): void {
+  mutateAWState((s) => ({
+    ...s,
+    accountWorkspaces: s.accountWorkspaces.map((aw) =>
+      aw.id === awId ? { ...aw, role } : aw,
+    ),
+  }));
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useAccountWorkspacesStore(): AccountWorkspacesState {
+  const [snapshot, setSnapshot] = useState<AccountWorkspacesState>(() => loadAWState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadAWState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
