@@ -0,0 +1,98 @@
+// Org store — persists organisations in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+
+import { useEffect, useState } from 'react';
+import type { Org } from '../types/saas';
+
+const KEY = 'org-store:v1';
+
+interface OrgState {
+  orgs: Org[];
+}
+
+const EMPTY: OrgState = { orgs: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let orgCache: OrgState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadOrgs(): OrgState {
+  if (orgCache !== null) return orgCache;
+  if (typeof localStorage === 'undefined') {
+    orgCache = { ...EMPTY };
+    return orgCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    orgCache = { ...EMPTY };
+    return orgCache;
+  }
+  try {
+    orgCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<OrgState>) };
+    return orgCache;
+  } catch {
+    orgCache = { ...EMPTY };
+    return orgCache;
+  }
+}
+
+function saveOrgs(next: OrgState): void {
+  orgCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    orgCache = null;
+    console.warn('[org-store] localStorage write failed:', err);
+  }
+}
+
+function mutateOrgs(fn: (current: OrgState) => OrgState): OrgState {
+  const current = loadOrgs();
+  const next = fn(current);
+  saveOrgs(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function createOrg(name: string, logo?: string): Org {
+  const org: Org = {
+    id: genId('org'),
+    name: name.trim(),
+    ...(logo ? { logo } : {}),
+  };
+  mutateOrgs((s) => ({ ...s, orgs: [...s.orgs, org] }));
+  return org;
+}
+
+export function getOrg(id: string): Org | null {
+  return loadOrgs().orgs.find((o) => o.id === id) ?? null;
+}
+
+export function listOrgs(): Org[] {
+  return loadOrgs().orgs;
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useOrgStore(): OrgState {
+  const [snapshot, setSnapshot] = useState<OrgState>(() => loadOrgs());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadOrgs());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
