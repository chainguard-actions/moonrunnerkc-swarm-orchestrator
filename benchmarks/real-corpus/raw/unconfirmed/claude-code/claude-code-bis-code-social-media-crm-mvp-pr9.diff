@@ -0,0 +1,232 @@
+// Domain types for the content production pipeline.
+// Spec: docs/superpowers/specs/2026-05-22-content-production-pipeline-design.md
+
+export type StageId =
+  | 'brainstorm'
+  | 'preproduction'
+  | 'production'
+  | 'postproduction'
+  | 'publish';
+
+export const STAGE_ORDER: StageId[] = [
+  'brainstorm',
+  'preproduction',
+  'production',
+  'postproduction',
+  'publish',
+];
+
+export const STAGE_LABEL: Record<StageId, string> = {
+  brainstorm: 'Brainstorm',
+  preproduction: 'Pre-production',
+  production: 'Production',
+  postproduction: 'Post-production',
+  publish: 'Publish',
+};
+
+export type Platform = 'tiktok' | 'reels' | 'shorts';
+
+export const PLATFORM_LABEL: Record<Platform, string> = {
+  tiktok: 'TikTok',
+  reels: 'Reels',
+  shorts: 'YouTube Shorts',
+};
+
+export type TaskStatus = 'todo' | 'doing' | 'done';
+
+export interface PieceTask {
+  id: string;
+  /**
+   * For legacy suggested tasks: a dot-namespaced string like 'brainstorm.hook-locked'.
+   * For Phase 2 library tasks: the TaskDefinition.id (e.g. 'sys.brainstorm.hook-locked').
+   * The two overlap for system defs — both forms are accepted by `isAutoDerivedTask`.
+   */
+  suggestedKey?: string;
+  title: string;
+  status: TaskStatus;
+  /** Typed value for non-checkbox task types. string | string[] for text/dropdown/multiselect/link, number for number, boolean for checkbox (auto-derived). */
+  value?: string | string[] | number | boolean;
+}
+
+export interface ReferenceLink {
+  id: string;
+  url: string;
+  title?: string;
+  screenshotDataUrl?: string;
+}
+
+export interface VaultIdea {
+  id: string;
+  /** Workspace this idea belongs to. Added in Phase 3a; migration backfills existing ideas. */
+  workspaceId: string;
+  title: string;
+  contentText: string;
+  references: ReferenceLink[];
+  notes: string;
+  tags: string[];
+  createdAt: number;
+  promotedPieceIds: string[];
+}
+
+export interface BrainstormData {
+  hook: string;
+  platforms: Platform[];
+  angleNotes: string;
+}
+
+export interface ShotListItem {
+  id: string;
+  description: string;
+  referenceImageDataUrl?: string;
+  captured: boolean;
+  reshootReason?: string;
+}
+
+export interface PreProductionData {
+  script: string;
+  shotList: ShotListItem[];
+  storyboardImageDataUrls: string[];
+  logisticsLocation: string;
+  logisticsProps: string;
+  logisticsWardrobe: string;
+  shootDate?: string;
+  collaboratorName: string;
+  collaboratorRole: string;
+  references: ReferenceLink[];
+}
+
+export interface ProductionData {
+  setNotes: string;
+  shootDone: boolean;
+  shootDoneAt?: string;
+}
+
+export interface PostProductionData {
+  editChecklist: {
+    roughCut: boolean;
+    audio: boolean;
+    color: boolean;
+    captionsOnScreen: boolean;
+    music: boolean;
+    finalCut: boolean;
+  };
+  hookOnScreen: string;
+  captionsPerPlatform: Partial<Record<Platform, string>>;
+  hashtags: string;
+  musicCredits: string;
+  reviewExternalLink: string;
+  reviewComments: string;
+}
+
+export interface PublishScheduleRow {
+  platform: Platform;
+  scheduledAt?: string;
+  posted: boolean;
+  postedAt?: string;
+}
+
+export interface PublishData {
+  schedule: PublishScheduleRow[];
+}
+
+export interface PieceStageData {
+  brainstorm: BrainstormData;
+  preproduction: PreProductionData;
+  production: ProductionData;
+  postproduction: PostProductionData;
+  publish: PublishData;
+}
+
+export interface Piece {
+  id: string;
+  /** Workspace this piece belongs to. Added in Phase 3a; migration backfills existing pieces. */
+  workspaceId?: string;
+  title: string;
+  currentStage: StageId;
+  sourceVaultId?: string;
+  stageData: PieceStageData;
+  tasksByStage: Record<StageId, PieceTask[]>;
+  /** Hours spent per stage, keyed by StageId. Optional; absent keys are treated as 0. */
+  hoursPerStage?: Partial<Record<StageId, number>>;
+  createdAt: number;
+  doneAt?: number;
+}
+
+export function emptyStageData(): PieceStageData {
+  return {
+    brainstorm: { hook: '', platforms: [], angleNotes: '' },
+    preproduction: {
+      script: '',
+      shotList: [],
+      storyboardImageDataUrls: [],
+      logisticsLocation: '',
+      logisticsProps: '',
+      logisticsWardrobe: '',
+      shootDate: undefined,
+      collaboratorName: '',
+      collaboratorRole: '',
+      references: [],
+    },
+    production: { setNotes: '', shootDone: false, shootDoneAt: undefined },
+    postproduction: {
+      editChecklist: {
+        roughCut: false,
+        audio: false,
+        color: false,
+        captionsOnScreen: false,
+        music: false,
+        finalCut: false,
+      },
+      hookOnScreen: '',
+      captionsPerPlatform: {},
+      hashtags: '',
+      musicCredits: '',
+      reviewExternalLink: '',
+      reviewComments: '',
+    },
+    publish: { schedule: [] },
+  };
+}
+
+export interface SuggestedTaskDef {
+  key: string;
+  title: string;
+}
+
+export const SUGGESTED_TASKS: Record<StageId, SuggestedTaskDef[]> = {
+  brainstorm: [
+    { key: 'brainstorm.hook-locked', title: 'Hook' },
+    { key: 'brainstorm.platforms-picked', title: 'Platforms' },
+  ],
+  preproduction: [
+    { key: 'preproduction.script-written', title: 'Script written' },
+    { key: 'preproduction.shot-list-ready', title: 'Shot list ready' },
+    { key: 'preproduction.shoot-date-set', title: 'Shoot date set' },
+  ],
+  production: [
+    { key: 'production.shots-captured', title: 'All shots captured (or reshoot-flagged)' },
+    { key: 'production.shoot-done', title: 'Shoot marked done' },
+  ],
+  postproduction: [
+    { key: 'postproduction.cut-final', title: 'Cut final' },
+    { key: 'postproduction.captions-written', title: 'Captions written per platform' },
+    { key: 'postproduction.hashtags-ready', title: 'Hashtags ready' },
+  ],
+  publish: [
+    { key: 'publish.scheduled', title: 'Scheduled for each platform' },
+    { key: 'publish.posted', title: 'Posted on each platform' },
+  ],
+};
+
+export function emptyTasksByStage(): Record<StageId, PieceTask[]> {
+  const out = {} as Record<StageId, PieceTask[]>;
+  for (const stage of STAGE_ORDER) {
+    out[stage] = SUGGESTED_TASKS[stage].map((d) => ({
+      id: `t-${stage}-${d.key}`,
+      suggestedKey: d.key,
+      title: d.title,
+      status: 'todo' as TaskStatus,
+    }));
+  }
+  return out;
+}
