diff --git a/src/screens/Vault.tsx b/src/screens/Vault.tsx
--- /dev/null
+++ b/src/screens/Vault.tsx
@@ -0,0 +1,85 @@
+import { useState } from 'react';
+import { useNavigate } from 'react-router-dom';
+import { PageHeader } from '../shell/PageHeader';
+import {
+  createVaultIdea,
+  deleteVaultIdea,
+  promoteVaultToPiece,
+  updateVaultIdea,
+  useProductionStore,
+} from '../data/production-store';
+import { VaultCard } from '../components/production/VaultCard';
+import { VaultEditor } from '../components/production/VaultEditor';
+import type { VaultIdea } from '../types/production';
+
+export function Vault() {
+  const [state] = useProductionStore();
+  const [editing, setEditing] = useState<VaultIdea | null | undefined>(undefined);
+  const navigate = useNavigate();
+
+  const handlePromote = (vaultId: string) => {
+    const piece = promoteVaultToPiece(vaultId);
+    if (piece) navigate(`/screens/piece/${piece.id}`);
+  };
+
+  return (
+    <div style={{ padding: '24px 32px' }}>
+      <PageHeader
+        title="Vault"
+        subtitle="Raw ideas before they enter the pipeline"
+        actions={
+          <button
+            onClick={() => setEditing(null)}
+            style={{ padding: '8px 14px', background: 'var(--ink)', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}
+          >
+            + New idea
+          </button>
+        }
+      />
+      <div
+        style={{
+          marginTop: 24,
+          display: 'grid',
+          gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))',
+          gap: 16,
+        }}
+      >
+        {state.vault.length === 0 && (
+          <div style={{ color: 'var(--muted)', fontSize: 14, gridColumn: '1 / -1' }}>
+            No ideas yet — click "+ New idea" to capture one.
+          </div>
+        )}
+        {state.vault.map((idea) => (
+          <VaultCard
+            key={idea.id}
+            idea={idea}
+            onClick={() => setEditing(idea)}
+            onPromote={() => handlePromote(idea.id)}
+          />
+        ))}
+      </div>
+      {editing !== undefined && (
+        <VaultEditor
+          idea={editing}
+          onSave={(patch) => {
+            if (editing === null) {
+              createVaultIdea(patch);
+            } else {
+              updateVaultIdea(editing.id, patch);
+            }
+            setEditing(undefined);
+          }}
+          onCancel={() => setEditing(undefined)}
+          onDelete={
+            editing
+              ? () => {
+                  deleteVaultIdea(editing.id);
+                  setEditing(undefined);
+                }
+              : undefined
+          }
+        />
+      )}
+    </div>
+  );
+}
