@@ -0,0 +1,52 @@
+// Predicate engine for TaskDefinition.autoCompleteWhen.
+// Extracted from production-store.ts so predicates have a dedicated home
+// and can be tested in isolation.
+//
+// TODO: add new predicates here, e.g. shotListNonEmpty, captionDraftReady
+
+import type { Piece } from '../types/production';
+import type { TaskDefinition } from '../types/saas';
+import type { TaskStatus } from '../types/production';
+
+/**
+ * Evaluate a TaskDefinition.autoCompleteWhen predicate against a piece.
+ * Returns 'done' / 'todo' based on the predicate result.
+ *
+ * Defensive access (??/optional chaining) guards against hand-edited or
+ * migrated localStorage rows where fields may be absent.
+ */
+export function evaluateAutoCompletePredicate(
+  predicate: TaskDefinition['autoCompleteWhen'],
+  piece: Piece,
+): TaskStatus {
+  switch (predicate) {
+    case 'hookNonEmpty':
+      return (piece.stageData.brainstorm?.hook ?? '').trim().length > 0 ? 'done' : 'todo';
+    case 'shotListNonEmpty':
+      return (piece.stageData.preproduction?.shotList ?? []).length >= 1 ? 'done' : 'todo';
+    case 'productionNotesNonEmpty':
+      // Maps to preproduction.script (the "Script / outline" field)
+      return (piece.stageData.preproduction?.script ?? '').trim().length > 0 ? 'done' : 'todo';
+    case 'footageNotesNonEmpty':
+      // Maps to production.setNotes (the "Set notes" field)
+      return (piece.stageData.production?.setNotes ?? '').trim().length > 0 ? 'done' : 'todo';
+    case 'editingNotesNonEmpty':
+      // Maps to postproduction.reviewComments (the "Review" notes field)
+      return (piece.stageData.postproduction?.reviewComments ?? '').trim().length > 0 ? 'done' : 'todo';
+    case 'captionDraftNonEmpty':
+      // Done when any platform has a non-empty caption
+      return Object.values(piece.stageData.postproduction?.captionsPerPlatform ?? {}).some(
+        (c) => typeof c === 'string' && c.trim().length > 0,
+      )
+        ? 'done'
+        : 'todo';
+    case 'scheduleNonEmpty':
+      return (piece.stageData.publish?.schedule ?? []).length >= 1 ? 'done' : 'todo';
+    case 'allScheduledPosted': {
+      const schedule = piece.stageData.publish?.schedule ?? [];
+      return schedule.length >= 1 && schedule.every((row) => row.posted === true) ? 'done' : 'todo';
+    }
+    default:
+      return 'todo';
+  }
+}
