+import { useEffect } from 'react';
+import type { Piece, StageId } from '../../types/production';
+import { STAGE_LABEL } from '../../types/production';
+
+export function AdvanceModal({
+  piece,
+  nextStage,
+  incompleteTasks,
+  onConfirm,
+  onCancel,
+}: {
+  piece: Piece;
+  nextStage: StageId;
+  incompleteTasks: string[];
+  onConfirm: () => void;
+  onCancel: () => void;
+}) {
+  useEffect(() => {
+    const handler = (e: KeyboardEvent) => {
+      if (e.key === 'Escape') onCancel();
+    };
+    window.addEventListener('keydown', handler);
+    return () => window.removeEventListener('keydown', handler);
+  }, [onCancel]);
+
+  return (
+    <div
+      onClick={onCancel}
+      style={{
+        position: 'fixed',
+        inset: 0,
+        background: 'rgba(0,0,0,0.4)',
+        display: 'flex',
+        alignItems: 'center',
+        justifyContent: 'center',
+        // Above BottomTabBar (z:150) so the modal isn't obscured by the
+        // mobile tab strip; below the Sidebar drawer overlay (z:201) so
+        // drawer can override if both are open.
+        zIndex: 200,
+      }}
+    >
+      <div
+        onClick={(e) => e.stopPropagation()}
+        style={{
+          background: 'var(--bg)',
+          borderRadius: 12,
+          padding: 24,
+          width: 'min(480px, 92vw)',
+          border: '1px solid var(--line)',
+        }}
+      >
+        <h2 style={{ fontSize: 18, fontWeight: 600, marginBottom: 12 }}>
+          Advance to {STAGE_LABEL[nextStage]}?
+        </h2>
+        {incompleteTasks.length > 0 ? (
+          <>
+            <p style={{ fontSize: 14, color: 'var(--muted)', marginBottom: 8 }}>
+              {incompleteTasks.length} item{incompleteTasks.length === 1 ? '' : 's'} still unchecked:
+            </p>
+            <ul style={{ fontSize: 13, color: 'var(--muted)', paddingInlineStart: 20, marginBottom: 16 }}>
+              {incompleteTasks.map((t) => (
+                <li key={t}>{t}</li>
+              ))}
+            </ul>
+          </>
+        ) : (
+          <p style={{ fontSize: 14, color: 'var(--muted)', marginBottom: 16 }}>
+            All suggested items done. Ready to move {piece.title} forward.
+          </p>
+        )}
+        <div style={{ display: 'flex', gap: 8 }}>
+          <button
+            onClick={onConfirm}
+            style={{ padding: '8px 14px', background: 'var(--ink)', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}
+          >
+            Advance anyway
+          </button>
+          <button
+            onClick={onCancel}
+            style={{ padding: '8px 14px', background: 'transparent', color: 'var(--ink)', border: '1px solid var(--line)', borderRadius: 6, cursor: 'pointer' }}
+          >
+            Cancel
+          </button>
+        </div>
+      </div>
+    </div>
+  );
+}
