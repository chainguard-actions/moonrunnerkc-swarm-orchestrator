@@ -0,0 +1,76 @@
+import type { VaultIdea } from '../../types/production';
+
+export function VaultCard({
+  idea,
+  onClick,
+  onPromote,
+}: {
+  idea: VaultIdea;
+  onClick: () => void;
+  onPromote: () => void;
+}) {
+  const refCount = idea.references.length;
+  const promoted = idea.promotedPieceIds.length;
+  return (
+    <div
+      onClick={onClick}
+      style={{
+        border: '1px solid var(--line)',
+        borderRadius: 10,
+        padding: 14,
+        background: 'var(--surface)',
+        cursor: 'pointer',
+        display: 'flex',
+        flexDirection: 'column',
+        gap: 8,
+        minHeight: 140,
+      }}
+    >
+      <div style={{ fontWeight: 600, fontSize: 14 }}>{idea.title}</div>
+      <div
+        style={{
+          fontSize: 12,
+          color: 'var(--muted)',
+          flex: 1,
+          overflow: 'hidden',
+          display: '-webkit-box',
+          WebkitLineClamp: 4,
+          WebkitBoxOrient: 'vertical',
+          whiteSpace: 'pre-wrap',
+        }}
+      >
+        {idea.contentText || '(no content yet)'}
+      </div>
+      <div style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 11, color: 'var(--muted)' }}>
+        {idea.tags.length > 0 && (
+          <span>
+            {idea.tags.map((t) => `#${t}`).join(' ')}
+          </span>
+        )}
+        <span style={{ marginInlineStart: 'auto' }}>
+          {refCount > 0 && <span title="references">📎{refCount} </span>}
+          {promoted > 0 && <span title="promoted">→ {promoted} piece{promoted === 1 ? '' : 's'}</span>}
+        </span>
+      </div>
+      <button
+        onClick={(e) => {
+          e.stopPropagation();
+          onPromote();
+        }}
+        style={{
+          marginTop: 4,
+          padding: '6px 10px',
+          border: '1px solid var(--line)',
+          borderRadius: 6,
+          background: 'var(--ink)',
+          color: '#fff',
+          fontSize: 12,
+          fontWeight: 600,
+          cursor: 'pointer',
+        }}
+      >
+        Promote to Pipeline →
+      </button>
+    </div>
+  );
+}
diff --git a/src/components/production/VaultEditor.tsx b/src/components/production/VaultEditor.tsx
--- /dev/null
+++ b/src/components/production/VaultEditor.tsx
@@ -0,0 +1,126 @@
+import { useEffect, useState } from 'react';
+import type { VaultIdea } from '../../types/production';
+
+export function VaultEditor({
+  idea,
+  onSave,
+  onCancel,
+  onDelete,
+}: {
+  idea: VaultIdea | null;
+  onSave: (patch: { title: string; contentText: string; notes: string; tags: string[] }) => void;
+  onCancel: () => void;
+  onDelete?: () => void;
+}) {
+  const [title, setTitle] = useState(idea?.title ?? '');
+  const [contentText, setContentText] = useState(idea?.contentText ?? '');
+  const [notes, setNotes] = useState(idea?.notes ?? '');
+  const [tagsInput, setTagsInput] = useState((idea?.tags ?? []).join(', '));
+
+  useEffect(() => {
+    setTitle(idea?.title ?? '');
+    setContentText(idea?.contentText ?? '');
+    setNotes(idea?.notes ?? '');
+    setTagsInput((idea?.tags ?? []).join(', '));
+  }, [idea?.id]);
+
+  const handleSave = () => {
+    const tags = tagsInput
+      .split(',')
+      .map((t) => t.trim().replace(/^#/, ''))
+      .filter(Boolean);
+    onSave({
+      title: title.trim() || 'Untitled idea',
+      contentText,
+      notes,
+      tags,
+    });
+  };
+
+  return (
+    <div
+      style={{
+        position: 'fixed',
+        inset: 0,
+        background: 'rgba(0,0,0,0.4)',
+        display: 'flex',
+        alignItems: 'center',
+        justifyContent: 'center',
+        // Above BottomTabBar (z:150); below Sidebar drawer overlay (z:201).
+        zIndex: 200,
+      }}
+      onClick={onCancel}
+    >
+      <div
+        onClick={(e) => e.stopPropagation()}
+        style={{
+          background: 'var(--bg)',
+          borderRadius: 12,
+          padding: 24,
+          width: 'min(640px, 92vw)',
+          maxHeight: '88vh',
+          overflowY: 'auto',
+          border: '1px solid var(--line)',
+        }}
+      >
+        <h2 style={{ fontSize: 18, fontWeight: 600, marginBottom: 16 }}>
+          {idea ? 'Edit idea' : 'New idea'}
+        </h2>
+        <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
+          <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+            Title
+            <input
+              type="text"
+              value={title}
+              onChange={(e) => setTitle(e.target.value)}
+              placeholder="Untitled idea"
+              style={{ width: '100%', marginTop: 4, padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+            />
+          </label>
+          <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+            Paste from AI chat / brainstorm
+            <textarea
+              value={contentText}
+              onChange={(e) => setContentText(e.target.value)}
+              placeholder="Paste your AI conversation, ideas, half-thoughts here…"
+              rows={10}
+              style={{ width: '100%', marginTop: 4, padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+            />
+          </label>
+          <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+            Notes
+            <textarea
+              value={notes}
+              onChange={(e) => setNotes(e.target.value)}
+              rows={3}
+              style={{ width: '100%', marginTop: 4, padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+            />
+          </label>
+          <label style={{ fontSize: 12, color: 'var(--muted)' }}>
+            Tags (comma-separated)
+            <input
+              type="text"
+              value={tagsInput}
+              onChange={(e) => setTagsInput(e.target.value)}
+              placeholder="fitness, productivity"
+              style={{ width: '100%', marginTop: 4, padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6 }}
+            />
+          </label>
+        </div>
+        <div style={{ display: 'flex', gap: 8, marginTop: 16 }}>
+          <button onClick={handleSave} style={{ padding: '8px 14px', background: 'var(--ink)', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}>
+            Save
+          </button>
+          <button onClick={onCancel} style={{ padding: '8px 14px', background: 'transparent', color: 'var(--ink)', border: '1px solid var(--line)', borderRadius: 6, cursor: 'pointer' }}>
+            Cancel
+          </button>
+          {onDelete && idea && (
+            <button onClick={onDelete} style={{ marginInlineStart: 'auto', padding: '8px 14px', background: 'transparent', color: 'var(--red, #c33)', border: '1px solid var(--line)', borderRadius: 6, cursor: 'pointer' }}>
+              Delete
+            </button>
+          )}
+        </div>
+      </div>
+    </div>
+  );
+}
