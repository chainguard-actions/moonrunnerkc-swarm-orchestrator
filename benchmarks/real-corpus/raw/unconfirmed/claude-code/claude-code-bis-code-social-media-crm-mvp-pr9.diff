+                    {PLATFORM_LABEL[sa.platform as keyof typeof PLATFORM_LABEL] ?? sa.platform}
+                  </span>
+                  <span style={{ flex: 1, color: 'var(--ink, #111)' }}>{sa.handle}</span>
+                  {href ? (
+                    <a
+                      href={href}
+                      target="_blank"
+                      rel="noopener noreferrer"
+                      style={{ fontSize: 11, color: 'var(--green, #22c55e)', textDecoration: 'none' }}
