diff --git a/src/components/production/TaskList.tsx b/src/components/production/TaskList.tsx
--- /dev/null
+++ b/src/components/production/TaskList.tsx
@@ -0,0 +1,205 @@
+import { useState } from 'react';
+import type { Piece, PieceTask, StageId } from '../../types/production';
+import {
+  addLibraryTaskAndSnapshot,
+  removeWorkspaceTaskFromPiece,
+  renamePieceTasksBySuggestedKey,
+  setTaskStatus,
+  getEffectiveTaskStatus,
+  isAutoDerivedTask,
+} from '../../data/production-store';
+import { findTaskDefById, updateTaskDef } from '../../data/task-definitions-store';
+import { useCan } from '../../data/use-can';
+import { Icons } from '../../icons';
+import { AddTaskDialog } from './AddTaskDialog';
+import type { TaskDefinition } from '../../types/saas';
+import { useIsMobile } from '../../data/route-buckets';
+
+export function TaskList({ piece, stage }: { piece: Piece; stage: StageId }) {
+  const tasks = piece.tasksByStage[stage];
+  const [dialogOpen, setDialogOpen] = useState(false);
+  const [editingTaskId, setEditingTaskId] = useState<string | null>(null);
+
+  // Gate "+ add task" — matrix-driven via useCan.
+  // Anyone who can CREATE_PIECE (Creator, PM, Administrator) can also add tasks.
+  const canManageTasks = useCan('CREATE_PIECE');
+
+  function handleAdd(name: string, type: TaskDefinition['type'], options?: string[]) {
+    addLibraryTaskAndSnapshot(piece.id, stage, name, type, options);
+  }
+
+  function handleEdit(name: string, _type: TaskDefinition['type'], options?: string[]) {
+    if (!editingTaskId) return;
+    const task = tasks.find((t) => t.id === editingTaskId);
+    if (!task?.suggestedKey) return;
+    // Update the library definition (name + options; type is locked in edit mode)
+    updateTaskDef(task.suggestedKey, { name, options });
+    // Propagate the new title to all pieces that snapshotted this def
+    renamePieceTasksBySuggestedKey(task.suggestedKey, name);
+    setEditingTaskId(null);
+  }
+
+  const editingTask = editingTaskId ? tasks.find((t) => t.id === editingTaskId) ?? null : null;
+  const editingDef = editingTask?.suggestedKey ? findTaskDefById(editingTask.suggestedKey) : null;
+
+  return (
+    <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
+      <div style={{ fontSize: 12, fontWeight: 600, color: 'var(--muted)', textTransform: 'uppercase', letterSpacing: 0.4 }}>
+        Tasks
+      </div>
+      <ul style={{ display: 'flex', flexDirection: 'column', gap: 4, listStyle: 'none', padding: 0, margin: 0 }}>
+        {tasks.map((task) => (
+          <TaskRow
+            key={task.id}
+            piece={piece}
+            stage={stage}
+            task={task}
+            onEdit={canManageTasks ? () => setEditingTaskId(task.id) : undefined}
+          />
+        ))}
+      </ul>
+      {canManageTasks ? (
+        <button
+          onClick={() => setDialogOpen(true)}
+          style={{
+            alignSelf: 'flex-start',
+            padding: '5px 10px',
+            background: 'transparent',
+            color: 'var(--ink-2)',
+            border: '1px solid var(--line)',
+            borderRadius: 6,
+            fontSize: 12,
+            cursor: 'pointer',
+          }}
+        >
+          + Add task
+        </button>
+      ) : null}
+      {dialogOpen && (
+        <AddTaskDialog
+          onAdd={handleAdd}
+          onClose={() => setDialogOpen(false)}
+        />
+      )}
+      {editingTaskId && editingDef && (
+        <AddTaskDialog
+          mode="edit"
+          initial={{
+            name: editingDef.name,
+            type: editingDef.type,
+            options: editingDef.options,
+          }}
+          onAdd={handleEdit}
+          onClose={() => setEditingTaskId(null)}
+        />
+      )}
+    </div>
+  );
+}
+
+function TaskRow({
+  piece,
+  stage,
+  task,
+  onEdit,
+}: {
+  piece: Piece;
+  stage: StageId;
+  task: PieceTask;
+  onEdit?: () => void;
+}) {
+  const def: TaskDefinition | null = task.suggestedKey ? findTaskDefById(task.suggestedKey) : null;
+  const isMobile = useIsMobile();
+
+  const isSystemTask = def ? def.workspaceId === 'system' : !task.suggestedKey ? false : true;
+  const isAutoDerived = isAutoDerivedTask(task);
+  const isDone = getEffectiveTaskStatus(piece, task) === 'done';
+
+  const handleChange = isAutoDerived
+    ? () => {}
+    : (e: React.ChangeEvent<HTMLInputElement>) =>
+        setTaskStatus(piece.id, stage, task.id, e.target.checked ? 'done' : 'todo');
+
+  return (
+    <li
+      style={{
+        display: 'flex',
+        alignItems: 'center',
+        gap: 8,
+        padding: '3px 0',
+        fontSize: 13,
+      }}
+    >
+      <input
+        type="checkbox"
+        checked={isDone}
+        onChange={handleChange}
+        disabled={isAutoDerived}
+        title={isAutoDerived ? 'Auto-checked from your inputs' : undefined}
+        style={{ flexShrink: 0 }}
+      />
+      <span
+        style={{
+          flex: 1,
+          textDecoration: isDone ? 'line-through' : 'none',
+          color: isDone ? 'var(--muted)' : 'inherit',
+          fontWeight: isSystemTask ? 500 : 400,
+          overflow: 'hidden',
+          textOverflow: 'ellipsis',
+          whiteSpace: 'nowrap',
+        }}
+      >
+        {task.title}
+      </span>
+      {/* Pencil icon — available for all tasks (system and user-added) */}
+      {onEdit && (
+        <button
+          onClick={onEdit}
+          title="Edit task"
+          aria-label="Edit task"
+          style={{
+            background: 'transparent',
+            border: 'none',
+            color: 'var(--muted)',
+            cursor: 'pointer',
+            // Hit-area floor 44×44 on mobile (cycle 2 finding C2-D-5); the
+            // pencil glyph stays small but the tappable box meets WCAG 2.5.5.
+            padding: isMobile ? '12px' : '0 2px',
+            minWidth: isMobile ? 44 : undefined,
+            minHeight: isMobile ? 44 : undefined,
+            flexShrink: 0,
+            display: 'flex',
+            alignItems: 'center',
+            justifyContent: 'center',
+          }}
+        >
+          <Icons.Edit size={12} />
+        </button>
+      )}
+      {/* × removes the task from this piece. For system tasks (Hook/Platforms) the
+          system TaskDefinition stays in the library — only this piece's snapshot is
+          dropped. For user-added tasks the workspace def is also deleted. */}
+      <button
+        onClick={() => removeWorkspaceTaskFromPiece(piece.id, stage, task.id)}
+        title={isSystemTask ? 'Remove from this piece (keeps in library)' : 'Remove task'}
+        style={{
+          background: 'transparent',
+          border: 'none',
+          color: 'var(--muted)',
+          cursor: 'pointer',
+          fontSize: 14,
+          // Hit-area floor 44×44 on mobile (cycle 2 finding C2-D-5).
+          padding: isMobile ? '12px' : '0 2px',
+          minWidth: isMobile ? 44 : undefined,
+          minHeight: isMobile ? 44 : undefined,
+          flexShrink: 0,
+          display: 'flex',
+          alignItems: 'center',
+          justifyContent: 'center',
+        }}
+      >
+        ×
+      </button>
+    </li>
+  );
+}
diff --git a/src/components/production/TaskTypeRenderer.tsx b/src/components/production/TaskTypeRenderer.tsx
--- /dev/null
+++ b/src/components/production/TaskTypeRenderer.tsx
@@ -0,0 +1,253 @@
+/**
+ * TaskTypeRenderer — renders a type-specific input for a PieceTask.
+ *
+ * Used by TaskList to show the appropriate form control based on the task's
+ * linked TaskDefinition.type. Checkbox tasks are handled by the parent
+ * (auto-derived or manual tick); this component renders the value input for
+ * text, dropdown, multiselect, date, number, and link types.
+ */
+
+import { useState } from 'react';
+import type { PieceTask } from '../../types/production';
+import type { TaskDefinition } from '../../types/saas';
+
+const inputStyle: React.CSSProperties = {
+  width: '100%',
+  padding: '5px 8px',
+  border: '1px solid var(--line)',
+  borderRadius: 6,
+  fontSize: 12,
+  background: 'var(--surface, #fff)',
+  color: 'var(--ink)',
+  outline: 'none',
+  boxSizing: 'border-box',
+};
+
+interface Props {
+  task: PieceTask;
+  def: TaskDefinition;
+  onChange: (value: PieceTask['value']) => void;
+}
+
+export function TaskTypeRenderer({ task, def, onChange }: Props) {
+  const { type, options } = def;
+  const rawValue = task.value;
+
+  // Checkbox type is handled by the parent TaskRow (as an auto-derived or manual tick).
+  // We should not render a separate control for it here.
+  if (type === 'checkbox') return null;
+
+  if (type === 'text' || type === 'link') {
+    const strVal = typeof rawValue === 'string' ? rawValue : '';
+    return (
+      <input
+        type={type === 'link' ? 'url' : 'text'}
+        value={strVal}
+        placeholder={type === 'link' ? 'https://…' : 'Enter value…'}
+        onChange={(e) => onChange(e.target.value)}
+        style={inputStyle}
+      />
+    );
+  }
+
+  if (type === 'textarea') {
+    const strVal = typeof rawValue === 'string' ? rawValue : '';
+    return (
+      <textarea
+        value={strVal}
+        rows={4}
+        placeholder="Enter text…"
+        onChange={(e) => onChange(e.target.value)}
+        style={{
+          ...inputStyle,
+          minHeight: 80,
+          resize: 'vertical',
+          fontFamily: 'inherit',
+        }}
+      />
+    );
+  }
+
+  if (type === 'number') {
+    const numVal = typeof rawValue === 'number' ? String(rawValue) : '';
+    return (
+      <input
+        type="number"
+        value={numVal}
+        placeholder="0"
+        onChange={(e) => {
+          const n = parseFloat(e.target.value);
+          onChange(Number.isFinite(n) ? n : undefined);
+        }}
+        style={inputStyle}
+      />
+    );
+  }
+
+  if (type === 'date') {
+    const dateVal = typeof rawValue === 'string' ? rawValue : '';
+    return (
+      <input
+        type="date"
+        value={dateVal}
+        onChange={(e) => onChange(e.target.value)}
+        style={inputStyle}
+      />
+    );
+  }
+
+  if (type === 'dropdown') {
+    const strVal = typeof rawValue === 'string' ? rawValue : '';
+    const opts = options ?? [];
+    return (
+      <select
+        value={strVal}
+        onChange={(e) => onChange(e.target.value)}
+        style={{ ...inputStyle, appearance: 'auto' }}
+      >
+        <option value="">— pick one —</option>
+        {opts.map((o) => (
+          <option key={o} value={o}>
+            {o}
+          </option>
+        ))}
+      </select>
+    );
+  }
+
+  // 'list' — array of free-text items, mirroring the shot-list UI.
+  // Each item is editable; × deletes; an empty trailing input adds on Enter.
+  if (type === 'list') {
+    const items: string[] = Array.isArray(rawValue) ? (rawValue as string[]) : [];
+    return (
+      <ListInput items={items} onChange={onChange as (next: string[]) => void} />
+    );
+  }
+
+  if (type === 'multiselect') {
+    const selected: string[] = Array.isArray(rawValue) ? (rawValue as string[]) : [];
+    const opts = options ?? [];
+    const toggle = (opt: string) => {
+      const next = selected.includes(opt)
+        ? selected.filter((v) => v !== opt)
+        : [...selected, opt];
+      onChange(next);
+    };
+    return (
+      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 4, marginTop: 2 }}>
+        {opts.map((opt) => {
+          const active = selected.includes(opt);
+          return (
+            <button
+              key={opt}
+              type="button"
+              onClick={() => toggle(opt)}
+              style={{
+                padding: '3px 8px',
+                fontSize: 11,
+                borderRadius: 999,
+                border: '1px solid ' + (active ? 'var(--ink)' : 'var(--line)'),
+                background: active ? 'var(--ink)' : 'transparent',
+                color: active ? '#fff' : 'var(--ink)',
+                cursor: 'pointer',
+                fontWeight: active ? 600 : 400,
+                transition: 'all 120ms',
+              }}
+            >
+              {opt}
+            </button>
+          );
+        })}
+      </div>
+    );
+  }
+
+  if (type === 'checklist') {
+    const selected: string[] = Array.isArray(rawValue) ? (rawValue as string[]) : [];
+    const opts = options ?? [];
+    const toggle = (opt: string) => {
+      const next = selected.includes(opt)
+        ? selected.filter((v) => v !== opt)
+        : [...selected, opt];
+      onChange(next);
+    };
+    return (
+      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 12 }}>
+        {opts.map((opt) => (
+          <label key={opt} style={{ display: 'inline-flex', alignItems: 'center', gap: 6, fontSize: 13 }}>
+            <input
+              type="checkbox"
+              checked={selected.includes(opt)}
+              onChange={() => toggle(opt)}
+            />
+            {opt}
+          </label>
+        ))}
+      </div>
+    );
+  }
+
+  return null;
+}
+
+/**
+ * ListInput — free-text item list with add-on-Enter + delete-per-row,
+ * mirroring the existing shot-list UI in StagePreProduction.
+ */
+function ListInput({ items, onChange }: { items: string[]; onChange: (next: string[]) => void }) {
+  const [draft, setDraft] = useState('');
+
+  function commitDraft() {
+    const trimmed = draft.trim();
+    if (!trimmed) return;
+    onChange([...items, trimmed]);
+    setDraft('');
+  }
+
+  function updateAt(idx: number, value: string) {
+    const next = items.slice();
+    next[idx] = value;
+    onChange(next);
+  }
+
+  function removeAt(idx: number) {
+    onChange(items.filter((_, i) => i !== idx));
+  }
+
+  return (
+    <ul style={{ listStyle: 'none', padding: 0, margin: 0, display: 'flex', flexDirection: 'column', gap: 6 }}>
+      {items.map((item, idx) => (
+        <li key={idx} style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 13 }}>
+          <span style={{ width: 22, color: 'var(--muted)', textAlign: 'right' }}>{idx + 1}.</span>
+          <input
+            type="text"
+            value={item}
+            onChange={(e) => updateAt(idx, e.target.value)}
+            style={{ flex: 1, padding: '6px 8px', border: '1px solid var(--line)', borderRadius: 6 }}
+          />
+          <button
+            onClick={() => removeAt(idx)}
+            title="Delete item"
+            aria-label="Delete item"
+            style={{ background: 'transparent', border: 'none', color: 'var(--muted)', cursor: 'pointer', fontSize: 16 }}
+          >
+            ×
+          </button>
+        </li>
+      ))}
+      <li style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
+        <span style={{ width: 22 }} />
+        <input
+          type="text"
+          value={draft}
+          onChange={(e) => setDraft(e.target.value)}
+          onKeyDown={(e) => {
+            if (e.key === 'Enter') commitDraft();
+          }}
+          placeholder="Add an item — press Enter"
+          style={{ flex: 1, padding: '6px 8px', border: '1px dashed var(--line)', borderRadius: 6, fontSize: 13 }}
+        />
+      </li>
+    </ul>
+  );
+}
diff --git a/src/components/production/UserTasksSection.tsx b/src/components/production/UserTasksSection.tsx
--- /dev/null
+++ b/src/components/production/UserTasksSection.tsx
@@ -0,0 +1,58 @@
+/**
+ * UserTasksSection — renders the user-added tasks for a stage in the LEFT panel.
+ *
+ * For each non-system PieceTask on the given piece/stage, it renders a FieldCard
+ * with a TaskTypeRenderer input inside.  System tasks (workspaceId === 'system')
+ * are excluded here — they have their own dedicated FieldCard sections in the
+ * Stage* components.
+ */
+
+import type { Piece, StageId } from '../../types/production';
+import { setTaskValue } from '../../data/production-store';
+import { findTaskDefById } from '../../data/task-definitions-store';
+import { FieldCard } from './FieldCard';
+import { TaskTypeRenderer } from './TaskTypeRenderer';
+
+interface Props {
+  piece: Piece;
+  stage: StageId;
+}
+
+export function UserTasksSection({ piece, stage }: Props) {
+  const tasks = piece.tasksByStage[stage];
+
+  // Filter to user-added tasks only: those with a suggestedKey that resolves to a
+  // non-system TaskDefinition.  System tasks (workspaceId === 'system') are shown
+  // via their dedicated Stage* FieldCard sections.
+  const userTasks = tasks.filter((t) => {
+    if (!t.suggestedKey) return false;
+    const def = findTaskDefById(t.suggestedKey);
+    if (!def) return false;
+    return def.workspaceId !== 'system';
+  });
+
+  if (userTasks.length === 0) return null;
+
+  return (
+    <>
+      {userTasks.map((task) => {
+        const def = findTaskDefById(task.suggestedKey!)!;
+        // Checkbox-type tasks have no separate input widget — their status is
+        // toggled via the RIGHT panel checklist.  Still render a FieldCard so
+        // the user sees the task label on the left, but omit the input.
+        const hasInput = def.type !== 'checkbox';
+        return (
+          <FieldCard key={task.id} label={task.title}>
+            {hasInput && (
+              <TaskTypeRenderer
+                task={task}
+                def={def}
+                onChange={(value) => setTaskValue(piece.id, stage, task.id, value)}
+              />
+            )}
+          </FieldCard>
+        );
+      })}
+    </>
+  );
+}
