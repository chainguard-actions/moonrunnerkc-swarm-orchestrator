+                      </td>
+                      <td style={{ padding: '12px 16px', color: 'var(--ink-3)', fontSize: 12 }}>
+                        {client.contactEmail ?? '—'}
+                      </td>
+                      <td style={{ padding: '12px 16px' }}>
+                        <span
+                          style={{
+                            display: 'inline-block',
+                            padding: '2px 8px',
+                            borderRadius: 12,
+                            fontSize: 11,
