diff --git a/src/settings/WorkspaceInviteModal.tsx b/src/settings/WorkspaceInviteModal.tsx
--- /dev/null
+++ b/src/settings/WorkspaceInviteModal.tsx
@@ -0,0 +1,358 @@
+// WorkspaceInviteModal — modal form for inviting a new workspace member.
+//
+// Collects: email (required), role (dropdown, non-Administrator roles only),
+// and — when role === 'Sponsor' — a client selector.
+//
+// On submit: calls workspace-invites-store.createInvite and displays the
+// copyable invite URL. No email is actually sent (Phase 3 is frontend-only).
+
+import { useState, type FormEvent } from 'react';
+import { useSession } from '../data/session-store';
+import { createInvite } from '../data/workspace-invites-store';
+import { listClientsForWorkspace } from '../data/client-store';
+import type { Role } from '../types/saas';
+
+const NON_ADMIN_ROLES: Exclude<Role, 'Administrator'>[] = [
+  'PM',
+  'Production',
+  'Marketing',
+  'Creator',
+  'Sponsor',
+];
+
+interface Props {
+  workspaceId: string;
+  onClose: () => void;
+  /** Pre-select a role when opening the modal. Defaults to 'PM'. */
+  initialRole?: Exclude<Role, 'Administrator'>;
+  /** Pre-select a client when opening with role Sponsor. */
+  initialClientId?: string;
+}
+
+// Email shape validation — basic, sufficient for demo.
+function isValidEmail(v: string): boolean {
+  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
+}
+
+export function WorkspaceInviteModal({ workspaceId, onClose, initialRole, initialClientId }: Props) {
+  const session = useSession();
+
+  const [email, setEmail] = useState('');
+  const [role, setRole] = useState<Exclude<Role, 'Administrator'>>(initialRole ?? 'PM');
+  const [clientId, setClientId] = useState(initialClientId ?? '');
+  const [error, setError] = useState<string | null>(null);
+  const [inviteUrl, setInviteUrl] = useState<string | null>(null);
+  const [copied, setCopied] = useState<'idle' | 'copied' | 'error'>('idle');
+
+  const clients = listClientsForWorkspace(workspaceId);
+  const currentAccountId = session.currentAccountId;
+
+  // Disable submit when role is Sponsor but no clients exist yet (can't link the invite).
+  const submitDisabled = role === 'Sponsor' && clients.length === 0;
+
+  function handleSubmit(e: FormEvent) {
+    e.preventDefault();
+    setError(null);
+
+    if (!isValidEmail(email)) {
+      setError('Please enter a valid email address.');
+      return;
+    }
+
+    if (role === 'Sponsor' && !clientId) {
+      setError('Please select a client for the Sponsor role.');
+      return;
+    }
+
+    if (!currentAccountId) {
+      setError('No active session — please log in again.');
+      return;
+    }
+
+    const token = createInvite(
+      workspaceId,
+      email,
+      role,
+      role === 'Sponsor' ? clientId || undefined : undefined,
+      currentAccountId,
+    );
+
+    const url = `${window.location.origin}/invite/${token}`;
+    setInviteUrl(url);
+  }
+
+  async function handleCopy() {
+    if (!inviteUrl) return;
+    try {
+      await navigator.clipboard.writeText(inviteUrl);
+      setCopied('copied');
+      setTimeout(() => setCopied('idle'), 2000);
+    } catch {
+      setCopied('error');
+    }
+  }
+
+  const inputStyle = {
+    border: '1px solid var(--line-2)',
+    borderRadius: 8,
+    padding: '8px 12px',
+    fontSize: 13,
+    background: 'var(--surface)',
+    color: 'var(--ink)',
+    outline: 'none',
+    width: '100%',
+    boxSizing: 'border-box' as const,
+  } as const;
+
+  return (
+    /* Backdrop */
+    <div
+      style={{
+        position: 'fixed',
+        inset: 0,
+        background: 'rgba(0,0,0,0.45)',
+        display: 'flex',
+        alignItems: 'center',
+        justifyContent: 'center',
+        zIndex: 1000,
+      }}
+      onClick={(e) => {
+        if (e.target === e.currentTarget) onClose();
+      }}
+    >
+      <div
+        style={{
+          background: 'var(--surface)',
+          border: '1px solid var(--line-2)',
+          borderRadius: 12,
+          padding: 28,
+          width: '100%',
+          maxWidth: 420,
+          boxShadow: '0 8px 32px rgba(0,0,0,0.18)',
+        }}
+      >
+        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 20 }}>
+          <div>
+            <div
+              style={{
+                fontSize: 11,
+                fontWeight: 600,
+                letterSpacing: '0.08em',
+                textTransform: 'uppercase',
+                color: 'var(--green)',
+                marginBottom: 2,
+              }}
+            >
+              Invite member
+            </div>
+            <h2 style={{ fontSize: 18, fontWeight: 600, color: 'var(--ink)', margin: 0 }}>
+              Send workspace invite
+            </h2>
+          </div>
+          <button
+            onClick={onClose}
+            style={{
+              background: 'transparent',
+              border: 'none',
+              fontSize: 20,
+              color: 'var(--ink-3)',
+              cursor: 'pointer',
+              lineHeight: 1,
+              padding: 4,
+            }}
+          >
+            ×
+          </button>
+        </div>
+
+        {inviteUrl ? (
+          /* Success state — show copyable URL */
+          <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
+            <p style={{ fontSize: 13, color: 'var(--ink-2)', margin: 0 }}>
+              Invite created! Share this link with <strong>{email}</strong>:
+            </p>
+            <div
+              style={{
+                background: 'var(--surface-2, var(--line))',
+                border: '1px solid var(--line-2)',
+                borderRadius: 8,
+                padding: '10px 14px',
+                fontSize: 12,
+                color: 'var(--ink-2)',
+                wordBreak: 'break-all',
+                fontFamily: 'monospace',
+              }}
+              data-testid="invite-url"
+            >
+              {inviteUrl}
+            </div>
+            <div style={{ display: 'flex', gap: 8 }}>
+              <button
+                onClick={handleCopy}
+                style={{
+                  flex: 1,
+                  padding: '9px 16px',
+                  background: copied === 'copied' ? 'var(--green)' : copied === 'error' ? 'var(--danger)' : 'var(--ink)',
+                  color: '#fff',
+                  border: 'none',
+                  borderRadius: 8,
+                  fontSize: 13,
+                  fontWeight: 600,
+                  cursor: 'pointer',
+                  transition: 'background 0.15s',
+                }}
+              >
+                {copied === 'copied' ? 'Copied!' : copied === 'error' ? 'Copy failed — select the URL above to copy manually' : 'Copy link'}
+              </button>
+              <button
+                onClick={onClose}
+                style={{
+                  padding: '9px 16px',
+                  background: 'transparent',
+                  border: '1px solid var(--line-2)',
+                  borderRadius: 8,
+                  fontSize: 13,
+                  color: 'var(--ink-2)',
+                  cursor: 'pointer',
+                }}
+              >
+                Done
+              </button>
+            </div>
+          </div>
+        ) : (
+          /* Form state */
+          <form
+            onSubmit={handleSubmit}
+            style={{ display: 'flex', flexDirection: 'column', gap: 16 }}
+          >
+            <label style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
+              <span style={{ fontSize: 12, fontWeight: 500, color: 'var(--ink-2)' }}>
+                Email address
+              </span>
+              <input
+                type="email"
+                value={email}
+                onChange={(e) => setEmail(e.target.value)}
+                placeholder="invitee@example.com"
+                required
+                autoComplete="off"
+                style={inputStyle}
+              />
+            </label>
+
+            <label style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
+              <span style={{ fontSize: 12, fontWeight: 500, color: 'var(--ink-2)' }}>
+                Role
+              </span>
+              <select
+                value={role}
+                onChange={(e) => {
+                  const newRole = e.target.value as Exclude<Role, 'Administrator'>;
+                  setRole(newRole);
+                  // When switching back to Sponsor, restore the pre-filled clientId so
+                  // the original initialClientId isn't lost (WARNING 6).
+                  setClientId(newRole === 'Sponsor' ? (initialClientId ?? '') : '');
+                }}
+                style={{ ...inputStyle, cursor: 'pointer' }}
+              >
+                {NON_ADMIN_ROLES.map((r) => (
+                  <option key={r} value={r}>
+                    {r}
+                  </option>
+                ))}
+              </select>
+            </label>
+
+            {role === 'Sponsor' && (
+              <label style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
+                <span style={{ fontSize: 12, fontWeight: 500, color: 'var(--ink-2)' }}>
+                  Client (required for Sponsor)
+                </span>
+                {clients.length === 0 ? (
+                  <div
+                    style={{
+                      padding: '10px 12px',
+                      border: '1px solid var(--line-2)',
+                      borderRadius: 8,
+                      fontSize: 12,
+                      color: 'var(--ink-3)',
+                      fontStyle: 'italic',
+                    }}
+                  >
+                    No clients yet. Create a client first via Settings → Clients.
+                  </div>
+                ) : (
+                  <select
+                    value={clientId}
+                    onChange={(e) => setClientId(e.target.value)}
+                    required
+                    style={{ ...inputStyle, cursor: 'pointer' }}
+                  >
+                    <option value="">Select a client…</option>
+                    {clients.map((c) => (
+                      <option key={c.id} value={c.id}>
+                        {c.name}
+                      </option>
+                    ))}
+                  </select>
+                )}
+              </label>
+            )}
+
+            {error && (
+              <div
+                style={{
+                  fontSize: 12,
+                  color: 'var(--danger)',
+                  background: 'var(--danger-soft)',
+                  border: '1px solid var(--danger)',
+                  borderRadius: 6,
+                  padding: '8px 12px',
+                }}
+              >
+                {error}
+              </div>
+            )}
+
+            <div style={{ display: 'flex', gap: 8, marginTop: 4 }}>
+              <button
+                type="submit"
+                disabled={submitDisabled}
+                style={{
+                  flex: 1,
+                  padding: '9px 16px',
+                  background: 'var(--green)',
+                  color: '#fff',
+                  border: 'none',
+                  borderRadius: 8,
+                  fontSize: 13,
+                  fontWeight: 600,
+                  cursor: submitDisabled ? 'not-allowed' : 'pointer',
+                  opacity: submitDisabled ? 0.5 : 1,
+                }}
+              >
+                Create invite
+              </button>
+              <button
+                type="button"
+                onClick={onClose}
+                style={{
+                  padding: '9px 16px',
+                  background: 'transparent',
+                  border: '1px solid var(--line-2)',
+                  borderRadius: 8,
+                  fontSize: 13,
+                  color: 'var(--ink-2)',
+                  cursor: 'pointer',
+                }}
+              >
+                Cancel
+              </button>
+            </div>
+          </form>
+        )}
+      </div>
+    </div>
+  );
+}
