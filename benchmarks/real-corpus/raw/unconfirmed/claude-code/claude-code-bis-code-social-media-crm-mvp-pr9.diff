+export function PieceDetail() {
+  const { id } = useParams<{ id: string }>();
+  const [state] = useProductionStore();
+  const piece = state.pieces.find((p) => p.id === id);
+  const [activeStage, setActiveStage] = useState<StageId | null>(null);
+  const [advanceOpen, setAdvanceOpen] = useState(false);
+  const isMobile = useIsMobile();
+
+  if (!piece) {
+    return (
+      <div style={{ padding: 32 }}>
+        <p style={{ color: 'var(--muted)' }}>
+          Piece not found. <Link to="/screens/pipeline">Back to Pipeline</Link>
+        </p>
+      </div>
+    );
+  }
+
+  const shownStage = activeStage ?? piece.currentStage;
+  const currentIdx = STAGE_ORDER.indexOf(piece.currentStage);
+  const nextStage: StageId | null =
+    currentIdx >= 0 && currentIdx < STAGE_ORDER.length - 1 ? STAGE_ORDER[currentIdx + 1] : null;
+
+  const incompleteSuggested = piece.tasksByStage[piece.currentStage]
+    .filter((t) => t.suggestedKey && getEffectiveTaskStatus(piece, t) !== 'done')
+    .map((t) => t.title);
+
+  const handleAdvanceClick = () => {
+    if (!nextStage) return;
+    setAdvanceOpen(true);
+  };
+
+  const handleConfirmAdvance = () => {
+    if (!nextStage) return;
+    advancePiece(piece.id);
+    setActiveStage(null);
+    setAdvanceOpen(false);
+  };
+
+  return (
+    <div style={{ padding: isMobile ? '16px 12px' : '24px 32px', display: 'flex', flexDirection: 'column', height: '100%' }}>
+      <Breadcrumbs
+        items={[
+          { label: 'Pipeline', to: '/screens/pipeline' },
+          { label: piece.title },
+        ]}
+      />
+      <PageHeader
+        title={
+          <InlineTitleEdit
+            title={piece.title}
+            onSave={(next) => updatePieceTitle(piece.id, next)}
+            ariaLabelEditing="Edit piece title"
+          />
+        }
+        subtitle={`Current stage: ${STAGE_LABEL[piece.currentStage]}`}
+        actions={
+          <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
+            {nextStage && (
+              <button
+                onClick={handleAdvanceClick}
+                style={{ padding: '8px 14px', background: 'var(--ink)', color: '#fff', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}
+              >
+                Advance →
+              </button>
+            )}
+          </div>
+        }
