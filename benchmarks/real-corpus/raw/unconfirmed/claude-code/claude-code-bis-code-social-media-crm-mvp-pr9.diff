@@ -0,0 +1,300 @@
+// ShareView — public read-only view for /share/recap/:token and /share/billing/:token.
+//
+// No SessionGuard — this is publicly accessible without auth.
+// Reads the token from URL params, validates it, then renders a minimal
+// read-only view of the client's data scoped to the token type.
+
+import { useParams } from 'react-router-dom';
+import { findShareToken } from '../data/share-tokens-store';
+import { getClient } from '../data/client-store';
+import { listSocialAccountsForClient } from '../data/social-account-store';
+import { PLATFORM_LABEL } from '../types/production';
+import { safeHttpUrl } from '../lib/sanitize-url';
+
+interface Props {
+  type: 'recap' | 'billing';
+}
+
+export function ShareView({ type }: Props) {
+  const { token } = useParams<{ token: string }>();
+
+  if (!token) {
+    return <ErrorCard />;
+  }
+
+  const shareToken = findShareToken(token);
+
+  // CRITICAL: also check that the token's type matches the route's type.
+  // Prevents a recap- token from being used at /share/billing/<token> and vice-versa.
+  if (!shareToken || shareToken.type !== type) {
+    return <ErrorCard />;
+  }
+
+  const client = getClient(shareToken.clientId);
+
+  if (!client) {
+    return <ErrorCard />;
+  }
+
+  const socialAccounts = listSocialAccountsForClient(client.id);
+
+  return (
+    <div
+      style={{
+        minHeight: '100vh',
+        background: 'var(--bg, #f5f5f5)',
+        display: 'flex',
+        flexDirection: 'column',
+        alignItems: 'center',
+        justifyContent: 'flex-start',
+        padding: '48px 16px 64px',
+        fontFamily: 'system-ui, sans-serif',
+      }}
+    >
+      {/* Logo / brand strip */}
+      <div
+        style={{
+          fontSize: 12,
+          fontWeight: 700,
+          letterSpacing: '0.1em',
+          textTransform: 'uppercase',
+          color: 'var(--ink-3, #aaa)',
+          marginBottom: 32,
+        }}
+      >
+        Tribe Studio
+      </div>
+
+      {/* Card */}
+      <div
+        style={{
+          background: 'var(--surface, #fff)',
+          border: '1px solid var(--line, #e5e5e5)',
+          borderRadius: 14,
+          padding: 32,
+          width: '100%',
+          maxWidth: 540,
+          boxShadow: '0 4px 24px rgba(0,0,0,0.07)',
+        }}
+      >
+        {/* Type badge */}
+        <div
+          style={{
+            display: 'inline-block',
+            padding: '3px 10px',
+            borderRadius: 20,
+            fontSize: 11,
+            fontWeight: 700,
+            letterSpacing: '0.08em',
+            textTransform: 'uppercase',
+            background: type === 'recap' ? 'var(--green, #22c55e)22' : '#f59e0b22',
+            color: type === 'recap' ? 'var(--green, #22c55e)' : '#f59e0b',
+            marginBottom: 16,
+          }}
+        >
+          {type === 'recap' ? 'Content Recap' : 'Billing Summary'}
+        </div>
+
+        {/* Client name */}
+        <h1
+          style={{
+            fontSize: 24,
+            fontWeight: 700,
+            color: 'var(--ink, #111)',
+            margin: '0 0 24px 0',
