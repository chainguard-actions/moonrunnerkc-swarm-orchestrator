--- /dev/null
+++ b/src/components/InlineTitleEdit.tsx
@@ -0,0 +1,185 @@
+import { useState, useRef, useEffect } from 'react';
+import { Icons } from '../icons';
+import { useIsMobile } from '../data/route-buckets';
+
+interface InlineTitleEditProps {
+  title: string;
+  onSave: (next: string) => void;
+  ariaLabelEditing?: string;
+}
+
+export function InlineTitleEdit({ title, onSave, ariaLabelEditing = 'Edit title' }: InlineTitleEditProps) {
+  const [editing, setEditing] = useState(false);
+  const [draft, setDraft] = useState(title);
+  const [hovering, setHovering] = useState(false);
+  const inputRef = useRef<HTMLInputElement>(null);
+  const isMobile = useIsMobile();
+
+  useEffect(() => {
+    if (!editing) setDraft(title);
+  }, [title, editing]);
+
+  const enterEdit = () => {
+    setDraft(title);
+    setEditing(true);
+  };
+
+  const handleSave = () => {
+    const trimmed = draft.trim();
+    if (!trimmed) return;
+    onSave(trimmed);
+    setEditing(false);
+    setHovering(false);
+  };
+
+  const handleCancel = () => {
+    setDraft(title);
+    setEditing(false);
+    setHovering(false);
+  };
+
+  const handleKeyDown = (e: React.KeyboardEvent<HTMLInputElement>) => {
+    if (e.key === 'Enter') {
+      e.preventDefault();
+      handleSave();
+    } else if (e.key === 'Escape') {
+      e.preventDefault();
+      handleCancel();
+    }
+  };
+
+  useEffect(() => {
+    if (editing && inputRef.current) {
+      inputRef.current.focus();
+      inputRef.current.select();
+    }
+  }, [editing]);
+
+  const isEmptyOrWhitespace = draft.trim().length === 0;
+
+  if (editing) {
+    return (
+      <span
+        style={{
+          // Wrap on mobile so Save/Cancel don't push off the right edge when
+          // the title is long; let the input expand to a sane max on desktop.
+          display: isMobile ? 'flex' : 'inline-flex',
+          flexWrap: isMobile ? 'wrap' : 'nowrap',
+          alignItems: 'center',
+          gap: 8,
+          maxWidth: '100%',
+        }}
+      >
+        <input
+          ref={inputRef}
+          type="text"
+          value={draft}
+          onChange={(e) => setDraft(e.target.value)}
+          onKeyDown={handleKeyDown}
+          // size= drives px-width by char count and overflows narrow viewports.
+          // On mobile, force input to flex-grow to fill the row; on desktop,
+          // keep size-based sizing but cap at a sane max.
+          {...(isMobile ? {} : { size: Math.max(draft.length, 8) })}
+          style={{
+            fontSize: 22,
+            fontWeight: 600,
+            letterSpacing: '-0.02em',
+            padding: '2px 8px',
+            border: '1.5px solid var(--ink)',
+            borderRadius: 6,
+            outline: 'none',
+            background: 'var(--surface)',
+            color: 'var(--ink)',
+            minWidth: isMobile ? 0 : 200,
+            maxWidth: isMobile ? '100%' : undefined,
+            flex: isMobile ? '1 1 100%' : undefined,
+            fontFamily: 'inherit',
+            boxSizing: 'border-box',
+          }}
+          aria-label={ariaLabelEditing}
+        />
+        <button
+          onClick={handleSave}
+          disabled={isEmptyOrWhitespace}
+          title="Save"
+          style={{
+            padding: '4px 10px',
+            background: isEmptyOrWhitespace ? 'var(--line)' : 'var(--ink)',
+            color: isEmptyOrWhitespace ? 'var(--muted)' : '#fff',
+            border: 'none',
+            borderRadius: 6,
+            fontSize: 12,
+            fontWeight: 600,
+            cursor: isEmptyOrWhitespace ? 'not-allowed' : 'pointer',
+          }}
+        >
+          Save
+        </button>
+        <button
+          onClick={handleCancel}
+          title="Cancel"
+          style={{
+            padding: '4px 10px',
+            background: 'transparent',
+            color: 'var(--muted)',
+            border: '1px solid var(--line)',
+            borderRadius: 6,
+            fontSize: 12,
+            fontWeight: 500,
+            cursor: 'pointer',
+          }}
+        >
+          Cancel
+        </button>
+      </span>
+    );
+  }
+
+  return (
+    <span
+      style={{ display: 'inline-flex', alignItems: 'center', gap: 8 }}
+      onMouseEnter={() => setHovering(true)}
+      onMouseLeave={() => setHovering(false)}
+    >
+      <button
+        type="button"
+        onClick={enterEdit}
+        aria-label={`Edit: ${title}`}
+        style={{
+          background: 'none',
+          border: 'none',
+          padding: 0,
+          margin: 0,
+          cursor: 'text',
+          font: 'inherit',
+          color: 'inherit',
+          letterSpacing: 'inherit',
+          textAlign: 'inherit',
+        }}
+        title="Click to edit"
+      >
+        {title}
+      </button>
+      <button
+        onClick={enterEdit}
+        title="Edit"
+        aria-hidden="true"
+        tabIndex={-1}
+        style={{
+          background: 'transparent',
+          border: 'none',
+          padding: 4,
+          cursor: 'pointer',
+          color: 'var(--muted)',
+          display: 'flex',
+          alignItems: 'center',
+          opacity: isMobile || hovering ? 1 : 0,
+          transition: 'opacity 0.15s',
+          borderRadius: 4,
+        }}
+      >
+        <Icons.Edit size={14} />
+      </button>
+    </span>
+  );
+}
