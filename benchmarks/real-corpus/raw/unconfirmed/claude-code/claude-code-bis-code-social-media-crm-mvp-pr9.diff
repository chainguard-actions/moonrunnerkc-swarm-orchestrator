+      if (p.id !== pieceId || p.workspaceId !== wsId) return p;
+      const platforms = p.stageData.brainstorm.platforms;
+      const existingByPlatform = new Map(p.stageData.publish.schedule.map((r) => [r.platform, r]));
+      const nextSchedule = platforms.map<PublishScheduleRow>(
