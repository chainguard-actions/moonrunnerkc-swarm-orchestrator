+// Social account store — persists linked social accounts per client in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+
+import { useEffect, useState } from 'react';
+import type { SocialAccount } from '../types/saas';
+import type { Platform } from '../types/production';
+
+const KEY = 'social-account-store:v1';
+
+interface SocialAccountState {
+  socialAccounts: SocialAccount[];
+}
+
+const EMPTY: SocialAccountState = { socialAccounts: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let saCache: SocialAccountState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadSAState(): SocialAccountState {
+  if (saCache !== null) return saCache;
+  if (typeof localStorage === 'undefined') {
+    saCache = { ...EMPTY };
+    return saCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    saCache = { ...EMPTY };
+    return saCache;
+  }
+  try {
+    saCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<SocialAccountState>) };
+    return saCache;
+  } catch {
+    saCache = { ...EMPTY };
+    return saCache;
+  }
+}
+
+function saveSAState(next: SocialAccountState): void {
+  saCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    saCache = null;
+    console.warn('[social-account-store] localStorage write failed:', err);
+  }
+}
+
+function mutateSAState(
+  fn: (current: SocialAccountState) => SocialAccountState,
+): SocialAccountState {
+  const current = loadSAState();
+  const next = fn(current);
+  saveSAState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function linkSocialAccount(
+  clientId: string,
+  platform: Platform,
+  handle: string,
+  url?: string,
+): SocialAccount {
+  if (url) {
+    const trimmed = url.trim();
+    if (trimmed && !/^https?:\/\//i.test(trimmed)) {
+      throw new Error('Social account URL must start with http:// or https://');
+    }
+  }
+  const sa: SocialAccount = {
+    id: genId('sa'),
+    clientId,
+    platform,
+    handle: handle.trim(),
+    ...(url ? { url: url.trim() } : {}),
+  };
+  mutateSAState((s) => ({ ...s, socialAccounts: [...s.socialAccounts, sa] }));
+  return sa;
+}
+
+export function unlinkSocialAccount(id: string): void {
+  mutateSAState((s) => ({
+    ...s,
+    socialAccounts: s.socialAccounts.filter((sa) => sa.id !== id),
+  }));
+}
+
+export function listSocialAccountsForClient(clientId: string): SocialAccount[] {
+  return loadSAState().socialAccounts.filter((sa) => sa.clientId === clientId);
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useSocialAccountStore(): SocialAccountState {
+  const [snapshot, setSnapshot] = useState<SocialAccountState>(() => loadSAState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadSAState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
