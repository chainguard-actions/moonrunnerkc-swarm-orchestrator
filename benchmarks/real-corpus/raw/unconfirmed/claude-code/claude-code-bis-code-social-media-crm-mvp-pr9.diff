-// Sentinel returned when castVote refuses a duplicate ballot from the same
-// voter. Distinguishes "no such ballot" (null) from "voter already voted on
-// this ballot" so the UI can surface a specific toast.
-export const ALREADY_VOTED = Symbol('ALREADY_VOTED');
-export type CastVoteResult = VotingCard | null | typeof ALREADY_VOTED;
-
-export function castVote(
-  cardId: string,
-  choice: 'yes' | 'no',
-  commentOrVoter?: string,
-  maybeVoterId?: string,
-): CastVoteResult {
-  // Back-compat shim: legacy call sites pass `(cardId, choice, comment?)`. We
-  // accept either `(cardId, choice, comment, voterId)` or — preferred at new
-  // call sites — `(cardId, choice, voterId)` when no comment is needed. To
-  // disambiguate without breaking existing callers we treat the third arg as
-  // a comment and read voterId from the fourth slot.
-  const comment = commentOrVoter;
-  const voterId = (maybeVoterId ?? '').trim();
-
-  let updated: VotingCard | null = null;
-  let alreadyVoted = false;
-
-  mutatePipeline((s) => {
-    const stamp = entry(choice === 'yes' ? 'Voted yes' : 'Voted no', comment?.trim() || undefined);
-    const next = s.voting.map<VotingCard>((c) => {
-      if (c.id !== cardId) return c;
-      // Idempotency guard: refuse to add the same voter twice. This protects
-      // the tally invariant `yes + no <= total`. If no voterId is supplied
-      // (legacy callers), fall through to the old behaviour.
-      if (voterId && (c.votedBy ?? []).includes(voterId)) {
-        alreadyVoted = true;
-        return c;
-      }
-      const votes = {
-        yes: c.votes.yes + (choice === 'yes' ? 1 : 0),
-        no: c.votes.no + (choice === 'no' ? 1 : 0),
-        total: c.votes.total,
-      };
-      const votedBy = voterId ? [...(c.votedBy ?? []), voterId] : c.votedBy;
-      const out: VotingCard = { ...c, votes, votedBy, audit: [...(c.audit ?? []), stamp] };
-      updated = out;
-      return out;
-    });
-    return { ...s, voting: next, recentTaskIds: [] };
-  });
-
-  if (alreadyVoted) return ALREADY_VOTED;
-  return updated;
-}
