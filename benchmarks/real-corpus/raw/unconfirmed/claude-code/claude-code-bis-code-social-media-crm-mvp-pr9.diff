-    const cleanedVoting = state.voting.filter((c) => !LEGACY_SEED_IDS.has(c.id));
-    const seeded: IdeaPipelineState = {
-      ...state,
-      voting: [...buildVotingSeed(), ...cleanedVoting],
-    };
-    localStorage.setItem(KEY, JSON.stringify(seeded));
-    return seeded;
-  };
-
-  if (!raw) return seedVoting(empty);
-  try {
-    const parsed = { ...empty, ...(JSON.parse(raw) as Partial<IdeaPipelineState>) };
-    return seedVoting(parsed);
-  } catch {
-    return seedVoting(empty);
-  }
-}
