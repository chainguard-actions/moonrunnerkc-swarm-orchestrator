+                    >
+                      <td style={{ padding: '12px 16px' }}>
+                        <div style={{ fontWeight: 500, color: 'var(--ink)' }}>{client.name}</div>
+                        {client.notes && (
+                          <div
+                            style={{
+                              fontSize: 11,
+                              color: 'var(--ink-3)',
+                              marginTop: 2,
+                              maxWidth: 200,
+                              overflow: 'hidden',
+                              textOverflow: 'ellipsis',
