diff --git a/src/shell/AccountWorkspaceSwitcher.tsx b/src/shell/AccountWorkspaceSwitcher.tsx
--- /dev/null
+++ b/src/shell/AccountWorkspaceSwitcher.tsx
@@ -0,0 +1,299 @@
+// AccountWorkspaceSwitcher — top-bar dropdown showing the current AccountWorkspace.
+//
+// Displays: Org · Workspace · Role
+// On click: lists ALL AccountWorkspaces the current account has, grouped by org → workspace,
+// plus a "+ New workspace" action that opens CreateWorkspaceModal scoped to the current org.
+// Picking an existing entry calls session-store.switchAccountWorkspace(awId).
+// Always renders as a dropdown — even with a single AW — so the "+ New workspace" action
+// stays reachable. Reactive via useSession() + useAccountWorkspacesStore() so the label
+// updates on workspace switch and when _devSetCurrentAWRole mutates a role in-place.
+
+import { useMemo, useState } from 'react';
+import { Menu, MenuButton, MenuItems, MenuItem } from '@headlessui/react';
+import { Icons } from '../icons';
+import { useSession, switchAccountWorkspace } from '../data/session-store';
+import { listAccountWorkspacesForAccount, useAccountWorkspacesStore } from '../data/account-workspaces-store';
+import { getWorkspace } from '../data/workspace-store';
+import { getOrg } from '../data/org-store';
+import type { AccountWorkspace } from '../types/saas';
+import { CreateWorkspaceModal } from './CreateWorkspaceModal';
+
+// ─── Role badge colour map ────────────────────────────────────────────────────
+
+const ROLE_BADGE_STYLE: Record<string, { background: string; color: string }> = {
+  Administrator: { background: 'var(--green-soft, #dcfce7)', color: 'var(--green, #16a34a)' },
+  PM:            { background: '#dbeafe', color: '#1d4ed8' },
+  Production:    { background: '#fef3c7', color: '#b45309' },
+  Marketing:     { background: '#fce7f3', color: '#be185d' },
+  Creator:       { background: '#ede9fe', color: '#7c3aed' },
+  Sponsor:       { background: '#f0f9ff', color: '#0369a1' },
+};
+
+function roleBadgeStyle(role: string) {
+  return ROLE_BADGE_STYLE[role] ?? { background: 'var(--surface-2)', color: 'var(--ink-2)' };
+}
+
+// ─── Derived label for a single AW ────────────────────────────────────────────
+
+interface AWLabel {
+  orgName: string;
+  workspaceName: string;
+  role: string;
+}
+
+function resolveAWLabel(aw: AccountWorkspace): AWLabel | null {
+  const workspace = getWorkspace(aw.workspaceId);
+  if (!workspace) return null;
+  const org = getOrg(workspace.orgId);
+  return {
+    orgName: org?.name ?? 'Unknown org',
+    workspaceName: workspace.name,
+    role: aw.role,
+  };
+}
+
+// ─── Grouped structure ────────────────────────────────────────────────────────
+
+interface GroupedAW {
+  orgName: string;
+  workspaceName: string;
+  workspaceId: string;
+  members: AccountWorkspace[];
+}
+
+function groupAWs(aws: AccountWorkspace[]): GroupedAW[] {
+  const map = new Map<string, GroupedAW>();
+  for (const aw of aws) {
+    const workspace = getWorkspace(aw.workspaceId);
+    if (!workspace) continue;
+    const org = getOrg(workspace.orgId);
+    const key = `${workspace.orgId}:${aw.workspaceId}`;
+    if (!map.has(key)) {
+      map.set(key, {
+        orgName: org?.name ?? 'Unknown org',
+        workspaceName: workspace.name,
+        workspaceId: aw.workspaceId,
+        members: [],
+      });
+    }
+    map.get(key)!.members.push(aw);
+  }
+  return Array.from(map.values());
+}
+
+// ─── Component ────────────────────────────────────────────────────────────────
+
+export function AccountWorkspaceSwitcher() {
+  const session = useSession();
+  // Subscription only — return value used for re-render trigger so the switcher
+  // reflects AW mutations (e.g. _devSetCurrentAWRole) that bypass the session store.
+  const awSnapshot = useAccountWorkspacesStore();
+  const [createOpen, setCreateOpen] = useState(false);
+
+  const { currentAccountId, currentAccountWorkspaceId } = session;
+
+  // Derive all computed values from the AW snapshot + session IDs.
+  // Memoised so we don't re-run listAccountWorkspacesForAccount / resolveAWLabel /
+  // groupAWs on every render — the switcher mounts in TopBar which renders on every page.
+  const { currentLabel, groups } = useMemo(() => {
+    if (!currentAccountId || !currentAccountWorkspaceId) {
+      return { currentLabel: null, groups: [] };
+    }
+    const allAWs = listAccountWorkspacesForAccount(currentAccountId);
+    const aw = allAWs.find((a) => a.id === currentAccountWorkspaceId) ?? null;
+    const currentLabel = aw ? resolveAWLabel(aw) : null;
+    const groups = groupAWs(allAWs);
+    return { currentLabel, groups };
+  // awSnapshot is the invalidation key — when the AW store notifies (e.g. role change),
+  // the memo re-runs with the latest data from listAccountWorkspacesForAccount.
+  // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [awSnapshot, currentAccountId, currentAccountWorkspaceId]);
+
+  // Can't render without a session
+  if (!currentAccountId || !currentAccountWorkspaceId) {
+    return null;
+  }
+
+  return (
+    <>
+    <Menu as="div" style={{ position: 'relative' }} data-testid="aw-switcher">
+      <MenuButton
+        data-testid="aw-switcher-button"
+        className="btn ghost"
+        style={{
+          padding: '5px 10px',
+          display: 'inline-flex',
+          alignItems: 'center',
+          gap: 6,
+          fontSize: 12,
+          border: '1px solid var(--line)',
+          borderRadius: 999,
+          color: 'var(--ink-2)',
+        }}
+        title={
+          currentLabel
+            ? `${currentLabel.orgName} · ${currentLabel.workspaceName} · ${currentLabel.role}`
+            : 'Switch workspace'
+        }
+      >
+        <Icons.Building size={12} />
+        {currentLabel ? (
+          <>
+            <span style={{ fontWeight: 500, maxWidth: 280, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
+              {currentLabel.orgName}
+              <span style={{ color: 'var(--line-2, #ccc)', margin: '0 4px' }}>·</span>
+              {currentLabel.workspaceName}
+            </span>
+            <span
+              style={{
+                fontSize: 10,
+                fontWeight: 700,
+                padding: '1px 6px',
+                borderRadius: 99,
+                ...roleBadgeStyle(currentLabel.role),
+              }}
+            >
+              {currentLabel.role}
+            </span>
+          </>
+        ) : (
+          <span style={{ fontWeight: 500 }}>Switch workspace</span>
+        )}
+        <Icons.ChevronDown size={12} />
+      </MenuButton>
+
+      <MenuItems
+        anchor="bottom start"
+        className="glass-popover"
+        style={{
+          marginTop: 8,
+          minWidth: 280,
+          padding: 6,
+          borderRadius: 12,
+          boxShadow: '0 12px 32px rgba(0,0,0,0.16)',
+          background: 'var(--surface)',
+          border: '1px solid var(--line)',
+          zIndex: 100,
+        }}
+      >
+        <div
+          style={{
+            padding: '6px 10px 8px',
+            fontSize: 10,
+            letterSpacing: '0.08em',
+            textTransform: 'uppercase',
+            color: 'var(--muted)',
+            fontWeight: 600,
+          }}
+        >
+          Your workspaces
+        </div>
+
+        {groups.map((group) => (
+          <div key={`${group.orgName}:${group.workspaceId}`}>
+            {/* Org + workspace heading */}
+            <div
+              style={{
+                padding: '4px 10px 2px',
+                fontSize: 11,
+                fontWeight: 600,
+                color: 'var(--ink-2)',
+                display: 'flex',
+                alignItems: 'center',
+                gap: 6,
+              }}
+            >
+              <Icons.Building size={11} />
+              <span>{group.orgName}</span>
+              <Icons.ChevronRight size={10} style={{ color: 'var(--muted)' }} />
+              <span>{group.workspaceName}</span>
+            </div>
+
+            {/* AW entries (one per role) */}
+            {group.members.map((aw) => {
+              const isActive = aw.id === currentAccountWorkspaceId;
+              const badge = roleBadgeStyle(aw.role);
+              return (
+                <MenuItem key={aw.id}>
+                  {({ focus }) => (
+                    <button
+                      type="button"
+                      onClick={() => switchAccountWorkspace(aw.id)}
+                      style={{
+                        display: 'flex',
+                        width: '100%',
+                        alignItems: 'center',
+                        gap: 8,
+                        padding: '7px 10px 7px 22px',
+                        borderRadius: 8,
+                        background: focus ? 'var(--surface-2)' : 'transparent',
+                        border: 'none',
+                        textAlign: 'start',
+                        cursor: 'pointer',
+                        color: 'inherit',
+                      }}
+                    >
+                      <span
+                        style={{
+                          fontSize: 11,
+                          fontWeight: 700,
+                          padding: '1px 8px',
+                          borderRadius: 99,
+                          flex: 1,
+                          ...badge,
+                        }}
+                      >
+                        {aw.role}
+                      </span>
+                      {isActive && (
+                        <Icons.Check size={13} style={{ color: 'var(--green)', flexShrink: 0 }} />
+                      )}
+                    </button>
+                  )}
+                </MenuItem>
+              );
+            })}
+          </div>
+        ))}
+
+        {/* Divider + "+ New workspace" action — opens a modal that creates a
+            brand-new org for the user before minting the workspace + AW. */}
+        <div style={{ height: 1, background: 'var(--line)', margin: '6px 4px' }} />
+        <MenuItem>
+          {({ focus }) => (
+            <button
+              type="button"
+              data-testid="aw-switcher-create"
+              onClick={() => setCreateOpen(true)}
+              style={{
+                display: 'flex',
+                width: '100%',
+                alignItems: 'center',
+                gap: 8,
+                padding: '8px 10px',
+                borderRadius: 8,
+                background: focus ? 'var(--surface-2)' : 'transparent',
+                border: 'none',
+                textAlign: 'start',
+                cursor: 'pointer',
+                color: 'var(--ink-2)',
+                fontSize: 12,
+                fontWeight: 500,
+              }}
+            >
+              <Icons.Plus size={13} />
+              <span>New workspace</span>
+            </button>
+          )}
+        </MenuItem>
+      </MenuItems>
+    </Menu>
+
+    <CreateWorkspaceModal
+      open={createOpen}
+      onClose={() => setCreateOpen(false)}
+      accountId={currentAccountId}
+    />
+    </>
+  );
+}
diff --git a/src/shell/BottomTabBar.tsx b/src/shell/BottomTabBar.tsx
--- /dev/null
+++ b/src/shell/BottomTabBar.tsx
@@ -0,0 +1,87 @@
+import { useLocation, useNavigate } from 'react-router-dom';
+import { useIsMobile } from '../data/route-buckets';
+import { Icons } from '../icons';
+
+interface Tab {
+  id: string;
+  label: string;
+  path: string;
+  icon: keyof typeof Icons;
+  /** exact match or prefix match */
+  matchPrefix?: boolean;
+}
+
+const TABS: Tab[] = [
+  { id: 'vault',    label: 'Vault',    path: '/screens/vault',    icon: 'Inbox' },
+  { id: 'pipeline', label: 'Pipeline', path: '/screens/pipeline', icon: 'Kanban', matchPrefix: true },
+  { id: 'settings', label: 'Settings', path: '/screens/settings', icon: 'Settings' },
+];
+
+function isTabActive(tab: Tab, pathname: string): boolean {
+  if (pathname === tab.path) return true;
+  if (tab.matchPrefix) return pathname.startsWith(tab.path + '/');
+  return pathname.startsWith(tab.path + '/');
+}
+
+export function BottomTabBar() {
+  const isMobile = useIsMobile();
+  const location = useLocation();
+  const navigate = useNavigate();
+
+  if (!isMobile) return null;
+
+  return (
+    <nav
+      aria-label="Bottom navigation"
+      data-testid="bottom-tab-bar"
+      style={{
+        position: 'fixed',
+        bottom: 0,
+        left: 0,
+        right: 0,
+        height: 56,
+        paddingBottom: 'env(safe-area-inset-bottom)',
+        background: 'var(--surface)',
+        borderTop: '1px solid var(--line)',
+        display: 'flex',
+        alignItems: 'stretch',
+        zIndex: 150,
+      }}
+    >
+      {TABS.map((tab) => {
+        const active = isTabActive(tab, location.pathname);
+        const Icon = Icons[tab.icon];
+        return (
+          <button
+            key={tab.id}
+            type="button"
+            data-testid={`bottom-tab-${tab.id}`}
+            onClick={() => navigate(tab.path)}
+            aria-label={tab.label}
+            aria-current={active ? 'page' : undefined}
+            style={{
+              flex: 1,
+              display: 'flex',
+              flexDirection: 'column',
+              alignItems: 'center',
+              justifyContent: 'center',
+              gap: 3,
+              background: active ? 'var(--surface-2, rgba(0,0,0,0.04))' : 'transparent',
+              border: 'none',
+              cursor: 'pointer',
+              color: active ? 'var(--ink)' : 'var(--muted)',
+              fontSize: 10,
+              fontWeight: active ? 600 : 400,
+              padding: '6px 0',
+              borderRadius: 0,
+              transition: 'background 0.12s, color 0.12s',
+            }}
+          >
+            {Icon ? <Icon size={20} /> : null}
+            <span>{tab.label}</span>
+          </button>
+        );
+      })}
+    </nav>
+  );
+}
diff --git a/src/shell/CreateWorkspaceModal.tsx b/src/shell/CreateWorkspaceModal.tsx
--- /dev/null
+++ b/src/shell/CreateWorkspaceModal.tsx
@@ -0,0 +1,194 @@
+// CreateWorkspaceModal — self-serve "new workspace" flow opened from the
+// AccountWorkspaceSwitcher dropdown. Mirrors the onboarding wizard's three
+// steps (org → jurisdiction → workspace) collapsed into a single dialog.
+//
+// Every self-created workspace lives under a brand-new org owned by the
+// creator. No org picker: this avoids cross-tenancy confusion (someone
+// invited to org A would otherwise be able to attach workspaces to it) and
+// matches the product model where each user owns their own org(s).
+//
+// On submit the chain is: createOrg → createWorkspace → createAccountWorkspace
+// (Administrator) → switchAccountWorkspace. The four writes are NOT atomic
+// across the three stores — if a later step throws (extremely unlikely;
+// requires localStorage quota exhaustion or disabled storage), earlier writes
+// stay. We accept this limitation for the localStorage-only architecture and
+// will revisit when general workspace/org management (delete actions, etc.)
+// lands. The handleSubmit catch surfaces a generic error and leaves the modal
+// open so the user can retry or close manually.
+
+import { useState, type FormEvent } from 'react';
+import { DialogShell } from '../components/DialogShell';
+import { TextField } from '../components/TextField';
+import { Field } from '../components/FieldLabel';
+import { Icons } from '../icons';
+import { createOrg } from '../data/org-store';
+import { createWorkspace } from '../data/workspace-store';
+import { createAccountWorkspace } from '../data/account-workspaces-store';
+import { switchAccountWorkspace } from '../data/session-store';
+import { toast } from '../components/ToastHost';
+import { JURISDICTIONS, type Jurisdiction } from '../data/jurisdictions';
+
+export interface CreateWorkspaceModalProps {
+  open: boolean;
+  onClose: () => void;
+  /** Account that becomes Administrator on the new workspace + owner of the new org. */
+  accountId: string;
+}
+
+export function CreateWorkspaceModal({ open, onClose, accountId }: CreateWorkspaceModalProps) {
+  const [orgName, setOrgName] = useState('');
+  const [name, setName] = useState('');
+  const [jurisdiction, setJurisdiction] = useState<Jurisdiction>('SA');
+  const [submitting, setSubmitting] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  function reset(): void {
+    setOrgName('');
+    setName('');
+    setJurisdiction('SA');
+    setError(null);
+    setSubmitting(false);
+  }
+
+  function handleClose(): void {
+    if (submitting) return;
+    reset();
+    onClose();
+  }
+
+  function handleSubmit(e: FormEvent): void {
+    e.preventDefault();
+    if (submitting) return;
+    const trimmedOrg = orgName.trim();
+    const trimmedName = name.trim();
+    if (!trimmedOrg) {
+      setError('Organisation name is required.');
+      return;
+    }
+    if (!trimmedName) {
+      setError('Workspace name is required.');
+      return;
+    }
+    setSubmitting(true);
+    setError(null);
+    try {
+      const org = createOrg(trimmedOrg);
+      const workspace = createWorkspace(org.id, trimmedName, undefined, undefined, jurisdiction);
+      const aw = createAccountWorkspace(accountId, workspace.id, 'Administrator');
+      switchAccountWorkspace(aw.id);
+      toast({
+        message: `Created “${workspace.name}”`,
+        kind: 'success',
+        detail: `You're now active on ${workspace.name} as Administrator of ${org.name}.`,
+      });
+      reset();
+      onClose();
+    } catch (err) {
+      setSubmitting(false);
+      setError(err instanceof Error ? err.message : 'Failed to create workspace.');
+    }
+  }
+
+  const canSubmit = !submitting && orgName.trim().length > 0 && name.trim().length > 0;
+
+  return (
+    <DialogShell
+      open={open}
+      onClose={handleClose}
