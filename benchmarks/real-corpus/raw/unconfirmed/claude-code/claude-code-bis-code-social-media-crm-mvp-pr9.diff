+          >
+            Finish setup →
+          </button>
+        </div>
+      </form>
+    </div>
+  );
+}
+
+// ─── Onboarding wizard orchestrator ──────────────────────────────────────────
+
+type WizardStep = 'org' | 'jurisdiction' | 'workspace';
+
+interface WizardState {
+  step: WizardStep;
+  org: Org | null;
+  orgName: string;
+  logo: string;
+  jurisdiction: Jurisdiction;
+  wsName: string;
+  niche: string;
+  location: string;
+}
+
+export function Onboarding() {
+  const [state, setState] = useState<WizardState>({
+    step: 'org',
+    org: null,
+    orgName: '',
+    logo: '',
+    jurisdiction: 'SA',
+    wsName: '',
+    niche: '',
+    location: '',
+  });
+
+  // Mid-wizard refresh recovery: if the user already created an org (tracked
+  // via sessionStorage pendingOrgId) but no AccountWorkspace exists yet, skip
+  // step 1 and pre-populate step 2 with the existing org so we don't create a
+  // second orphan org.
+  useEffect(() => {
+    try {
+      const pendingOrgId = sessionStorage.getItem(PENDING_ORG_KEY);
+      if (!pendingOrgId) return;
+
+      const currentAccountId = getCurrentAccountId();
+      if (!currentAccountId) return;
+
+      // If the account already has an AW, onboarding is complete — clear and bail
+      const existingAWs = listAccountWorkspacesForAccount(currentAccountId);
+      if (existingAWs.length > 0) {
+        sessionStorage.removeItem(PENDING_ORG_KEY);
+        return;
+      }
+
+      // If the org still exists, skip to step 2
+      const existingOrg = getOrg(pendingOrgId);
+      if (existingOrg) {
+        setState((prev) => ({
+          ...prev,
+          step: 'workspace',
+          org: existingOrg,
+          orgName: existingOrg.name,
+          logo: existingOrg.logo ?? '',
+        }));
+      } else {
+        // Org was lost (e.g. localStorage cleared) — clear the stale pointer
+        sessionStorage.removeItem(PENDING_ORG_KEY);
+      }
+    } catch {
+      // sessionStorage unavailable — silently ignore
+    }
+  // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, []);
+
+  function handleOrgNext(org: Org) {
+    setState((prev) => ({
+      ...prev,
+      step: 'jurisdiction',
+      org,
+      orgName: org.name,
+      logo: org.logo ?? '',
+    }));
+  }
+
+  function handleJurisdictionChange(j: Jurisdiction) {
+    setState((prev) => ({ ...prev, jurisdiction: j }));
+  }
+
+  function handleJurisdictionNext() {
+    setState((prev) => ({ ...prev, step: 'workspace' }));
+  }
+
+  function handleJurisdictionBack() {
+    setState((prev) => ({ ...prev, step: 'org' }));
+  }
+
+  function handleBack(partialValues: { wsName: string; niche: string; location: string }) {
+    setState((prev) => ({
+      ...prev,
+      step: 'jurisdiction',
+      wsName: partialValues.wsName,
+      niche: partialValues.niche,
+      location: partialValues.location,
+    }));
+  }
+
+  // Navigation happens inside StepCreateWorkspace after login() is called
+  function handleDone() {}
+
+  return (
+    <AuthChrome>
+      {state.step === 'org' && (
+        <StepCreateOrg
+          onNext={handleOrgNext}
+          initialOrgName={state.orgName}
+          initialLogo={state.logo}
+        />
+      )}
+      {state.step === 'jurisdiction' && (
+        <StepSelectJurisdiction
+          value={state.jurisdiction}
+          onChange={handleJurisdictionChange}
+          onNext={handleJurisdictionNext}
+          onBack={handleJurisdictionBack}
+        />
+      )}
+      {state.step === 'workspace' && (
+        <StepCreateWorkspace
+          org={state.org!}
+          jurisdiction={state.jurisdiction}
+          onBack={handleBack}
+          onDone={handleDone}
+          initialWsName={state.wsName}
+          initialNiche={state.niche}
+          initialLocation={state.location}
+        />
+      )}
+    </AuthChrome>
+  );
+}
