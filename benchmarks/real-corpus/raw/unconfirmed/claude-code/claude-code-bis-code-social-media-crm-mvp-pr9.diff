+            onClick={() => onBack({ wsName, niche, location })}
+            style={{ ...ghostBtnStyle, flex: '0 0 auto' }}
+          >
+            ← Back
+          </button>
+          <button
+            type="submit"
+            disabled={submitting}
+            style={{
+              ...primaryBtnStyle,
+              opacity: submitting ? 0.7 : 1,
+              cursor: submitting ? 'not-allowed' : 'pointer',
