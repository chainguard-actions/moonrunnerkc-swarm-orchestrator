+// Multi-tenant SaaS data model types.
+// This is the canonical definition for the Phase 3 data layer.
+// Security note: this is a LOCAL-ONLY mock. passwordHash is stored as
+// plain text — it is NOT a cryptographic hash. Real auth comes in a
+// backend brainstorm later.
+
+import type { Platform, StageId } from './production';
+import type { Jurisdiction } from '../data/jurisdictions';
+
+// ─── Roles ───────────────────────────────────────────────────────────────────
+// These 6 roles are the canonical role vocabulary (replaces old `Role` in `src/types.ts`).
+// `rbac.ts` imports `MemberRole` from `members-store.ts` which aliases this type.
+// The legacy `Role` in `src/types.ts` has been deleted.
+export type Role =
+  | 'Administrator'
+  | 'PM'
+  | 'Production'
+  | 'Marketing'
+  | 'Creator'
+  | 'Sponsor';
+
+// ─── Capabilities ─────────────────────────────────────────────────────────────
+// Flat permission matrix — used by useCan() hook and permissions-matrix.ts.
+// Administrator gets every capability implicitly (computed).
+// The other 5 roles each have an explicit set defined in permissions-matrix.ts.
+export type Capability =
+  // Org-level (Administrator only)
+  | 'MANAGE_USERS'
+  | 'MANAGE_BILLING'
+  | 'MANAGE_WORKSPACES'
+  // Workspace-level
+  | 'MANAGE_WORKSPACE_SETTINGS'
+  | 'MANAGE_CLIENTS'
+  | 'MANAGE_SOCIAL_ACCOUNTS'
+  | 'VIEW_WORKSPACE_BILLING'
+  | 'INVITE_SPONSOR'
+  // Pipeline / piece work
+  | 'CREATE_PIECE'
+  | 'EDIT_PIECE'
+  | 'ADVANCE_STAGE'
+  | 'DELETE_PIECE'
+  // Stage-specific
+  | 'BRAINSTORM'
+  | 'PRE_PRODUCTION'
+  | 'PRODUCTION'
+  | 'POST_PRODUCTION'
+  | 'PUBLISH'
+  // Client-facing
+  | 'VIEW_OWN_CLIENT_DATA'
+  | 'VIEW_OWN_BILLING'
+  | 'COMMENT_ON_OWN_PIECES';
+
+// ─── Org ─────────────────────────────────────────────────────────────────────
+export interface Org {
+  id: string;
+  name: string;
+  logo?: string; // data URL or remote URL
+}
+
+// ─── Account ─────────────────────────────────────────────────────────────────
+export interface Account {
+  id: string;
+  name: string;
+  email: string;
+  // MOCK ONLY — not a real hash. Stored as-is in localStorage.
+  // Phase 3b will keep this approach; real crypto waits for the backend.
+  passwordHash: string;
+}
+
+// ─── Workspace ───────────────────────────────────────────────────────────────
+export interface Workspace {
+  id: string;
+  orgId: string;
+  name: string;
+  niche?: string;
+  location?: string;
+  // Identity
+  website?: string;
+  photoDataUrl?: string;
+  // Address
+  address?: string;
+  city?: string;
+  phone?: string;
+  contactEmail?: string;
+  // Jurisdiction — operating country/market. Set once at onboarding, IMMUTABLE
+  // thereafter (mirrors AccountWorkspace.role). Drives compliance features +
+  // currency/VAT/tax-id/suggested-language defaults via src/data/jurisdictions.ts.
+  jurisdiction: Jurisdiction;
+  // Compliance
+  vatNumber?: string;
+  vatRate?: number;  // decimal, e.g. 0.15 for 15%
+  crNumber?: string;
+  // Defaults
+  currency?: 'SAR' | 'USD' | 'EUR';
+  timezone?: string;
+}
+
+// ─── AccountWorkspace (membership) ───────────────────────────────────────────
+// role is IMMUTABLE once set. To change a role: revoke the AW and invite again.
+// The same accountId may hold multiple AWs on the same workspaceId (multi-hat).
+export interface AccountWorkspace {
+  id: string;
+  accountId: string;
+  workspaceId: string;
+  role: Role;
+  /** Only present when role === 'Sponsor' — links to the specific Client. Phase 3c will use this. */
+  clientId?: string;
+  preferences?: Record<string, unknown>;
+  createdAt: number;
+}
+
+// ─── Client ──────────────────────────────────────────────────────────────────
+export interface Client {
+  id: string;
+  workspaceId: string;
+  name: string;
+  contactEmail?: string;
+  notes?: string;
+}
+
+// ─── SocialAccount ───────────────────────────────────────────────────────────
+// `Platform` is reused from production.ts (tiktok | reels | shorts).
+export interface SocialAccount {
+  id: string;
+  clientId: string;
+  platform: Platform;
+  handle: string;
+  url?: string;
+}
+
+// ─── WorkspaceInvite ─────────────────────────────────────────────────────────
+// clientId is only set when invitedRole === 'Sponsor'.
+export interface WorkspaceInvite {
+  id: string;
+  workspaceId: string;
+  invitedEmail: string;
+  invitedRole: Role;
+  /** Only set when invitedRole === 'Sponsor' */
+  clientId?: string;
+  invitedByAccountId: string;
+  status: 'pending' | 'accepted' | 'revoked';
+  token: string;
+  createdAt: number;
+}
+
+// ─── ShareToken ──────────────────────────────────────────────────────────────
+export interface ShareToken {
+  token: string;
+  type: 'recap' | 'billing';
+  clientId: string;
+  expiresAt?: number;
+}
+
+// ─── TaskDefinition ──────────────────────────────────────────────────────────
+// workspaceId === 'system' means it's a built-in seed shared across all
+// workspaces. Workspace-local definitions use the workspace's own id.
+export interface TaskDefinition {
+  id: string;
+  /** 'system' for built-in seeds, or a real workspaceId for workspace-local definitions */
+  workspaceId: string;
+  stage: StageId;
+  name: string;
+  type: 'text' | 'textarea' | 'list' | 'checklist' | 'dropdown' | 'multiselect' | 'checkbox' | 'date' | 'number' | 'link';
+  options?: string[];
+  isDefault: boolean;
+  /**
+   * Auto-complete condition. When the condition is met the task is marked done
+   * automatically (non-interactive).
+   * - 'hookNonEmpty'              → done when brainstorm.hook is non-empty
+   * - 'platformCount>=1'         → done when brainstorm.platforms.length >= 1
+   * - 'shotListNonEmpty'          → done when preproduction.shotList.length >= 1
+   * - 'productionNotesNonEmpty'   → done when preproduction.script is non-empty
+   * - 'footageNotesNonEmpty'      → done when production.setNotes is non-empty
+   * - 'editingNotesNonEmpty'      → done when postproduction.reviewComments is non-empty
+   * - 'captionDraftNonEmpty'      → done when any captionsPerPlatform entry is non-empty
+   * - 'scheduleNonEmpty'          → done when publish.schedule.length >= 1
+   * - 'allScheduledPosted'        → done when schedule.length >= 1 && every row is posted
+   */
+  autoCompleteWhen?:
+    | 'hookNonEmpty'
+    | 'platformCount>=1'
+    | 'shotListNonEmpty'
+    | 'productionNotesNonEmpty'
+    | 'footageNotesNonEmpty'
+    | 'editingNotesNonEmpty'
+    | 'captionDraftNonEmpty'
+    | 'scheduleNonEmpty'
+    | 'allScheduledPosted';
+  /** undefined for system-seeded definitions */
+  createdByAccountId?: string;
+}
+
+// ─── Session ─────────────────────────────────────────────────────────────────
+export interface Session {
+  currentAccountId: string | null;
+  currentAccountWorkspaceId: string | null;
+}
