@@ -0,0 +1,114 @@
+// Permission matrix — maps each Role to its set of allowed Capabilities.
+//
+// Administrator is a computed superuser: all capabilities are granted
+// automatically (no entry in the table).
+//
+// The 5 non-admin roles have an explicit, independent capability set drawn
+// directly from the plan's permission matrix (jazzy-swimming-bentley.md §Permission matrix).
+//
+// `~` entries in the plan ("scoped to user's own pieces/clients only") are
+// modelled as a full grant here; the scoping logic is enforced separately
+// in the components that render the data. Phase 3d will add scope checks.
+
+import type { Role, Capability } from '../types/saas';
+
+type PermMatrix = Record<Exclude<Role, 'Administrator'>, Set<Capability>>;
+
+const ALL_CAPABILITIES: Capability[] = [
+  'MANAGE_USERS',
+  'MANAGE_BILLING',
+  'MANAGE_WORKSPACES',
+  'MANAGE_WORKSPACE_SETTINGS',
+  'MANAGE_CLIENTS',
+  'MANAGE_SOCIAL_ACCOUNTS',
+  'VIEW_WORKSPACE_BILLING',
+  'INVITE_SPONSOR',
+  'CREATE_PIECE',
+  'EDIT_PIECE',
+  'ADVANCE_STAGE',
+  'DELETE_PIECE',
+  'BRAINSTORM',
+  'PRE_PRODUCTION',
+  'PRODUCTION',
+  'POST_PRODUCTION',
+  'PUBLISH',
+  'VIEW_OWN_CLIENT_DATA',
+  'VIEW_OWN_BILLING',
+  'COMMENT_ON_OWN_PIECES',
+];
+
+// Exported so tests and the RoleSwitcher can inspect it.
+export const MATRIX: PermMatrix = {
+  PM: new Set<Capability>([
+    'MANAGE_WORKSPACE_SETTINGS',
+    'MANAGE_CLIENTS',
+    'MANAGE_SOCIAL_ACCOUNTS',
+    'VIEW_WORKSPACE_BILLING',
+    'INVITE_SPONSOR',
+    'CREATE_PIECE',
+    'EDIT_PIECE',
+    'ADVANCE_STAGE',
+    'DELETE_PIECE',
+    'BRAINSTORM',
+    'PRE_PRODUCTION',
+    'PRODUCTION',
+    'POST_PRODUCTION',
+    'PUBLISH',
+    'VIEW_OWN_CLIENT_DATA',
+    'VIEW_OWN_BILLING',
+    'COMMENT_ON_OWN_PIECES',
+  ]),
+
+  Production: new Set<Capability>([
+    'EDIT_PIECE',         // includes own scope (~ in plan)
+    'ADVANCE_STAGE',
+    'PRE_PRODUCTION',     // includes ~ (own scope)
+    'PRODUCTION',
+    'POST_PRODUCTION',
+    'VIEW_OWN_CLIENT_DATA',
+    'COMMENT_ON_OWN_PIECES',
+  ]),
+
+  Marketing: new Set<Capability>([
+    'EDIT_PIECE',         // ~ (own scope)
+    'ADVANCE_STAGE',
+    'POST_PRODUCTION',
+    'PUBLISH',
+    'MANAGE_SOCIAL_ACCOUNTS',
+    'VIEW_OWN_CLIENT_DATA',
+    'COMMENT_ON_OWN_PIECES',
+  ]),
+
+  Creator: new Set<Capability>([
+    'CREATE_PIECE',
+    'EDIT_PIECE',
+    'ADVANCE_STAGE',
+    'BRAINSTORM',
+    'PRE_PRODUCTION',     // ~ (own scope)
+    'VIEW_OWN_CLIENT_DATA',
+    'COMMENT_ON_OWN_PIECES',
+  ]),
+
+  Sponsor: new Set<Capability>([
+    'VIEW_OWN_CLIENT_DATA',
+    'VIEW_OWN_BILLING',
+    'COMMENT_ON_OWN_PIECES',
+  ]),
+};
+
+// ─── Lookup helper ─────────────────────────────────────────────────────────────
+
+/**
+ * Returns true if the given role has the given capability.
+ * Administrator always returns true (superuser).
+ * Absent role or unknown role returns false.
+ */
+export function roleHasCap(role: Role | undefined, cap: Capability): boolean {
+  if (!role) return false;
+  if (role === 'Administrator') return true;
+  const roleSet = MATRIX[role as Exclude<Role, 'Administrator'>];
+  return roleSet?.has(cap) ?? false;
+}
+
+// Re-export so callers don't need to import from two places.
+export { ALL_CAPABILITIES };
