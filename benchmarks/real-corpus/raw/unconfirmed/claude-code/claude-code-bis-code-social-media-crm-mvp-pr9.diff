diff --git a/src/screens/InviteAccept.tsx b/src/screens/InviteAccept.tsx
--- /dev/null
+++ b/src/screens/InviteAccept.tsx
@@ -0,0 +1,227 @@
+// InviteAccept — /invite/:token route.
+//
+// Public route (no SessionGuard). Handles two cases:
+//   1. User is logged in: show "Accept invite to <workspace> as <role>" UI.
+//   2. User is NOT logged in: show "Sign in or register to accept" UI.
+//
+// On accept: creates an AccountWorkspace + sets the session to the new AW,
+// then navigates to /screens/pipeline.
+
+import { useParams, useNavigate, Link } from 'react-router-dom';
+import { AuthChrome } from '../components/AuthChrome';
+import { getInviteByToken, acceptInvite } from '../data/workspace-invites-store';
+import { getSession, login } from '../data/session-store';
+import { getWorkspace } from '../data/workspace-store';
+import { listAccountWorkspacesForAccount } from '../data/account-workspaces-store';
+
+export function InviteAccept() {
+  const { token } = useParams<{ token: string }>();
+  const navigate = useNavigate();
+
+  if (!token) {
+    return (
+      <AuthChrome>
+        <ErrorCard message="Invalid invite link — no token found." />
+      </AuthChrome>
+    );
+  }
+
+  const invite = getInviteByToken(token);
+
+  if (!invite || invite.status !== 'pending') {
+    return (
+      <AuthChrome>
+        <ErrorCard
+          message={
+            invite
+              ? `This invite has already been ${invite.status}.`
+              : 'Invite not found or has expired.'
+          }
+        />
+      </AuthChrome>
+    );
+  }
+
+  const workspace = getWorkspace(invite.workspaceId);
+  const workspaceName = workspace?.name ?? 'the workspace';
+  const session = getSession();
+  const isLoggedIn = Boolean(session.currentAccountId);
+
+  function handleAccept() {
+    if (!session.currentAccountId || !token) return;
+
+    const claimedInvite = acceptInvite(token, session.currentAccountId);
+    if (!claimedInvite) {
+      alert('Failed to accept invite. It may have already been used, or this invite was sent to a different email address.');
+      return;
+    }
+
+    // Find the AW that was just created for this account + workspace.
+    const aws = listAccountWorkspacesForAccount(session.currentAccountId);
+    const newAW = [...aws]
+      .filter((aw) => aw.workspaceId === claimedInvite.workspaceId)
+      .sort((a, b) => b.createdAt - a.createdAt)[0];
+
+    // Set the new AW as the active session and navigate to the app.
+    login(session.currentAccountId, newAW?.id ?? null);
+    navigate('/screens/pipeline', { replace: true });
+  }
+
+  function handleDecline() {
+    navigate('/', { replace: true });
+  }
+
+  return (
+    <AuthChrome>
+      <div
+        style={{
+          background: 'var(--surface)',
+          border: '1px solid var(--line-2)',
+          borderRadius: 12,
+          padding: 32,
+          maxWidth: 400,
+          width: '100%',
+        }}
+      >
+        <p
+          style={{
+            fontSize: 11,
+            fontWeight: 600,
+            letterSpacing: '0.08em',
+            textTransform: 'uppercase',
+            color: 'var(--green)',
+            marginBottom: 8,
+          }}
+        >
+          Workspace invite
+        </p>
+        <h1
+          style={{
+            fontSize: 22,
+            fontWeight: 600,
+            color: 'var(--ink)',
+            marginBottom: 8,
+          }}
+        >
+          You've been invited
+        </h1>
+        <p style={{ fontSize: 13, color: 'var(--ink-2)', marginBottom: 24, lineHeight: 1.5 }}>
+          You've been invited to join{' '}
+          <strong style={{ color: 'var(--ink)' }}>{workspaceName}</strong> as{' '}
+          <strong style={{ color: 'var(--ink)' }}>{invite.invitedRole}</strong>.
+        </p>
+
+        {isLoggedIn ? (
+          <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
+            <button
+              onClick={handleAccept}
+              style={{
+                padding: '10px 16px',
+                background: 'var(--green)',
+                color: '#fff',
+                border: 'none',
+                borderRadius: 8,
+                fontSize: 13,
+                fontWeight: 600,
+                cursor: 'pointer',
+              }}
+            >
+              Accept invite
+            </button>
+            <button
+              onClick={handleDecline}
+              style={{
+                padding: '10px 16px',
+                background: 'transparent',
+                border: '1px solid var(--line-2)',
+                borderRadius: 8,
+                fontSize: 13,
+                color: 'var(--ink-2)',
+                cursor: 'pointer',
+              }}
+            >
+              Decline
+            </button>
+          </div>
+        ) : (
+          <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
+            <p style={{ fontSize: 13, color: 'var(--ink-3)', margin: '0 0 8px' }}>
+              Sign in or register to accept this invite.
+            </p>
+            <Link
+              to={`/login?invite=${token}`}
+              style={{
+                display: 'block',
+                padding: '10px 16px',
+                background: 'var(--green)',
+                color: '#fff',
+                borderRadius: 8,
+                fontSize: 13,
+                fontWeight: 600,
+                textDecoration: 'none',
+                textAlign: 'center',
+              }}
+            >
+              Sign in
+            </Link>
+            <Link
+              to={`/register?invite=${token}`}
+              style={{
+                display: 'block',
+                padding: '10px 16px',
+                background: 'transparent',
+                border: '1px solid var(--line-2)',
+                borderRadius: 8,
+                fontSize: 13,
+                color: 'var(--ink-2)',
+                textDecoration: 'none',
+                textAlign: 'center',
+              }}
+            >
+              Register
+            </Link>
+          </div>
+        )}
+      </div>
+    </AuthChrome>
+  );
+}
+
+function ErrorCard({ message }: { message: string }) {
+  return (
+    <div
+      style={{
+        background: 'var(--surface)',
+        border: '1px solid var(--line-2)',
+        borderRadius: 12,
+        padding: 32,
+        maxWidth: 400,
+        width: '100%',
+        textAlign: 'center',
+      }}
+    >
+      <div style={{ fontSize: 32, marginBottom: 16 }}>⚠️</div>
+      <h2 style={{ fontSize: 18, fontWeight: 600, color: 'var(--ink)', marginBottom: 8 }}>
+        Invite not valid
+      </h2>
+      <p style={{ fontSize: 13, color: 'var(--ink-3)', marginBottom: 24, lineHeight: 1.5 }}>
+        {message}
+      </p>
+      <Link
+        to="/"
+        style={{
+          display: 'inline-block',
+          padding: '8px 16px',
+          background: 'var(--green)',
+          color: '#fff',
+          borderRadius: 8,
+          fontSize: 13,
+          fontWeight: 600,
+          textDecoration: 'none',
+        }}
+      >
+        Go home
+      </Link>
+    </div>
+  );
+}
