+                        >
+                          {saCount} account{saCount !== 1 ? 's' : ''}
+                        </span>
+                      </td>
+                      <td style={{ padding: '12px 16px' }}>
+                        <div style={{ display: 'flex', gap: 6 }}>
+                          <button
+                            onClick={() =>
+                              setExpandedClientId(isExpanded ? null : client.id)
+                            }
+                            data-testid={`manage-client-btn-${client.id}`}
+                            style={{
+                              padding: '4px 10px',
+                              background: isExpanded ? 'var(--ink)' : 'transparent',
+                              border: '1px solid var(--line-2)',
+                              borderRadius: 6,
+                              fontSize: 12,
+                              color: isExpanded ? '#fff' : 'var(--ink-2)',
+                              cursor: 'pointer',
+                            }}
+                          >
+                            {isExpanded ? 'Close' : 'Manage'}
+                          </button>
+                          <button
+                            onClick={() => handleDelete(client.id, client.name)}
+                            style={{
+                              padding: '4px 10px',
+                              background: 'transparent',
+                              border: '1px solid var(--line-2)',
+                              borderRadius: 6,
+                              fontSize: 12,
+                              color: 'var(--danger)',
+                              cursor: 'pointer',
+                            }}
+                          >
+                            Delete
+                          </button>
+                        </div>
+                      </td>
+                    </tr>
+                    {isExpanded && (
+                      <tr>
+                        <td
+                          colSpan={4}
+                          style={{ padding: '0 16px 16px 16px' }}
+                        >
+                          <ClientDetailPanel
+                            client={client}
+                            workspaceId={workspaceId!}
+                            onClose={() => setExpandedClientId(null)}
+                          />
+                        </td>
+                      </tr>
+                    )}
+                  </React.Fragment>
+                );
+              })}
+            </tbody>
+          </table>
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
