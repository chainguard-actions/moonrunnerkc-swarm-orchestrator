+++ b/src/data/use-can.ts
@@ -0,0 +1,49 @@
+// useCan — matrix-driven permission hook for Phase 3c.
+//
+// Reads the current AccountWorkspace from the session store, looks up
+// its role, and checks the permissions-matrix. Returns false if there is
+// no active session or the role does not have the capability.
+//
+// Also exports `currentCanCheck` as a non-hook variant for use in store
+// actions or other non-React code paths.
+
+import { useSession, getSession } from './session-store';
+import { getAccountWorkspace, useAccountWorkspacesStore } from './account-workspaces-store';
+import { roleHasCap } from './permissions-matrix';
+import type { Capability } from '../types/saas';
+
+/**
+ * React hook: returns true if the current user has the given capability.
+ * Subscribes to session changes AND AW store changes — the component
+ * re-renders when the active AccountWorkspace changes (e.g. workspace
+ * switcher in Phase 3e) OR when _devSetCurrentAWRole mutates the AW role
+ * in-place without going through a session event.
+ */
+export function useCan(capability: Capability): boolean {
+  const session = useSession();
+  // Subscription only — return value used for re-render trigger when AW role
+  // is mutated via _devSetCurrentAWRole (which updates the AW store without
+  // touching the session store).
+  useAccountWorkspacesStore();
+  if (!session.currentAccountWorkspaceId) return false;
+
+  const aw = getAccountWorkspace(session.currentAccountWorkspaceId);
+  if (!aw) return false;
+
+  return roleHasCap(aw.role, capability);
+}
+
+/**
+ * Non-hook variant — safe to call from store actions, event handlers,
+ * or anywhere outside the React render cycle.
+ * Does NOT subscribe to changes — call inside a render if reactivity matters.
+ */
+export function currentCanCheck(capability: Capability): boolean {
+  const session = getSession();
+  if (!session.currentAccountWorkspaceId) return false;
+
+  const aw = getAccountWorkspace(session.currentAccountWorkspaceId);
+  if (!aw) return false;
+
+  return roleHasCap(aw.role, capability);
+}
