+// Task definitions store — persists workspace-scoped task library in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+//
+// System seeds (workspaceId === 'system') are inserted on first-run if absent.
+// They represent the default brainstorm tasks that auto-complete based on piece data.
+
+import { useEffect, useState } from 'react';
+import type { TaskDefinition } from '../types/saas';
+import type { StageId } from '../types/production';
+
+const KEY = 'task-definitions-store:v1';
+
+interface TaskDefinitionsState {
+  taskDefinitions: TaskDefinition[];
+}
+
+const EMPTY: TaskDefinitionsState = { taskDefinitions: [] };
+
+// ─── System seeds ─────────────────────────────────────────────────────────────
+// These two definitions replace the hard-coded `suggestedKey` checks in
+// production-store.ts (getEffectiveTaskStatus / isAutoDerivedTask).
+// Phase 2 will fully build out the task library UI; for now they live in
+// localStorage so production-store can reference them by id.
+const SYSTEM_SEEDS: TaskDefinition[] = [
+  {
+    id: 'sys.brainstorm.hook-locked',
+    workspaceId: 'system',
+    stage: 'brainstorm',
+    name: 'Hook',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'hookNonEmpty',
+  },
+  {
+    id: 'sys.preproduction.shot-list',
+    workspaceId: 'system',
+    stage: 'preproduction',
+    name: 'Shot list',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'shotListNonEmpty',
+  },
+  {
+    id: 'sys.preproduction.production-notes',
+    workspaceId: 'system',
+    stage: 'preproduction',
+    name: 'Production notes',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'productionNotesNonEmpty',
+  },
+  {
+    id: 'sys.production.footage-notes',
+    workspaceId: 'system',
+    stage: 'production',
+    name: 'Footage notes',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'footageNotesNonEmpty',
+  },
+  {
+    id: 'sys.postproduction.editing-notes',
+    workspaceId: 'system',
+    stage: 'postproduction',
+    name: 'Editing notes',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'editingNotesNonEmpty',
+  },
+  {
+    id: 'sys.postproduction.caption-draft',
+    workspaceId: 'system',
+    stage: 'postproduction',
+    name: 'Caption draft',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'captionDraftNonEmpty',
+  },
+  {
+    id: 'sys.publish.schedule',
+    workspaceId: 'system',
+    stage: 'publish',
+    name: 'Schedule',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'scheduleNonEmpty',
+  },
+  {
+    id: 'sys.publish.all-posted',
+    workspaceId: 'system',
+    stage: 'publish',
+    name: 'All posted',
+    type: 'checkbox',
+    isDefault: true,
+    autoCompleteWhen: 'allScheduledPosted',
+  },
+];
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache. Populated on first loadTDState() call, invalidated
+// on every saveTDState(). Prevents repeated localStorage.getItem + JSON.parse
+// on each TaskRow render (called per task per re-render across the entire board).
+let cache: TaskDefinitionsState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadTDState(): TaskDefinitionsState {
+  // Return cached state when available — avoids localStorage read + JSON.parse per call.
+  if (cache !== null) return cache;
+
+  if (typeof localStorage === 'undefined') {
+    cache = { taskDefinitions: [...SYSTEM_SEEDS] };
+    return cache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    // First run — seed system definitions
+    const initial: TaskDefinitionsState = { taskDefinitions: [...SYSTEM_SEEDS] };
+    localStorage.setItem(KEY, JSON.stringify(initial));
+    cache = initial;
+    return cache;
+  }
+  try {
+    const parsed = { ...EMPTY, ...(JSON.parse(raw) as Partial<TaskDefinitionsState>) };
+    // Ensure system seeds are always present (idempotent backfill)
+    const ids = new Set(parsed.taskDefinitions.map((d) => d.id));
+    const missing = SYSTEM_SEEDS.filter((s) => !ids.has(s.id));
+    if (missing.length > 0) {
+      parsed.taskDefinitions = [...missing, ...parsed.taskDefinitions];
+    }
+    // One-shot cleanup: remove the retired platforms-picked system seed if still present.
+    const PLATFORMS_REMOVED_FLAG = 'task-definitions-store:platforms-removed-v1:done';
+    if (localStorage.getItem(PLATFORMS_REMOVED_FLAG) !== '1') {
+      const before = parsed.taskDefinitions.length;
+      parsed.taskDefinitions = parsed.taskDefinitions.filter(
+        (d) => d.id !== 'sys.brainstorm.platforms-picked',
+      );
+      if (parsed.taskDefinitions.length !== before || missing.length > 0) {
+        localStorage.setItem(KEY, JSON.stringify(parsed));
+      }
+      try { localStorage.setItem(PLATFORMS_REMOVED_FLAG, '1'); } catch { /* ignore */ }
+    } else if (missing.length > 0) {
+      localStorage.setItem(KEY, JSON.stringify(parsed));
+    }
+    cache = parsed;
+    return cache;
+  } catch {
+    const initial: TaskDefinitionsState = { taskDefinitions: [...SYSTEM_SEEDS] };
+    localStorage.setItem(KEY, JSON.stringify(initial));
+    cache = initial;
+    return cache;
+  }
+}
+
+function saveTDState(next: TaskDefinitionsState): void {
+  // Update cache and write to localStorage atomically.
+  // Cache is updated to the new value (not null) so the next read is still cached.
+  cache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    // If the write fails, invalidate cache so the next read falls back to localStorage.
+    cache = null;
+    console.warn('[task-definitions-store] localStorage write failed:', err);
+  }
+}
+
+function mutateTDState(
+  fn: (current: TaskDefinitionsState) => TaskDefinitionsState,
+): TaskDefinitionsState {
+  const current = loadTDState();
+  const next = fn(current);
+  saveTDState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function createTaskDef(
+  workspaceId: string,
+  stage: StageId,
+  name: string,
+  type: TaskDefinition['type'],
+  options?: string[],
+  createdByAccountId?: string,
+): TaskDefinition {
+  const def: TaskDefinition = {
+    id: genId('taskdef'),
+    workspaceId,
+    stage,
+    name: name.trim(),
+    type,
+    isDefault: false,
+    ...(options && options.length > 0 ? { options } : {}),
+    ...(createdByAccountId ? { createdByAccountId } : {}),
+  };
+  mutateTDState((s) => ({ ...s, taskDefinitions: [...s.taskDefinitions, def] }));
+  return def;
+}
+
+export function updateTaskDef(
+  id: string,
+  patch: Partial<Pick<TaskDefinition, 'name' | 'type' | 'options'>>,
+): void {
+  mutateTDState((s) => ({
+    ...s,
+    taskDefinitions: s.taskDefinitions.map((d) =>
+      d.id === id ? { ...d, ...patch } : d,
+    ),
+  }));
+}
+
+export function deleteTaskDef(id: string): void {
+  mutateTDState((s) => ({
+    ...s,
+    // System seeds are not deletable
+    taskDefinitions: s.taskDefinitions.filter(
+      (d) => d.id !== id || d.workspaceId === 'system',
+    ),
+  }));
+}
+
+/**
+ * List all task definitions for a given stage, including system seeds.
+ * Pass workspaceId to also include workspace-local definitions.
+ */
+export function listTaskDefsForStage(workspaceId: string, stage: StageId): TaskDefinition[] {
+  return loadTDState().taskDefinitions.filter(
+    (d) => d.stage === stage && (d.workspaceId === 'system' || d.workspaceId === workspaceId),
+  );
+}
+
+/**
+ * Find a single TaskDefinition by its id.
+ * Returns null when the id is unknown.
+ */
+export function findTaskDefById(id: string): TaskDefinition | null {
+  return loadTDState().taskDefinitions.find((d) => d.id === id) ?? null;
+}
+
+/**
+ * List ALL definitions for a workspace across ALL stages (system + workspace-local).
+ * Used by the snapshot logic and Settings → Task Library.
+ */
+export function listAllTaskDefsForWorkspace(workspaceId: string): TaskDefinition[] {
+  return loadTDState().taskDefinitions.filter(
+    (d) => d.workspaceId === 'system' || d.workspaceId === workspaceId,
+  );
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useTaskDefinitionsStore(): TaskDefinitionsState {
+  const [snapshot, setSnapshot] = useState<TaskDefinitionsState>(() => loadTDState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadTDState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
