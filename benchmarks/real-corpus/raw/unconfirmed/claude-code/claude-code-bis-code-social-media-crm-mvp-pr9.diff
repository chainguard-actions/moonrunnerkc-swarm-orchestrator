+                background: selected ? 'var(--green-soft, #dcfce7)' : 'var(--surface)',
+                color: 'var(--ink)',
+                cursor: 'pointer',
+                fontSize: '13px',
+                fontWeight: 500,
+              }}
+            >
+              {JURISDICTIONS[j].label.en}
