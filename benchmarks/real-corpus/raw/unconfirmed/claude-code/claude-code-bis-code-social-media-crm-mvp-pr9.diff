--- /dev/null
+++ b/src/components/production/AddTaskDialog.tsx
@@ -0,0 +1,197 @@
+import { useEffect, useState } from 'react';
+import type { TaskDefinition } from '../../types/saas';
+
+// Types that can be picked when ADDING or EDITING a task via this dialog.
+// 'checkbox' is intentionally excluded — that type is reserved for system
+// tasks (Hook, Platforms, etc.) which use a predicate-derived tick rather
+// than a per-item input.
+// 'textarea' is excluded from the picker (decided during UX review); existing
+// textarea tasks continue to render correctly via TaskTypeRenderer.
+const TASK_TYPES: TaskDefinition['type'][] = [
+  'text',
+  'list',
+  'checklist',
+  'dropdown',
+  'multiselect',
+  'date',
+  'number',
+  'link',
+];
+
+interface Props {
+  onAdd: (name: string, type: TaskDefinition['type'], options?: string[]) => void;
+  onClose: () => void;
+  /** When provided, the dialog opens in edit mode pre-filled with these values. */
+  initial?: { name: string; type: TaskDefinition['type']; options?: string[] };
+  mode?: 'add' | 'edit';
+}
+
+export function AddTaskDialog({ onAdd, onClose, initial, mode = 'add' }: Props) {
+  const [name, setName] = useState(initial?.name ?? '');
+  const [type, setType] = useState<TaskDefinition['type']>(initial?.type ?? 'text');
+  const [optionsRaw, setOptionsRaw] = useState(initial?.options?.join(', ') ?? '');
+
+  useEffect(() => {
+    const handler = (e: KeyboardEvent) => {
+      if (e.key === 'Escape') onClose();
+    };
+    window.addEventListener('keydown', handler);
+    return () => window.removeEventListener('keydown', handler);
+  }, [onClose]);
+
+  const showOptions = type === 'dropdown' || type === 'multiselect' || type === 'checklist';
+
+  function handleSubmit() {
+    const trimmedName = name.trim();
+    if (!trimmedName) return;
+    const options = showOptions
+      ? optionsRaw
+          .split(',')
+          .map((o) => o.trim())
+          .filter(Boolean)
+      : undefined;
+    onAdd(trimmedName, type, options?.length ? options : undefined);
+    onClose();
+  }
+
+  const inputStyle: React.CSSProperties = {
+    border: '1px solid var(--line)',
+    borderRadius: 6,
+    padding: '7px 10px',
+    fontSize: 13,
+    background: 'var(--bg)',
+    color: 'var(--ink)',
+    outline: 'none',
+    width: '100%',
+    boxSizing: 'border-box',
+  };
+
+  const labelStyle: React.CSSProperties = {
+    display: 'flex',
+    flexDirection: 'column',
+    gap: 5,
+  };
+
+  const labelTextStyle: React.CSSProperties = {
+    fontSize: 12,
+    fontWeight: 500,
+    color: 'var(--ink-2)',
+  };
+
+  return (
+    <div
+      onClick={onClose}
+      style={{
+        position: 'fixed',
+        inset: 0,
+        background: 'rgba(0,0,0,0.4)',
+        display: 'flex',
+        alignItems: 'center',
+        justifyContent: 'center',
+        // Above BottomTabBar (z:150); below Sidebar drawer overlay (z:201).
+        zIndex: 200,
+      }}
+    >
+      <div
+        onClick={(e) => e.stopPropagation()}
+        style={{
+          background: '#fff',
+          borderRadius: 10,
+          padding: 20,
+          width: '100%',
+          maxWidth: 420,
+          border: '1px solid var(--line)',
+        }}
+      >
+        <h2 style={{ fontSize: 16, fontWeight: 600, margin: '0 0 16px 0', color: 'var(--ink)' }}>
+          {mode === 'edit' ? 'Edit task' : 'Add task'}
+        </h2>
+
+        <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>
+          <label style={labelStyle}>
+            <span style={labelTextStyle}>Name</span>
+            <input
+              type="text"
+              value={name}
+              onChange={(e) => setName(e.target.value)}
+              onKeyDown={(e) => {
+                if (e.key === 'Enter') handleSubmit();
+              }}
+              placeholder="e.g. Shot location"
+              autoFocus
+              style={inputStyle}
+            />
+          </label>
+
+          <label style={labelStyle}>
+            <span style={labelTextStyle}>Type{mode === 'edit' ? ' (locked)' : ''}</span>
+            <select
+              value={type}
+              onChange={(e) => setType(e.target.value as TaskDefinition['type'])}
+              disabled={mode === 'edit'}
+              style={{ ...inputStyle, cursor: mode === 'edit' ? 'default' : 'pointer', opacity: mode === 'edit' ? 0.6 : 1 }}
+            >
+              {/* In edit mode, also include the current type if it's not in the add-mode list
+                  (e.g. 'checkbox' for system tasks, 'textarea' for legacy tasks) */}
+              {mode === 'edit' && !TASK_TYPES.includes(type) && (
+                <option key={type} value={type}>{type}</option>
+              )}
+              {TASK_TYPES.map((t) => (
+                <option key={t} value={t}>
+                  {t}
+                </option>
+              ))}
+            </select>
+          </label>
+
+          {showOptions && (
+            <label style={labelStyle}>
+              <span style={labelTextStyle}>Options (comma-separated)</span>
+              <input
+                type="text"
+                value={optionsRaw}
+                onChange={(e) => setOptionsRaw(e.target.value)}
+                placeholder="Option 1, Option 2, …"
+                style={inputStyle}
+              />
+            </label>
+          )}
+        </div>
+
+        <div style={{ display: 'flex', gap: 8, marginTop: 20 }}>
+          <button
+            onClick={handleSubmit}
+            disabled={!name.trim()}
+            style={{
+              padding: '8px 14px',
+              background: 'var(--ink)',
+              color: '#fff',
+              border: 'none',
+              borderRadius: 6,
+              fontWeight: 600,
+              fontSize: 13,
+              cursor: name.trim() ? 'pointer' : 'not-allowed',
+              opacity: name.trim() ? 1 : 0.5,
+            }}
+          >
+            {mode === 'edit' ? 'Save' : 'Add task'}
+          </button>
+          <button
+            onClick={onClose}
+            style={{
+              padding: '8px 14px',
+              background: 'transparent',
+              color: 'var(--ink)',
+              border: '1px solid var(--line)',
+              borderRadius: 6,
+              fontSize: 13,
+              cursor: 'pointer',
+            }}
+          >
+            Cancel
+          </button>
+        </div>
+      </div>
+    </div>
+  );
+}
