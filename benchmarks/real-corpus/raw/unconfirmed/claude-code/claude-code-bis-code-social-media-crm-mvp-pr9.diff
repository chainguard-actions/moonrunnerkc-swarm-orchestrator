+import type { Piece } from '../../types/production';
+import { suggestedTaskProgress } from '../../data/production-store';
+
+export function PieceCard({
+  piece,
+  onClick,
+}: {
+  piece: Piece;
+  onClick: () => void;
+}) {
+  const { done, total } = suggestedTaskProgress(piece, piece.currentStage);
+  const hookPreview =
+    piece.stageData.brainstorm.hook ||
+    piece.stageData.preproduction.script.split('\n')[0]?.slice(0, 80) ||
+    '(no hook yet)';
+  const platforms = piece.stageData.brainstorm.platforms;
+  const shootDate = piece.stageData.preproduction.shootDate;
+  return (
+    <div
+      onClick={onClick}
+      style={{
+        border: '1px solid var(--line)',
+        borderRadius: 10,
+        padding: 12,
+        background: 'var(--surface)',
+        cursor: 'pointer',
+        display: 'flex',
+        flexDirection: 'column',
+        gap: 6,
+      }}
+    >
+      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 8 }}>
+        <div style={{ fontWeight: 600, fontSize: 13 }}>{piece.title}</div>
+        {piece.doneAt && (
+          <span style={{ fontSize: 10, color: 'var(--green, #2a7)', fontWeight: 700, letterSpacing: 0.4 }}>
+            ✓ DONE
+          </span>
+        )}
+      </div>
+      <div
+        style={{
+          fontSize: 11,
+          color: 'var(--muted)',
+          overflow: 'hidden',
+          textOverflow: 'ellipsis',
+          whiteSpace: 'nowrap',
+        }}
+        title={hookPreview}
+      >
+        "{hookPreview}"
+      </div>
+      <div style={{ display: 'flex', alignItems: 'center', gap: 6, fontSize: 10.5, color: 'var(--muted)' }}>
+        <span
+          style={{
+            background: 'var(--line)',
+            padding: '2px 6px',
+            borderRadius: 4,
+            fontWeight: 600,
+          }}
+        >
+          {done}/{total}
+        </span>
+        {platforms.length > 0 && <span>{platforms.join(', ')}</span>}
+        {shootDate && <span style={{ marginInlineStart: 'auto' }}>📅 {shootDate}</span>}
+        {piece.sourceVaultId && (
+          <span style={{ marginInlineStart: 'auto' }} title="From Vault">
+            ↩
+          </span>
+        )}
+      </div>
+    </div>
+  );
+}
