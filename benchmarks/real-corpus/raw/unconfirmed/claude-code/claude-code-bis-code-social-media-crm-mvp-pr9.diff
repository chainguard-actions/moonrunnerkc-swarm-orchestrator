+/**
+ * Evaluate a TaskDefinition.autoCompleteWhen predicate against a piece.
+ * Delegates to task-predicates.ts — see that module to add new predicates.
+ */
+function evalAutoComplete(
+  predicate: TaskDefinition['autoCompleteWhen'],
+  piece: Piece,
+): TaskStatus {
+  return evaluateAutoCompletePredicate(predicate, piece);
+}
+
+/**
+ * Resolve the TaskDefinition for a given PieceTask, if any.
+ *
+ * Resolution order:
+ *  1. task.suggestedKey matches a TaskDefinition id directly (Phase 2 library snapshot)
+ *  2. task.suggestedKey is a legacy dot-key (e.g. 'brainstorm.hook-locked') — map to
+ *     the canonical system def ids for backwards compatibility.
+ */
+function resolveTaskDef(task: PieceTask): TaskDefinition | null {
+  if (!task.suggestedKey) return null;
+  // Try direct id lookup first (Phase 2 path)
+  const byId = findTaskDefById(task.suggestedKey);
+  if (byId) return byId;
+  // Legacy dot-key → canonical system def id mapping
+  // TODO: delete this map and inline pass-through once SEED_PIECES are migrated to
+  // the library-snapshot format (via snapshotTasksForWorkspace). Currently kept for
+  // the legacy seed paths that use emptyTasksByStage() + hard-coded dot-key suggestedKeys.
+  const legacyMap: Record<string, string> = {
+    'brainstorm.hook-locked': 'sys.brainstorm.hook-locked',
+    'brainstorm.platforms-picked': 'sys.brainstorm.platforms-picked',
+  };
+  const canonicalId = legacyMap[task.suggestedKey];
+  if (canonicalId) return findTaskDefById(canonicalId);
+  return null;
+}
+
+/**
+ * Returns the effective status for a task, taking into account any
+ * autoCompleteWhen predicate declared on the matching TaskDefinition.
+ *
+ * Lookup order:
+ *  1. If the task has a suggestedKey, find the matching TaskDefinition.
+ *  2. If the def has autoCompleteWhen, evaluate it against the piece's stage data.
+ *  3. Otherwise fall through to task.status.
+ *
+ * This replaces the previous hard-coded suggestedKey checks and is fully driven
+ * by the task definitions library.
+ */
+/** Value-based task types: completion is derived from `task.value` being meaningfully populated. */
+function isValueBasedType(type: TaskDefinition['type']): boolean {
+  return type !== 'checkbox';
+}
+
+function isTaskValuePresent(task: PieceTask, type: TaskDefinition['type'], def?: TaskDefinition | null): boolean {
+  const v = task.value;
+  switch (type) {
+    case 'text':
+    case 'textarea':
+    case 'link':
+    case 'date':
+    case 'dropdown':
+      return typeof v === 'string' && v.trim().length > 0;
+    case 'multiselect':
+    case 'list':
+      return Array.isArray(v) && v.length > 0;
+    case 'number':
+      return typeof v === 'number' && Number.isFinite(v);
+    case 'checklist':
+      // All items must be checked for the task to count as done.
+      return (
+        Array.isArray(v) &&
+        v.length > 0 &&
+        def != null &&
+        (def.options ?? []).length > 0 &&
+        v.length === (def.options ?? []).length
+      );
+    case 'checkbox':
+      return false;
+    default:
+      return false;
+  }
+}
+
+export function getEffectiveTaskStatus(piece: Piece, task: PieceTask): TaskStatus {
+  const def = resolveTaskDef(task);
+  if (def?.autoCompleteWhen) {
+    return evalAutoComplete(def.autoCompleteWhen, piece);
+  }
+  // User-added value-typed tasks (text/dropdown/multiselect/date/number/link/checklist) tick
+  // automatically once their input is filled — same UX as the system tasks.
+  if (def && isValueBasedType(def.type)) {
+    return isTaskValuePresent(task, def.type, def) ? 'done' : 'todo';
+  }
+  return task.status;
+}
+
+/**
+ * Returns true when a task's status is auto-derived from piece data rather than
+ * set manually by the user. The UI uses this to render the checkbox as non-interactive.
+ */
+export function isAutoDerivedTask(task: PieceTask): boolean {
+  const def = resolveTaskDef(task);
+  if (!def) return false;
+  if (def.autoCompleteWhen !== undefined) return true;
+  return isValueBasedType(def.type);
+}
