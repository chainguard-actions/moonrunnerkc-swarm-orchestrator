+      if (p.id !== pieceId || p.workspaceId !== wsId) return p;
+      const allPosted =
+        p.stageData.publish.schedule.length > 0 &&
+        p.stageData.publish.schedule.every((r) => r.posted);
+      if (allPosted && !p.doneAt) return { ...p, doneAt: Date.now() };
+      if (!allPosted && p.doneAt) return { ...p, doneAt: undefined };
+      return p;
+    }),
+  }));
