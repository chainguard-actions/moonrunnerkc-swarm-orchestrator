@@ -0,0 +1,994 @@
+// localStorage-backed store for the content production pipeline.
+// Pattern mirrors src/data/store.ts and src/data/idea-pipeline-store.ts.
+//
+// Phase 3a: every piece now carries a workspaceId. Read actions filter by the
+// current workspace (from session-store). Write actions inject workspaceId.
+// The migration in saas-migration.ts backfills pieces that existed before Phase 3a.
+
+import { useEffect, useState } from 'react';
+import type {
+  Piece,
+  PieceTask,
+  Platform,
+  PublishScheduleRow,
+  ShotListItem,
+  StageId,
+  TaskStatus,
+  VaultIdea,
+} from '../types/production';
+import {
+  STAGE_ORDER,
+  emptyStageData,
+} from '../types/production';
+import { SEED_VAULT_IDEAS, SEED_PIECES } from './production-fixtures';
+import { getCurrentAccountWorkspaceId, subscribeSession } from './session-store';
+import { getAccountWorkspace } from './account-workspaces-store';
+import { createTaskDef, deleteTaskDef, findTaskDefById, listTaskDefsForStage, listAllTaskDefsForWorkspace } from './task-definitions-store';
+import type { TaskDefinition } from '../types/saas';
+import { evaluateAutoCompletePredicate } from './task-predicates';
+
+const KEY = 'production-store:v1';
+
+export interface ProductionState {
+  vault: VaultIdea[];
+  pieces: Piece[];
+}
+
+const empty: ProductionState = { vault: [], pieces: [] };
+
+/**
+ * Derive the current workspaceId from the session.
+ * Returns null when no session is active (app boots before migration runs, or user is logged out).
+ */
+function currentWorkspaceId(): string | null {
+  const awId = getCurrentAccountWorkspaceId();
+  if (!awId) return null;
+  const aw = getAccountWorkspace(awId);
+  return aw?.workspaceId ?? null;
+}
+
+/**
+ * Get current workspaceId; throw a descriptive error if it's null.
+ * Used in write actions so failures are loud and debuggable.
+ */
+function requireWorkspaceId(): string {
+  const wsId = currentWorkspaceId();
+  if (!wsId) {
+    throw new Error(
+      '[production-store] No active workspace. ' +
+      'Ensure runMigrationIfNeeded() ran before calling write actions, ' +
+      'or that the user is logged in.',
+    );
+  }
+  return wsId;
+}
+
+const listeners = new Set<() => void>();
+function notify() {
+  listeners.forEach((fn) => fn());
+}
+
+function seedFresh(): ProductionState {
+  return {
+    vault: structuredClone(SEED_VAULT_IDEAS),
+    pieces: structuredClone(SEED_PIECES),
+  };
+}
+
+export function loadProduction(): ProductionState {
+  if (typeof localStorage === 'undefined') return empty;
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    const fresh = seedFresh();
+    localStorage.setItem(KEY, JSON.stringify(fresh));
+    return fresh;
+  }
+  try {
+    return { ...empty, ...(JSON.parse(raw) as Partial<ProductionState>) };
+  } catch {
+    const fresh = seedFresh();
+    localStorage.setItem(KEY, JSON.stringify(fresh));
+    return fresh;
+  }
+}
+
+export function saveProduction(next: ProductionState): void {
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    console.warn('[production-store] localStorage write failed:', err);
+  }
+}
+
+/**
+ * One-time migration: retitle tasks that were snapshotted onto existing pieces with
+ * the pre-rename system task names. Pieces created before commit 9eaa42d have
+ * `task.title === 'Hook locked' | 'Platforms picked'`; new pieces use the renamed
+ * 'Hook' / 'Platforms'. This walks the existing store once and rewrites titles so
+ * the UI is consistent without requiring users to clear localStorage.
+ */
+const LEGACY_TITLE_RENAME_FLAG = 'production-store:title-rename-v1:done';
+const LEGACY_TITLE_RENAMES: Record<string, string> = {
+  'Hook locked': 'Hook',
+  'Platforms picked': 'Platforms',
+};
+
+export function migrateLegacyTaskTitles(): void {
+  if (typeof localStorage === 'undefined') return;
+  if (localStorage.getItem(LEGACY_TITLE_RENAME_FLAG) === '1') return;
+
+  const state = loadProduction();
+  let changed = false;
+  const newPieces = state.pieces.map((piece) => {
+    let pieceChanged = false;
+    const newTBS = { ...piece.tasksByStage } as Piece['tasksByStage'];
+    for (const stage of STAGE_ORDER) {
+      const tasks = piece.tasksByStage[stage];
+      const updated = tasks.map((t) => {
+        const renamed = LEGACY_TITLE_RENAMES[t.title];
+        if (renamed && renamed !== t.title) {
+          pieceChanged = true;
+          return { ...t, title: renamed };
+        }
+        return t;
+      });
+      if (pieceChanged) newTBS[stage] = updated;
+    }
+    if (pieceChanged) {
+      changed = true;
+      return { ...piece, tasksByStage: newTBS };
+    }
+    return piece;
+  });
+
+  if (changed) saveProduction({ ...state, pieces: newPieces });
+  try {
+    localStorage.setItem(LEGACY_TITLE_RENAME_FLAG, '1');
+  } catch (err) {
+    console.warn('[production-store] legacy-title-rename flag write failed:', err);
+  }
+}
+
+/**
+ * One-time migration: backfill the 7 new non-brainstorm system tasks onto
+ * every existing piece. Existing pieces only have brainstorm tasks snapshotted
+ * (Hook + Platforms). This runs once per browser and appends the new system
+ * task stubs onto preproduction / production / postproduction / publish stages.
+ *
+ * Brainstorm tasks are intentionally skipped — they already exist on all pieces
+ * and we must not undo a user's deliberate × removal.
+ *
+ * Deduplication: a stage entry is only appended when no existing task has a
+ * matching suggestedKey === def.id, so re-running is safe.
+ */
+const SYSTEM_TASKS_V2_FLAG = 'production-store:system-tasks-v2:done';
+
+// The new system def ids introduced in this migration (non-brainstorm only).
+const NEW_SYSTEM_DEF_IDS = new Set([
+  'sys.preproduction.shot-list',
+  'sys.preproduction.production-notes',
+  'sys.production.footage-notes',
+  'sys.postproduction.editing-notes',
+  'sys.postproduction.caption-draft',
+  'sys.publish.schedule',
+  'sys.publish.all-posted',
+]);
+
+export function migrateBackfillSystemTasks(): void {
+  if (typeof localStorage === 'undefined') return;
+  if (localStorage.getItem(SYSTEM_TASKS_V2_FLAG) === '1') return;
+
+  const state = loadProduction();
+  let changed = false;
+
+  // Collect all new system defs once (they're workspace-agnostic — workspaceId === 'system').
+  // listAllTaskDefsForWorkspace('system') returns only system defs when called with 'system'.
+  const allSystemDefs = listAllTaskDefsForWorkspace('system').filter((d) =>
+    NEW_SYSTEM_DEF_IDS.has(d.id),
+  );
+
+  const newPieces = state.pieces.map((piece) => {
+    const newTBS = { ...piece.tasksByStage } as Piece['tasksByStage'];
+    let pieceChanged = false;
+
+    for (const stage of STAGE_ORDER) {
+      // Skip brainstorm — those tasks already exist and we don't want to duplicate or
+      // re-add what the user may have removed.
+      if (stage === 'brainstorm') continue;
+
+      const stageDefs = allSystemDefs.filter((d) => d.stage === stage);
+      if (stageDefs.length === 0) continue;
+
+      const existingKeys = new Set(
+        (piece.tasksByStage[stage] ?? []).map((t) => t.suggestedKey).filter(Boolean),
+      );
+
+      const toAppend = stageDefs.filter((d) => !existingKeys.has(d.id));
+      if (toAppend.length === 0) continue;
+
+      newTBS[stage] = [
+        ...(piece.tasksByStage[stage] ?? []),
+        ...toAppend.map((def) => ({
+          id: genId('task'),
+          title: def.name,
+          suggestedKey: def.id,
+          status: 'todo' as TaskStatus,
+        })),
+      ];
+      pieceChanged = true;
+    }
+
+    if (pieceChanged) {
+      changed = true;
+      return { ...piece, tasksByStage: newTBS };
+    }
+    return piece;
+  });
+
+  if (changed) saveProduction({ ...state, pieces: newPieces });
+  try {
+    localStorage.setItem(SYSTEM_TASKS_V2_FLAG, '1');
+  } catch (err) {
+    console.warn('[production-store] system-tasks-v2 flag write failed:', err);
+  }
+}
+
+/**
+ * One-time migration: remove the retired 'sys.brainstorm.platforms-picked' task
+ * from every piece's brainstorm task list. The Platforms picker has moved to the
+ * PieceDetail header and is no longer represented as a checklist task.
+ *
+ * Flag: production-store:platforms-task-removed-v1:done
+ */
+const PLATFORMS_TASK_REMOVED_FLAG = 'production-store:platforms-task-removed-v1:done';
+
+export function migrateDropPlatformsTask(): void {
+  if (typeof localStorage === 'undefined') return;
+  if (localStorage.getItem(PLATFORMS_TASK_REMOVED_FLAG) === '1') return;
+
+  const state = loadProduction();
+  let changed = false;
+  const newPieces = state.pieces.map((piece) => {
+    const brainstormTasks = piece.tasksByStage.brainstorm;
+    const filtered = brainstormTasks.filter(
+      (t) =>
+        t.suggestedKey !== 'sys.brainstorm.platforms-picked' &&
+        t.suggestedKey !== 'brainstorm.platforms-picked',
+    );
+    if (filtered.length === brainstormTasks.length) return piece;
+    changed = true;
+    return {
+      ...piece,
+      tasksByStage: { ...piece.tasksByStage, brainstorm: filtered },
+    };
+  });
+
+  if (changed) saveProduction({ ...state, pieces: newPieces });
+  try {
+    localStorage.setItem(PLATFORMS_TASK_REMOVED_FLAG, '1');
+  } catch (err) {
+    console.warn('[production-store] platforms-task-removed flag write failed:', err);
+  }
+}
+
+export function mutateProduction(
+  fn: (current: ProductionState) => ProductionState,
+): ProductionState {
+  const current = loadProduction();
+  const next = fn(current);
+  saveProduction(next);
+  return next;
+}
