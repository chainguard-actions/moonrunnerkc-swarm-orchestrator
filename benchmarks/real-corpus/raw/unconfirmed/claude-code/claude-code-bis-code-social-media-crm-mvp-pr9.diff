--- /dev/null
+++ b/src/lib/sanitize-url.ts
@@ -0,0 +1,11 @@
+// URL sanitization helpers — prevent XSS via javascript: and data: URLs.
+
+/**
+ * Returns the URL if it starts with http:// or https://, otherwise returns null.
+ * Use this at any render site that outputs an <a href> from user-supplied data.
+ */
+export function safeHttpUrl(url: string | undefined | null): string | null {
+  if (!url) return null;
+  const trimmed = url.trim();
+  return /^https?:\/\//i.test(trimmed) ? trimmed : null;
+}
