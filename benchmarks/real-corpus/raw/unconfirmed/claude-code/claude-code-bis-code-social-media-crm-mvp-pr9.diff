+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((p) => {
+      if (p.id !== pieceId || p.workspaceId !== wsId) return p;
+      const idx = STAGE_ORDER.indexOf(p.currentStage);
+      if (idx === -1 || idx >= STAGE_ORDER.length - 1) return p;
+      next = STAGE_ORDER[idx + 1];
+      return { ...p, currentStage: next };
+    }),
+  }));
+  return next;
