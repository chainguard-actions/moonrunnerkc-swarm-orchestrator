diff --git a/src/data/saas-migration.ts b/src/data/saas-migration.ts
--- /dev/null
+++ b/src/data/saas-migration.ts
@@ -0,0 +1,151 @@
+// SaaS data-layer migration — runs once on app boot (idempotent).
+//
+// On first run (no accounts exist in localStorage):
+//   1. Creates a "Default" Org
+//   2. Creates a demo Account (name: 'You', email: 'demo@example.com', passwordHash: 'demo')
+//   3. Creates a "Default workspace" Workspace under the Default Org
+//   4. Creates an Administrator AccountWorkspace linking the account to the workspace
+//   5. Sets the session to that AccountWorkspace so the app boots into the pipeline
+//
+// On subsequent runs (accounts already exist):
+//   - Existing pieces without workspaceId are assigned to the Default workspace.
+//   - No accounts/orgs/workspaces are re-created.
+//
+// The migration is gated by the `saas-migration:v1:done` localStorage flag.
+// Clearing that key forces a re-run (useful for dev/testing).
+
+import { createOrg, listOrgs } from './org-store';
+import { createWorkspace, listAllWorkspaces } from './workspace-store';
+import { createAccount, findAccountByEmail } from './account-store';
+import { createAccountWorkspace, listAccountWorkspacesForAccount } from './account-workspaces-store';
+import { login, getSession } from './session-store';
+import { loadProduction, saveProduction } from './production-store';
+
+const MIGRATION_FLAG = 'saas-migration:v1:done';
+const DEFAULT_WORKSPACE_ID_KEY = 'saas-migration:v1:defaultWorkspaceId';
+const JURISDICTION_BACKFILL_FLAG = 'saas-migration:v2:jurisdiction:done';
+
+/** Returns the Default workspace id seeded by this migration, or null if not yet run. */
+export function getDefaultWorkspaceId(): string | null {
+  if (typeof localStorage === 'undefined') return null;
+  return localStorage.getItem(DEFAULT_WORKSPACE_ID_KEY);
+}
+
+/**
+ * Run the SaaS foundation migration if it hasn't been run yet.
+ * Safe to call multiple times — truly one-shot: returns immediately after first successful run.
+ * To force a re-run (dev/testing): clear localStorage key `saas-migration:v1:done`.
+ * To add a new migration version: bump the flag key to `saas-migration:v2:done`.
+ */
+export function runMigrationIfNeeded(): void {
+  if (typeof localStorage === 'undefined') return;
+  if (localStorage.getItem(MIGRATION_FLAG) === '1') return;
+
+  // ── Step 1: Seed Default Org / Account / Workspace if this is a fresh install
+  const orgs = listOrgs();
+  let defaultWorkspaceId = localStorage.getItem(DEFAULT_WORKSPACE_ID_KEY);
+
+  if (orgs.length === 0) {
+    // Brand-new install — seed everything
+    const org = createOrg('Default');
+
+    // MOCK ONLY: passwordHash stored as plain text (see account-store.ts)
+    const account = createAccount('You', 'demo@example.com', 'demo');
+
+    const workspace = createWorkspace(org.id, 'Default workspace');
+    defaultWorkspaceId = workspace.id;
+    localStorage.setItem(DEFAULT_WORKSPACE_ID_KEY, workspace.id);
+
+    const aw = createAccountWorkspace(account.id, workspace.id, 'Administrator');
+
+    // Set session so the app boots directly into the pipeline
+    login(account.id, aw.id);
+  } else if (!defaultWorkspaceId) {
+    // Orgs exist but we lost the default workspace pointer — try to recover it
+    // (e.g. after a partial migration or a manual localStorage edit)
+    const workspaces = listAllWorkspaces();
+    if (workspaces.length > 0) {
+      defaultWorkspaceId = workspaces[0].id;
+      localStorage.setItem(DEFAULT_WORKSPACE_ID_KEY, workspaces[0].id);
+    }
+  }
+
+  // ── Step 2: Ensure demo account session is set if no session exists
+  if (defaultWorkspaceId) {
+    const session = getSession();
+    if (!session.currentAccountId || !session.currentAccountWorkspaceId) {
+      // Session lost (e.g. explicit logout) — re-seed from the demo account
+      const demo = findAccountByEmail('demo@example.com');
+      if (demo) {
+        const aws = listAccountWorkspacesForAccount(demo.id);
+        const aw = aws.find((a) => a.workspaceId === defaultWorkspaceId);
+        if (aw) {
+          login(demo.id, aw.id);
+        }
+      }
+    }
+  }
+
+  // ── Step 3: Migrate existing pieces and vault ideas — assign workspaceId if missing
+  if (defaultWorkspaceId) {
+    const state = loadProduction();
+    let didMutate = false;
+    const migratedPieces = state.pieces.map((p) => {
+      if (!('workspaceId' in p) || !(p as { workspaceId?: string }).workspaceId) {
+        didMutate = true;
+        return { ...p, workspaceId: defaultWorkspaceId as string };
+      }
+      return p;
+    });
+    const migratedVault = state.vault.map((v) => {
+      if (!('workspaceId' in v) || !(v as { workspaceId?: string }).workspaceId) {
+        didMutate = true;
+        return { ...v, workspaceId: defaultWorkspaceId as string };
+      }
+      return v;
+    });
+    if (didMutate) {
+      saveProduction({ ...state, pieces: migratedPieces, vault: migratedVault });
+    }
+  }
+
+  // Mark migration as done
+  localStorage.setItem(MIGRATION_FLAG, '1');
+}
+
+
+/** v2 — backfill Workspace.jurisdiction from legacy country/locale/currency/vat
+ *  signals, then delete the legacy fields. Runs once; idempotent. */
+export function runJurisdictionBackfillIfNeeded(): void {
+  if (typeof localStorage === 'undefined') return;
+  if (localStorage.getItem(JURISDICTION_BACKFILL_FLAG) === '1') return;
+
+  const raw = localStorage.getItem('workspace-store:v1');
+  if (raw) {
+    try {
+      const state = JSON.parse(raw) as { workspaces: Array<Record<string, unknown>> };
+      let didMutate = false;
+      const workspaces = state.workspaces.map((w) => {
+        if (typeof w.jurisdiction === 'string') return w; // already set
+        didMutate = true;
+        const country = typeof w.country === 'string' ? w.country.toLowerCase() : '';
+        const locale = typeof w.locale === 'string' ? w.locale : '';
+        const currency = w.currency;
+        const isSaudi =
+          country.includes('saudi') || country === 'sa' || country === 'ksa' ||
+          locale.endsWith('-SA') ||
+          currency === 'SAR' ||
+          typeof w.vatNumber === 'string';
+        const { country: _c, locale: _l, ...rest } = w; // drop legacy fields
+        return { ...rest, jurisdiction: isSaudi ? 'SA' : 'INTL' };
+      });
+      if (didMutate) {
+        localStorage.setItem('workspace-store:v1', JSON.stringify({ ...state, workspaces }));
+      }
+    } catch {
+      // ignore malformed store — backfill flag still set below so we do not loop
+    }
+  }
+
+  localStorage.setItem(JURISDICTION_BACKFILL_FLAG, '1');
+}
