--- /dev/null
+++ b/src/data/client-store.ts
@@ -0,0 +1,145 @@
+// Client store — persists clients (Sponsor/agency records) in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+
+import { useEffect, useState } from 'react';
+import type { Client } from '../types/saas';
+import { getSession } from './session-store';
+import { getAccountWorkspace } from './account-workspaces-store';
+import { listShareTokensForClient, revokeShareToken } from './share-tokens-store';
+
+const KEY = 'client-store:v1';
+
+interface ClientState {
+  clients: Client[];
+}
+
+const EMPTY: ClientState = { clients: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let clientCache: ClientState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadClientState(): ClientState {
+  if (clientCache !== null) return clientCache;
+  if (typeof localStorage === 'undefined') {
+    clientCache = { ...EMPTY };
+    return clientCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    clientCache = { ...EMPTY };
+    return clientCache;
+  }
+  try {
+    clientCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<ClientState>) };
+    return clientCache;
+  } catch {
+    clientCache = { ...EMPTY };
+    return clientCache;
+  }
+}
+
+function saveClientState(next: ClientState): void {
+  clientCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    clientCache = null;
+    console.warn('[client-store] localStorage write failed:', err);
+  }
+}
+
+function mutateClientState(fn: (current: ClientState) => ClientState): ClientState {
+  const current = loadClientState();
+  const next = fn(current);
+  saveClientState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function createClient(
+  workspaceId: string,
+  name: string,
+  contactEmail?: string,
+): Client {
+  const client: Client = {
+    id: genId('client'),
+    workspaceId,
+    name: name.trim(),
+    ...(contactEmail ? { contactEmail: contactEmail.trim() } : {}),
+  };
+  mutateClientState((s) => ({ ...s, clients: [...s.clients, client] }));
+  return client;
+}
+
+export function updateClient(
+  id: string,
+  patch: Partial<Pick<Client, 'name' | 'contactEmail' | 'notes'>>,
+): void {
+  mutateClientState((s) => ({
+    ...s,
+    clients: s.clients.map((c) => (c.id === id ? { ...c, ...patch } : c)),
+  }));
+}
+
+export function deleteClient(id: string): void {
+  // Cascade-delete orphaned share tokens so they cannot be redeemed after the client is gone.
+  listShareTokensForClient(id).forEach((t) => revokeShareToken(t.token));
+  mutateClientState((s) => ({
+    ...s,
+    clients: s.clients.filter((c) => c.id !== id),
+  }));
+}
+
+export function listClientsForWorkspace(workspaceId: string): Client[] {
+  return loadClientState().clients.filter((c) => c.workspaceId === workspaceId);
+}
+
+export function getClient(id: string): Client | null {
+  return loadClientState().clients.find((c) => c.id === id) ?? null;
+}
+
+/**
+ * Returns the client(s) for the current Sponsor's AW.
+ * Returns [] if:
+ *   - no active session
+ *   - current AW role is not 'Sponsor'
+ *   - no clientId set on the AW
+ *
+ * Trade-off: this function reads from session-store and account-workspaces-store,
+ * coupling session-awareness into the data layer.
+ * TODO(refactor): if more callers appear, move to src/lib/client-selectors.ts to keep client-store pure-data.
+ */
+export function listClientsForCurrentSponsor(): Client[] {
+  const session = getSession();
+  if (!session.currentAccountWorkspaceId) return [];
+  const aw = getAccountWorkspace(session.currentAccountWorkspaceId);
+  if (!aw || aw.role !== 'Sponsor' || !aw.clientId) return [];
+  const client = getClient(aw.clientId);
+  return client ? [client] : [];
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useClientStore(): ClientState {
+  const [snapshot, setSnapshot] = useState<ClientState>(() => loadClientState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadClientState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
+}
