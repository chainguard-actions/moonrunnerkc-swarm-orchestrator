+
+export function updateShot(pieceId: string, shotId: string, patch: Partial<ShotListItem>): void {
+  const wsId = requireWorkspaceId();
+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((p) =>
+      p.id === pieceId && p.workspaceId === wsId
+        ? {
+            ...p,
+            stageData: {
+              ...p.stageData,
+              preproduction: {
+                ...p.stageData.preproduction,
+                shotList: p.stageData.preproduction.shotList.map((sh) =>
+                  sh.id === shotId ? { ...sh, ...patch } : sh,
+                ),
+              },
+            },
+          }
+        : p,
+    ),
+  }));
+}
+
+export function deleteShot(pieceId: string, shotId: string): void {
+  const wsId = requireWorkspaceId();
+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((p) =>
+      p.id === pieceId && p.workspaceId === wsId
+        ? {
+            ...p,
+            stageData: {
+              ...p.stageData,
+              preproduction: {
+                ...p.stageData.preproduction,
+                shotList: p.stageData.preproduction.shotList.filter((sh) => sh.id !== shotId),
+              },
+            },
+          }
+        : p,
+    ),
+  }));
+}
+
+/**
+ * Remove a user-added task from this piece AND delete its TaskDefinition from the
+ * workspace library so future pieces don't snapshot it.
+ *
+ * Semantics: "user-added task" means a task whose suggestedKey resolves to a
+ * non-system TaskDefinition (workspaceId !== 'system').  System tasks (Hook,
+ * Platforms) are never passed here — the UI only shows × for non-system tasks.
+ *
+ * Side-effects:
+ *   1. Removes the PieceTask from piece.tasksByStage[stage].
+ *   2. Calls deleteTaskDef(task.suggestedKey) to remove the TaskDefinition from
+ *      the workspace library (so future pieces created after this call will not
+ *      snapshot it).  Existing OTHER pieces that already snapshotted the same def
+ *      keep their own PieceTask rows unaffected — we only remove the definition
+ *      record, not other pieces' tasks.
+ */
+export function removeWorkspaceTaskFromPiece(
+  pieceId: string,
+  stage: StageId,
+  taskId: string,
+): void {
+  const wsId = requireWorkspaceId();
+  // Resolve the suggestedKey before mutating so we can also clean up the def.
+  const state = loadProduction();
+  const piece = state.pieces.find((p) => p.id === pieceId && p.workspaceId === wsId);
+  const task = piece?.tasksByStage[stage].find((t) => t.id === taskId);
+  const defId = task?.suggestedKey ?? null;
+
+  // Remove from this piece's task list.
+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((p) =>
+      p.id === pieceId && p.workspaceId === wsId
+        ? {
+            ...p,
+            tasksByStage: {
+              ...p.tasksByStage,
+              [stage]: p.tasksByStage[stage].filter((t) => t.id !== taskId),
+            },
+          }
+        : p,
+    ),
+  }));
+
+  // Delete the library definition (non-system only — deleteTaskDef guards system seeds).
+  if (defId) {
+    const def = findTaskDefById(defId);
+    if (def && def.workspaceId !== 'system') {
+      deleteTaskDef(defId);
+    }
+  }
+}
