+import {
+  updatePieceStageData,
+  useProductionStore,
+} from '../../data/production-store';
+import type { Piece } from '../../types/production';
+import { FieldCard } from './FieldCard';
+import { StageWorkspace } from './StageWorkspace';
+import { UserTasksSection } from './UserTasksSection';
+
+const HOOK_LIMIT = 140;
+
+export function StageBrainstorm({ piece }: { piece: Piece }) {
+  const [state] = useProductionStore();
+  const source = piece.sourceVaultId
+    ? state.vault.find((v) => v.id === piece.sourceVaultId) ?? null
+    : null;
+  const data = piece.stageData.brainstorm;
+
+  return (
+    <StageWorkspace piece={piece} stage="brainstorm">
+      {source && (
+        <FieldCard label="Source (from Vault)">
+          <div style={{ fontSize: 13, color: 'var(--muted)', whiteSpace: 'pre-wrap', maxHeight: 200, overflowY: 'auto', border: '1px solid var(--line)', borderRadius: 6, padding: 10 }}>
+            <div style={{ fontWeight: 600, color: 'var(--ink)', marginBottom: 4 }}>{source.title}</div>
+            {source.contentText || '(no content)'}
+          </div>
+        </FieldCard>
+      )}
+      <FieldCard label="Hook">
+        <input
+          type="text"
+          value={data.hook}
+          maxLength={HOOK_LIMIT}
+          onChange={(e) => updatePieceStageData(piece.id, 'brainstorm', { hook: e.target.value })}
+          placeholder="The make-or-break first line…"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontSize: 14 }}
+        />
+        <div style={{ fontSize: 11, color: 'var(--muted)', marginTop: 4 }}>
+          {data.hook.length}/{HOOK_LIMIT}
+        </div>
+      </FieldCard>
+      <FieldCard label="Angle / audience notes">
+        <textarea
+          value={data.angleNotes}
+          onChange={(e) => updatePieceStageData(piece.id, 'brainstorm', { angleNotes: e.target.value })}
+          rows={4}
+          placeholder="Tone, audience, format notes…"
+          style={{ width: '100%', padding: '8px 10px', border: '1px solid var(--line)', borderRadius: 6, fontFamily: 'inherit', resize: 'vertical' }}
+        />
+      </FieldCard>
+      <UserTasksSection piece={piece} stage="brainstorm" />
+    </StageWorkspace>
+  );
+}
