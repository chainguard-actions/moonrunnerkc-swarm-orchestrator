+}
+
+// ─── Step 3: Create Workspace ─────────────────────────────────────────────────
+
+interface StepWorkspaceProps {
+  org: Org;
+  jurisdiction: Jurisdiction;
+  onBack: (partialValues: { wsName: string; niche: string; location: string }) => void;
+  onDone: () => void;
+  initialWsName?: string;
+  initialNiche?: string;
+  initialLocation?: string;
+}
+
+function StepCreateWorkspace({
+  org,
+  jurisdiction,
+  onBack,
+  onDone,
+  initialWsName = '',
+  initialNiche = '',
+  initialLocation = '',
+}: StepWorkspaceProps) {
+  const navigate = useNavigate();
+  const [wsName, setWsName] = useState(initialWsName);
+  const [niche, setNiche] = useState(initialNiche);
+  const [location, setLocation] = useState(initialLocation);
+  const [error, setError] = useState<string | null>(null);
+  const [submitting, setSubmitting] = useState(false);
+
+  function handleSubmit(e: FormEvent) {
+    e.preventDefault();
+    setError(null);
+
+    if (!wsName.trim()) {
+      setError('Workspace name is required.');
+      return;
+    }
+
+    const currentAccountId = getCurrentAccountId();
+    if (!currentAccountId) {
+      setError('Session error — please go back to the login screen.');
+      setSubmitting(false);
+      return;
+    }
+
+    setSubmitting(true);
+
+    // Create workspace under the org — jurisdiction is the LAST positional
+    // arg per Task 3 createWorkspace signature.
+    const workspace = createWorkspace(
+      org.id,
+      wsName.trim(),
+      niche.trim() || undefined,
+      location.trim() || undefined,
+      jurisdiction,
+    );
+
+    // Seed the UI language from the jurisdiction's suggested default on first
+    // run only — returning users with saved prefs keep their explicit choice.
+    seedLanguageIfUnset(JURISDICTIONS[jurisdiction].suggestedLanguage);
+
+    // The user who creates the org auto-becomes Administrator on this workspace
+    // (locked decision #4 from the SaaS Foundation plan).
+    const aw = createAccountWorkspace(currentAccountId, workspace.id, 'Administrator');
+
+    // Set session with the new AW so the app boots into the pipeline
+    login(currentAccountId, aw.id);
+
+    // Clear the pending org tracker now that setup is complete
+    try { sessionStorage.removeItem(PENDING_ORG_KEY); } catch { /* ignore */ }
+
+    onDone();
+    navigate('/screens/pipeline');
+  }
+
+  return (
+    <div style={cardStyle}>
+      <StepIndicator step={3} total={3} />
+
+      <p style={kickerStyle}>Almost there</p>
+      <h1 style={headingStyle}>Create your first workspace</h1>
+      <p style={subheadStyle}>
+        Under{' '}
+        <strong style={{ fontWeight: 600, color: 'var(--ink)' }}>{org.name}</strong> — you
+        can add more workspaces later.
+      </p>
+
+      <form
+        onSubmit={handleSubmit}
+        style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}
+      >
+        <label style={{ display: 'flex', flexDirection: 'column', gap: '6px' }}>
+          <span style={labelTextStyle}>Workspace name</span>
+          <input
+            type="text"
+            value={wsName}
+            onChange={(e) => setWsName(e.target.value)}
+            placeholder="e.g. Tribe Studio – Main"
+            required
+            style={fieldStyle}
+            onFocus={(e) => {
+              e.currentTarget.style.borderColor = 'var(--ink-3)';
+            }}
+            onBlur={(e) => {
+              e.currentTarget.style.borderColor = 'var(--line-2)';
+            }}
+          />
+        </label>
+
+        <label style={{ display: 'flex', flexDirection: 'column', gap: '6px' }}>
+          <span style={labelTextStyle}>
+            Niche{' '}
+            <span style={{ fontWeight: 400, color: 'var(--muted)' }}>(optional)</span>
+          </span>
+          <input
+            type="text"
+            value={niche}
+            onChange={(e) => setNiche(e.target.value)}
+            placeholder="e.g. Fitness, Restaurants, Tech"
+            style={fieldStyle}
+            onFocus={(e) => {
+              e.currentTarget.style.borderColor = 'var(--ink-3)';
+            }}
+            onBlur={(e) => {
+              e.currentTarget.style.borderColor = 'var(--line-2)';
+            }}
+          />
+        </label>
+
+        <label style={{ display: 'flex', flexDirection: 'column', gap: '6px' }}>
+          <span style={labelTextStyle}>
+            Location{' '}
+            <span style={{ fontWeight: 400, color: 'var(--muted)' }}>(optional)</span>
+          </span>
