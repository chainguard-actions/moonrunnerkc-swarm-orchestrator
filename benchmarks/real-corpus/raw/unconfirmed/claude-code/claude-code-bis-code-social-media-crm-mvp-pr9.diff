+
+export function updatePublishRow(
+  pieceId: string,
+  platform: Platform,
+  patch: Partial<PublishScheduleRow>,
+): void {
+  const wsId = requireWorkspaceId();
+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((p) => {
+      if (p.id !== pieceId || p.workspaceId !== wsId) return p;
+      const nextSchedule = p.stageData.publish.schedule.map((r) =>
+        r.platform === platform ? { ...r, ...patch } : r,
+      );
+      const allPosted =
+        nextSchedule.length > 0 && nextSchedule.every((r) => r.posted);
+      // doneAt flip rules: set on first all-posted transition, clear when no
+      // longer all-posted. Preserve existing doneAt if still all-posted.
+      const nextDoneAt = allPosted
+        ? (p.doneAt ?? Date.now())
+        : undefined;
+      return {
+        ...p,
+        stageData: {
+          ...p.stageData,
+          publish: { ...p.stageData.publish, schedule: nextSchedule },
+        },
+        doneAt: nextDoneAt,
+      };
+    }),
+  }));
+}
+
+/**
+ * Rename the snapshotted title for every task (across ALL pieces in the workspace)
+ * whose suggestedKey matches the given defId. Called from the task-edit flow so that
+ * renaming a library definition propagates to pieces that already snapshotted it.
+ *
+ * Does NOT require a workspaceId argument — it walks all pieces but only touches
+ * tasks matching the given defId, so cross-workspace safety is preserved via the
+ * suggestedKey being workspace-unique (generated with workspace-scoped createTaskDef).
+ */
+export function renamePieceTasksBySuggestedKey(defId: string, newTitle: string): void {
+  mutateProduction((s) => ({
+    ...s,
+    pieces: s.pieces.map((piece) => {
+      let pieceChanged = false;
+      const newTBS = { ...piece.tasksByStage } as Piece['tasksByStage'];
+      for (const stage of STAGE_ORDER) {
+        const tasks = piece.tasksByStage[stage];
+        const updated = tasks.map((t) => {
+          if (t.suggestedKey === defId && t.title !== newTitle) {
+            pieceChanged = true;
+            return { ...t, title: newTitle };
+          }
+          return t;
+        });
+        if (pieceChanged) newTBS[stage] = updated;
+      }
+      if (pieceChanged) return { ...piece, tasksByStage: newTBS };
+      return piece;
+    }),
+  }));
+}
