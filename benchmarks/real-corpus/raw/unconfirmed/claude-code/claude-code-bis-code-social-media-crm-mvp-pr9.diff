@@ -0,0 +1,165 @@
+// Workspace store — persists workspaces in localStorage.
+// Pattern mirrors production-store.ts: listeners Set + loadX/saveX + useXStore hook.
+
+import { useEffect, useState } from 'react';
+import type { Workspace } from '../types/saas';
+import type { Jurisdiction } from './jurisdictions';
+
+const KEY = 'workspace-store:v1';
+const LAST_ACTIVE_KEY = 'tribe-studio-v1:lastActiveWorkspace';
+
+interface WorkspaceState {
+  workspaces: Workspace[];
+}
+
+const EMPTY: WorkspaceState = { workspaces: [] };
+
+const listeners = new Set<() => void>();
+
+// Module-level read cache — avoids repeated localStorage reads.
+let workspaceCache: WorkspaceState | null = null;
+
+function notify(): void {
+  listeners.forEach((fn) => fn());
+}
+
+function loadWorkspaceState(): WorkspaceState {
+  if (workspaceCache !== null) return workspaceCache;
+  if (typeof localStorage === 'undefined') {
+    workspaceCache = { ...EMPTY };
+    return workspaceCache;
+  }
+  const raw = localStorage.getItem(KEY);
+  if (!raw) {
+    workspaceCache = { ...EMPTY };
+    return workspaceCache;
+  }
+  try {
+    workspaceCache = { ...EMPTY, ...(JSON.parse(raw) as Partial<WorkspaceState>) };
+    return workspaceCache;
+  } catch {
+    workspaceCache = { ...EMPTY };
+    return workspaceCache;
+  }
+}
+
+function saveWorkspaceState(next: WorkspaceState): void {
+  workspaceCache = next;
+  try {
+    localStorage.setItem(KEY, JSON.stringify(next));
+    notify();
+  } catch (err) {
+    workspaceCache = null;
+    console.warn('[workspace-store] localStorage write failed:', err);
+  }
+}
+
+function mutateWorkspaceState(fn: (current: WorkspaceState) => WorkspaceState): WorkspaceState {
+  const current = loadWorkspaceState();
+  const next = fn(current);
+  saveWorkspaceState(next);
+  return next;
+}
+
+function genId(prefix: string): string {
+  return `${prefix}-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
+
+// ─── Actions ─────────────────────────────────────────────────────────────────
+
+export function createWorkspace(
+  orgId: string,
+  name: string,
+  niche?: string,
+  location?: string,
+  jurisdiction: Jurisdiction = 'INTL',
+): Workspace {
+  const workspace: Workspace = {
+    id: genId('ws'),
+    orgId,
+    name: name.trim(),
+    ...(niche ? { niche } : {}),
+    ...(location ? { location } : {}),
+    jurisdiction,
+  };
+  mutateWorkspaceState((s) => ({ ...s, workspaces: [...s.workspaces, workspace] }));
+  return workspace;
+}
+
+export function getWorkspace(id: string): Workspace | null {
+  return loadWorkspaceState().workspaces.find((w) => w.id === id) ?? null;
+}
+
+/**
+ * Update mutable workspace fields. Only allowed fields are accepted;
+ * id and orgId are immutable.
+ */
+export function updateWorkspace(id: string, partial: Partial<Omit<Workspace, 'id' | 'orgId'>>): Workspace | null {
+  const existing = getWorkspace(id);
+  if (!existing) return null;
+  const updated: Workspace = { ...existing, ...partial };
+  mutateWorkspaceState((s) => ({
+    ...s,
+    workspaces: s.workspaces.map((w) => (w.id === id ? updated : w)),
+  }));
+  return updated;
+}
+
+export function listWorkspaces(orgId: string): Workspace[] {
+  return loadWorkspaceState().workspaces.filter((w) => w.orgId === orgId);
+}
+
+export function listAllWorkspaces(): Workspace[] {
+  return loadWorkspaceState().workspaces;
+}
+
+// ─── Legacy compat (used by Login.tsx before Phase 3b auth rewrite) ──────────
+
+export function getLastActiveWorkspaceId(email: string): string | null {
+  try {
+    const key = `${LAST_ACTIVE_KEY}:${email}`;
+    const raw = typeof localStorage !== 'undefined' ? localStorage.getItem(key) : null;
+    return raw ?? null;
+  } catch {
+    return null;
+  }
+}
+
+export function setLastActiveWorkspaceId(email: string, workspaceId: string): void {
+  try {
+    const key = `${LAST_ACTIVE_KEY}:${email}`;
+    localStorage.setItem(key, workspaceId);
+  } catch {
+    // ignore quota / disabled storage
+  }
+}
+
+/** Legacy hook for Login.tsx compatibility — returns old-shape { id, name } objects. */
+export function useWorkspaces(): { id: string; name: string }[] {
+  const [state, setState] = useState<{ id: string; name: string }[]>(() =>
+    loadWorkspaceState().workspaces.map((w) => ({ id: w.id, name: w.name })),
+  );
+  useEffect(() => {
+    const fn = () =>
+      setState(loadWorkspaceState().workspaces.map((w) => ({ id: w.id, name: w.name })));
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return state;
+}
+
+// ─── React hook ──────────────────────────────────────────────────────────────
+
+export function useWorkspaceStore(): WorkspaceState {
+  const [snapshot, setSnapshot] = useState<WorkspaceState>(() => loadWorkspaceState());
+  useEffect(() => {
+    const fn = () => setSnapshot(loadWorkspaceState());
+    listeners.add(fn);
+    return () => {
+      listeners.delete(fn);
+    };
+  }, []);
+  return snapshot;
