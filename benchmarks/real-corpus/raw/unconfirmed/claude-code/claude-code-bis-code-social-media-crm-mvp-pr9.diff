+// OnboardingGuard — guard for /onboarding.
+//
+// Requires at minimum a currentAccountId in the session.
+// Redirects to /login if the user is not authenticated at all.
+// Allows access regardless of whether currentAccountWorkspaceId is set so the
+// wizard can complete setup after /register.
+
+import { Navigate } from 'react-router-dom';
+import { getSession } from '../data/session-store';
+
+interface OnboardingGuardProps {
+  children: React.ReactNode;
+}
+
+export function OnboardingGuard({ children }: OnboardingGuardProps) {
+  const session = getSession();
+
+  if (!session.currentAccountId) {
+    return <Navigate to="/login" replace />;
+  }
+
+  return <>{children}</>;
+}
