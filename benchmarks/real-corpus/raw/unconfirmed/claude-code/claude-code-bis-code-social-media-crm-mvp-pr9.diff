@@ -0,0 +1,32 @@
+// SessionGuard — auth guard component for the /screens/* subtree.
+//
+// Routing rules:
+//   No session                     → /login
+//   Account set, no workspace      → /onboarding
+//   Both set                       → render children (ShellLayout)
+
+import { Navigate, useLocation } from 'react-router-dom';
+import { useSession } from '../data/session-store';
+
+interface SessionGuardProps {
+  children: React.ReactNode;
+}
+
+export function SessionGuard({ children }: SessionGuardProps) {
+  const location = useLocation();
+  // Reactive subscription so the guard re-renders if the session ever
+  // changes without an explicit navigation (e.g. expiry triggered by
+  // background polling, or a parallel-tab logout). Cycle 2 finding C2-A-2.
+  const session = useSession();
+
+  if (!session.currentAccountId) {
+    return <Navigate to="/login" replace state={{ from: location.pathname }} />;
+  }
+
+  if (session.currentAccountId && !session.currentAccountWorkspaceId) {
+    // Account exists but no workspace — drive through onboarding
+    return <Navigate to="/onboarding" replace />;
+  }
+
+  return <>{children}</>;
+}
