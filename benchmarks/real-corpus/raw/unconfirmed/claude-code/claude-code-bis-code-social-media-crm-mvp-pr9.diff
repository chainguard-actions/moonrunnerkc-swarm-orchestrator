+
+// ─── Progress indicator ───────────────────────────────────────────────────────
+
+function StepIndicator({ step, total }: { step: number; total: number }) {
+  return (
+    <div
+      style={{
+        display: 'flex',
+        alignItems: 'center',
+        gap: '8px',
+        marginBottom: '24px',
+      }}
+    >
+      {Array.from({ length: total }, (_, i) => (
+        <div
+          key={i}
+          style={{
+            height: '4px',
+            flex: 1,
+            borderRadius: '2px',
+            background: i < step ? 'var(--green)' : 'var(--line-2)',
+            transition: 'background 0.2s',
+          }}
+        />
+      ))}
+      <span
+        style={{
+          fontSize: '11px',
+          fontWeight: 500,
+          color: 'var(--ink-3)',
+          whiteSpace: 'nowrap',
+        }}
+      >
+        Step {step} of {total}
+      </span>
+    </div>
+  );
+}
+
+// ─── Step 1: Create Org ───────────────────────────────────────────────────────
+
+interface Step1Props {
+  onNext: (org: Org) => void;
+  initialOrgName?: string;
+  initialLogo?: string;
+}
+
+function StepCreateOrg({ onNext, initialOrgName = '', initialLogo = '' }: Step1Props) {
+  const [orgName, setOrgName] = useState(initialOrgName);
+  const [logo, setLogo] = useState(initialLogo);
+  const [error, setError] = useState<string | null>(null);
+
+  function handleSubmit(e: FormEvent) {
+    e.preventDefault();
+    setError(null);
+    if (!orgName.trim()) {
+      setError('Organisation name is required.');
+      return;
+    }
+    const org = createOrg(orgName.trim(), logo.trim() || undefined);
+    try { sessionStorage.setItem(PENDING_ORG_KEY, org.id); } catch { /* ignore */ }
+    onNext(org);
+  }
+
+  return (
+    <div style={cardStyle}>
+      <StepIndicator step={1} total={3} />
+
+      <p style={kickerStyle}>New organisation</p>
+      <h1 style={headingStyle}>Name your organisation</h1>
+      <p style={subheadStyle}>This is the top-level entity your workspaces live under.</p>
+
+      <form
+        onSubmit={handleSubmit}
+        style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}
+      >
+        <label style={{ display: 'flex', flexDirection: 'column', gap: '6px' }}>
+          <span style={labelTextStyle}>Organisation name</span>
+          <input
+            type="text"
+            value={orgName}
+            onChange={(e) => setOrgName(e.target.value)}
+            placeholder="e.g. Tribe Studio"
+            required
+            style={fieldStyle}
+            onFocus={(e) => {
+              e.currentTarget.style.borderColor = 'var(--ink-3)';
+            }}
+            onBlur={(e) => {
+              e.currentTarget.style.borderColor = 'var(--line-2)';
+            }}
+          />
+        </label>
+
+        <label style={{ display: 'flex', flexDirection: 'column', gap: '6px' }}>
+          <span style={labelTextStyle}>
+            Logo URL{' '}
+            <span style={{ fontWeight: 400, color: 'var(--muted)' }}>(optional)</span>
+          </span>
+          <input
+            type="url"
+            value={logo}
+            onChange={(e) => setLogo(e.target.value)}
+            placeholder="https://example.com/logo.png"
+            style={fieldStyle}
+            onFocus={(e) => {
+              e.currentTarget.style.borderColor = 'var(--ink-3)';
+            }}
+            onBlur={(e) => {
+              e.currentTarget.style.borderColor = 'var(--line-2)';
+            }}
+          />
+        </label>
+
+        {error && <div style={errorStyle}>{error}</div>}
+
+        <button type="submit" style={primaryBtnStyle}>
