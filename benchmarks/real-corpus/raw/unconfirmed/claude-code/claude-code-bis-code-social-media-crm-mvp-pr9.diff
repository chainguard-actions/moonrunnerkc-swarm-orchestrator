+
+        {type === 'recap' ? (
+          <RecapContent socialAccounts={socialAccounts} />
+        ) : (
+          <BillingContent clientName={client.name} />
+        )}
+      </div>
+
+      {/* Footer */}
+      <div
+        style={{
+          marginTop: 24,
+          fontSize: 11,
+          color: 'var(--ink-3, #bbb)',
+        }}
+      >
+        This link is view-only and expires on{' '}
+        {shareToken.expiresAt
+          ? new Date(shareToken.expiresAt).toLocaleDateString('en-US', {
+              year: 'numeric',
+              month: 'long',
+              day: 'numeric',
+            })
+          : 'never'}
+        .
+      </div>
+    </div>
+  );
+}
+
+// ─── RecapContent ─────────────────────────────────────────────────────────────
+
+interface RecapContentProps {
+  socialAccounts: Array<{ id: string; platform: string; handle: string; url?: string }>;
+}
+
+function RecapContent({ socialAccounts }: RecapContentProps) {
+  return (
+    <div style={{ display: 'flex', flexDirection: 'column', gap: 24 }}>
+      {/* Social accounts */}
+      <section>
+        <SectionHeading>Linked Social Accounts</SectionHeading>
+        {socialAccounts.length === 0 ? (
+          <EmptyHint>No social accounts linked to this client yet.</EmptyHint>
+        ) : (
+          <ul style={{ listStyle: 'none', margin: 0, padding: 0, display: 'flex', flexDirection: 'column', gap: 8 }}>
+            {socialAccounts.map((sa) => {
+              const href = safeHttpUrl(sa.url);
+              return (
+                <li
+                  key={sa.id}
+                  style={{
+                    display: 'flex',
+                    alignItems: 'center',
+                    gap: 10,
+                    padding: '8px 12px',
+                    border: '1px solid var(--line, #e5e5e5)',
+                    borderRadius: 8,
+                    fontSize: 13,
+                  }}
+                >
+                  <span
+                    style={{
+                      fontWeight: 600,
+                      color: 'var(--ink-2, #555)',
+                      minWidth: 90,
