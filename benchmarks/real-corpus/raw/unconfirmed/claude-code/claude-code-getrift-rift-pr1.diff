-  return (
-    <div className="space-y-1">
-      <ColorPicker
-        label="Fill"
-        value={bgColor}
-        opacity={bgOpacity}
-        onChange={(value) => setStyleOverride(selectedPath, 'backgroundColor', value)}
-        onOpacityChange={(value) => setStyleOverride(selectedPath, 'backgroundOpacity', value)}
-      />
-    </div>
-  );
-}
