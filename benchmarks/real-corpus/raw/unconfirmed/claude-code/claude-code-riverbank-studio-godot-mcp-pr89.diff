+}
+
+registerSceneTool({
+  name: "add_node",
+  description: "Add a node to an existing scene",
+  inputSchema: {
+    type: "object",
+    properties: {
+      projectPath: {
+        type: "string",
+        description: "Path to the Godot project directory",
+      },
+      scenePath: {
+        type: "string",
+        description: "Path to the scene file (relative to project)",
