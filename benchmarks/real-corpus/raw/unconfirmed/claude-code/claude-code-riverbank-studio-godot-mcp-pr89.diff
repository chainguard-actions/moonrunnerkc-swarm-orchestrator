+    expect(result.partial).toBe(false);
+    expect(result.diagnostics).toHaveLength(1);
+    expect(result.diagnostics[0].message).toBe("boom");
+  });
+
+  it("times out with partial:true when the server never pushes", async () => {
+    const { fs } = fakeFs({
