+        text = text.rstrip() + f"\n\n[{section}]\n{key} = {toml_value}\n"
+    else:
+        section_text = section_match.group(1)
+        key_pattern = re.compile(
+            rf"^({re.escape(key)}\s*=\s*).*$",
+            re.MULTILINE,
+        )
+        key_match = key_pattern.search(section_text)
+        if key_match:
