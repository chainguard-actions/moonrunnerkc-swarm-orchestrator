+    if not CONFIG_FILE.exists():
+        return False
+
+    text = CONFIG_FILE.read_text()
+
+    # Format the value for TOML
+    if isinstance(value, bool):
+        toml_value = "true" if value else "false"
+    elif isinstance(value, int):
+        toml_value = str(value)
+    else:
+        toml_value = f'"{value}"'
