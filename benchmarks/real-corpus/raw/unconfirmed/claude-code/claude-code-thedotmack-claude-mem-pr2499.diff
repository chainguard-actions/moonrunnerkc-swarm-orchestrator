+      }) as Record<string, unknown>;
+      expect(postToolOutput).not.toHaveProperty('suppressOutput');
+      expect(postToolOutput).toEqual({
+        continue: true,
+        hookSpecificOutput: {
+          hookEventName: 'PostToolUse',
+          additionalContext: 'ctx',
+        },
+      });
     });
   });
 
