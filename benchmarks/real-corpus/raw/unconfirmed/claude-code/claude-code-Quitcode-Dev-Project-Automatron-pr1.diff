-            session_id=state.get("session_id"),
-            stage="validating",
-        )
-        return {
-            "validation_gate_status": "PASS",
-            "validation_command_results": results,
-        }
-
-    await trace_event(
-        state["project_id"],
-        "validator",
-        "validator.completed",
-        {"task_id": active_task_id, "gate_status": "FAIL", "results": results},
-        session_id=state.get("session_id"),
-        stage="validating",
-    )
-    return {
