+    }
+
+    /* Plan comparison table */
+    .plan-table {
+      width: 100%;
+      border-collapse: collapse;
+      font-size: 0.875rem;
+      margin-bottom: 1.5rem;
+    }
+
+    .plan-table th {
+      background: var(--surface2);
+      padding: 0.6rem 1rem;
+      text-align: left;
+      font-weight: 600;
+      color: var(--muted);
+      font-size: 0.75rem;
+      text-transform: uppercase;
+      letter-spacing: 0.05em;
+      border-bottom: 1px solid var(--border);
+    }
+
+    .plan-table th:not(:first-child) {
+      text-align: center;
+    }
+
+    .plan-table td {
+      padding: 0.65rem 1rem;
+      border-bottom: 1px solid var(--border);
+      color: var(--text);
+    }
+
+    .plan-table td:not(:first-child) {
+      text-align: center;
+    }
+
+    .plan-table tr:last-child td { border-bottom: none; }
+
+    .plan-table tbody tr:hover { background: var(--surface2); }
+
+    .plan-table .feature { color: var(--muted); font-size: 0.82rem; }
+
+    .badge-yes   { color: var(--green);  font-weight: 600; }
+    .badge-no    { color: var(--red);    font-weight: 600; }
+    .badge-maybe { color: var(--yellow); font-weight: 600; }
+    .badge-plan  { color: var(--purple); font-weight: 600; }
+
+    /* Limit cards */
+    .cards {
+      display: grid;
+      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
+      gap: 1rem;
+      margin-bottom: 1.5rem;
+    }
+
+    .card {
