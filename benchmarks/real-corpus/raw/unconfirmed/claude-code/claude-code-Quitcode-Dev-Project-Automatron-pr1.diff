+
+    p { margin-bottom: 0.75rem; font-size: 0.875rem; color: var(--muted); }
+  </style>
+</head>
+<body>
+<div class="container">
+
+  <!-- Header -->
+  <div class="header">
+    <div class="logo">⚡</div>
+    <div class="header-text">
+      <h1>GitHub Copilot — Limits &amp; Constraints</h1>
+      <p>Reference for Automatron integration · April 2026</p>
+    </div>
+  </div>
+
+  <!-- TL;DR -->
+  <div class="alert alert-yellow">
+    <span class="alert-icon">⚠️</span>
+    <div>
+      <strong>Key constraint:</strong> The Copilot <em>coding agent</em> (the one that opens PRs autonomously)
+      cannot be triggered via the public GitHub REST or GraphQL API. It can only be assigned
+      through the GitHub web UI. Automatron works around this by creating issues and linking you
+      directly to the GitHub assignment flow.
+    </div>
+  </div>
+
+  <!-- Plans -->
+  <h2>Plan Availability</h2>
+  <table class="plan-table">
+    <thead>
+      <tr>
+        <th>Feature</th>
+        <th>Free</th>
+        <th>Pro / Pro+</th>
+        <th>Business</th>
+        <th>Enterprise</th>
+      </tr>
+    </thead>
+    <tbody>
+      <tr>
+        <td>Code completions (IDE)</td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+      </tr>
+      <tr>
+        <td>Chat (github.com / IDE)</td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+        <td><span class="badge-yes">✓</span></td>
+      </tr>
