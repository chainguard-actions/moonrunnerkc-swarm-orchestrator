+def _parse_tagged_block(response: str, tag: str) -> str | None:
+    marker = f"```{tag}"
+    if marker not in response:
+        return None
+    try:
+        start = response.index(marker) + len(marker)
+        end = response.index("```", start)
+        return response[start:end].strip() or None
+    except ValueError:
+        return None
+
