+  it('propagates container from message_delta into final snapshot', async () => {
+    // Regression: previously, the non-beta accumulator merged stop_reason / stop_sequence /
+    // usage from message_delta but dropped event.delta.container, so finalMessage().container
+    // was always null even when the SSE stream carried the container info. The next request
+    // would then fail with `container_id is required when there are pending tool uses
+    // generated by code execution with tools.` See anthropics/anthropic-sdk-typescript#964.
+    const { fetch, handleStreamEvents } = mockFetch();
+    const anthropic = new Anthropic({ apiKey: '...', fetch });
+
+    const fixtureContent = loadFixture('code_execution_response.txt');
+    const streamEvents = await parseSSEFixture(fixtureContent);
+    handleStreamEvents(streamEvents);
+
+    const stream = anthropic.messages.stream({
+      max_tokens: 1024,
+      model: 'claude-sonnet-4-20250514',
+      messages: [{ role: 'user', content: 'Run some code.' }],
+    });
+
+    for await (const _event of stream) {
+      // drain
+    }
+    await stream.done();
+    const finalMessage = await stream.finalMessage();
+
+    expect(finalMessage.container).toEqual({
+      id: 'container_01AbCdEfGhIjKlMnOpQrStUv',
+      expires_at: '2030-01-01T00:00:00.000000+00:00',
+    });
+  });
+
