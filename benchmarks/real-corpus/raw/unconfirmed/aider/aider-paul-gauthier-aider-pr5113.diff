+    html_src = f"""
+<style>
+  body {{ margin: 0; padding: 0; overflow: hidden; background: transparent; }}
+</style>
+<script>
+(function() {{
+  var SKILLS = {skills_json};
+
+  // --- State ---
+  var popover = null;
