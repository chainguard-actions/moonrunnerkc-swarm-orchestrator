+          },
+          "Attachment": {
+            "type": "object",
+            "description": "Email attachment.",
+            "properties": {
+              "name": {
+                "type": "string",
+                "description": "Attachment file name."
+              }
+            }
+          },
+          "EmailAddress": {
+            "type": "object",
+            "description": "Email address object.",
+            "properties": {
+              "address": {
+                "type": "string",
+                "description": "SMTP address."
+              }
+            }
+          },
+          "GiantUnusedPayload": {
+            "type": "object",
+            "description": "Representative unreachable Outlook payload.",
+            "properties": {
+              "opaque": {
+                "type": "string"
+              }
+            }
+          }
+        }
+      },
+      "expected_preserved": [
