+
+  const goal = report?.goal ?? null;
+  const threadId = goal?.threadId ?? report?.threadId ?? null;
+  if (!goal) {
+    lines.push("No Codex goal is set for this repository.");
+    if (threadId) {
+      lines.push(`Thread: ${threadId}`);
