+            "model": "deepseek-v4-flash",
+            "input": [
+                {"type": "function_call", "call_id": "call_1", "name": "get_weather", "arguments": "{\"city\":\"NYC\"}"},
+                {"type": "function_call_output", "call_id": "call_1", "output": "Sunny"},
+                {"role": "user", "content": [{"type": "input_text", "text": "Thanks"}]}
