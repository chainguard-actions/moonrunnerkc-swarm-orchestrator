+}
+
+function assertEqual<T>(actual: T, expected: T, label?: string): void {
+  if (actual !== expected) {
+    throw new Error(
+      `${label ?? 'assertEqual'}: expected ${JSON.stringify(expected)}, got ${JSON.stringify(actual)}`,
+    );
+  }
+}
