+    assertEqual(TOTAL_ROUTES, 1270, 'TOTAL_ROUTES');
+    assertEqual(TOTAL_PAGES, 62, 'TOTAL_PAGES');
+    assertEqual(TOTAL_DIAGNOSTIKA, 2368, 'TOTAL_DIAGNOSTIKA');
+  });
