+const GAME_EXECUTABLE_CANDIDATES: &[&str] = &["online.exe", "pso.exe", "psobb.exe"];
+const ALLOWED_ROOT_FILES: &[&str] = &["dinput8.dll", "dinput8.pdb", "README.md", "CHANGELOG.md"];
