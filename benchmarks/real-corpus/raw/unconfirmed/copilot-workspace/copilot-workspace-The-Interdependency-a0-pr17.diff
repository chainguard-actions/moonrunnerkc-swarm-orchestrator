+        status_md = gr.HTML("")
+
+        save_btn.click(
+            fn=_save_settings,
+            inputs=[
+                model_dd, api_key_box, port_num, host_box,
+                local_model_box, ollama_base_box, model_path_box,
+                memory_key_box,
+                runtime_dd, trainer_model_box, training_dir_box,
