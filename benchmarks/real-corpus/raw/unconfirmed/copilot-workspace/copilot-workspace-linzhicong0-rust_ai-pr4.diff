+        let start = start + 3;
+        if let Some(end) = trimmed[start..].find("```") {
+            let json_str = trimmed[start..start + end].trim();
+            if let Some(fixed) = fix_json(json_str) {
+                return Some(fixed);
+            }
+        }
+    }
+
+    // Try fixing the whole input
+    fix_json(trimmed)
+}
