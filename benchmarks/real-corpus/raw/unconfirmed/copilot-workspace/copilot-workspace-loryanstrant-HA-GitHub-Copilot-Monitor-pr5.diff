+    async def _async_get_usage_metrics(
+        self, session: aiohttp.ClientSession, headers: dict[str, str]
+    ) -> tuple[float, float]:
+        """Fetch usage metrics for either user or organization scope."""
+        if self._org:
+            async with session.get(
+                f"https://api.github.com/orgs/{self._org}/copilot/billing", headers=headers
+            ) as response:
+                if response.status != 200:
+                    _LOGGER.error("Failed to fetch org billing data from GitHub: %s", response.status)
+                    return 0.0, 0.0
+                data = await response.json()
+                breakdown = data.get("seat_breakdown", {})
+                limit = float(breakdown.get("total", 0))
+                used = float(
+                    breakdown.get(
+                        "active_this_cycle",
+                        breakdown.get("active", 0),
+                    )
+                )
+                return limit, used
+
+        username = await self._async_resolve_username(session, headers)
+        if not username:
+            return 0.0, 0.0
+
+        async with session.get(
+            f"https://api.github.com/users/{username}/settings/billing/usage/summary",
+            headers=headers,
+        ) as response:
+            if response.status == 200:
+                data = await response.json()
+                limit = float(data.get("userPremiumRequestEntitlement", 0))
+                used = self._calculate_used_requests(data)
+                return limit, used
+
+        async with session.get(
+            f"https://api.github.com/users/{username}/settings/billing/usage/premium_requests",
+            headers=headers,
+        ) as response:
+            if response.status != 200:
+                _LOGGER.error("Failed to fetch user billing data from GitHub: %s", response.status)
+                return 0.0, 0.0
+
+            data = await response.json()
+            quotas = data.get("quotas", {})
+            limits = quotas.get("limits", {})
+            remaining = quotas.get("remaining", {})
+
+            limit = float(
+                data.get(
+                    "userPremiumRequestEntitlement",
+                    limits.get("premiumInteractions", 0),
+                )
+            )
+            used = self._calculate_used_requests(data)
+            if used == 0 and "premiumInteractions" in remaining and limit:
+                used = max(0.0, limit - float(remaining["premiumInteractions"]))
+
+            return limit, used
+
+    async def _async_resolve_username(
+        self, session: aiohttp.ClientSession, headers: dict[str, str]
+    ) -> str | None:
+        """Resolve the username for user-level billing requests."""
+        if self._username:
+            return self._username
+
+        async with session.get("https://api.github.com/user", headers=headers) as response:
+            if response.status != 200:
+                _LOGGER.error("Failed to resolve username from GitHub: %s", response.status)
+                return None
+            user_data = await response.json()
+            username = user_data.get("login")
+            if not username:
+                _LOGGER.error("GitHub user lookup succeeded but no login value was returned")
+                return None
+            return username
+
+    @staticmethod
+    def _calculate_used_requests(data: dict) -> float:
+        """Calculate used premium requests as included usage plus billed overage usage."""
