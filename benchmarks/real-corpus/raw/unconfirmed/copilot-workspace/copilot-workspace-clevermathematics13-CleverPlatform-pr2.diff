+      function renderResultsTable(submitted, grades) {
+        var container = document.getElementById('resultsTableContainer');
+
+        // Build lookup maps
+        var subMap = {};
+        var subTotal = 0;
+        (submitted || []).forEach(function(s) {
+          subMap[s.question_label] = s.marks_reported;
+          subTotal += (parseFloat(s.marks_reported) || 0);
+        });
+
+        var gradeMap = {};
+        var gradeTotal = 0;
+        var maxTotal = 0;
+        (grades || []).forEach(function(g) {
+          gradeMap[g.question_code] = g;
+          gradeTotal += (parseFloat(g.marks_awarded) || 0);
+          maxTotal += (parseFloat(g.marks_possible) || 0);
+        });
+
+        // Merge all labels (union of submitted + graded)
+        var allLabels = [];
+        var seen = {};
+        (submitted || []).forEach(function(s) {
+          if (!seen[s.question_label]) { allLabels.push(s.question_label); seen[s.question_label] = true; }
+        });
+        (grades || []).forEach(function(g) {
+          if (!seen[g.question_code]) { allLabels.push(g.question_code); seen[g.question_code] = true; }
+        });
+
+        // Natural sort: split into [text, number, suffix] so 7a < 7b < 7d, 6a < 6b etc.
+        allLabels.sort(function(a, b) {
+          var re = /^(\d+)(.*)/;
+          var ma = a.match(re), mb = b.match(re);
+          if (ma && mb) {
+            var na = parseInt(ma[1]), nb = parseInt(mb[1]);
+            if (na !== nb) return na - nb;
+            return (ma[2] || '').localeCompare(mb[2] || '');
+          }
+          return a.localeCompare(b);
+        });
+
+        var hasGrades = grades && grades.length > 0;
