+        }
+
+        container.innerHTML = html;
+        container.style.display = 'block';
+
+        // Attach inline-edit listeners to self-assessed cells
+        if (!isInstructor) {
+          container.querySelectorAll('.self-cell').forEach(function(td) {
+            // On keydown: if user types a digit, replace cell content with an input
+            td.addEventListener('keydown', function(e) {
