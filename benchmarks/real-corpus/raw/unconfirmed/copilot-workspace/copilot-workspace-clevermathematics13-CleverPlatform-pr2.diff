+        var html = '<table class="results-table"><thead><tr>' +
+          '<th style="text-align:left;">Question</th>' +
+          '<th>Self-Assessed</th>';
+        if (hasGrades) {
+          html += '<th>Clev-Assessed</th><th>Max</th>';
+        }
+        html += '</tr></thead><tbody>';
+
+        allLabels.forEach(function(label) {
+          var sub = subMap[label];
+          var grade = gradeMap[label];
+          var subVal = (sub !== undefined) ? sub : '';
+          var offVal = grade ? grade.marks_awarded : '';
+          var maxVal = grade ? grade.marks_possible : '';
+
+          // Determine match/mismatch styling
+          var matchClass = '';
+          if (sub !== undefined && grade) {
+            matchClass = (parseFloat(sub) === parseFloat(grade.marks_awarded)) ? 'match' : 'mismatch';
+          }
+
+          // Build editable self-assessed cell (only for non-instructor student view)
