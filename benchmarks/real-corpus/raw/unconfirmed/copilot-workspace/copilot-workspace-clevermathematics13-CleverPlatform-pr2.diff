+<!DOCTYPE html>
+<html>
+  <head>
+    <base target="_top">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <style>
+      * { box-sizing: border-box; margin: 0; padding: 0; }
+      body {
+        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
+        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
+        min-height: 100vh; padding: 16px;
+      }
+      .container {
+        background: white; border-radius: 12px;
+        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
+        overflow: hidden; max-width: 100%;
+      }
+      .header {
+        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
+        color: white; padding: 18px 24px; display: flex;
+        align-items: center; justify-content: space-between;
+      }
+      .header h1 { font-size: 1.4em; font-weight: 300; }
+      .header .save-status { font-size: 13px; opacity: 0.85; }
+
+      .toolbar {
+        padding: 14px 24px; border-bottom: 1px solid #e0e0e0;
+        display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
+        background: #f8f9fa;
+      }
+      .toolbar select {
+        padding: 8px 12px; border: 2px solid #e0e0e0; border-radius: 6px;
+        font-size: 14px; min-width: 200px;
+      }
+      .toolbar select:focus { border-color: #667eea; outline: none; }
+      .toolbar .btn {
+        padding: 8px 16px; border: none; border-radius: 6px;
+        font-size: 14px; font-weight: 600; cursor: pointer;
+      }
+      .btn-back {
+        background: transparent; color: #667eea; border: 2px solid #667eea !important;
+      }
+      .btn-back:hover { background: #f0f4ff; }
+
+      .grid-wrap {
+        overflow: auto; max-height: calc(100vh - 160px); padding: 0;
+      }
+      table.grade-grid {
+        border-collapse: collapse; width: 100%; font-size: 13px;
+      }
+      table.grade-grid th, table.grade-grid td {
+        border: 1px solid #e8e8e8; padding: 0; text-align: center;
+        white-space: nowrap;
+      }
+      table.grade-grid thead th {
+        background: #f0f2f5; position: sticky; top: 0; z-index: 2;
+        padding: 8px 6px; font-size: 12px; color: #555;
+        font-weight: 700; letter-spacing: 0.3px;
+      }
+      table.grade-grid thead th.corner {
+        position: sticky; left: 0; z-index: 3; background: #e8eaf0;
