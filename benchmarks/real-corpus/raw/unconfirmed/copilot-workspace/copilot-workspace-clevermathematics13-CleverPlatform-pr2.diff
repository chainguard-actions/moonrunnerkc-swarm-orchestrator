+          } else {
+            selfCell = '<td>' + (subVal !== '' ? subVal : '<span class="pending">—</span>') + '</td>';
+          }
+
+          html += '<tr>' +
+            '<td class="label-cell">' + escapeHtml(label) + '</td>' +
+            selfCell;
+          if (hasGrades) {
+            html += '<td class="' + matchClass + '">' +
+              (offVal !== '' ? offVal : '<span class="pending">pending</span>') + '</td>' +
+              '<td>' + (maxVal !== '' ? maxVal : '') + '</td>';
+          }
+          html += '</tr>';
+        });
+
+        // Totals row
+        html += '<tr class="total-row-table">' +
+          '<td class="label-cell">Total</td>' +
+          '<td>' + subTotal + '</td>';
+        if (hasGrades) {
+          var totalMatch = (subTotal === gradeTotal) ? 'match' : 'mismatch';
+          html += '<td class="' + totalMatch + '">' + gradeTotal + '</td>' +
+            '<td>' + maxTotal + '</td>';
