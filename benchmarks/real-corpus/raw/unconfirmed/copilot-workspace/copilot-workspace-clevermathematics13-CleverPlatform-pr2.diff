+      }
+      function hideStatus() {
+        var el = document.getElementById('statusMsg');
+        el.style.display = 'none';
+        el.className = 'status';
+      }
+
+      function esc(str) {
+        var div = document.createElement('div');
+        div.textContent = str;
+        return div.innerHTML;
+      }
+    </script>
+  </body>
+</html>
