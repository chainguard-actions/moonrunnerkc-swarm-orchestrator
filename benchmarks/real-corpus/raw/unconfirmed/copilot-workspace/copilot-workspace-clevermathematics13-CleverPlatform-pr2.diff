+          })
+          .saveGradeCell(examData.sheetName, sheetRow, sheetCol, newVal === '' ? '' : parseFloat(newVal));
+      }
+
+      function updateRowTotal(sIdx) {
+        if (!examData) return;
+        var total = 0;
+        var maxTotal = 0;
+        examData.questions.forEach(function(q, qIdx) {
+          var cellEl = document.getElementById('cell_' + sIdx + '_' + qIdx);
+          if (cellEl) {
+            var inp = cellEl.querySelector('input');
+            var v = parseFloat(inp.value);
+            if (!isNaN(v)) total += v;
+          }
+          if (q.maxMarks !== null) maxTotal += q.maxMarks;
+        });
+        var totalEl = document.getElementById('total_' + sIdx);
+        if (totalEl) totalEl.textContent = total + ' / ' + maxTotal;
+      }
+
+      function updateSaveStatus(delta) {
+        pendingSaves += delta;
+        var el = document.getElementById('saveStatus');
+        if (pendingSaves > 0) {
+          el.textContent = 'Saving... (' + pendingSaves + ' pending)';
+          el.style.opacity = '1';
+        } else {
+          el.textContent = '✓ All saved';
+          el.style.opacity = '0.85';
+          setTimeout(function() {
+            if (pendingSaves === 0) el.textContent = 'Auto-saves on each cell';
+          }, 2000);
+        }
+      }
+
+      function goBack() {
+        google.script.run
+          .withSuccessHandler(function(url) {
