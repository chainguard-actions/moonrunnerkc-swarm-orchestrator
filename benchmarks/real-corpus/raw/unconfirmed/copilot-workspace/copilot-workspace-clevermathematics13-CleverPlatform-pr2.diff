+
+      function startSelfEdit(td, initialVal) {
+        var label = td.getAttribute('data-label');
+        var inp = document.createElement('input');
+        inp.type = 'number';
+        inp.min = '0';
+        inp.style.cssText = 'width:50px;text-align:center;font-size:inherit;border:1px solid #2196F3;border-radius:3px;padding:2px 4px;';
+        inp.value = initialVal;
+        td.textContent = '';
+        td.appendChild(inp);
+        inp.focus();
+
+        function commit() {
+          var val = inp.value.trim();
+          td.textContent = val !== '' ? val : '—';
+          if (val !== '') {
+            td.style.background = '#FFF9C4';
+            saveSelfMark(label, parseFloat(val), td);
+          }
+        }
+        inp.addEventListener('blur', commit);
+        inp.addEventListener('keydown', function(ev) {
+          if (ev.key === 'Enter') { inp.blur(); }
+          if (ev.key === 'Escape') {
+            // restore original without saving
+            td.textContent = td.getAttribute('data-orig') || '—';
+          }
+        });
+        // Store original for Escape
+        td.setAttribute('data-orig', td.textContent);
+      }
+
+      function saveSelfMark(questionLabel, value, td) {
+        var code = document.getElementById('resultsExamTitle').textContent;
+        google.script.run
+          .withSuccessHandler(function(res) {
+            if (res && res.error) {
