+          })
+          .loadGradingData(sheetName);
+      }
+
+      function renderGrid(data) {
+        var questions = data.questions;
+        var students = data.students;
+
+        // Build header rows
+        var headHtml = '<tr><th class="corner" rowspan="2">Student</th>';
+        questions.forEach(function(q) {
