+    var rows = supabaseRequest_("GET", "students", null,
+      "email=eq." + encodeURIComponent(email) +
+      "&select=email,name&limit=1");
+
+    if (rows && rows.length > 0) {
+      return { verified: true, name: rows[0].name || "" };
+    }
+    return { verified: false };
+  } catch (e) {
