+            } else {
+              td.style.background = '#C8E6C9';
+              setTimeout(function() { td.style.background = ''; }, 1500);
+            }
+          })
+          .withFailureHandler(function(err) {
+            td.style.background = '#FFCDD2';
+            td.title = err.message;
+          })
+          .updateStudentMark(code, resultsEmail, questionLabel, value);
+      }
+
+      function showExamList() {
