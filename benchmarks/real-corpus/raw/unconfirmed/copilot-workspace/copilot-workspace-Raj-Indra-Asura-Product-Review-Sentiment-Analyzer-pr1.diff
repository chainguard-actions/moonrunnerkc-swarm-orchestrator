+# app.py — Day 5
+# Full dashboard: deep analysis + aspect summary + keywords + product score.
+
+import gradio as gr
+import pandas as pd
+
+from aspects import (
+    deep_analyze,
+    overall_score,
+    top_keywords,
+    aspect_summary,
+)
+
+
+def run(text_block: str):
+    reviews = [l.strip() for l in text_block.splitlines() if l.strip()]
+    if not reviews:
+        empty = pd.DataFrame()
+        return empty, empty, empty, empty, "—"
+
+    # 1) Analyse each review
+    results = [deep_analyze(r) for r in reviews]
+
+    # 2) Per-review breakdown table
+    per_review = pd.DataFrame([{
+        "Review":      r[:80] + ("…" if len(r) > 80 else ""),
+        "Language":    res.get("language", ""),
+        "Sentiment":   res.get("sentiment", ""),
+        "Reason":      res.get("reason", ""),
+        "Translation": res.get("translation") or "",
+    } for r, res in zip(reviews, results)])
+
+    # 3) Aspect summary table
+    aspects = aspect_summary(results)
+    aspect_df = pd.DataFrame([{"Aspect": a, **counts}
+                              for a, counts in aspects.items()])
+
+    # 4) Top keywords (positive / negative)
+    pos_df = pd.DataFrame(top_keywords(results, "positive"),
+                          columns=["Positive keyword", "Mentions"])
+    neg_df = pd.DataFrame(top_keywords(results, "negative"),
+                          columns=["Negative keyword", "Mentions"])
+
+    # 5) Overall product score
+    score = f"⭐ Overall product score: **{overall_score(results)} / 10**"
+
+    return per_review, aspect_df, pos_df, neg_df, score
+
+
+with gr.Blocks(title="🛒 Product Review Analyzer — Day 5") as demo:
+    gr.Markdown(
+        "## 🛒 Product Review Sentiment Analyzer\n"
+        "Paste one review per line. We will return a per-review breakdown, "
+        "an aspect summary, top keywords and an overall product score."
+    )
+
+    inp = gr.Textbox(lines=10, label="Reviews (one per line)")
+    btn = gr.Button("Analyse", variant="primary")
+
+    score_box      = gr.Markdown()
+    per_review_tbl = gr.Dataframe(label="Per-review breakdown", wrap=True)
+    aspect_tbl     = gr.Dataframe(label="Aspect summary")
+    with gr.Row():
+        pos_tbl = gr.Dataframe(label="Top positive keywords")
+        neg_tbl = gr.Dataframe(label="Top negative keywords")
+
+    btn.click(
+        fn=run,
+        inputs=inp,
+        outputs=[per_review_tbl, aspect_tbl, pos_tbl, neg_tbl, score_box],
+    )
+
+
+if __name__ == "__main__":
+    demo.launch()
