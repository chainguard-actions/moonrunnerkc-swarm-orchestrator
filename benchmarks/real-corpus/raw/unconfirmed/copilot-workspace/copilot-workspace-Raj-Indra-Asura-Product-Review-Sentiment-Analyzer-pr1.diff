+# aspects.py — Day 5
+# Asks OpenAI for sentiment + aspects + keywords + language in one call,
+# and provides helpers to aggregate results across many reviews.
+
+import json
+from collections import Counter
+from dotenv import load_dotenv
+from openai import OpenAI
+
+load_dotenv()
+client = OpenAI()
+
+SYSTEM_PROMPT = """You are a product-review analyst.
+For the review, return ONLY valid JSON with this exact shape:
+
+{
+  "sentiment": "Positive" | "Negative" | "Neutral",
+  "reason":    "one short sentence",
+  "language":  "ISO 639-1 code, e.g. en, es, hi",
+  "translation": "English translation if language != en, else null",
+  "aspects":   [{"aspect": "Battery", "sentiment": "Negative"}, ...],
+  "keywords":  {"positive": ["..."], "negative": ["..."]}
+}
+
+Rules:
+- Aspects are concrete product features ('Battery', 'Delivery', 'Price', 'Camera').
+- Keywords are 1-2 word phrases taken directly from the review.
+- No markdown, no extra keys, no text outside the JSON."""
+
+
+def deep_analyze(review: str) -> dict:
+    """Run the full Day-5 analysis on one review."""
+    resp = client.chat.completions.create(
+        model="gpt-4o-mini",
+        temperature=0,
+        messages=[
+            {"role": "system", "content": SYSTEM_PROMPT},
+            {"role": "user",   "content": review},
+        ],
+    )
+    return json.loads(resp.choices[0].message.content)
+
+
+# ---------- Aggregation helpers ----------
+
+# Numeric mapping used to compute the 0–10 product score.
+_SENT_TO_VALUE = {"Positive": 1.0, "Neutral": 0.5, "Negative": 0.0}
+
+
+def overall_score(results: list) -> float:
+    """Average sentiment value across all reviews → 0–10 scale."""
+    if not results:
+        return 0.0
+    values = [_SENT_TO_VALUE.get(r["sentiment"], 0.5) for r in results]
+    return round((sum(values) / len(values)) * 10, 1)
+
+
+def top_keywords(results: list, polarity: str, n: int = 10) -> list:
+    """Most frequent positive OR negative keywords across all reviews."""
+    bag = []
+    for r in results:
+        bag.extend(r.get("keywords", {}).get(polarity, []))
+    bag = [w.strip().lower() for w in bag if w and w.strip()]
+    return Counter(bag).most_common(n)
+
+
+def aspect_summary(results: list) -> dict:
+    """Per-aspect counts of Positive / Negative / Neutral."""
+    summary: dict = {}
+    for r in results:
+        for a in r.get("aspects", []):
+            name = a["aspect"]
+            sent = a["sentiment"]
+            summary.setdefault(name, {"Positive": 0, "Negative": 0, "Neutral": 0})
+            summary[name][sent] = summary[name].get(sent, 0) + 1
+    return summary
