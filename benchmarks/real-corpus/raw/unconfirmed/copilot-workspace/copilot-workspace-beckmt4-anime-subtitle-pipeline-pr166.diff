+                    )
+                if domain_style.get("skip_op_ed_segments"):
+                    domain_lines.append(
+                        "- For OP/ED lyrics, preserve intent and avoid creative rewrites."
+                    )
+                if domain_style.get("translate_on_screen_text"):
+                    domain_lines.append(
