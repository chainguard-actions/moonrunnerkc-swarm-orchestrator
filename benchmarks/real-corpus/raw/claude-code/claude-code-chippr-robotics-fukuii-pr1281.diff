+# Dedicated single-thread dispatcher for SNAP state validation (account- and
+# storage-trie walks). These walks take ~28 min on Mordor and multi-hour on
+# mainnet; running them on `sync-dispatcher` would tie up a worker for the
+# duration. Pinning to a single fixed thread keeps the work isolated and
+# guarantees it can't squeeze the rest of the actor system. Caveat: a stuck
+# validation monopolises this thread; that's acceptable because a stuck
+# `validateAccountTrie` is a correctness bug at the StateValidator layer, and
+# the calling actor remains responsive either way.
+snap-validation-dispatcher {
+  type = Dispatcher
+  executor = "thread-pool-executor"
+  thread-pool-executor {
+    fixed-pool-size = 1
+  }
+  throughput = 1
+}
+
 # Dedicated dispatcher for the Engine API HTTP server. CL clients (Lighthouse,
 # Prysm, etc.) issue forkchoiceUpdated and newPayload calls every ~12s and time
 # out hard at ~8s. Sharing the default dispatcher with peer-management actors
@@ -75,6 +92,52 @@ engine-api-dispatcher {
   throughput = 5
 }
 
+# Dedicated bounded dispatcher for AccountRangeCoordinator's trie flush + finalisation
+# work. Periodic `flushTrieToStorage` collapses a large in-memory trie (RLP-encode +
+# Keccak-256 every node on the modified path) and writes a RocksDB batch — 50-200ms
+# bursts. `finalizeTrie` is the same pattern but on the entire accumulated tree (10+
+# minutes on mainnet). Pinning to a small thread pool keeps both off `sync-dispatcher`
+# so other sync actors don't stall, and bounds parallelism so concurrent flushes can't
+# squeeze the global pool.
+account-trie-dispatcher {
+  type = Dispatcher
+  executor = "thread-pool-executor"
+  thread-pool-executor {
+    fixed-pool-size = 2
+  }
+  throughput = 1
