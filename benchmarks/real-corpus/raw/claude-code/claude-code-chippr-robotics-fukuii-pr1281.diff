+
+    // Now in idle — a new FetchStorageRanges should be accepted
+    worker ! Messages.FetchStorageRanges(makeStorageTask(), peer)
+    coordinator.expectMsg(1.second, Messages.StoragePeerAvailable(peer))
+  }
+}
