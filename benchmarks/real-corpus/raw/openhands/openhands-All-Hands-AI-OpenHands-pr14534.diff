+        return 'JIRA_DC_SERVICE_ACCOUNT_EMAIL must be a valid email address.'
+
+    if api_key and any(char.isspace() for char in api_key):
+        return 'JIRA_DC_SERVICE_ACCOUNT_PAT cannot contain whitespace.'
+
+    return None
+
+
