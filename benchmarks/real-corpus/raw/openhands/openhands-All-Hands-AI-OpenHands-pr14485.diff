-
-    @staticmethod
-    def _mask_key(secret: SecretStr | None) -> str | None:
-        """Mask an API key, showing only last 4 characters."""
-        if secret is None:
-            return None
-        raw = secret.get_secret_value()
-        if not raw:
-            return None
-        if len(raw) <= 4:
-            return '****'
-        return '****' + raw[-4:]
