-                stmt = (
-                    select(ProactiveConversation)
-                    .where(
-                        and_(
-                            ProactiveConversation.repo_id == provider_repo_id,
-                            ProactiveConversation.pr_number == pr_number,
-                            ProactiveConversation.commit == incoming_commit,
