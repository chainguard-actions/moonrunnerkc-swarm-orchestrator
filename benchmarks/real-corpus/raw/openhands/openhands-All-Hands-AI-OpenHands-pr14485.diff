-                    'invitation_id': invitation_id,
-                    'old_status': old_status,
-                    'new_status': status,
-                    'accepted_by_user_id': (
-                        str(accepted_by_user_id) if accepted_by_user_id else None
-                    ),
-                },
-            )
-
-            return invitation
-
-    @staticmethod
