-            text(
-                """
-                INSERT INTO conversation_metadata (conversation_id, user_id, conversation_version, created_at, last_updated_at)
-                VALUES (:conv_id, :user_id, 'V0', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
