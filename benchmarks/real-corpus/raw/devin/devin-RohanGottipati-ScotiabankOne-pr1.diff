+        <p className="text-[13px] text-scotia-grey-400 mt-0.5">Scotia Smart Investor TFSA</p>
+      </motion.div>
+
+      {/* TFSA Summary */}
+      <motion.div
+        variants={itemVariants}
+        className="rounded-2xl p-6 mt-4"
+        style={{ background: 'linear-gradient(135deg, #1A1A1A 0%, #2D2D2D 100%)' }}
