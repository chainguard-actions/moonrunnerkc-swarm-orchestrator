+@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap');
+@import "tailwindcss";
+
+@theme {
+  --color-scotia-red: #EC111A;
+  --color-scotia-red-dark: #B50D13;
+  --color-scotia-red-light: #FFF0F0;
+  --color-scotia-white: #FFFFFF;
+  --color-scotia-grey-50: #F7F7F7;
+  --color-scotia-grey-100: #F0F0F0;
+  --color-scotia-grey-200: #E0E0E0;
+  --color-scotia-grey-400: #9E9E9E;
+  --color-scotia-grey-700: #424242;
+  --color-scotia-grey-900: #1A1A1A;
+  --color-scotia-green: #2E7D32;
+  --color-scotia-green-light: #E8F5E9;
+  --color-scotia-amber: #E65100;
+}
+
+body {
+  font-family: 'DM Sans', sans-serif;
+  background-color: #1A1A1A;
+  color: #1A1A1A;
+  margin: 0;
+  padding: 0;
+  -webkit-font-smoothing: antialiased;
+  -moz-osx-font-smoothing: grayscale;
+}
+
+.display-number {
+  font-family: 'DM Serif Display', serif;
+}
+
+/* Money Moment card pulse animation */
+@keyframes moment-pulse {
+  0%, 100% { box-shadow: 0 0 0 0 rgba(236, 17, 26, 0.3); }
+  50% { box-shadow: 0 0 0 8px rgba(236, 17, 26, 0); }
+}
+.money-moment-card {
+  animation: moment-pulse 3s ease-in-out infinite;
+}
+
+/* Confirmation checkmark draw animation */
+@keyframes draw-check {
+  from { stroke-dashoffset: 100; }
+  to { stroke-dashoffset: 0; }
+}
+.checkmark-path {
+  stroke-dasharray: 100;
+  stroke-dashoffset: 100;
+  animation: draw-check 0.5s ease-out 0.4s forwards;
+}
+
+/* Circle scale animation */
+@keyframes circle-scale {
+  from { transform: scale(0); opacity: 0; }
+  to { transform: scale(1); opacity: 1; }
+}
+.check-circle {
+  animation: circle-scale 0.3s ease-out forwards;
+}
+
+/* Confetti fall */
+@keyframes fall {
+  from { transform: translateY(-20px) rotate(0deg); opacity: 1; }
+  to { transform: translateY(100vh) rotate(720deg); opacity: 0; }
+}
+.confetti-particle {
+  position: fixed;
+  width: 8px;
+  height: 8px;
+  border-radius: 2px;
+  animation: fall 1.5s ease-in forwards;
+  z-index: 100;
+}
+
+/* Scrollbar styling */
+::-webkit-scrollbar {
+  display: none;
+}
+* {
+  -ms-overflow-style: none;
+  scrollbar-width: none;
+}
