+	defer r.mu.RUnlock()
+	if t, ok := r.data[id]; ok {
+		return t, nil
+	}
+	return nil, nil
+}
+
+func (r *MockTemplateRepo) Update(_ context.Context, t *TicketTemplate) error {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	r.data[t.ID] = t
+	return nil
+}
+
+func (r *MockTemplateRepo) List(_ context.Context, tenantID int64) ([]*TicketTemplate, error) {
+	r.mu.RLock()
+	defer r.mu.RUnlock()
+	var result []*TicketTemplate
