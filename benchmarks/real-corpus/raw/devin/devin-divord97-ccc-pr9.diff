+
+	s, err := svc.Create(ctx, CreateScriptInput{
+		TenantID: 1,
+		Name:     "欢迎话术",
+		Content:  `{"steps":[{"text":"您好，请问有什么可以帮您？"},{"text":"好的，我来为您查看"}]}`,
+		IsActive: true,
+	})
+	require.NoError(t, err)
+	assert.NotZero(t, s.ID)
+	assert.True(t, s.IsActive)
