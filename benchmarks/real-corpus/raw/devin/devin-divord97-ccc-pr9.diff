+func (r *MockCommentRepo) ListByTicket(_ context.Context, ticketID int64) ([]*TicketComment, error) {
+	r.mu.RLock()
+	defer r.mu.RUnlock()
+	var result []*TicketComment
+	for _, c := range r.data {
+		if c.TicketID == ticketID {
+			result = append(result, c)
+		}
+	}
+	return result, nil
+}
