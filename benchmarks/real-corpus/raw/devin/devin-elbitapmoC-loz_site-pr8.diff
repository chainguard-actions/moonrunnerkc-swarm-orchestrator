+export type BulletinEditorContext = {
+  user: Doc<"users">;
+  identity: AuthenticatedIdentity;
+};
+
+/**
+ * Ensures the caller has the Administrator or Columnist role.
+ * Use for bulletin-related mutations that either role may perform.
+ */
+export async function requireBulletinEditor(ctx: AuthCtx): Promise<BulletinEditorContext> {
+  const { identity } = await requireAuthenticated(ctx);
+
+  let user = await ctx.db
+    .query("users")
+    .withIndex("by_clerk_id", (q) => q.eq("clerkUserId", identity.subject))
+    .first();
+
+  if (!user && identity.email) {
+    user = await ctx.db
+      .query("users")
+      .withIndex("by_email", (q) => q.eq("email", identity.email as string))
+      .first();
+  }
+
+  if (!user) {
+    throw new Error("User not found");
+  }
+
+  if (!user.roleId) {
+    throw new Error("User does not have a role");
+  }
+
+  const role = await ctx.db.get(user.roleId);
+  if (role?.name !== "Administrator" && role?.name !== "Columnist") {
+    throw new Error("Unauthorized: requires Administrator or Columnist role");
+  }
+
+  return { user, identity };
+}
+
