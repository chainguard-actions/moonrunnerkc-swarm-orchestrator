+  async function carregar() {
+    const res = await fetch('/api/temas')
+    const data = await res.json()
+    setTemas(data)
+    setCarregando(false)
+  }
+
+  useEffect(() => {
+    let active = true
+    fetch('/api/temas')
+      .then((r) => r.json())
