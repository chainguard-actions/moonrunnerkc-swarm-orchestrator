+    setSalvando(true)
+    await fetch('/api/temas', {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({
+        nome,
+        cor_primaria: corPrimaria,
+        cor_secundaria: corSecundaria,
+        cor_fundo: corFundo,
+        cor_texto: corTexto,
+      }),
+    })
+    setNome('')
+    setSalvando(false)
+    carregar()
