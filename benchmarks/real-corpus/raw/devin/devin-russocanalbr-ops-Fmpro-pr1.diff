+def agregar_ticks_em_candles(ticks: List[Any], periodo: int) -> List[Dict[str, float]]:
+    buckets: Dict[int, List[float]] = {}
+    for tick in ticks:
+        if not isinstance(tick, dict) or "price" not in tick:
+            continue
+        timestamp = float(tick.get("time", tick.get("timestamp", time.time())))
+        if timestamp > 10_000_000_000:
+            timestamp = timestamp / 1000
+        bucket = int(timestamp // periodo) * periodo
+        buckets.setdefault(bucket, []).append(float(tick["price"]))
+    candles = []
+    for bucket, prices in sorted(buckets.items()):
+        candles.append({
+            "open": prices[0],
+            "close": prices[-1],
+            "high": max(prices),
+            "low": min(prices),
+            "time": float(bucket),
+        })
+    return candles
+
+def candle_body(candle: Dict[str, float]) -> float:
+    return abs(candle["close"] - candle["open"])
+
+def candle_range(candle: Dict[str, float]) -> float:
+    return max(candle["high"] - candle["low"], 1e-9)
+
+def calcular_atr_percentual(candles: List[Dict[str, float]], periodo: int = 5) -> float:
+    if len(candles) < periodo:
+        return 0.0
+    recentes = candles[-periodo:]
+    atr = sum(candle_range(c) for c in recentes) / len(recentes)
+    preco = recentes[-1]["close"] or 1.0
+    return (atr / preco) * 100
+
+def mercado_indeciso(candles: List[Dict[str, float]]) -> bool:
+    if len(candles) < 5:
+        return True
+    indecisas = 0
+    for candle in candles[-5:]:
+        total = candle_range(candle)
+        upper = candle["high"] - max(candle["open"], candle["close"])
+        lower = min(candle["open"], candle["close"]) - candle["low"]
+        if upper / total > PAVIO_MAXIMO_RATIO and lower / total > PAVIO_MAXIMO_RATIO:
+            indecisas += 1
+    return indecisas >= 2
+
+def detectar_estrutura(candles: List[Dict[str, float]], lookback: int = 8) -> str:
+    if len(candles) < lookback:
+        return "neutral"
+    recentes = candles[-lookback:]
+    highs = [c["high"] for c in recentes]
+    lows = [c["low"] for c in recentes]
+    if highs[-1] > highs[-3] > highs[-5] and lows[-1] > lows[-3] > lows[-5]:
+        return "bull"
+    if highs[-1] < highs[-3] < highs[-5] and lows[-1] < lows[-3] < lows[-5]:
+        return "bear"
+    first_close = recentes[0]["close"]
+    last_close = recentes[-1]["close"]
+    variation = (last_close - first_close) / first_close if first_close else 0
+    if variation > 0.0005:
+        return "bull"
+    if variation < -0.0005:
+        return "bear"
+    return "neutral"
+
+def mapear_zonas(candles: List[Dict[str, float]], janela: int = 20) -> Dict[str, float]:
+    recentes = candles[-janela:] if len(candles) >= janela else candles
+    if not recentes:
+        return {"support": 0.0, "resistance": 0.0, "range": 0.0}
+    support = min(c["low"] for c in recentes)
+    resistance = max(c["high"] for c in recentes)
+    return {
+        "support": support,
+        "resistance": resistance,
+        "range": max(resistance - support, 1e-9),
+    }
+
+def perto_de_zona(preco: float, zona: float, amplitude: float) -> bool:
+    tolerancia = max(amplitude * 0.12, preco * 0.00015)
+    return abs(preco - zona) <= tolerancia
