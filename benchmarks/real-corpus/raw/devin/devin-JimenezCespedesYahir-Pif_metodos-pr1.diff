+"""
+FIGURA M3: Fragilidad espacial de rutas críticas.
+
+Visualiza espacialmente las rutas con mayor riesgo operacional,
+con coloración por nivel de fragilidad, buffers de zonas vulnerables,
+heatmap de densidad y cuellos de botella territoriales.
+"""
+
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import pandas as pd
+from folium.plugins import HeatMap
+from matplotlib.colors import LinearSegmentedColormap
+from matplotlib.lines import Line2D
+from matplotlib.patches import Patch
+from scipy.stats import gaussian_kde
+from shapely.geometry import LineString, Point
+
+from . import config as cfg
+from . import data_loader as dl
+from .utils import (
+    add_basemap,
+    apply_academic_style,
+    create_base_map,
+    ensure_dir,
+    nodes_to_gdf,
+    reproject_utm,
+    save_folium_map,
+    save_matplotlib_fig,
+)
+
+
+def _compute_route_fragility(routes_df: pd.DataFrame, nodes_df: pd.DataFrame):
+    """Calcular fragilidad por ruta: 1 - (slack / variability)."""
+    route_summaries = []
+    for route_id, group in routes_df.groupby("route_id"):
+        first = group.iloc[0]
+        cap = pd.to_numeric(first.get("capacity_kg", 0), errors="coerce")
+        load = pd.to_numeric(first.get("route_load_kg", 0), errors="coerce")
+        util = pd.to_numeric(first.get("utilization_pct", 0), errors="coerce")
+
+        if pd.isna(cap) or cap == 0:
+            cap = 1000.0
+        if pd.isna(load):
+            load = 0.0
+        if pd.isna(util):
+            util = (load / cap) * 100 if cap > 0 else 0
+
+        slack = cap - load
+        demand_nodes = group[group["node_id"] != "DEPOT_DSRSLCC"]
+        demands = pd.to_numeric(demand_nodes["demand_kg"], errors="coerce").dropna()
+
+        if len(demands) > 0:
+            variability = demands.std() * np.sqrt(len(demands))
+        else:
+            variability = 1.0
+
+        if variability > 0:
+            fragility = max(0, min(1, 1 - (slack / (variability + 1e-6))))
+        else:
+            fragility = 0.0
+
+        route_summaries.append({
+            "route_id": route_id,
+            "vehicle_id": first["vehicle_id"],
+            "vehicle_name": first["vehicle_name"],
+            "capacity_kg": cap,
+            "load_kg": load,
+            "utilization_pct": util,
+            "slack": slack,
+            "variability": variability,
+            "fragility": fragility,
+        })
+    return pd.DataFrame(route_summaries)
+
+
+def _get_fragility_level(fragility: float) -> dict:
+    """Obtener nivel de fragilidad (alto/medio/bajo)."""
+    if fragility >= 0.9:
+        return cfg.FRAGILITY_LEVELS["alto"]
+    elif fragility >= 0.7:
+        return cfg.FRAGILITY_LEVELS["medio"]
+    else:
+        return cfg.FRAGILITY_LEVELS["bajo"]
+
+
+def _build_route_coords(routes_df, node_lookup):
+    """Coordenadas por ruta."""
+    route_coords = {}
+    for route_id, group in routes_df.groupby("route_id"):
+        group = group.sort_values("stop_sequence")
+        coords = []
+        for _, row in group.iterrows():
+            nid = str(row["node_id"])
+            if nid in node_lookup:
+                coords.append(node_lookup[nid])
+        depot = node_lookup.get("DEPOT_DSRSLCC")
+        if depot and coords and coords[-1] != depot:
+            coords.append(depot)
+        route_coords[route_id] = coords
+    return route_coords
+
+
+def _generate_m3_static(
+    frag_df: pd.DataFrame,
+    route_coords: dict,
+    nodes_gdf: gpd.GeoDataFrame,
+):
+    """Generar versión estática (PNG) con heatmap de fragilidad."""
+    apply_academic_style()
+
+    fig = plt.figure(figsize=(16, 11))
+    ax_main = fig.add_axes([0.05, 0.05, 0.65, 0.88])
+    ax_inset = fig.add_axes([0.72, 0.52, 0.26, 0.40])
+
+    for ax in [ax_main, ax_inset]:
+        nodes_gdf.plot(
+            ax=ax, color="#BDC3C7", markersize=15,
+            edgecolor="white", linewidth=0.3, zorder=3,
+        )
+        ax.plot(
+            cfg.DEPOT_LON, cfg.DEPOT_LAT,
+            marker="*", color="#C0392B", markersize=16,
+            markeredgecolor="white", markeredgewidth=0.5, zorder=6,
+        )
+
+    # Rutas coloreadas por fragilidad
+    critical_nodes = []
+    for _, row in frag_df.iterrows():
+        rid = row["route_id"]
+        coords = route_coords.get(rid, [])
+        if len(coords) < 2:
+            continue
+        level = _get_fragility_level(row["fragility"])
+        lats = [c[0] for c in coords]
+        lons = [c[1] for c in coords]
+
+        for ax in [ax_main, ax_inset]:
+            ax.plot(
+                lons, lats,
+                color=level["color"],
+                linewidth=level["linewidth"],
+                alpha=0.75,
+                zorder=4,
+            )
+
+        if row["fragility"] >= 0.7:
+            for lat, lon in coords[1:-1]:
+                critical_nodes.append((lat, lon))
+
+    # Heatmap de densidad de fragilidad
+    if len(critical_nodes) > 2:
+        cn = np.array(critical_nodes)
+        try:
+            kde = gaussian_kde(cn.T, bw_method=0.3)
+            xmin, xmax = cn[:, 1].min() - 0.1, cn[:, 1].max() + 0.1
+            ymin, ymax = cn[:, 0].min() - 0.1, cn[:, 0].max() + 0.1
+            xx, yy = np.meshgrid(
+                np.linspace(xmin, xmax, 100),
+                np.linspace(ymin, ymax, 100),
+            )
+            zz = kde(np.vstack([yy.ravel(), xx.ravel()])).reshape(xx.shape)
+            ax_main.contourf(
+                xx, yy, zz, levels=10,
+                cmap="Reds", alpha=0.25, zorder=2,
+            )
+        except Exception:
+            pass
+
+    # Cuellos de botella (nodos con múltiples rutas críticas)
+    node_critical_count: dict[tuple, int] = {}
+    for _, row in frag_df[frag_df["fragility"] >= 0.7].iterrows():
+        coords = route_coords.get(row["route_id"], [])
+        for c in coords[1:-1]:
+            node_critical_count[c] = node_critical_count.get(c, 0) + 1
+    bottlenecks = {k: v for k, v in node_critical_count.items() if v >= 2}
+    for (lat, lon), count in bottlenecks.items():
+        ax_main.scatter(
+            lon, lat, s=count * 80, facecolors="none",
+            edgecolors="#E74C3C", linewidths=2, zorder=7,
+        )
+
+    try:
+        add_basemap(ax_main)
+        add_basemap(ax_inset)
+    except Exception:
+        pass
+
+    # Inset: zoom a zona más crítica
+    if critical_nodes:
+        cn = np.array(critical_nodes)
+        cx, cy = cn[:, 1].mean(), cn[:, 0].mean()
+        ax_inset.set_xlim(cx - 0.3, cx + 0.3)
+        ax_inset.set_ylim(cy - 0.2, cy + 0.2)
+        ax_inset.set_title("Detalle zona crítica", fontsize=9, fontweight="bold")
+
+    # Leyenda
+    handles = [
+        Line2D([0], [0], color=cfg.FRAGILITY_LEVELS["alto"]["color"],
+               lw=4, label="Fragilidad alta (≥0.9)"),
+        Line2D([0], [0], color=cfg.FRAGILITY_LEVELS["medio"]["color"],
+               lw=3, label="Fragilidad media (0.7–0.9)"),
+        Line2D([0], [0], color=cfg.FRAGILITY_LEVELS["bajo"]["color"],
+               lw=2, label="Fragilidad baja (<0.7)"),
+        Line2D([0], [0], marker="o", color="w", markerfacecolor="none",
+               markeredgecolor="#E74C3C", markersize=10, markeredgewidth=2,
+               label="Cuello de botella", linestyle="None"),
+    ]
+    ax_main.legend(handles=handles, loc="lower left", framealpha=0.9, fontsize=8)
+    ax_main.set_title(cfg.FIGURE_TITLES["M3"], fontsize=11, fontweight="bold", pad=12)
+    ax_main.set_xlabel("Longitud")
+    ax_main.set_ylabel("Latitud")
+
+    # Panel de KPIs
+    ax_kpi = fig.add_axes([0.72, 0.05, 0.26, 0.42])
+    ax_kpi.axis("off")
+    kpi_text = "Resumen de fragilidad\n" + "=" * 28 + "\n"
+    for _, row in frag_df.sort_values("fragility", ascending=False).iterrows():
+        level_name = (
+            "ALTO" if row["fragility"] >= 0.9
+            else "MEDIO" if row["fragility"] >= 0.7
+            else "bajo"
+        )
+        vname = cfg.VEHICLE_SHORT_LABELS.get(row["vehicle_id"], row["vehicle_name"])
+        kpi_text += (
+            f"R{row['route_id']} ({vname})\n"
+            f"  Frag={row['fragility']:.2f} [{level_name}]\n"
+            f"  Util={row['utilization_pct']:.0f}%\n"
+        )
+    ax_kpi.text(
+        0, 1, kpi_text, transform=ax_kpi.transAxes,
+        fontsize=7, fontfamily="monospace", verticalalignment="top",
+    )
+
+    save_matplotlib_fig(fig, cfg.M3_OUTPUT_DIR, "M3_fragilidad_espacial.png")
+
+
+def _generate_m3_interactive(
+    frag_df: pd.DataFrame,
+    route_coords: dict,
+    nodes_df: pd.DataFrame,
+):
+    """Generar versión interactiva (HTML) con Folium + HeatMap."""
+    m = create_base_map(zoom_start=8)
+
+    folium.Marker(
+        location=[cfg.DEPOT_LAT, cfg.DEPOT_LON],
+        popup=f"<b>{cfg.DEPOT_NAME}</b>",
+        icon=folium.Icon(color="red", icon="star", prefix="fa"),
+    ).add_to(m)
+
+    heat_data = []
+
+    for _, row in frag_df.iterrows():
+        rid = row["route_id"]
+        coords = route_coords.get(rid, [])
+        if len(coords) < 2:
+            continue
+        level = _get_fragility_level(row["fragility"])
+        vname = cfg.VEHICLE_SHORT_LABELS.get(row["vehicle_id"], row["vehicle_name"])
+
+        popup_text = (
+            f"<b>Ruta {rid}</b><br>"
+            f"Vehículo: {vname}<br>"
+            f"Fragilidad: {row['fragility']:.2f}<br>"
+            f"Utilización: {row['utilization_pct']:.0f}%<br>"
+            f"Slack: {row['slack']:.0f} kg"
+        )
+
+        folium.PolyLine(
+            locations=coords,
+            color=level["color"],
+            weight=level["linewidth"],
+            opacity=0.8,
+            popup=folium.Popup(popup_text, max_width=200),
+        ).add_to(m)
+
+        if row["fragility"] >= 0.7:
+            for lat, lon in coords[1:-1]:
+                heat_data.append([lat, lon, row["fragility"]])
+
+    if heat_data:
+        HeatMap(
+            heat_data, radius=25, blur=15,
+            gradient={0.4: "yellow", 0.7: "orange", 1.0: "red"},
+        ).add_to(m)
+
+    title_html = (
+        '<div style="position:fixed;top:10px;left:50%;transform:translateX(-50%);'
+        'z-index:9999;background:white;padding:8px 16px;border-radius:4px;'
+        'box-shadow:0 2px 6px rgba(0,0,0,0.3);font-family:serif;font-size:13px;'
+        f'font-weight:bold;">{cfg.FIGURE_TITLES["M3"]}</div>'
+    )
+    m.get_root().html.add_child(folium.Element(title_html))
+
+    save_folium_map(m, cfg.M3_OUTPUT_DIR, "M3_fragilidad_espacial.html")
+
+
+def generate_m3():
+    """Generar FIGURA M3: Fragilidad espacial de rutas críticas."""
+    print("  Cargando datos...")
+    nodes_df = dl.load_nodes()
+    routes_df = dl.load_baseline_routes()
+    node_lookup = dl.build_node_lookup(nodes_df)
+
+    print("  Calculando fragilidad por ruta...")
+    frag_df = _compute_route_fragility(routes_df, nodes_df)
+    route_coords = _build_route_coords(routes_df, node_lookup)
+
+    nodes_gdf = nodes_to_gdf(nodes_df)
+
+    print("  Generando mapa estático (PNG)...")
+    _generate_m3_static(frag_df, route_coords, nodes_gdf)
+
+    print("  Generando mapa interactivo (HTML)...")
+    _generate_m3_interactive(frag_df, route_coords, nodes_df)
+
+
+if __name__ == "__main__":
+    generate_m3()
