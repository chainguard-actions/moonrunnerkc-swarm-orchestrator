+"""
+FIGURA M5: Comparación de escenarios robustos.
+
+Panel comparativo 2×2 mostrando baseline, no_hilux_+NLR, no_hilux_+FUSO
+y diferencia de reliability. Incluye indicadores de mejora/empeoramiento
+y KPIs comparativos en cada panel.
+"""
+
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import pandas as pd
+from matplotlib.lines import Line2D
+from matplotlib.patches import FancyArrowPatch, Patch
+
+from . import config as cfg
+from . import data_loader as dl
+from .utils import (
+    add_basemap,
+    apply_academic_style,
+    create_base_map,
+    nodes_to_gdf,
+    save_folium_map,
+    save_matplotlib_fig,
+    vehicle_legend_handles,
+)
+
+
+SCENARIO_LABELS = {
+    "baseline": "Baseline (con Hilux)",
+    "no_hilux_+NLR": "Sin Hilux + NLR",
+    "no_hilux_+FUSO": "Sin Hilux + FUSO",
+}
+
+SCENARIO_KEYS = ["baseline", "no_hilux_+NLR", "no_hilux_+FUSO"]
+
+
+def _build_route_coords(routes_df, node_lookup):
+    """Coordenadas por ruta."""
+    route_coords = {}
+    for route_id, group in routes_df.groupby("route_id"):
+        group = group.sort_values("stop_sequence")
+        coords = []
+        for _, row in group.iterrows():
+            nid = str(row["node_id"])
+            if nid in node_lookup:
+                coords.append(node_lookup[nid])
+        depot = node_lookup.get("DEPOT_DSRSLCC")
+        if depot and coords and coords[-1] != depot:
+            coords.append(depot)
+        route_coords[route_id] = {
+            "coords": coords,
+            "vehicle_id": group.iloc[0]["vehicle_id"],
+            "vehicle_name": group.iloc[0]["vehicle_name"],
+        }
+    return route_coords
+
+
+def _plot_scenario_panel(
+    ax,
+    title: str,
+    route_coords: dict,
+    nodes_gdf: gpd.GeoDataFrame,
+    kpis: dict | None = None,
+):
+    """Plotear un panel individual de escenario."""
+    nodes_gdf.plot(
+        ax=ax, color="#BDC3C7", markersize=10,
+        edgecolor="white", linewidth=0.2, zorder=3,
+    )
+    ax.plot(
+        cfg.DEPOT_LON, cfg.DEPOT_LAT,
+        marker="*", color="#C0392B", markersize=14,
+        markeredgecolor="white", markeredgewidth=0.5, zorder=6,
+    )
+
+    for rid, rdata in route_coords.items():
+        coords = rdata["coords"]
+        if len(coords) < 2:
+            continue
+        color = cfg.VEHICLE_COLORS.get(rdata["vehicle_id"], "#333333")
+        lats = [c[0] for c in coords]
+        lons = [c[1] for c in coords]
+        ax.plot(lons, lats, color=color, linewidth=2, alpha=0.75, zorder=4)
+
+    ax.set_title(title, fontsize=9, fontweight="bold", pad=8)
+
+    if kpis:
+        kpi_text = (
+            f"E[Costo]: S/ {kpis.get('expected_cost', 0):,.0f}\n"
+            f"Reliability: {kpis.get('reliability', 0) * 100:.1f}%\n"
+            f"CVaR 5%: S/ {kpis.get('CVaR_0.05', 0):,.0f}"
+        )
+        ax.text(
+            0.02, 0.02, kpi_text, transform=ax.transAxes,
+            fontsize=7, fontfamily="monospace",
+            verticalalignment="bottom",
+            bbox=dict(
+                boxstyle="round,pad=0.3",
+                facecolor="white",
+                edgecolor="#2C3E50",
+                alpha=0.9,
+            ),
+            zorder=8,
+        )
+
+
+def _plot_reliability_diff(
+    ax,
+    experiments_df: pd.DataFrame,
+    nodes_gdf: gpd.GeoDataFrame,
+):
+    """Panel 4: Diferencia de reliability entre escenarios."""
+    nodes_gdf.plot(
+        ax=ax, color="#BDC3C7", markersize=10,
+        edgecolor="white", linewidth=0.2, zorder=3,
+    )
+    ax.plot(
+        cfg.DEPOT_LON, cfg.DEPOT_LAT,
+        marker="*", color="#C0392B", markersize=14,
+        markeredgecolor="white", markeredgewidth=0.5, zorder=6,
+    )
+
+    baseline_row = experiments_df[experiments_df["experiment"] == "baseline"]
+    nlr_row = experiments_df[experiments_df["experiment"] == "no_hilux_+NLR"]
+    fuso_row = experiments_df[experiments_df["experiment"] == "no_hilux_+FUSO"]
+
+    data = []
+    labels = []
+    colors = []
+    if not baseline_row.empty and not nlr_row.empty:
+        bl_rel = baseline_row.iloc[0]["reliability"]
+        nlr_rel = nlr_row.iloc[0]["reliability"]
+        diff_nlr = nlr_rel - bl_rel
+        data.append(("NLR", diff_nlr, nlr_rel, bl_rel))
+    if not baseline_row.empty and not fuso_row.empty:
+        bl_rel = baseline_row.iloc[0]["reliability"]
+        fuso_rel = fuso_row.iloc[0]["reliability"]
+        diff_fuso = fuso_rel - bl_rel
+        data.append(("FUSO", diff_fuso, fuso_rel, bl_rel))
+
+    # Summary text
+    summary_lines = ["Δ Reliability vs Baseline\n" + "=" * 30]
+    for label, diff, new, old in data:
+        arrow = "▲" if diff > 0 else "▼"
+        color = "#27AE60" if diff > 0 else "#C0392B"
+        summary_lines.append(
+            f"\n{label}:\n"
+            f"  {old * 100:.1f}% → {new * 100:.1f}%\n"
+            f"  {arrow} {abs(diff) * 100:.1f} pp"
+        )
+
+    # Bar chart
+    if data:
+        bar_labels = [d[0] for d in data]
+        bar_vals = [d[1] * 100 for d in data]
+        bar_colors = ["#27AE60" if v > 0 else "#C0392B" for v in bar_vals]
+        y_pos = range(len(bar_labels))
+        ax.barh(
+            [0.3 + i * 0.15 for i in y_pos],
+            [abs(v) / 100 * 0.3 for v in bar_vals],
+            height=0.1,
+            left=cfg.DEPOT_LON - 0.5,
+            color=bar_colors, alpha=0.7, zorder=5,
+        )
+
+    ax.text(
+        0.02, 0.98, "\n".join(summary_lines),
+        transform=ax.transAxes, fontsize=7,
+        fontfamily="monospace", verticalalignment="top",
+        bbox=dict(
+            boxstyle="round,pad=0.3",
+            facecolor="white", edgecolor="#2C3E50", alpha=0.9,
+        ),
+        zorder=8,
+    )
+
+    # Improvement arrows scattered across the map
+    np.random.seed(cfg.RANDOM_SEED)
+    for _, node in nodes_gdf.sample(min(10, len(nodes_gdf))).iterrows():
+        ax.annotate(
+            "",
+            xy=(node.geometry.x + 0.02, node.geometry.y + 0.02),
+            xytext=(node.geometry.x, node.geometry.y),
+            arrowprops=dict(
+                arrowstyle="->", color="#27AE60",
+                lw=1.5, alpha=0.6,
+            ),
+            zorder=7,
+        )
+
+    ax.set_title("Diferencia de reliability", fontsize=9, fontweight="bold", pad=8)
+
+
+def _generate_m5_static(
+    experiments_df: pd.DataFrame,
+    route_coords: dict,
+    nodes_gdf: gpd.GeoDataFrame,
+):
+    """Generar panel comparativo 2×2 (PNG)."""
+    apply_academic_style()
+
+    fig, axes = plt.subplots(2, 2, figsize=(16, 14))
+
+    scenarios_for_panels = SCENARIO_KEYS[:3]
+
+    for idx, scenario in enumerate(scenarios_for_panels):
+        ax = axes[idx // 2][idx % 2]
+        exp_row = experiments_df[experiments_df["experiment"] == scenario]
+        kpis = exp_row.iloc[0].to_dict() if not exp_row.empty else None
+        label = SCENARIO_LABELS.get(scenario, scenario)
+
+        _plot_scenario_panel(ax, label, route_coords, nodes_gdf, kpis)
+
+        try:
+            add_basemap(ax)
+        except Exception:
+            pass
+
+    # Panel 4: Diferencia de reliability
+    ax4 = axes[1][1]
+    _plot_reliability_diff(ax4, experiments_df, nodes_gdf)
+    try:
+        add_basemap(ax4)
+    except Exception:
+        pass
+
+    # Leyenda unificada
+    handles = vehicle_legend_handles()
+    handles.append(
+        Line2D([0], [0], marker="*", color="w",
+               markerfacecolor="#C0392B", markersize=12,
+               label="Depósito", linestyle="None")
+    )
+    fig.legend(
+        handles=handles, loc="lower center",
+        ncol=len(handles), frameon=True,
+        framealpha=0.9, fontsize=8,
+        bbox_to_anchor=(0.5, -0.02),
+    )
+
+    fig.suptitle(
+        cfg.FIGURE_TITLES["M5"],
+        fontsize=12, fontweight="bold", y=0.98,
+    )
+    plt.tight_layout(rect=[0, 0.02, 1, 0.96])
+
+    save_matplotlib_fig(fig, cfg.M5_OUTPUT_DIR, "M5_comparacion_escenarios.png")
+
+
+def _generate_m5_interactive(
+    experiments_df: pd.DataFrame,
+    route_coords: dict,
+    nodes_df: pd.DataFrame,
+):
+    """Generar versión interactiva (HTML) con tabs por escenario."""
+    m = create_base_map(zoom_start=8)
+
+    folium.Marker(
+        location=[cfg.DEPOT_LAT, cfg.DEPOT_LON],
+        popup=f"<b>{cfg.DEPOT_NAME}</b>",
+        icon=folium.Icon(color="red", icon="star", prefix="fa"),
+    ).add_to(m)
+
+    for scenario in SCENARIO_KEYS:
+        label = SCENARIO_LABELS.get(scenario, scenario)
+        group = folium.FeatureGroup(name=label)
+
+        exp_row = experiments_df[experiments_df["experiment"] == scenario]
+        kpi_text = ""
+        if not exp_row.empty:
+            row = exp_row.iloc[0]
+            kpi_text = (
+                f"E[Costo]: S/ {row['expected_cost']:,.0f} | "
+                f"Reliability: {row['reliability'] * 100:.1f}% | "
+                f"CVaR 5%: S/ {row['CVaR_0.05']:,.0f}"
+            )
+
+        for rid, rdata in route_coords.items():
+            coords = rdata["coords"]
+            if len(coords) < 2:
+                continue
+            color = cfg.VEHICLE_COLORS.get(rdata["vehicle_id"], "#333333")
+            vname = cfg.VEHICLE_SHORT_LABELS.get(
+                rdata["vehicle_id"], rdata["vehicle_name"]
+            )
+            popup_text = (
+                f"<b>{label}</b><br>"
+                f"Ruta {rid} – {vname}<br>"
+                f"{kpi_text}"
+            )
+            folium.PolyLine(
+                locations=coords,
+                color=color,
+                weight=3,
+                opacity=0.8,
+                popup=folium.Popup(popup_text, max_width=300),
+            ).add_to(group)
+
+        group.add_to(m)
+
+    folium.LayerControl(collapsed=False).add_to(m)
+
+    title_html = (
+        '<div style="position:fixed;top:10px;left:50%;transform:translateX(-50%);'
+        'z-index:9999;background:white;padding:8px 16px;border-radius:4px;'
+        'box-shadow:0 2px 6px rgba(0,0,0,0.3);font-family:serif;font-size:13px;'
+        f'font-weight:bold;">{cfg.FIGURE_TITLES["M5"]}</div>'
+    )
+    m.get_root().html.add_child(folium.Element(title_html))
+
+    save_folium_map(m, cfg.M5_OUTPUT_DIR, "M5_comparacion_escenarios.html")
+
+
+def generate_m5():
+    """Generar FIGURA M5: Comparación de escenarios robustos."""
+    print("  Cargando datos...")
+    nodes_df = dl.load_nodes()
+    routes_df = dl.load_baseline_routes()
+    experiments_df = dl.load_capacity_experiments()
+    node_lookup = dl.build_node_lookup(nodes_df)
+
+    print("  Construyendo rutas para visualización...")
+    route_coords = _build_route_coords(routes_df, node_lookup)
+    nodes_gdf = nodes_to_gdf(nodes_df)
+
+    print("  Generando panel comparativo estático (PNG)...")
+    _generate_m5_static(experiments_df, route_coords, nodes_gdf)
+
+    print("  Generando mapa interactivo (HTML)...")
+    _generate_m5_interactive(experiments_df, route_coords, nodes_df)
+
+
+if __name__ == "__main__":
+    generate_m5()
