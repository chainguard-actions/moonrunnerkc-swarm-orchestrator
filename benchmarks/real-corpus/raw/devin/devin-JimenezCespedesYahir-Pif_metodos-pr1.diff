@@ -0,0 +1,208 @@
+"""
+FIGURA M1: Red vial real DSRSLCC sobre OpenStreetMap.
+
+Muestra la red logística territorial completa con 81 nodos IPRESS
+diferenciados por categoría, clustering espacial K-means y red vial
+principal descargada de OpenStreetMap vía OSMnx.
+"""
+
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import osmnx as ox
+from folium.plugins import MarkerCluster
+from matplotlib.patches import Patch
+
+from . import config as cfg
+from . import data_loader as dl
+from .utils import (
+    add_basemap,
+    apply_academic_style,
+    calculate_bounding_box,
+    cluster_nodes,
+    create_base_map,
+    download_road_network,
+    ensure_dir,
+    filter_main_roads,
+    ipress_legend_handles,
+    nodes_to_gdf,
+    save_folium_map,
+    save_matplotlib_fig,
+)
+
+CLUSTER_COLORS = ["#E74C3C", "#3498DB", "#2ECC71", "#9B59B6", "#F39C12"]
+
+
+def _generate_m1_static(nodes_gdf: gpd.GeoDataFrame):
+    """Generar versión estática (PNG) con Matplotlib + Contextily."""
+    apply_academic_style()
+
+    nodes_gdf = cluster_nodes(nodes_gdf)
+
+    fig, ax = plt.subplots(figsize=cfg.FIGURE_FIGSIZE)
+
+    try:
+        G = download_road_network(
+            bbox=(
+                cfg.STUDY_BBOX_NORTH,
+                cfg.STUDY_BBOX_SOUTH,
+                cfg.STUDY_BBOX_EAST,
+                cfg.STUDY_BBOX_WEST,
+            )
+        )
+        G_main = filter_main_roads(G)
+        edges_gdf = ox.graph_to_gdfs(G_main, nodes=False)
+        edges_gdf.plot(ax=ax, color="#95A5A6", linewidth=0.5, alpha=0.6)
+    except Exception as exc:
+        print(f"    Advertencia: No se pudo descargar red vial OSMnx: {exc}")
+        print("    Continuando sin capa de red vial...")
+
+    for cat, color in cfg.IPRESS_COLORS.items():
+        marker = cfg.IPRESS_MARKERS.get(cat, "o")
+        subset = nodes_gdf[nodes_gdf["categoria"] == cat]
+        if subset.empty:
+            continue
+        subset.plot(
+            ax=ax,
+            color=color,
+            marker=marker,
+            markersize=40,
+            edgecolor="white",
+            linewidth=0.5,
+            alpha=0.85,
+            zorder=4,
+        )
+
+    for cluster_id in range(cfg.N_CLUSTERS):
+        cl = nodes_gdf[nodes_gdf["cluster"] == cluster_id]
+        if cl.empty:
+            continue
+        centroid = cl.geometry.unary_union.centroid
+        circle = plt.Circle(
+            (centroid.x, centroid.y),
+            0.12,
+            fill=False,
+            edgecolor=CLUSTER_COLORS[cluster_id % len(CLUSTER_COLORS)],
+            linewidth=1.5,
+            linestyle="--",
+            alpha=0.6,
+            zorder=3,
+        )
+        ax.add_patch(circle)
+        ax.annotate(
+            f"Z{cluster_id + 1}",
+            xy=(centroid.x, centroid.y),
+            fontsize=8,
+            fontweight="bold",
+            color=CLUSTER_COLORS[cluster_id % len(CLUSTER_COLORS)],
+            ha="center",
+            va="center",
+            zorder=5,
+        )
+
+    ax.plot(
+        cfg.DEPOT_LON,
+        cfg.DEPOT_LAT,
+        marker="*",
+        color="#C0392B",
+        markersize=18,
+        markeredgecolor="white",
+        markeredgewidth=0.8,
+        zorder=6,
+    )
+
+    try:
+        add_basemap(ax)
+    except Exception:
+        pass
+
+    handles = ipress_legend_handles()
+    cluster_handles = [
+        Patch(
+            facecolor="none",
+            edgecolor=CLUSTER_COLORS[i],
+            linestyle="--",
+            linewidth=1.5,
+            label=f"Zona {i + 1}",
+        )
+        for i in range(cfg.N_CLUSTERS)
+    ]
+    ax.legend(
+        handles=handles + cluster_handles,
+        loc="lower left",
+        frameon=True,
+        framealpha=0.9,
+        fontsize=8,
+    )
+
+    ax.set_title(cfg.FIGURE_TITLES["M1"], fontsize=11, fontweight="bold", pad=12)
+    ax.set_xlabel("Longitud")
+    ax.set_ylabel("Latitud")
+
+    save_matplotlib_fig(fig, cfg.M1_OUTPUT_DIR, "M1_red_vial_DSRSLCC.png")
+
+
+def _generate_m1_interactive(nodes_df):
+    """Generar versión interactiva (HTML) con Folium."""
+    m = create_base_map(zoom_start=8)
+
+    folium.Marker(
+        location=[cfg.DEPOT_LAT, cfg.DEPOT_LON],
+        popup=f"<b>{cfg.DEPOT_NAME}</b><br>Depósito principal",
+        icon=folium.Icon(color="red", icon="star", prefix="fa"),
+    ).add_to(m)
+
+    cs_group = folium.FeatureGroup(name="Centros de Salud")
+    ps_group = folium.FeatureGroup(name="Puestos de Salud")
+
+    for _, row in nodes_df.iterrows():
+        cat = row["categoria"]
+        color = "blue" if cat == "CENTRO DE SALUD" else "green"
+        icon_shape = "square" if cat == "CENTRO DE SALUD" else "circle"
+        popup_html = (
+            f"<b>{row['nombre']}</b><br>"
+            f"Categoría: {cat}<br>"
+            f"Provincia: {row.get('province', 'N/A')}<br>"
+            f"Demanda media: {row.get('demand_mean', 'N/A')} kg"
+        )
+        marker = folium.Marker(
+            location=[row["latitude"], row["longitude"]],
+            popup=folium.Popup(popup_html, max_width=250),
+            icon=folium.Icon(color=color, icon="plus-sign"),
+        )
+        if cat == "CENTRO DE SALUD":
+            marker.add_to(cs_group)
+        else:
+            marker.add_to(ps_group)
+
+    cs_group.add_to(m)
+    ps_group.add_to(m)
+    folium.LayerControl().add_to(m)
+
+    title_html = (
+        '<div style="position:fixed;top:10px;left:50%;transform:translateX(-50%);'
+        'z-index:9999;background:white;padding:8px 16px;border-radius:4px;'
+        'box-shadow:0 2px 6px rgba(0,0,0,0.3);font-family:serif;font-size:13px;'
+        f'font-weight:bold;">{cfg.FIGURE_TITLES["M1"]}</div>'
+    )
+    m.get_root().html.add_child(folium.Element(title_html))
+
+    save_folium_map(m, cfg.M1_OUTPUT_DIR, "M1_red_vial_DSRSLCC.html")
+
+
+def generate_m1():
+    """Generar FIGURA M1: Red vial real DSRSLCC."""
+    print("  Cargando nodos IPRESS...")
+    nodes_df = dl.load_nodes()
+    nodes_gdf = nodes_to_gdf(nodes_df)
+
+    print("  Generando mapa estático (PNG)...")
+    _generate_m1_static(nodes_gdf)
+
+    print("  Generando mapa interactivo (HTML)...")
+    _generate_m1_interactive(nodes_df)
+
+
+if __name__ == "__main__":
+    generate_m1()
diff --git a/src/maps_osm/fig_m2_rutas_baseline.py b/src/maps_osm/fig_m2_rutas_baseline.py
