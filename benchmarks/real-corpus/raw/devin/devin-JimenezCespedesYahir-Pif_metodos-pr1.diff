+"""
+FIGURA M4: Mapa de variabilidad vial.
+
+Representa la incertidumbre geográfica de tiempos de viaje usando
+heatmap de CV sobre arcos, identificación de arcos críticos y
+estadísticas por provincia.
+"""
+
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import pandas as pd
+from folium.plugins import HeatMap
+from matplotlib.collections import LineCollection
+from matplotlib.colorbar import ColorbarBase
+from matplotlib.colors import LinearSegmentedColormap, Normalize
+from matplotlib.lines import Line2D
+
+from . import config as cfg
+from . import data_loader as dl
+from .utils import (
+    add_basemap,
+    apply_academic_style,
+    create_base_map,
+    nodes_to_gdf,
+    save_folium_map,
+    save_matplotlib_fig,
+)
+
+
+def _prepare_arcs_geo(arcs_df: pd.DataFrame):
+    """Preparar arcos con geometría de línea."""
+    arcs_df = arcs_df.copy()
+    arcs_df["travel_time_cv"] = pd.to_numeric(
+        arcs_df["travel_time_cv"], errors="coerce"
+    )
+    arcs_df["travel_time_std"] = pd.to_numeric(
+        arcs_df["travel_time_std"], errors="coerce"
+    )
+    arcs_df["duration_min"] = pd.to_numeric(
+        arcs_df["duration_min"], errors="coerce"
+    )
+    arcs_df["origin_lat"] = pd.to_numeric(arcs_df["origin_lat"], errors="coerce")
+    arcs_df["origin_lon"] = pd.to_numeric(arcs_df["origin_lon"], errors="coerce")
+    arcs_df["destination_lat"] = pd.to_numeric(
+        arcs_df["destination_lat"], errors="coerce"
+    )
+    arcs_df["destination_lon"] = pd.to_numeric(
+        arcs_df["destination_lon"], errors="coerce"
+    )
+    arcs_df = arcs_df.dropna(
+        subset=["origin_lat", "origin_lon", "destination_lat", "destination_lon",
+                "travel_time_cv"]
+    )
+    return arcs_df
+
+
+def _generate_m4_static(arcs_df: pd.DataFrame, nodes_gdf: gpd.GeoDataFrame):
+    """Generar versión estática (PNG) con Matplotlib + Contextily."""
+    apply_academic_style()
+
+    fig, (ax_map, ax_stats) = plt.subplots(
+        1, 2, figsize=(18, 10),
+        gridspec_kw={"width_ratios": [3, 1]},
+    )
+
+    nodes_gdf.plot(
+        ax=ax_map, color="#7F8C8D", markersize=15,
+        edgecolor="white", linewidth=0.3, zorder=3,
+    )
+    ax_map.plot(
+        cfg.DEPOT_LON, cfg.DEPOT_LAT,
+        marker="*", color="#C0392B", markersize=16,
+        markeredgecolor="white", markeredgewidth=0.5, zorder=6,
+    )
+
+    cmap = LinearSegmentedColormap.from_list(
+        "cv_cmap", ["#27AE60", "#F1C40F", "#C0392B"]
+    )
+    cv_min = arcs_df["travel_time_cv"].min()
+    cv_max = arcs_df["travel_time_cv"].max()
+    norm = Normalize(vmin=cv_min, vmax=cv_max)
+
+    segments = []
+    colors = []
+    for _, row in arcs_df.iterrows():
+        seg = [
+            (row["origin_lon"], row["origin_lat"]),
+            (row["destination_lon"], row["destination_lat"]),
+        ]
+        segments.append(seg)
+        cv = row["travel_time_cv"]
+        alpha = 0.3 + 0.5 * ((cv - cv_min) / (cv_max - cv_min + 1e-9))
+        colors.append((*cmap(norm(cv))[:3], alpha))
+
+    lc = LineCollection(segments, colors=colors, linewidths=1.2, zorder=4)
+    ax_map.add_collection(lc)
+
+    # Arcos críticos (CV > 0.25 o duración > 60 min)
+    critical = arcs_df[
+        (arcs_df["travel_time_cv"] > 0.25)
+        | (arcs_df["duration_min"] > 60)
+    ]
+    for _, row in critical.iterrows():
+        ax_map.plot(
+            [row["origin_lon"], row["destination_lon"]],
+            [row["origin_lat"], row["destination_lat"]],
+            color="#C0392B", linewidth=2.5, alpha=0.6,
+            linestyle="--", zorder=5,
+        )
+
+    # Círculos proporcionales a std en nodos
+    node_std = {}
+    for _, row in arcs_df.iterrows():
+        key = (row["origin_lat"], row["origin_lon"])
+        if key not in node_std:
+            node_std[key] = []
+        node_std[key].append(row["travel_time_std"])
+    for (lat, lon), stds in node_std.items():
+        mean_std = np.mean(stds)
+        size = 5 + mean_std * 15
+        ax_map.scatter(
+            lon, lat, s=size,
+            facecolors="none", edgecolors="#8E44AD",
+            linewidths=0.8, alpha=0.5, zorder=4,
+        )
+
+    try:
+        add_basemap(ax_map)
+    except Exception:
+        pass
+
+    sm = plt.cm.ScalarMappable(cmap=cmap, norm=norm)
+    sm.set_array([])
+    cbar = plt.colorbar(sm, ax=ax_map, shrink=0.6, pad=0.02)
+    cbar.set_label("Coeficiente de variación (CV)", fontsize=9)
+
+    handles = [
+        Line2D([0], [0], color="#C0392B", lw=2, linestyle="--",
+               label="Arco crítico (CV>0.25 ó >60min)"),
+        Line2D([0], [0], marker="o", color="w", markerfacecolor="none",
+               markeredgecolor="#8E44AD", markersize=8, markeredgewidth=1,
+               label="σ promedio en nodo", linestyle="None"),
+    ]
+    ax_map.legend(handles=handles, loc="lower left", framealpha=0.9, fontsize=8)
+    ax_map.set_title(cfg.FIGURE_TITLES["M4"], fontsize=11, fontweight="bold", pad=12)
+    ax_map.set_xlabel("Longitud")
+    ax_map.set_ylabel("Latitud")
+
+    # Panel de estadísticas
+    ax_stats.axis("off")
+
+    stats_text = "Estadísticas de variabilidad\n" + "=" * 32 + "\n\n"
+    stats_text += f"CV promedio global: {arcs_df['travel_time_cv'].mean():.3f}\n"
+    stats_text += f"CV mediana: {arcs_df['travel_time_cv'].median():.3f}\n"
+    stats_text += f"CV máximo: {arcs_df['travel_time_cv'].max():.3f}\n"
+    stats_text += f"N° arcos totales: {len(arcs_df)}\n"
+    stats_text += f"N° arcos críticos: {len(critical)}\n\n"
+
+    top10 = arcs_df.nlargest(10, "travel_time_cv")
+    stats_text += "Top 10 arcos más variables:\n" + "-" * 32 + "\n"
+    for i, (_, row) in enumerate(top10.iterrows(), 1):
+        oname = str(row.get("origin_name", row["origin_id"]))[:18]
+        dname = str(row.get("destination_name", row["destination_id"]))[:18]
+        stats_text += f"{i}. {oname}\n   → {dname}\n   CV={row['travel_time_cv']:.3f}\n"
+
+    ax_stats.text(
+        0, 1, stats_text, transform=ax_stats.transAxes,
+        fontsize=7, fontfamily="monospace", verticalalignment="top",
+    )
+    ax_stats.set_title("Panel de variabilidad", fontsize=10, fontweight="bold", pad=12)
+
+    plt.tight_layout()
+    save_matplotlib_fig(fig, cfg.M4_OUTPUT_DIR, "M4_variabilidad_vial.png")
+
+
+def _generate_m4_interactive(arcs_df: pd.DataFrame, nodes_df: pd.DataFrame):
+    """Generar versión interactiva (HTML) con Folium."""
+    m = create_base_map(zoom_start=8)
+
+    folium.Marker(
+        location=[cfg.DEPOT_LAT, cfg.DEPOT_LON],
+        popup=f"<b>{cfg.DEPOT_NAME}</b>",
+        icon=folium.Icon(color="red", icon="star", prefix="fa"),
+    ).add_to(m)
+
+    cv_min = arcs_df["travel_time_cv"].min()
+    cv_max = arcs_df["travel_time_cv"].max()
+
+    all_arcs_group = folium.FeatureGroup(name="Arcos (CV)")
+    critical_group = folium.FeatureGroup(name="Arcos críticos")
+
+    for _, row in arcs_df.iterrows():
+        cv = row["travel_time_cv"]
+        ratio = (cv - cv_min) / (cv_max - cv_min + 1e-9)
+
+        if ratio < 0.33:
+            color = "#27AE60"
+        elif ratio < 0.66:
+            color = "#F1C40F"
+        else:
+            color = "#C0392B"
+
+        opacity = 0.3 + 0.5 * ratio
+        is_critical = cv > 0.25 or (
+            pd.notna(row.get("duration_min")) and row["duration_min"] > 60
+        )
+
+        popup_text = (
+            f"<b>{row.get('origin_name', row['origin_id'])}</b> → "
+            f"<b>{row.get('destination_name', row['destination_id'])}</b><br>"
+            f"CV: {cv:.3f}<br>"
+            f"σ: {row['travel_time_std']:.2f} min<br>"
+            f"Duración media: {row.get('travel_time_mean', 'N/A')} min"
+        )
+
+        line = folium.PolyLine(
+            locations=[
+                [row["origin_lat"], row["origin_lon"]],
+                [row["destination_lat"], row["destination_lon"]],
+            ],
+            color=color,
+            weight=2 if not is_critical else 4,
+            opacity=opacity,
+            popup=folium.Popup(popup_text, max_width=250),
+            dash_array="5 5" if is_critical else None,
+        )
+
+        if is_critical:
+            line.add_to(critical_group)
+        else:
+            line.add_to(all_arcs_group)
+
+    all_arcs_group.add_to(m)
+    critical_group.add_to(m)
+
+    # Heatmap de variabilidad
+    heat_data = []
+    for _, row in arcs_df.iterrows():
+        mid_lat = (row["origin_lat"] + row["destination_lat"]) / 2
+        mid_lon = (row["origin_lon"] + row["destination_lon"]) / 2
+        heat_data.append([mid_lat, mid_lon, row["travel_time_cv"]])
+
+    if heat_data:
+        heat_group = folium.FeatureGroup(name="Heatmap CV")
+        HeatMap(
+            heat_data, radius=20, blur=15,
+            gradient={0.3: "green", 0.6: "yellow", 1.0: "red"},
+        ).add_to(heat_group)
+        heat_group.add_to(m)
+
+    folium.LayerControl().add_to(m)
+
+    title_html = (
+        '<div style="position:fixed;top:10px;left:50%;transform:translateX(-50%);'
+        'z-index:9999;background:white;padding:8px 16px;border-radius:4px;'
+        'box-shadow:0 2px 6px rgba(0,0,0,0.3);font-family:serif;font-size:13px;'
+        f'font-weight:bold;">{cfg.FIGURE_TITLES["M4"]}</div>'
+    )
+    m.get_root().html.add_child(folium.Element(title_html))
+
+    save_folium_map(m, cfg.M4_OUTPUT_DIR, "M4_variabilidad_vial.html")
+
+
+def generate_m4():
+    """Generar FIGURA M4: Mapa de variabilidad vial."""
+    print("  Cargando datos...")
+    nodes_df = dl.load_nodes()
+    arcs_df = dl.load_arcs()
+
+    print("  Preparando arcos geoespaciales...")
+    arcs_df = _prepare_arcs_geo(arcs_df)
+    nodes_gdf = nodes_to_gdf(nodes_df)
+
+    print("  Generando mapa estático (PNG)...")
+    _generate_m4_static(arcs_df, nodes_gdf)
+
+    print("  Generando mapa interactivo (HTML)...")
+    _generate_m4_interactive(arcs_df, nodes_df)
+
+
+if __name__ == "__main__":
+    generate_m4()
