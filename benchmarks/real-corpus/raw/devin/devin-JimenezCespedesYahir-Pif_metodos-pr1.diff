+#!/usr/bin/env python3
+"""
+Generador de todas las visualizaciones cartográficas HVRPTW.
+
+Uso:
+    python -m src.maps_osm.generate_all_maps
+    python src/maps_osm/generate_all_maps.py
+"""
+
+import sys
+from pathlib import Path
+
+# Asegurar que la raíz del proyecto esté en sys.path
+_project_root = Path(__file__).resolve().parents[2]
+if str(_project_root) not in sys.path:
+    sys.path.insert(0, str(_project_root))
+
+from src.maps_osm.fig_m1_network_vial import generate_m1
+from src.maps_osm.fig_m2_rutas_baseline import generate_m2
+from src.maps_osm.fig_m3_fragilidad_espacial import generate_m3
+from src.maps_osm.fig_m4_variabilidad_vial import generate_m4
+from src.maps_osm.fig_m5_comparacion_escenarios import generate_m5
+
+
+def main():
+    print("Generando visualizaciones cartográficas HVRPTW...")
+    print("=" * 60)
+
+    maps = [
+        ("M1", "Red vial real DSRSLCC", generate_m1),
+        ("M2", "Rutas baseline", generate_m2),
+        ("M3", "Fragilidad espacial", generate_m3),
+        ("M4", "Variabilidad vial", generate_m4),
+        ("M5", "Comparación escenarios", generate_m5),
+    ]
+
+    results = []
+    for code, name, func in maps:
+        try:
+            print(f"\n[{code}] {name}...")
+            func()
+            print(f"  ✓ Completado")
+            results.append((code, name, True, None))
+        except Exception as e:
+            print(f"  ✗ Error: {e}")
+            results.append((code, name, False, str(e)))
+
+    print("\n" + "=" * 60)
+    print("Resumen de generación:")
+    for code, name, ok, err in results:
+        status = "✓" if ok else "✗"
+        print(f"  {status} [{code}] {name}" + (f" — {err}" if err else ""))
+
+    print(f"\nVisualizaciones generadas en results/maps_osm/")
+
+    failed = [r for r in results if not r[2]]
+    if failed:
+        print(f"\n⚠ {len(failed)} figura(s) con errores")
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
