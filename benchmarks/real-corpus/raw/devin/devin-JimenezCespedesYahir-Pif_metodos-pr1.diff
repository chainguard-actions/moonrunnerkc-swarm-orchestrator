@@ -0,0 +1,284 @@
+"""
+FIGURA M2: Rutas baseline HVRPTW sobre mapa real.
+
+Visualiza las rutas deterministas del solver sobre la red vial real,
+coloreadas por tipo de vehículo, con grosor proporcional a la carga
+y panel lateral con KPIs por ruta.
+"""
+
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import pandas as pd
+from matplotlib.lines import Line2D
+
+from . import config as cfg
+from . import data_loader as dl
+from .utils import (
+    add_basemap,
+    apply_academic_style,
+    create_base_map,
+    nodes_to_gdf,
+    save_folium_map,
+    save_matplotlib_fig,
+    vehicle_legend_handles,
+)
+
+
+def _build_route_sequences(routes_df: pd.DataFrame, node_lookup: dict):
+    """Construir secuencias de coordenadas por ruta."""
+    route_data = {}
+    for route_id, group in routes_df.groupby("route_id"):
+        group = group.sort_values("stop_sequence")
+        coords = []
+        node_ids = []
+        for _, row in group.iterrows():
+            nid = str(row["node_id"])
+            if nid in node_lookup:
+                coords.append(node_lookup[nid])
+                node_ids.append(nid)
+        # Retorno al depósito
+        depot = node_lookup.get("DEPOT_DSRSLCC")
+        if depot and (not coords or coords[-1] != depot):
+            coords.append(depot)
+            node_ids.append("DEPOT_DSRSLCC")
+
+        first = group.iloc[0]
+        route_data[route_id] = {
+            "coords": coords,
+            "node_ids": node_ids,
+            "vehicle_id": first["vehicle_id"],
+            "vehicle_name": first["vehicle_name"],
+            "capacity_kg": first["capacity_kg"],
+            "route_distance_km": pd.to_numeric(
+                first.get("route_distance_km", 0), errors="coerce"
+            ),
+            "route_load_kg": pd.to_numeric(
+                first.get("route_load_kg", 0), errors="coerce"
+            ),
+            "utilization_pct": pd.to_numeric(
+                first.get("utilization_pct", 0), errors="coerce"
+            ),
+        }
+    return route_data
+
+
+def _generate_m2_static(route_data: dict, nodes_gdf: gpd.GeoDataFrame):
+    """Generar versión estática (PNG) con Matplotlib."""
+    apply_academic_style()
+
+    fig, (ax_map, ax_table) = plt.subplots(
+        1, 2,
+        figsize=(18, 10),
+        gridspec_kw={"width_ratios": [3, 1]},
+    )
+
+    nodes_gdf.plot(
+        ax=ax_map,
+        color="#7F8C8D",
+        markersize=20,
+        edgecolor="white",
+        linewidth=0.3,
+        zorder=3,
+    )
+
+    ax_map.plot(
+        cfg.DEPOT_LON,
+        cfg.DEPOT_LAT,
+        marker="*",
+        color="#C0392B",
+        markersize=18,
+        markeredgecolor="white",
+        markeredgewidth=0.8,
+        zorder=6,
+    )
+
+    for route_id, rdata in sorted(route_data.items()):
+        coords = rdata["coords"]
+        if len(coords) < 2:
+            continue
+        lats = [c[0] for c in coords]
+        lons = [c[1] for c in coords]
+        color = cfg.VEHICLE_COLORS.get(rdata["vehicle_id"], "#333333")
+        util = rdata["utilization_pct"]
+        lw = 1.5 + (util / 100.0) * 3.5 if util else 2.0
+
+        ax_map.plot(lons, lats, color=color, linewidth=lw, alpha=0.75, zorder=4)
+
+        for i, (lat, lon) in enumerate(coords[1:-1], start=1):
+            ax_map.annotate(
+                str(i),
+                xy=(lon, lat),
+                fontsize=5,
+                fontweight="bold",
+                color=color,
+                ha="center",
+                va="center",
+                bbox=dict(
+                    boxstyle="round,pad=0.15",
+                    facecolor="white",
+                    edgecolor=color,
+                    alpha=0.8,
+                    linewidth=0.5,
+                ),
+                zorder=7,
+            )
+
+    try:
+        add_basemap(ax_map)
+    except Exception:
+        pass
+
+    handles = vehicle_legend_handles()
+    handles.append(
+        Line2D(
+            [0], [0], marker="*", color="w",
+            markerfacecolor="#C0392B", markersize=12,
+            label="Depósito", linestyle="None",
+        )
+    )
+    ax_map.legend(handles=handles, loc="lower left", framealpha=0.9, fontsize=8)
+    ax_map.set_title(cfg.FIGURE_TITLES["M2"], fontsize=11, fontweight="bold", pad=12)
