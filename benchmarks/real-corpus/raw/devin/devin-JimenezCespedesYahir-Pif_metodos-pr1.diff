+"""
+Utilidades GIS compartidas para las visualizaciones cartográficas HVRPTW.
+
+Proporciona funciones de creación de mapas Folium, descarga de red vial OSMnx,
+estilos académicos, exportación y clustering espacial.
+"""
+
+from pathlib import Path
+
+import contextily as ctx
+import folium
+import geopandas as gpd
+import matplotlib.pyplot as plt
+import numpy as np
+import osmnx as ox
+from matplotlib.colors import Normalize
+from matplotlib.lines import Line2D
+from shapely.geometry import Point
+from sklearn.cluster import KMeans
+
+from . import config as cfg
+
+
+# ---------------------------------------------------------------------------
+# Mapa Folium base
+# ---------------------------------------------------------------------------
+
+def create_base_map(
+    center: tuple[float, float] | None = None,
+    zoom_start: int = 9,
+    tiles: str = cfg.FOLIUM_TILES,
+) -> folium.Map:
+    """Crear mapa Folium base centrado en la zona de estudio."""
+    if center is None:
+        center = (cfg.DEPOT_LAT, cfg.DEPOT_LON)
+    m = folium.Map(
+        location=center,
+        zoom_start=zoom_start,
+        tiles=tiles,
+        control_scale=True,
+    )
+    return m
+
+
+# ---------------------------------------------------------------------------
+# Red vial OSMnx
+# ---------------------------------------------------------------------------
+
+def download_road_network(
+    bbox: tuple[float, float, float, float] | None = None,
+    network_type: str = "drive",
+    simplify: bool = True,
+) -> "ox.graph":
+    """Descargar red vial OSMnx para la región indicada.
+
+    Parameters
+    ----------
+    bbox : (north, south, east, west) o None para usar PIURA_BBOX
+    """
+    if bbox is None:
+        bbox = (
+            cfg.PIURA_BBOX_NORTH,
+            cfg.PIURA_BBOX_SOUTH,
+            cfg.PIURA_BBOX_EAST,
+            cfg.PIURA_BBOX_WEST,
+        )
+    north, south, east, west = bbox
+    ox.settings.use_cache = True
+    ox.settings.log_console = False
+    G = ox.graph_from_bbox(
+        bbox=(west, south, east, north),
+        network_type=network_type,
+        simplify=simplify,
+    )
+    return G
+
+
+def filter_main_roads(G: "ox.graph") -> "ox.graph":
+    """Filtrar red vial a carreteras principales (primary, secondary, tertiary)."""
+    main_types = {"primary", "secondary", "tertiary",
+                  "primary_link", "secondary_link", "tertiary_link",
+                  "trunk", "trunk_link"}
+    edges_to_remove = []
+    for u, v, k, data in G.edges(keys=True, data=True):
+        highway = data.get("highway", "")
+        if isinstance(highway, list):
+            if not any(h in main_types for h in highway):
+                edges_to_remove.append((u, v, k))
+        elif highway not in main_types:
+            edges_to_remove.append((u, v, k))
+    G2 = G.copy()
+    G2.remove_edges_from(edges_to_remove)
+    G2.remove_nodes_from(list(nx_isolates(G2)))
+    return G2
+
+
+def nx_isolates(G):
+    """Nodos aislados (sin aristas)."""
+    import networkx as nx
+    return nx.isolates(G)
+
+
+# ---------------------------------------------------------------------------
+# GeoDataFrame helpers
+# ---------------------------------------------------------------------------
+
+def nodes_to_gdf(df, lat_col: str = "latitude", lon_col: str = "longitude") -> gpd.GeoDataFrame:
+    """Convertir DataFrame con lat/lon a GeoDataFrame WGS-84."""
+    geometry = [Point(xy) for xy in zip(df[lon_col], df[lat_col])]
+    return gpd.GeoDataFrame(df, geometry=geometry, crs=cfg.CRS_WGS84)
+
+
+def reproject_utm(gdf: gpd.GeoDataFrame) -> gpd.GeoDataFrame:
+    """Reproyectar GeoDataFrame a UTM zona 17S para cálculos métricos."""
+    return gdf.to_crs(cfg.CRS_UTM17S)
+
+
+# ---------------------------------------------------------------------------
+# Clustering espacial
+# ---------------------------------------------------------------------------
+
+def cluster_nodes(
+    gdf: gpd.GeoDataFrame,
+    n_clusters: int = cfg.N_CLUSTERS,
+    random_state: int = cfg.RANDOM_SEED,
+) -> gpd.GeoDataFrame:
+    """Clustering K-means espacial de IPRESS."""
+    coords = np.column_stack([gdf.geometry.y, gdf.geometry.x])
+    km = KMeans(n_clusters=n_clusters, random_state=random_state, n_init=10)
+    gdf = gdf.copy()
+    gdf["cluster"] = km.fit_predict(coords)
+    return gdf
+
+
+# ---------------------------------------------------------------------------
+# Estilo académico Matplotlib
+# ---------------------------------------------------------------------------
+
+def apply_academic_style():
+    """Aplicar estilo académico a figuras Matplotlib."""
+    plt.rcParams.update(cfg.ACADEMIC_STYLE)
+
+
+def add_basemap(ax, crs=cfg.CRS_WGS84, source=None):
+    """Añadir mapa base Contextily a un Axes con GeoDataFrame."""
+    if source is None:
+        source = ctx.providers.CartoDB.Positron
+    ctx.add_basemap(ax, crs=crs, source=source, attribution_size=6)
+
+
+# ---------------------------------------------------------------------------
+# Leyendas
+# ---------------------------------------------------------------------------
+
+def vehicle_legend_handles() -> list[Line2D]:
+    """Handles de leyenda para tipos de vehículo."""
+    handles = []
+    for vid, label in cfg.VEHICLE_SHORT_LABELS.items():
+        color = cfg.VEHICLE_COLORS.get(vid, "#333333")
+        handles.append(Line2D([0], [0], color=color, lw=2, label=label))
+    return handles
+
+
+def ipress_legend_handles() -> list[Line2D]:
+    """Handles de leyenda para categorías de IPRESS."""
+    handles = []
+    for cat, color in cfg.IPRESS_COLORS.items():
+        marker = cfg.IPRESS_MARKERS.get(cat, "o")
+        handles.append(
+            Line2D(
+                [0], [0],
+                marker=marker,
+                color="w",
+                markerfacecolor=color,
+                markersize=8,
+                label=cat.title(),
+                linestyle="None",
+            )
+        )
+    handles.append(
+        Line2D(
+            [0], [0],
+            marker="*",
+            color="w",
+            markerfacecolor="#C0392B",
+            markersize=14,
+            label="Depósito DSRSLCC",
+            linestyle="None",
+        )
+    )
+    return handles
+
+
+# ---------------------------------------------------------------------------
+# Exportación
+# ---------------------------------------------------------------------------
+
+def ensure_dir(path: Path) -> Path:
+    """Crear directorio si no existe y retornarlo."""
+    path.mkdir(parents=True, exist_ok=True)
+    return path
+
+
+def save_matplotlib_fig(fig, output_dir: Path, filename: str, dpi: int = cfg.EXPORT_DPI):
+    """Guardar figura Matplotlib como PNG."""
+    ensure_dir(output_dir)
+    filepath = output_dir / filename
+    fig.savefig(filepath, dpi=dpi, bbox_inches="tight", pad_inches=0.1)
+    plt.close(fig)
+    print(f"    Guardado: {filepath}")
+    return filepath
+
+
+def save_folium_map(m: folium.Map, output_dir: Path, filename: str):
+    """Guardar mapa Folium como HTML."""
+    ensure_dir(output_dir)
+    filepath = output_dir / filename
+    m.save(str(filepath))
+    print(f"    Guardado: {filepath}")
+    return filepath
+
+
+# ---------------------------------------------------------------------------
+# Bounding box
+# ---------------------------------------------------------------------------
+
+def calculate_bounding_box(lats, lons, pad: float = 0.05):
+    """Calcular bounding box con margen de padding."""
+    return (
+        max(lats) + pad,   # north
+        min(lats) - pad,   # south
+        max(lons) + pad,   # east
+        min(lons) - pad,   # west
+    )
