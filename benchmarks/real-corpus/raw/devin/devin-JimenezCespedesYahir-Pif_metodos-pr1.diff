+        dist = rdata["route_distance_km"]
+        load = rdata["route_load_kg"]
+        util = rdata["utilization_pct"]
+        table_data.append([
+            f"R{rid}",
+            vname[:12],
+            f"{dist:.0f}" if pd.notna(dist) else "—",
+            f"{load:.0f}" if pd.notna(load) else "—",
+            f"{util:.0f}%" if pd.notna(util) else "—",
+        ])
+
+    if table_data:
+        col_labels = ["Ruta", "Vehículo", "Dist (km)", "Carga (kg)", "Util."]
+        table = ax_table.table(
+            cellText=table_data,
+            colLabels=col_labels,
+            loc="center",
+            cellLoc="center",
+        )
+        table.auto_set_font_size(False)
+        table.set_fontsize(8)
+        table.scale(1, 1.3)
+
+        for (row, col), cell in table.get_celld().items():
+            if row == 0:
+                cell.set_facecolor("#2C3E50")
+                cell.set_text_props(color="white", fontweight="bold")
+            else:
+                cell.set_facecolor("#F8F9FA" if row % 2 == 0 else "white")
+            cell.set_edgecolor("#DEE2E6")
+
+        ax_table.set_title(
+            "KPIs por ruta", fontsize=10, fontweight="bold", pad=12
+        )
+
+    plt.tight_layout()
+    save_matplotlib_fig(fig, cfg.M2_OUTPUT_DIR, "M2_rutas_baseline.png")
+
+
+def _generate_m2_interactive(route_data: dict, nodes_df):
+    """Generar versión interactiva (HTML) con Folium."""
+    m = create_base_map(zoom_start=8)
+
+    folium.Marker(
+        location=[cfg.DEPOT_LAT, cfg.DEPOT_LON],
+        popup=f"<b>{cfg.DEPOT_NAME}</b>",
+        icon=folium.Icon(color="red", icon="star", prefix="fa"),
+    ).add_to(m)
+
+    for route_id, rdata in sorted(route_data.items()):
+        coords = rdata["coords"]
+        if len(coords) < 2:
+            continue
+        color = cfg.VEHICLE_COLORS.get(rdata["vehicle_id"], "#333333")
+        vname = cfg.VEHICLE_SHORT_LABELS.get(
+            rdata["vehicle_id"], rdata["vehicle_name"]
+        )
+        util = rdata["utilization_pct"]
+        weight = 2 + (util / 100.0) * 3 if util and pd.notna(util) else 3
+
+        popup_text = (
+            f"<b>Ruta {route_id}</b><br>"
+            f"Vehículo: {vname}<br>"
+            f"Distancia: {rdata['route_distance_km']:.1f} km<br>"
+            f"Carga: {rdata['route_load_kg']:.0f} kg<br>"
+            f"Utilización: {util:.0f}%"
+            if pd.notna(util) else f"<b>Ruta {route_id}</b><br>Vehículo: {vname}"
+        )
+
+        route_group = folium.FeatureGroup(name=f"Ruta {route_id} – {vname}")
+        folium.PolyLine(
+            locations=coords,
+            color=color,
+            weight=weight,
+            opacity=0.8,
+            popup=folium.Popup(popup_text, max_width=200),
+        ).add_to(route_group)
+
+        for i, (lat, lon) in enumerate(coords[1:-1], start=1):
+            folium.CircleMarker(
+                location=[lat, lon],
+                radius=6,
+                color=color,
+                fill=True,
+                fill_color="white",
+                fill_opacity=0.9,
+                popup=f"Parada {i}",
+            ).add_to(route_group)
+            folium.Marker(
+                location=[lat, lon],
+                icon=folium.DivIcon(
+                    html=f'<div style="font-size:9px;font-weight:bold;'
+                    f'color:{color};text-align:center;">{i}</div>',
+                    icon_size=(15, 15),
+                    icon_anchor=(7, 7),
+                ),
+            ).add_to(route_group)
+
+        route_group.add_to(m)
+
+    folium.LayerControl().add_to(m)
+
+    title_html = (
+        '<div style="position:fixed;top:10px;left:50%;transform:translateX(-50%);'
+        'z-index:9999;background:white;padding:8px 16px;border-radius:4px;'
+        'box-shadow:0 2px 6px rgba(0,0,0,0.3);font-family:serif;font-size:13px;'
+        f'font-weight:bold;">{cfg.FIGURE_TITLES["M2"]}</div>'
+    )
+    m.get_root().html.add_child(folium.Element(title_html))
+
+    save_folium_map(m, cfg.M2_OUTPUT_DIR, "M2_rutas_baseline.html")
+
+
+def generate_m2():
+    """Generar FIGURA M2: Rutas baseline sobre mapa real."""
+    print("  Cargando datos...")
+    nodes_df = dl.load_nodes()
+    routes_df = dl.load_baseline_routes()
+    node_lookup = dl.build_node_lookup(nodes_df)
+
+    print("  Construyendo secuencias de rutas...")
