+"""
+Configuración centralizada para visualizaciones cartográficas HVRPTW.
+
+Define constantes geográficas, paletas de colores, estilos académicos
+y rutas de archivos utilizados por todas las figuras M1–M5.
+"""
+
+from pathlib import Path
+
+# ---------------------------------------------------------------------------
+# Rutas del proyecto (relativas a la raíz del repositorio)
+# ---------------------------------------------------------------------------
+PROJECT_ROOT = Path(__file__).resolve().parents[2]
+
+ANALYTICS_DIR = PROJECT_ROOT / "analytics"
+RESULTS_DIR = PROJECT_ROOT / "results"
+MAPS_OUTPUT_DIR = RESULTS_DIR / "maps_osm"
+
+# Archivos de datos de entrada
+NODES_CSV = ANALYTICS_DIR / "nodes_hvrptw.csv"
+ARCS_CSV = ANALYTICS_DIR / "arcs_with_variability.csv"
+VEHICLES_CSV = ANALYTICS_DIR / "vehicles_hvrptw.csv"
+BASELINE_ROUTES_CSV = RESULTS_DIR / "baseline_routes.csv"
+STOCHASTIC_KPIS_CSV = RESULTS_DIR / "stochastic_kpis.csv"
+CAPACITY_EXPERIMENTS_CSV = RESULTS_DIR / "capacity_experiments.csv"
+
+# Directorios de salida por figura
+M1_OUTPUT_DIR = MAPS_OUTPUT_DIR / "m1_red_vial"
+M2_OUTPUT_DIR = MAPS_OUTPUT_DIR / "m2_rutas_baseline"
+M3_OUTPUT_DIR = MAPS_OUTPUT_DIR / "m3_fragilidad"
+M4_OUTPUT_DIR = MAPS_OUTPUT_DIR / "m4_variabilidad"
+M5_OUTPUT_DIR = MAPS_OUTPUT_DIR / "m5_comparacion"
+
+# ---------------------------------------------------------------------------
+# Coordenadas de referencia
+# ---------------------------------------------------------------------------
+DEPOT_LAT = -4.906564
+DEPOT_LON = -80.728434
+DEPOT_NAME = "ALMACEN CENTRAL DSRSLCC"
+
+# Bounding box para descarga de red vial OSMnx (Piura ampliada)
+PIURA_BBOX_NORTH = -3.5
+PIURA_BBOX_SOUTH = -5.5
+PIURA_BBOX_EAST = -79.0
+PIURA_BBOX_WEST = -82.0
+
+# Bounding box acotada para la zona de estudio (Sullana y alrededores)
+STUDY_BBOX_NORTH = -4.2
+STUDY_BBOX_SOUTH = -5.2
+STUDY_BBOX_EAST = -79.3
+STUDY_BBOX_WEST = -81.0
+
+# CRS
+CRS_WGS84 = "EPSG:4326"
+CRS_UTM17S = "EPSG:32717"
+
+# ---------------------------------------------------------------------------
+# Paleta de colores por tipo de vehículo
+# ---------------------------------------------------------------------------
+VEHICLE_COLORS = {
+    "FUSO Canter 6T": "#2980B9",
+    "NLR 3.5 TON": "#27AE60",
+    "Toyota Hilux": "#C0392B",
+    "Fiat Ducato Refrigerada": "#F39C12",
+    "V1_FUSO_CANTER": "#2980B9",
+    "V2_FIAT_DUCATO": "#F39C12",
+    "V3_NLR_35T": "#27AE60",
+    "V4_TOYOTA_HILUX": "#C0392B",
+}
+
+VEHICLE_SHORT_LABELS = {
+    "V1_FUSO_CANTER": "FUSO Canter",
+    "V2_FIAT_DUCATO": "Fiat Ducato",
+    "V3_NLR_35T": "NLR 3.5T",
+    "V4_TOYOTA_HILUX": "Toyota Hilux",
+}
+
+# ---------------------------------------------------------------------------
+# Colores por categoría de IPRESS
+# ---------------------------------------------------------------------------
+IPRESS_COLORS = {
+    "CENTRO DE SALUD": "#2471A3",
+    "PUESTO DE SALUD": "#27AE60",
+}
+IPRESS_MARKERS = {
+    "CENTRO DE SALUD": "s",   # cuadrado
+    "PUESTO DE SALUD": "o",   # círculo
+}
+
+# ---------------------------------------------------------------------------
+# Niveles de fragilidad
+# ---------------------------------------------------------------------------
+FRAGILITY_LEVELS = {
+    "alto": {"threshold": 0.9, "color": "#C0392B", "linewidth": 5},
+    "medio": {"threshold": 0.7, "color": "#E74C3C", "linewidth": 4},
+    "bajo": {"threshold": 0.0, "color": "#27AE60", "linewidth": 2},
+}
+
+# ---------------------------------------------------------------------------
+# Estilos de mapa
+# ---------------------------------------------------------------------------
+TILE_CARTODB_POSITRON = "CartoDB positron"
+TILE_OSM = "OpenStreetMap"
+FOLIUM_TILES = TILE_CARTODB_POSITRON
+
+# ---------------------------------------------------------------------------
+# Estilos académicos para Matplotlib
+# ---------------------------------------------------------------------------
+ACADEMIC_STYLE = {
+    "font.family": "serif",
+    "font.serif": ["DejaVu Serif", "Times New Roman", "serif"],
+    "font.size": 10,
+    "axes.titlesize": 12,
+    "axes.labelsize": 10,
+    "xtick.labelsize": 8,
+    "ytick.labelsize": 8,
+    "legend.fontsize": 8,
+    "figure.dpi": 150,
+    "savefig.dpi": 300,
+    "savefig.bbox": "tight",
+    "savefig.pad_inches": 0.1,
+}
+
+# ---------------------------------------------------------------------------
+# Exportación
+# ---------------------------------------------------------------------------
+EXPORT_DPI = 300
+EXPORT_PNG_SIZE = (1600, 1200)  # píxeles
+FIGURE_FIGSIZE = (14, 10)      # pulgadas
+
+# ---------------------------------------------------------------------------
+# Clustering
+# ---------------------------------------------------------------------------
+N_CLUSTERS = 5
+RANDOM_SEED = 42
+
+# ---------------------------------------------------------------------------
+# Metadatos para títulos de figuras de la tesis
+# ---------------------------------------------------------------------------
+FIGURE_TITLES = {
+    "M1": "Figura M1. Red vial real y localización de IPRESS – DSRSLCC Sullana",
+    "M2": "Figura M2. Rutas baseline HVRPTW sobre red vial real",
+    "M3": "Figura M3. Fragilidad espacial de rutas operacionales críticas",
+    "M4": "Figura M4. Variabilidad vial de tiempos de viaje",
+    "M5": "Figura M5. Comparación espacial de escenarios de reconfiguración de flota",
+}
diff --git a/src/maps_osm/data_loader.py b/src/maps_osm/data_loader.py
new file mode 100644
index 00000000..8278b209
--- /dev/null
+++ b/src/maps_osm/data_loader.py
@@ -0,0 +1,90 @@
+"""
+Carga de datos existentes del proyecto HVRPTW para visualizaciones cartográficas.
+
+Lee los archivos CSV del directorio analytics/ y results/ y devuelve
+DataFrames listos para el análisis geoespacial.
+"""
+
+import pandas as pd
+
+from . import config as cfg
+
+
+def load_nodes() -> pd.DataFrame:
+    """Cargar nodos IPRESS con coordenadas (81 establecimientos)."""
+    df = pd.read_csv(cfg.NODES_CSV)
+    df["latitude"] = df["latitude"].astype(float)
+    df["longitude"] = df["longitude"].astype(float)
+    return df
+
+
+def load_arcs() -> pd.DataFrame:
+    """Cargar matriz OD con variabilidad de tiempos de viaje."""
+    return pd.read_csv(cfg.ARCS_CSV)
+
+
+def load_vehicles() -> pd.DataFrame:
+    """Cargar flota heterogénea (4 tipos de vehículo)."""
+    return pd.read_csv(cfg.VEHICLES_CSV)
+
+
+def load_baseline_routes() -> pd.DataFrame:
+    """Cargar rutas baseline del solver determinista."""
+    return pd.read_csv(cfg.BASELINE_ROUTES_CSV)
+
+
+def load_stochastic_kpis() -> pd.DataFrame:
+    """Cargar KPIs estocásticos de Monte Carlo."""
+    return pd.read_csv(cfg.STOCHASTIC_KPIS_CSV)
+
+
+def load_capacity_experiments() -> pd.DataFrame:
+    """Cargar resultados de experimentos de capacidad."""
+    return pd.read_csv(cfg.CAPACITY_EXPERIMENTS_CSV)
+
+
+def get_depot_row() -> dict:
+    """Retorna diccionario con coordenadas y nombre del depósito."""
+    return {
+        "node_id": "DEPOT_DSRSLCC",
+        "nombre": cfg.DEPOT_NAME,
+        "latitude": cfg.DEPOT_LAT,
+        "longitude": cfg.DEPOT_LON,
+        "categoria": "DEPOSITO",
+    }
+
+
+def get_route_summary(routes: pd.DataFrame) -> pd.DataFrame:
+    """Resumen por ruta: vehículo, distancia, carga, utilización."""
+    first_stops = routes[routes["stop_sequence"] == 0].copy()
+    summary = first_stops[
+        [
+            "route_id",
+            "vehicle_id",
+            "vehicle_name",
+            "capacity_kg",
+            "route_distance_km",
+            "route_load_kg",
+            "utilization_pct",
+        ]
+    ].copy()
+    summary["route_distance_km"] = pd.to_numeric(
+        summary["route_distance_km"], errors="coerce"
+    )
+    summary["route_load_kg"] = pd.to_numeric(
+        summary["route_load_kg"], errors="coerce"
+    )
+    summary["utilization_pct"] = pd.to_numeric(
+        summary["utilization_pct"], errors="coerce"
+    )
+    return summary.reset_index(drop=True)
+
+
+def build_node_lookup(nodes: pd.DataFrame) -> dict:
+    """Diccionario node_id → (lat, lon) incluyendo depósito."""
+    lookup: dict[str, tuple[float, float]] = {}
+    for _, row in nodes.iterrows():
+        nid = str(row["node_id"])
+        lookup[nid] = (row["latitude"], row["longitude"])
+    lookup["DEPOT_DSRSLCC"] = (cfg.DEPOT_LAT, cfg.DEPOT_LON)
+    return lookup
