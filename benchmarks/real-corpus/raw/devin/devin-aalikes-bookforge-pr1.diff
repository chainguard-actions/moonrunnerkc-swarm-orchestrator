+        metadata = { ...metadata, ...parsed.metadata };
+        if (parsed.coverPath) {
+          metadata.cover_path = parsed.coverPath;
+        }
+      } catch (parseErr) {
+        console.warn('EPUB parse warning:', parseErr.message);
+      }
+    }
+
+    const bookId = uuidv4();
