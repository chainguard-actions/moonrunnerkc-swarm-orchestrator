+      const chapters = await epubParser.getChapters(book.file_path);
+      if (chapter_index !== undefined && chapters[chapter_index]) {
+        text = chapters[chapter_index].content;
+      } else {
+        text = chapters.map(c => c.content).join('\n\n');
