+}
+.integration-card[data-integration="notion"]::before {
+  background: linear-gradient(90deg, #000, #444);
+}
+.integration-card[data-integration="github"]::before {
+  background: linear-gradient(90deg, #333, #666);
+}
+.integration-card[data-integration="obsidian"]::before {
+  background: linear-gradient(90deg, #7c3aed, #a78bfa);
+}
+
+.integration-header {
+  display: flex;
+  align-items: center;
+  gap: 1rem;
+  margin-bottom: 1rem;
+}
+
+.integration-icon {
