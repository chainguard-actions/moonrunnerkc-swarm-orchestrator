+  height: 44px;
+  border-radius: var(--radius-sm);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  font-weight: 800;
+  font-size: 1.15rem;
+  flex-shrink: 0;
+  box-shadow: var(--shadow-sm);
+}
+
+.readwise-icon { background: linear-gradient(135deg, #5C3D2E, #7a5040); color: #FCA311; }
+.notion-icon { background: #fff; color: #000; }
+.github-icon { background: linear-gradient(135deg, #24292e, #444); color: #fff; }
+.obsidian-icon { background: linear-gradient(135deg, #7c3aed, #6d28d9); color: #fff; }
+
+.integration-header h3 {
+  font-size: 1rem;
+  font-weight: 700;
+  margin-bottom: 0.15rem;
+}
+.integration-header p {
+  font-size: 0.78rem;
+  color: var(--text-muted);
+}
+
+.integration-status {
