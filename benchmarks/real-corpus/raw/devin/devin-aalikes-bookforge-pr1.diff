+      file_path: filePath,
+      file_name: req.file.originalname,
+      file_size: req.file.size,
+      format: ext.replace('.', '').toUpperCase()
+    });
+
+    res.json(book);
+  } catch (err) {
+    res.status(500).json({ error: err.message });
