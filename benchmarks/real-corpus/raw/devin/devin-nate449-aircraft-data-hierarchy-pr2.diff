+"""Parametrized tests for the validate_non_empty_string validator shared by
+Equipment, System, and Propulsion models."""
+
+import pytest
+from pydantic import ValidationError
+
+from aircraft_data_hierarchy.work_breakdown_structure.equipment import Equipment
+from aircraft_data_hierarchy.work_breakdown_structure.propulsion.propulsion import Propulsion
+from aircraft_data_hierarchy.work_breakdown_structure.systems.systems import System
+
+MODELS = [Equipment, System, Propulsion]
+FIELDS = ["name", "description"]
+
+EMPTY_VALUES = ["", " ", "   ", "\t", "\n", " \t\n "]
+
+
+@pytest.mark.parametrize("model_cls", MODELS, ids=lambda c: c.__name__)
+@pytest.mark.parametrize("field", FIELDS)
+class TestValidateNonEmptyString:
+    """Verify that name/description validators reject empty or whitespace-only
+    strings and accept valid values across Equipment, System, and Propulsion."""
+
+    @pytest.mark.parametrize("empty", EMPTY_VALUES, ids=repr)
+    def test_rejects_empty_or_whitespace(self, model_cls, field, empty):
+        with pytest.raises(
+            ValidationError,
+            match="Name and description fields must not be empty or whitespace only",
+        ):
+            model_cls(**{field: empty})
+
+    def test_accepts_none(self, model_cls, field):
+        obj = model_cls(**{field: None})
+        assert getattr(obj, field) is None
+
+    def test_accepts_valid_string(self, model_cls, field):
+        obj = model_cls(**{field: "Boeing 737"})
+        assert getattr(obj, field) == "Boeing 737"
