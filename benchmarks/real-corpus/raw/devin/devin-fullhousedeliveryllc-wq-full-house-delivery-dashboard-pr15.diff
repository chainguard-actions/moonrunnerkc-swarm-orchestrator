+    }).join('');
+}
+
+function addFinType() {
+    var input = document.getElementById('newFinTypeName');
+    var name = input.value.trim();
+    if (!name) return toast('Please enter a type name.');
+    if (financeTypes.some(function(t) { return t.toLowerCase() === name.toLowerCase(); })) return toast('Type already exists.');
+    financeTypes.push(name); input.value = '';
+    save(); renderFinanceTypes(); renderFinanceAll(); toast('Type "' + name + '" added!');
+}
+
+function removeFinType(i) {
+    var name = financeTypes[i];
+    if (!confirm('Remove "' + name + '"? Existing entries of this type will NOT be deleted.')) return;
+    financeTypes.splice(i, 1); save(); renderFinanceTypes(); renderFinanceAll();
+    toast('Type "' + name + '" removed.');
+}
+
+function moveFinType(i, dir) {
+    var j = i + dir;
