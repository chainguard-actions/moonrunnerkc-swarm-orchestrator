+            <div class="form-group">
+                <label for="rsvp-song">Song Request</label>
+                <input type="text" id="rsvp-song" name="song" placeholder="What song will get you on the dance floor?">
+            </div>
+            <div class="form-group">
+                <label for="rsvp-message">Message for the Couple</label>
+                <textarea id="rsvp-message" name="message" rows="4" placeholder="Share your well-wishes, travel plans, or a fun message!"></textarea>
+            </div>
+            <button type="submit" class="btn btn-primary btn-large">Send RSVP</button>
+        </form>
+        <div id="rsvp-success" class="rsvp-success" hidden>
