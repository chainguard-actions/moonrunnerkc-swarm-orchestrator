+    <div class="container">
+        <h2 class="section-subtitle">We Can't Wait to See You</h2>
+        <h3 class="section-title">RSVP</h3>
+        <p class="section-intro">Please let us know if you'll be joining us by <strong>August 1, 2026</strong>.</p>
+        <form id="rsvp-form" class="rsvp-form" novalidate>
+            <div class="form-row">
+                <div class="form-group">
+                    <label for="rsvp-name">Full Name <span class="required" aria-hidden="true">*</span></label>
+                    <input type="text" id="rsvp-name" name="name" required placeholder="Your full name" autocomplete="name">
+                    <span class="error-message" id="name-error" role="alert"></span>
+                </div>
+                <div class="form-group">
+                    <label for="rsvp-email">Email <span class="required" aria-hidden="true">*</span></label>
+                    <input type="email" id="rsvp-email" name="email" required placeholder="your@email.com" autocomplete="email">
+                    <span class="error-message" id="email-error" role="alert"></span>
+                </div>
+            </div>
+            <div class="form-row">
+                <div class="form-group">
+                    <label for="rsvp-attending">Will you be attending? <span class="required" aria-hidden="true">*</span></label>
+                    <select id="rsvp-attending" name="attending" required>
+                        <option value="">Please select...</option>
+                        <option value="yes">Joyfully Accepts</option>
+                        <option value="no">Regretfully Declines</option>
+                    </select>
+                    <span class="error-message" id="attending-error" role="alert"></span>
+                </div>
+                <div class="form-group">
+                    <label for="rsvp-guests">Number of Guests</label>
+                    <select id="rsvp-guests" name="guests">
+                        <option value="1">1</option>
+                        <option value="2">2</option>
+                        <option value="3">3</option>
+                        <option value="4">4</option>
+                    </select>
+                </div>
+            </div>
+            <div class="form-group">
+                <label for="rsvp-dietary">Dietary Restrictions</label>
+                <input type="text" id="rsvp-dietary" name="dietary" placeholder="Vegetarian, vegan, gluten-free, allergies, etc.">
+            </div>
+            <div class="form-group">
+                <label for="rsvp-events">Which events will you attend?</label>
+                <div class="checkbox-group">
+                    <label class="checkbox-label">
+                        <input type="checkbox" name="events" value="welcome-dinner"> Friday Welcome Dinner
+                    </label>
+                    <label class="checkbox-label">
+                        <input type="checkbox" name="events" value="ceremony"> Saturday Ceremony & Reception
+                    </label>
+                    <label class="checkbox-label">
+                        <input type="checkbox" name="events" value="brunch"> Sunday Farewell Brunch
+                    </label>
+                </div>
