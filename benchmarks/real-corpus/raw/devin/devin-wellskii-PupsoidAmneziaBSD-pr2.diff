+# Помощник для удаления клиента
+cat >/usr/local/sbin/amneziawg-remove-client <<'REMOVE_HELPER'
+#!/usr/bin/env bash
+# amneziawg-remove-client <client-name>  — удалить AmneziaWG-клиента
+set -Eeuo pipefail
+
+CLIENT_NAME="${1:-}"
+IFNAME="${IFNAME:-awg0}"
+[[ -n "$CLIENT_NAME" ]] || { echo "usage: $0 <client-name>" >&2; exit 1; }
+
+CONF_DIR="/etc/amnezia/amneziawg"
+CLIENTS_DIR="${CONF_DIR}/clients"
+SERVER_CONF="${CONF_DIR}/${IFNAME}.conf"
+CLIENT_CONF="${CLIENTS_DIR}/${CLIENT_NAME}.conf"
+
+[[ -s "$SERVER_CONF" ]] || { echo "Не нашёл $SERVER_CONF" >&2; exit 1; }
+[[ -s "$CLIENT_CONF" ]] || { echo "Не нашёл клиента $CLIENT_NAME ($CLIENT_CONF)" >&2; exit 2; }
+
+# Извлечь приватник клиента → получить публичный (для awg set ... remove)
+CLIENT_PRIV="$(awk -F'=' '/^PrivateKey[[:space:]]*=/ {sub(/^[[:space:]]+/,"",$2); print $2; exit}' "$CLIENT_CONF")"
+[[ -n "$CLIENT_PRIV" ]] || { echo "Не извлёк PrivateKey из $CLIENT_CONF" >&2; exit 1; }
+CLIENT_PUB="$(printf '%s' "$CLIENT_PRIV" | awg pubkey)"
+
+# Снять пира с live-интерфейса
+awg set "$IFNAME" peer "$CLIENT_PUB" remove
+
+# Удалить блок [Peer] из серверного .conf
+# Блок начинается с комментария "# <CLIENT_NAME>" и продолжается до пустой строки или EOF.
+python3 - "$SERVER_CONF" "$CLIENT_NAME" <<'PYEOF'
+import sys, re, pathlib
+path = pathlib.Path(sys.argv[1])
+name = sys.argv[2]
+lines = path.read_text().splitlines(keepends=True)
+out = []
+i = 0
+while i < len(lines):
+    if lines[i].strip() == f"# {name}":
+        # пропустить блок: # name, [Peer], PublicKey/PresharedKey/AllowedIPs до первой пустой строки
+        i += 1
+        while i < len(lines) and lines[i].strip() != "":
+            i += 1
+        # пропустить и пустую строку-разделитель
+        if i < len(lines) and lines[i].strip() == "":
+            i += 1
+        continue
+    out.append(lines[i])
+    i += 1
+path.write_text("".join(out))
+PYEOF
+
+# Удалить файл профиля
+rm -f "$CLIENT_CONF"
+
+echo "Клиент удалён: $CLIENT_NAME"
+echo "    Pubkey: $CLIENT_PUB"
+echo "    Файл:   $CLIENT_CONF (удалён)"
+echo "    Сервер: $SERVER_CONF (блок [Peer] удалён)"
+REMOVE_HELPER
+chmod +x /usr/local/sbin/amneziawg-remove-client
+ok "Создан помощник: /usr/local/sbin/amneziawg-remove-client"
+
 # Если клиента ещё нет — создаём дефолтного
 if [[ ! -f "$CLIENT_CONF" ]]; then
     step "Создание первого клиента: ${CLIENT_NAME}"
