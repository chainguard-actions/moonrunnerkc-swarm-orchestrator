+function handleChimeCSV(event) {
+    var file = event.target.files[0];
+    if (!file) return;
+    var reader = new FileReader();
+    reader.onload = function() {
+        try {
+            parseChimeCSV(reader.result);
+        } catch (err) {
+            toast('Error parsing Chime CSV: ' + err.message, true);
+        }
+    };
+    reader.readAsText(file);
+    event.target.value = '';
+}
+
+function parseChimeCSV(csvText) {
+    var lines = csvText.split(/\r?\n/).filter(function(l) { return l.trim().length > 0; });
+    if (lines.length < 2) { toast('CSV file appears empty.'); return; }
+
+    var headers = parseCSVLine(lines[0]);
+    var dateCol = -1, descCol = -1, amountCol = -1, balanceCol = -1;
+
+    headers.forEach(function(h, i) {
+        var lc = h.toLowerCase().replace(/[^a-z0-9]/g, '');
+        if (dateCol === -1 && /date|transactiondate|postdate/.test(lc)) dateCol = i;
+        if (descCol === -1 && /description|desc|memo|details|merchant|name/.test(lc)) descCol = i;
+        if (amountCol === -1 && /^(amount|transactionamount|amt)$/.test(lc)) amountCol = i;
+        if (balanceCol === -1 && /balance/.test(lc)) balanceCol = i;
+    });
+    if (dateCol === -1) dateCol = 0;
+    if (amountCol === -1) {
+        for (var j = 0; j < headers.length; j++) {
+            if (j !== dateCol && j !== descCol && j !== balanceCol) { amountCol = j; break; }
+        }
+    }
+
+    var imported = 0;
+    for (var i = 1; i < lines.length; i++) {
+        var fields = parseCSVLine(lines[i]);
+        if (fields.length < 2) continue;
+        var dateStr = parseDate(fields[dateCol]);
+        if (!dateStr) continue;
+        var desc = descCol !== -1 ? (fields[descCol] || '').trim() : '';
+        var amt = parseAmount(fields[amountCol]);
+        if (amt === null || amt === 0) continue;
+        var isDeposit = amt > 0;
+        chimeEntries.push({
+            id: Date.now() + Math.floor(Math.random() * 10000) + i,
+            date: dateStr,
+            type: isDeposit ? 'Deposit' : 'Withdrawal',
+            amount: Math.abs(amt),
+            description: desc.substring(0, 80) || 'Chime Transaction'
+        });
+        imported++;
+    }
+
+    if (imported === 0) { toast('No valid transactions found in the Chime CSV.'); return; }
+    saveChime(); saveLocal(); renderChimeAll();
+    toast(imported + ' Chime transactions imported!');
+}
