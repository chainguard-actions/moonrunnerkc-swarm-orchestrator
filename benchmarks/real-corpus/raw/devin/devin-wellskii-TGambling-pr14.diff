+"""Классификатор `domain_kind` для доменов в реестре (v0.10.6).
+
+В отличие от модуля :mod:`tgambling.noise`, который отвечает на вопрос
+«мусор ли это домен» (бинарный is_noise), модуль `kind` отвечает на более
+тонкий вопрос: **какую роль** этот домен играет в casino-pipeline.
+
+Категории:
+
+- ``backend`` — реальный сервер казино (игралка прямо на этом домене).
+  Это то, что должно попадать в ``/export/casinos.txt``. Признаки:
+  is_noise=0, title содержит casino/bet/слот/etc, final_url-host
+  совпадает с собственным хостом ИЛИ редирект на близкий поддомен.
+
+- ``landing`` — **landing-dispatcher** (раздатчик зеркал). HTML
+  страницы вида «X Official Site - working mirror, play online without
+  registration…», с одной CTA-кнопкой ведущей JS-редиректом на другой
+  backend. Сам по себе **не казино**, но полезен как источник новых
+  mirror'ов (см. v0.10.7 — Playwright mirror getter). Идёт в
+  ``/export/dispatchers.txt``. Признаки: title содержит
+  «working mirror», «official site», «play online», «registration
+  bonus», но домен **не** noise.
+
+- ``affiliate`` — CPA-редиректор на регистрацию казино с partner-id
+  (qtag=, registration?id=, и т.п.). Дублируется ``is_noise=1`` с
+  reason='affiliate-redirector'.
+
+- ``shortener`` — URL-сокращалка (bit.ly, clck.ru, …). Дублируется
+  ``is_noise=1`` с reason='url-shortener'.
+
+- ``staging`` — заготовка нерасчехлённого mirror'а (host *-blrs/*-way/…,
+  title='Welcome'). Дублируется ``is_noise=1`` с reason='mirror-staging'.
+
+- ``noise`` — общий «мусор» (not-casino-domain, refpa, dev-tool,
+  tracker-panel, generic-landing, bitly-custom). Все они уже
+  ``is_noise=1``, но более специфичной роли в pipeline у них нет.
+
+- ``None`` — не классифицирован (старая запись без http-check'а / или
+  edge-case вне известных паттернов).
+
+Хранение — в ``domains.domain_kind``. Заполнение — в
+:func:`tgambling.storage.backfill_domain_kind` после backfill_noise.
+
+Использование в экспортах:
+- ``/export/casinos.txt``    — только kind='backend' (+ NULL для legacy).
+- ``/export/dispatchers.txt`` — только kind='landing'.
+- ``/clusters``               — все (с фильтрами).
+"""
+
+from __future__ import annotations
+
+import re
+
+# ---------------------------------------------------------------------------
+# Title-сигналы landing-dispatcher'а.
+# ---------------------------------------------------------------------------
+
+# Шаблон «X Official Site - working mirror, play online without registration»
+# используется бесчисленным количеством раздатчиков (Blitz, Bounty, Vavada-mirror,
+# Selector, Friends, Bitzamo, Bounty-casino, и т.п.). Один из самых сильных
+# title-сигналов «это не сам сервер, это раздатчик».
+_LANDING_TITLE_RE = re.compile(
+    r"(?:"
+    r"\bofficial\s+site\b.{0,80}\bworking\s+mirror\b"   # …Official Site - working mirror
+    r"|\bworking\s+mirror\b.{0,80}\bplay\s+online\b"    # …working mirror, play online…
+    r"|\bplay\s+(?:online|now)\s+without\s+registration\b"
+    r"|\bget\s+(?:your|the)\s+(?:bonus|mirror)\b"
+    r"|\b(?:актуальное|рабочее|официальное)\s+зеркало\b"  # рус-вариант
+    r")",
+    re.IGNORECASE,
+)
+
+# Доп. fallback: title содержит и «mirror», и одно из «bonus/registration/play».
+_LANDING_TITLE_FALLBACK_RE = re.compile(
+    r"\bmirror\b.{0,80}\b(?:bonus|registration|play\s+(?:now|online))\b",
+    re.IGNORECASE,
+)
+
+
+def _host_of(url: str | None) -> str | None:
+    """Достать host из URL без urlparse (защита от мусорных строк)."""
+    if not url:
+        return None
+    s = url.strip().lower()
+    if s.startswith("http://"):
+        s = s[7:]
+    elif s.startswith("https://"):
+        s = s[8:]
+    # Дроп user-info / port / path / query / fragment.
+    for sep in ("/", "?", "#"):
+        idx = s.find(sep)
+        if idx != -1:
+            s = s[:idx]
+    if "@" in s:
+        s = s.split("@", 1)[1]
+    if ":" in s:
+        s = s.split(":", 1)[0]
+    return s or None
+
+
+def _strip_www(host: str | None) -> str | None:
+    if not host:
+        return None
+    if host.startswith("www."):
+        return host[4:]
+    return host
+
+
+def _registrable(host: str | None) -> str | None:
+    """Грубая аппроксимация registrable-домена.
+
+    Берёт последние два компонента (без TLD-suffix-маппинга). Достаточно
+    для целей сравнения «final_url-host тот же бренд, что domain».
+    """
+    h = _strip_www(host)
+    if not h:
+        return None
+    parts = h.split(".")
+    if len(parts) < 2:
+        return h
+    return ".".join(parts[-2:])
+
+
+def classify_domain_kind(
+    *,
+    domain: str,
+    title: str | None,
+    final_url: str | None,
+    is_noise: bool,
+    noise_reason: str | None,
+) -> str | None:
+    """Определить `domain_kind` для одного домена.
+
+    Args:
+        domain: e2LD домен (нормализованный, lowercase).
+        title: ``http_title`` из http-check.
+        final_url: ``http_final_url`` из http-check.
+        is_noise: текущий флаг is_noise (для маппинга noise_reason → kind).
+        noise_reason: текущий reason (источник для shortener/affiliate/staging
+            под-категорий).
+
+    Returns:
+        Одна из: ``"backend"``, ``"landing"``, ``"affiliate"``,
+        ``"shortener"``, ``"staging"``, ``"noise"``, либо ``None`` (если
+        домен не дочекан / нет ни одного сигнала).
+    """
+    if not domain:
+        return None
+    # Шум-домены: разводим по reason → конкретный kind. is_noise=1 без
+    # reason — общий "noise".
+    if is_noise:
+        if noise_reason == "url-shortener":
+            return "shortener"
+        if noise_reason == "affiliate-redirector":
+            return "affiliate"
+        if noise_reason == "mirror-staging":
+            return "staging"
+        # Прочие noise-категории (not-casino, refpa-affiliate, dev-tool,
+        # tracker-panel, generic-landing, bitly-custom) — общий "noise".
+        return "noise"
+    # Без HTTP-check'а классифицировать нечего.
+    if not title and not final_url:
+        return None
+    # Landing-dispatcher: title-маркеры. Самый сильный сигнал — фраза
+    # «Official Site - working mirror» (для blitz/bounty/vavada-landing'ов).
+    if title:
+        t = title.strip()
+        if t:
+            if _LANDING_TITLE_RE.search(t):
+                return "landing"
+            if _LANDING_TITLE_FALLBACK_RE.search(t):
+                return "landing"
+    # Иначе — backend (это alive non-noise non-landing домен).
+    return "backend"
