+"""Тесты для классификатора `domain_kind` (v0.10.6, `tgambling.kind`)."""
+
+from __future__ import annotations
+
+from tgambling.kind import classify_domain_kind
+
+# ---- noise-маппинг → kind ---------------------------------------------------
+
+
+def test_kind_shortener_from_noise() -> None:
+    """is_noise=True + reason='url-shortener' → kind='shortener'."""
+    k = classify_domain_kind(
+        domain="bit.ly",
+        title=None,
+        final_url=None,
+        is_noise=True,
+        noise_reason="url-shortener",
+    )
+    assert k == "shortener"
+
+
+def test_kind_affiliate_from_noise() -> None:
+    k = classify_domain_kind(
+        domain="aff.com",
+        title=None,
+        final_url=None,
+        is_noise=True,
+        noise_reason="affiliate-redirector",
+    )
+    assert k == "affiliate"
+
+
+def test_kind_staging_from_noise() -> None:
+    k = classify_domain_kind(
+        domain="x-blrs.com",
+        title=None,
+        final_url=None,
+        is_noise=True,
+        noise_reason="mirror-staging",
+    )
+    assert k == "staging"
+
+
+def test_kind_generic_noise() -> None:
+    """is_noise=True + reason='not-casino' → kind='noise' (общая ветка)."""
+    k = classify_domain_kind(
+        domain="apple.com",
+        title=None,
+        final_url=None,
+        is_noise=True,
+        noise_reason="not-casino",
+    )
+    assert k == "noise"
+
+
+def test_kind_generic_landing_noise() -> None:
+    """is_noise=True + reason='generic-landing' → 'noise'."""
+    k = classify_domain_kind(
+        domain="redir.example.com",
+        title="Redirecting...",
+        final_url=None,
+        is_noise=True,
+        noise_reason="generic-landing",
+    )
+    assert k == "noise"
+
+
+# ---- landing-dispatcher ----------------------------------------------------
+
+
+def test_kind_landing_working_mirror_title() -> None:
+    """`X Official Site - working mirror` → landing-dispatcher."""
+    k = classify_domain_kind(
+        domain="blitz-casino.cc",
+        title="Blitz Official Site - working mirror, play online",
+        final_url="https://blitz-casino.cc/ru",
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "landing"
+
+
+def test_kind_landing_play_without_registration() -> None:
+    k = classify_domain_kind(
+        domain="bounty-casino.life",
+        title="Bounty Casino — play online without registration",
+        final_url="https://bounty-casino.life/",
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "landing"
+
+
+def test_kind_landing_russian_mirror() -> None:
+    """Русские раздатчики: 'актуальное зеркало' / 'рабочее зеркало'."""
+    k = classify_domain_kind(
+        domain="vavada-mirror.com",
+        title="Vavada — актуальное зеркало",
+        final_url=None,
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "landing"
+
+
+def test_kind_landing_mirror_bonus_fallback() -> None:
+    """Fallback: title содержит 'mirror' И 'bonus'/'registration'."""
+    k = classify_domain_kind(
+        domain="some-mirror.com",
+        title="Get your mirror with registration bonus",
+        final_url=None,
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "landing"
+
+
+# ---- backend (real casino) -------------------------------------------------
+
+
+def test_kind_backend_simple() -> None:
+    """Обычный alive-домен с title и без landing-маркеров — backend."""
+    k = classify_domain_kind(
+        domain="vavada.com",
+        title="Vavada Casino — лучшие слоты",
+        final_url="https://vavada.com/",
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "backend"
+
+
+def test_kind_backend_no_title() -> None:
+    """final_url есть, title пустой — всё равно backend (нет landing-маркера)."""
+    k = classify_domain_kind(
+        domain="kazinovavada5.ru",
+        title=None,
+        final_url="https://kazinovavada5.ru/",
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k == "backend"
+
+
+# ---- edge cases ------------------------------------------------------------
+
+
+def test_kind_no_data_returns_none() -> None:
+    """Домен без title и final_url, не noise — нечего классифицировать."""
+    k = classify_domain_kind(
+        domain="unknown.com",
+        title=None,
+        final_url=None,
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k is None
+
+
+def test_kind_empty_domain() -> None:
+    k = classify_domain_kind(
+        domain="",
+        title="anything",
+        final_url=None,
+        is_noise=False,
+        noise_reason=None,
+    )
+    assert k is None
