+# v0.10.6: affiliate-redirector regex.
+# Применяется к ``http_final_url`` (final URL после редиректа). Если final-URL
+# содержит характерные параметры партнёрских CPA-трекеров — это **не казино**,
+# а реф-лендинг с partner-id, и его надо схлопывать в шум.
+#
+# Сигналы:
+#  - ``qtag=`` — Leon/Twin affiliate (`?qtag=a6004_t52294_…`).
+#  - ``registration?id=`` — BetWinner affiliate (`/registration/?id=18RM`).
+#  - ``/RJVV...?source=`` — aeclick.top tracker.
+#  - ``/nba/?p=%2Fregistration%2F`` — BetWinner альтернативный.
+#  - ``cid=\d+&pid=\d+`` — Mostbet/Avlpjfmb affiliate.
+#  - ``?registration=1&cid=`` — Mostbet прямой affiliate-параметр.
+#  - ``aeclick.top`` / ``laidtoday.net/tds/`` — known CPA hosts.
+_AFFILIATE_REDIRECTOR_RE = re.compile(
+    r"(\bqtag=|/registration\?id=|/RJVV[A-Za-z0-9]+|/nba/\?p=%2F"
+    r"|cid=\d+&pid=\d+|\?registration=1&cid=|aeclick\.top|laidtoday\.net/tds/)",
+    re.IGNORECASE,
+)
