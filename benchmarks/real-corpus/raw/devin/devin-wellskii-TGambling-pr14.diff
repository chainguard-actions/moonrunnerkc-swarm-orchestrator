+# ---- v0.10.6: /export/dispatchers.txt + landing exclusion ----------------
+
+
+def _populate_with_landing(tmp_path: Path) -> Path:
+    """БД с: 1 backend-кластер ×2 + 1 landing-кластер ×2."""
+    db = tmp_path / "export_dispatchers.db"
+    init_db(db)
+    with connect(db) as conn:
+        # Backend ×2 (через title-кластеризацию)
+        for d in ("vavada-1.com", "vavada-2.com"):
+            record_domain_seen(conn, domain=d, increment=10)
+        conn.execute(
+            "UPDATE domains SET http_status='alive', http_title='UNIQUEBRAND',"
+            " domain_kind='backend'"
+            " WHERE domain IN ('vavada-1.com','vavada-2.com')"
+        )
+        # Landing-dispatcher ×2 (общий title 'working mirror')
+        for d in ("blitz-casino.cc", "bounty-casino.life"):
+            record_domain_seen(conn, domain=d, increment=10)
+        conn.execute(
+            "UPDATE domains SET http_status='alive',"
+            " http_title='Casino Official Site - working mirror SHAREDTITLE',"
+            " domain_kind='landing'"
+            " WHERE domain IN ('blitz-casino.cc','bounty-casino.life')"
+        )
+    return db
+
+
+def test_export_dispatchers_txt_basic(tmp_path: Path) -> None:
+    """Endpoint доступен, возвращает только landing-кластеры."""
+    from fastapi.testclient import TestClient
+
+    from tgambling.web.app import create_app
+
+    db = _populate_with_landing(tmp_path)
+    c = TestClient(create_app(db_path=db))
+    r = c.get("/export/dispatchers.txt")
+    assert r.status_code == 200, r.text
+    assert 'filename="dispatchers.txt"' in r.headers["content-disposition"]
+    body = r.text
+    assert body.startswith("# tgambling /export/dispatchers.txt")
+    rows = [ln for ln in body.splitlines() if not ln.startswith("#") and ln.strip()]
+    # Должен быть один кластер landing-доменов (склеились по title).
+    assert len(rows) >= 1
+    # Vavada (backend) — НЕ в выдаче dispatchers.
+    assert "vavada-1.com" not in body
+    assert "vavada-2.com" not in body
+    # Landing-домен — в выдаче.
+    assert "blitz-casino.cc" in body or "bounty-casino.life" in body
+
+
+def test_export_casinos_excludes_landing(tmp_path: Path) -> None:
+    """/export/casinos.txt НЕ показывает landing-dispatcher'ы (v0.10.6)."""
+    from fastapi.testclient import TestClient
+
+    from tgambling.web.app import create_app
+
+    db = _populate_with_landing(tmp_path)
+    c = TestClient(create_app(db_path=db))
+    r = c.get("/export/casinos.txt")
+    assert r.status_code == 200
+    body = r.text
+    assert "blitz-casino.cc" not in body
+    assert "bounty-casino.life" not in body
+    # Backend остаётся.
+    assert "vavada-1.com" in body or "vavada-2.com" in body
+
+
