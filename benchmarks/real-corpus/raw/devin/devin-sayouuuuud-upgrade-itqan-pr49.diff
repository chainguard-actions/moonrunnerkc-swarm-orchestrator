+                    : isAr
+                      ? "أفضل إجابة"
+                      : "Mark best"}
+                </button>
+              )}
+
+              {canDelete && (
+                <button
+                  onClick={removeReply}
+                  className="inline-flex items-center gap-1 rounded-md px-1.5 py-1 text-rose-500 hover:bg-rose-500/10"
