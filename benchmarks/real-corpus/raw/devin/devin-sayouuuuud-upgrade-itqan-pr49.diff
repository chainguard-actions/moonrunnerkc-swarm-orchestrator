+                  {isAr ? "رد" : "Reply"}
+                </button>
+              )}
+
+              {canSelectBestAnswer && !node.parent_reply_id && (
+                <button
+                  onClick={toggleBest}
+                  className={`inline-flex items-center gap-1 rounded-md px-1.5 py-1 transition-colors ${
+                    node.is_best_answer
+                      ? "text-emerald-600"
+                      : "text-muted-foreground hover:bg-muted"
+                  }`}
+                >
+                  <CheckCircle2 className="w-3.5 h-3.5" />
+                  {node.is_best_answer
+                    ? isAr
+                      ? "إلغاء"
