+def _format_sap_error(exc: Exception) -> str:
+    """Return a human-readable message for any SAP-related exception."""
+    import httpx as _httpx
+
+    exc_str = str(exc)
+    exc_type = type(exc).__name__
+
+    if isinstance(exc, (_httpx.TimeoutException,)) or "timeout" in exc_str.lower() or "timed out" in exc_str.lower():
+        return (
+            "SAP system did not respond within the timeout period. "
+            "The system may be overloaded, unreachable, or processing a large request. "
+            "Try again or check SAP system availability."
+        )
+    if isinstance(exc, (_httpx.ConnectError,)) or "connect" in exc_str.lower() and "refused" in exc_str.lower():
+        return (
+            "Cannot connect to SAP system. "
+            "Check that the hostname, port, and network are correct and the system is running."
+        )
+    if "TABLE_WITHOUT_DATA" in exc_str:
+        return "The requested SAP table contains no data for the given filter criteria."
+    if "403" in exc_str or "Forbidden" in exc_str:
+        return (
+            "Access denied (HTTP 403). Check user authorizations and ensure the required "
+            "ICF service is activated in transaction SICF."
+        )
+    if "404" in exc_str or "Not Found" in exc_str:
+        return (
+            "Endpoint not found (HTTP 404). The requested SAP service or object may not exist "
+            "or the ICF service may not be activated."
+        )
+    if "401" in exc_str or "Unauthorized" in exc_str:
+        return "Authentication failed (HTTP 401). Check SAP system credentials."
+
+    detail = exc_str[:500] if exc_str else exc_type
+    return f"SAP system error: {detail}"
+
+
