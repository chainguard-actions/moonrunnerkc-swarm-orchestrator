@@ -0,0 +1,132 @@
+"use client";
+
+import Link from "next/link";
+import { ArrowLeft, ClipboardList } from "lucide-react";
+import { useOrders } from "@/context/OrderContext";
+import { Order } from "@/types";
+
+const statusOptions: Order["status"][] = [
+  "pendiente",
+  "preparando",
+  "listo",
+  "entregado",
+];
+
+const statusColors: Record<Order["status"], string> = {
+  pendiente: "bg-orange-100 text-orange-700",
+  preparando: "bg-blue-100 text-blue-700",
+  listo: "bg-green-100 text-green-700",
+  entregado: "bg-gray-100 text-gray-700",
+};
+
+export default function AdminOrdersPage() {
+  const { orders, updateOrderStatus } = useOrders();
+
+  if (orders.length === 0) {
+    return (
+      <div className="min-h-[60vh] flex flex-col items-center justify-center px-4 bg-gray-50">
+        <ClipboardList className="w-20 h-20 text-[var(--accent-light)] mb-6" />
+        <h1 className="text-2xl font-bold text-[var(--primary-dark)] mb-3">
+          No hay pedidos
+        </h1>
+        <p className="text-[var(--primary-light)] mb-6">
+          Los pedidos aparecer\u00e1n aqu\u00ed cuando los clientes ordenen
+        </p>
+        <Link href="/admin" className="btn-secondary inline-flex items-center gap-2">
+          <ArrowLeft className="w-4 h-4" />
+          Volver al panel
+        </Link>
+      </div>
+    );
+  }
+
+  return (
+    <div className="min-h-screen py-8 md:py-12 bg-gray-50">
+      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
+        <div className="flex items-center gap-4 mb-8">
+          <Link
+            href="/admin"
+            className="p-2 rounded-xl hover:bg-[var(--cream)] transition-colors"
+          >
+            <ArrowLeft className="w-5 h-5 text-[var(--primary)]" />
+          </Link>
+          <div>
+            <h1 className="text-3xl font-bold text-[var(--primary-dark)]">
+              Gestionar Pedidos
+            </h1>
+            <p className="text-[var(--primary-light)]">
+              {orders.length} pedidos registrados
+            </p>
+          </div>
+        </div>
+
+        <div className="space-y-4">
+          {orders.map((order) => (
+            <div key={order.id} className="card p-6">
+              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
+                <div>
+                  <h3 className="font-bold text-[var(--primary-dark)] text-lg">
+                    {order.id}
+                  </h3>
+                  <p className="text-sm text-[var(--primary-light)]">
+                    {order.customerName} \u2022 {order.customerPhone}
+                  </p>
+                  <p className="text-xs text-[var(--primary-light)]">
+                    {new Date(order.date).toLocaleDateString("es-MX", {
+                      year: "numeric",
+                      month: "long",
+                      day: "numeric",
+                      hour: "2-digit",
+                      minute: "2-digit",
+                    })}
+                  </p>
+                </div>
+                <div className="flex flex-col sm:flex-row items-start sm:items-center gap-3">
+                  <select
+                    value={order.status}
+                    onChange={(e) =>
+                      updateOrderStatus(
+                        order.id,
+                        e.target.value as Order["status"]
+                      )
+                    }
+                    className={`px-4 py-2 rounded-xl border-2 border-[var(--accent-light)] font-semibold text-sm focus:outline-none focus:border-[var(--primary)] capitalize ${
+                      statusColors[order.status]
+                    }`}
+                  >
+                    {statusOptions.map((status) => (
+                      <option key={status} value={status} className="capitalize">
+                        {status}
+                      </option>
+                    ))}
+                  </select>
+                  <span className="text-xl font-bold text-[var(--primary)]">
+                    ${order.total}
+                  </span>
+                </div>
+              </div>
+
+              <div className="border-t border-[var(--accent-light)] pt-3">
+                <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
+                  {order.items.map((item) => (
+                    <div
+                      key={item.product.id}
+                      className="flex justify-between bg-[var(--cream)] rounded-lg px-3 py-2 text-sm"
+                    >
+                      <span className="text-[var(--primary-dark)]">
+                        {item.product.name}
+                      </span>
+                      <span className="font-semibold text-[var(--primary)]">
+                        x{item.quantity}
+                      </span>
+                    </div>
+                  ))}
+                </div>
+              </div>
+            </div>
+          ))}
+        </div>
+      </div>
+    </div>
+  );
+}
