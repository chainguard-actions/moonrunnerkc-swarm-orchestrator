+  Lock,
+} from "lucide-react";
+import { useLoyalty } from "@/context/LoyaltyContext";
+
+const levelConfig: Record<
+  string,
+  { color: string; bg: string; nextLevel: string; pointsNeeded: number }
+> = {
+  Bronce: {
+    color: "text-amber-700",
+    bg: "bg-amber-100",
+    nextLevel: "Plata",
+    pointsNeeded: 200,
+  },
+  Plata: {
+    color: "text-gray-500",
+    bg: "bg-gray-100",
+    nextLevel: "Oro",
+    pointsNeeded: 500,
+  },
+  Oro: {
+    color: "text-yellow-500",
+    bg: "bg-yellow-100",
+    nextLevel: "Diamante",
+    pointsNeeded: 1000,
+  },
+  Diamante: {
+    color: "text-cyan-500",
+    bg: "bg-cyan-100",
+    nextLevel: "",
+    pointsNeeded: 0,
+  },
+};
+
+export default function LoyaltyPage() {
+  const { loyalty, redeemReward } = useLoyalty();
+  const config = levelConfig[loyalty.level];
+  const progress =
+    config.pointsNeeded > 0
+      ? Math.min((loyalty.points / config.pointsNeeded) * 100, 100)
+      : 100;
+
+  return (
+    <div className="min-h-screen py-8 md:py-12">
+      <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
+        <h1 className="section-title mb-2">Programa de Lealtad</h1>
+        <p className="section-subtitle mb-10">
+          Acumula puntos, sube de nivel y disfruta de recompensas exclusivas
+        </p>
+
+        {/* Loyalty Card */}
+        <div className="gradient-bg rounded-3xl p-6 md:p-10 text-white mb-10 relative overflow-hidden">
+          <div className="absolute top-0 right-0 w-64 h-64 rounded-full bg-white/5 -translate-y-1/2 translate-x-1/2" />
