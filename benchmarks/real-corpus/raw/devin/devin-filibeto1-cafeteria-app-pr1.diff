+export interface Product {
+  id: string;
+  name: string;
+  description: string;
+  price: number;
+  image: string;
+  category: Category;
+  featured: boolean;
+}
+
+export type Category =
+  | "cafe"
+  | "te"
+  | "pasteles"
+  | "sandwiches"
+  | "postres"
+  | "bebidas";
+
+export interface CartItem {
+  product: Product;
+  quantity: number;
+}
+
+export interface Order {
+  id: string;
+  items: CartItem[];
+  total: number;
+  status: "pendiente" | "preparando" | "listo" | "entregado";
+  date: string;
+  customerName: string;
+  customerPhone: string;
+  paymentMethod: "efectivo" | "tarjeta";
+}
+
+export interface LoyaltyInfo {
+  points: number;
+  level: "Bronce" | "Plata" | "Oro" | "Diamante";
+  totalOrders: number;
+  rewards: Reward[];
+}
+
+export interface Reward {
+  id: string;
+  name: string;
+  pointsCost: number;
+  description: string;
+  redeemed: boolean;
+}
+
+export const CATEGORY_LABELS: Record<Category, string> = {
+  cafe: "Caf\u00e9",
+  te: "T\u00e9",
+  pasteles: "Pasteles",
+  sandwiches: "S\u00e1ndwiches",
+  postres: "Postres",
+  bebidas: "Bebidas",
+};
