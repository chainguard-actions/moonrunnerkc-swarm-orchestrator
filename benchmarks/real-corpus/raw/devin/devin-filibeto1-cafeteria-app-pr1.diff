+"use client";
+
+import Link from "next/link";
+import {
+  Package,
+  ClipboardList,
+  TrendingUp,
+  DollarSign,
+  Coffee,
+} from "lucide-react";
+import { useOrders } from "@/context/OrderContext";
+import { products } from "@/data/products";
+
+export default function AdminPage() {
+  const { orders } = useOrders();
+
+  const totalRevenue = orders.reduce((sum, order) => sum + order.total, 0);
+  const pendingOrders = orders.filter((o) => o.status === "pendiente").length;
+  const preparingOrders = orders.filter(
+    (o) => o.status === "preparando"
+  ).length;
+
+  const stats = [
+    {
+      label: "Ingresos Totales",
+      value: `$${totalRevenue.toLocaleString()}`,
+      icon: DollarSign,
+      color: "text-green-600",
+      bg: "bg-green-50",
+    },
+    {
+      label: "Total Pedidos",
+      value: orders.length.toString(),
+      icon: ClipboardList,
+      color: "text-blue-600",
+      bg: "bg-blue-50",
+    },
+    {
+      label: "Pendientes",
+      value: pendingOrders.toString(),
+      icon: TrendingUp,
+      color: "text-orange-600",
+      bg: "bg-orange-50",
+    },
+    {
+      label: "En Preparaci\u00f3n",
+      value: preparingOrders.toString(),
+      icon: Coffee,
+      color: "text-purple-600",
+      bg: "bg-purple-50",
+    },
+  ];
+
+  return (
+    <div className="min-h-screen py-8 md:py-12 bg-gray-50">
+      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
+        <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
+          <div>
+            <h1 className="text-3xl font-bold text-[var(--primary-dark)]">
+              Panel de Administraci\u00f3n
+            </h1>
+            <p className="text-[var(--primary-light)]">
+              Gestiona tu cafeter\u00eda desde un solo lugar
+            </p>
+          </div>
+        </div>
+
+        {/* Stats */}
+        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
+          {stats.map((stat) => (
+            <div key={stat.label} className="card p-6">
+              <div className="flex items-center justify-between mb-3">
+                <span className="text-sm text-[var(--primary-light)]">
+                  {stat.label}
+                </span>
+                <div
+                  className={`w-10 h-10 rounded-xl ${stat.bg} flex items-center justify-center`}
+                >
+                  <stat.icon className={`w-5 h-5 ${stat.color}`} />
+                </div>
+              </div>
+              <div className="text-3xl font-bold text-[var(--primary-dark)]">
+                {stat.value}
+              </div>
+            </div>
+          ))}
+        </div>
+
+        {/* Quick Actions */}
+        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
+          <Link href="/admin/products" className="card p-8 group hover:border-[var(--primary)] border-2 border-transparent">
+            <div className="flex items-center gap-4">
+              <div className="w-16 h-16 rounded-2xl bg-[var(--cream)] flex items-center justify-center group-hover:bg-[var(--accent-light)] transition-colors">
+                <Package className="w-8 h-8 text-[var(--primary)]" />
+              </div>
+              <div>
+                <h2 className="text-xl font-bold text-[var(--primary-dark)]">
+                  Gestionar Productos
+                </h2>
+                <p className="text-[var(--primary-light)]">
+                  {products.length} productos en el men\u00fa
+                </p>
+              </div>
+            </div>
+          </Link>
+
+          <Link href="/admin/orders" className="card p-8 group hover:border-[var(--primary)] border-2 border-transparent">
+            <div className="flex items-center gap-4">
+              <div className="w-16 h-16 rounded-2xl bg-[var(--cream)] flex items-center justify-center group-hover:bg-[var(--accent-light)] transition-colors">
+                <ClipboardList className="w-8 h-8 text-[var(--primary)]" />
+              </div>
+              <div>
+                <h2 className="text-xl font-bold text-[var(--primary-dark)]">
+                  Gestionar Pedidos
+                </h2>
+                <p className="text-[var(--primary-light)]">
+                  {orders.length} pedidos registrados
+                </p>
+              </div>
+            </div>
+          </Link>
+        </div>
+
+        {/* Recent Orders */}
+        {orders.length > 0 && (
+          <div className="mt-8">
+            <h2 className="text-xl font-bold text-[var(--primary-dark)] mb-4">
+              Pedidos Recientes
+            </h2>
+            <div className="card overflow-hidden">
+              <div className="overflow-x-auto">
+                <table className="w-full">
+                  <thead className="bg-[var(--cream)]">
+                    <tr>
+                      <th className="px-6 py-3 text-left text-sm font-semibold text-[var(--primary-dark)]">
+                        ID
+                      </th>
+                      <th className="px-6 py-3 text-left text-sm font-semibold text-[var(--primary-dark)]">
+                        Cliente
+                      </th>
+                      <th className="px-6 py-3 text-left text-sm font-semibold text-[var(--primary-dark)]">
+                        Total
+                      </th>
+                      <th className="px-6 py-3 text-left text-sm font-semibold text-[var(--primary-dark)]">
+                        Estado
+                      </th>
+                      <th className="px-6 py-3 text-left text-sm font-semibold text-[var(--primary-dark)]">
+                        Fecha
+                      </th>
+                    </tr>
+                  </thead>
+                  <tbody className="divide-y divide-[var(--accent-light)]">
+                    {orders.slice(0, 5).map((order) => (
+                      <tr key={order.id} className="hover:bg-[var(--cream)]/50">
+                        <td className="px-6 py-4 text-sm font-mono font-bold text-[var(--primary)]">
+                          {order.id}
+                        </td>
+                        <td className="px-6 py-4 text-sm text-[var(--primary-dark)]">
+                          {order.customerName}
+                        </td>
+                        <td className="px-6 py-4 text-sm font-semibold text-[var(--primary)]">
+                          ${order.total}
+                        </td>
+                        <td className="px-6 py-4">
+                          <span
+                            className={`inline-flex px-3 py-1 rounded-full text-xs font-semibold capitalize ${
+                              order.status === "pendiente"
+                                ? "bg-orange-100 text-orange-700"
+                                : order.status === "preparando"
+                                ? "bg-blue-100 text-blue-700"
+                                : order.status === "listo"
+                                ? "bg-green-100 text-green-700"
+                                : "bg-gray-100 text-gray-700"
+                            }`}
+                          >
+                            {order.status}
+                          </span>
+                        </td>
+                        <td className="px-6 py-4 text-sm text-[var(--primary-light)]">
+                          {new Date(order.date).toLocaleDateString("es-MX")}
+                        </td>
+                      </tr>
+                    ))}
+                  </tbody>
+                </table>
+              </div>
+            </div>
+          </div>
+        )}
+      </div>
+    </div>
+  );
+}
