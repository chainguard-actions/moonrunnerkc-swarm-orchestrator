+                            {product.description}
+                          </p>
+                        </div>
+                      </div>
+                    </td>
+                    <td className="px-6 py-4">
+                      <span className="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[var(--cream)] text-[var(--primary)] text-sm font-medium">
+                        <Coffee className="w-3 h-3" />
+                        {CATEGORY_LABELS[product.category]}
+                      </span>
+                    </td>
+                    <td className="px-6 py-4 font-bold text-[var(--primary)]">
+                      ${product.price}
+                    </td>
+                    <td className="px-6 py-4">
+                      {product.featured ? (
+                        <span className="inline-flex px-3 py-1 rounded-full bg-[var(--accent-light)] text-[var(--primary-dark)] text-xs font-semibold">
+                          S\u00ed
+                        </span>
+                      ) : (
+                        <span className="text-[var(--primary-light)] text-sm">
+                          No
+                        </span>
+                      )}
+                    </td>
+                    <td className="px-6 py-4">
+                      <button className="p-2 rounded-xl hover:bg-[var(--cream)] text-[var(--primary)] transition-colors">
+                        <Edit className="w-4 h-4" />
+                      </button>
+                    </td>
+                  </tr>
+                ))}
+              </tbody>
+            </table>
+          </div>
+        </div>
+      </div>
+    </div>
+  );
+}
