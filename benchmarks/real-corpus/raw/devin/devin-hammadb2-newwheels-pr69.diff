diff --git a/src/content/pages/loader.ts b/src/content/pages/loader.ts
--- /dev/null
+++ b/src/content/pages/loader.ts
@@ -0,0 +1,120 @@
+// Build-time loader for hand-written JSON page content files.
+//
+// Walks `src/content/pages/` recursively for `.json` files and converts each
+// into a `ProgrammaticPage`. Pages with a `body` field are rendered via the
+// `<Markdown>` component in the catchall route; others fall through to the
+// legacy `sections` renderer.
+//
+// Hand-written pages take priority over programmatic generators — they are
+// loaded first in `buildAll()` and generators skip any slug already claimed.
+
+import { readdirSync, readFileSync, statSync } from "node:fs";
+import path from "node:path";
+import type { ProgrammaticPage, PageKind, RelatedLink } from "@/lib/programmatic/types";
+import type { FaqItem } from "@/lib/schema";
+
+const PAGES_DIR = path.resolve(process.cwd(), "src/content/pages");
+
+type PageFile = {
+  slug: string;
+  metaTitle: string;
+  metaDescription: string;
+  h1: string;
+  intro: string;
+  kind: PageKind;
+  category: string;
+  related: RelatedLink[];
+  body: string;
+  faq: FaqItem[];
+  tagline?: string;
+  ctaHeading?: string;
+};
+
+function walkDir(dir: string): string[] {
+  let results: string[] = [];
+  let entries: string[];
+  try {
+    entries = readdirSync(dir);
+  } catch {
+    return results;
+  }
+  for (const entry of entries) {
+    const full = path.join(dir, entry);
+    const stat = statSync(full);
+    if (stat.isDirectory()) {
+      results = results.concat(walkDir(full));
+    } else if (entry.endsWith(".json")) {
+      results.push(full);
+    }
+  }
+  return results;
+}
+
+function bodyToSections(body: string): { heading: string; paragraphs: string[]; bullets?: string[] }[] {
+  const sections: { heading: string; paragraphs: string[]; bullets?: string[] }[] = [];
+  const lines = body.split("\n");
+  let currentHeading = "";
+  let paragraphs: string[] = [];
+  let bullets: string[] = [];
+
+  const flush = () => {
+    if (currentHeading || paragraphs.length > 0 || bullets.length > 0) {
+      sections.push({
+        heading: currentHeading || "Overview",
+        paragraphs: paragraphs.filter(p => p.length > 0),
+        ...(bullets.length > 0 ? { bullets } : {}),
+      });
+      currentHeading = "";
+      paragraphs = [];
+      bullets = [];
+    }
+  };
+
+  for (const raw of lines) {
+    const line = raw.trim();
+    if (/^##\s+/.test(line)) {
+      flush();
+      currentHeading = line.replace(/^##\s+/, "");
+    } else if (/^###\s+/.test(line)) {
+      flush();
+      currentHeading = line.replace(/^###\s+/, "");
+    } else if (/^[-*]\s+/.test(line)) {
+      bullets.push(line.replace(/^[-*]\s+/, ""));
+    } else if (line.length > 0) {
+      paragraphs.push(line);
+    }
+  }
+  flush();
+  return sections;
+}
+
+export function loadHandWrittenPages(): ProgrammaticPage[] {
+  const files = walkDir(PAGES_DIR);
+  const pages: ProgrammaticPage[] = [];
+
+  for (const filePath of files) {
+    try {
+      const raw = readFileSync(filePath, "utf8");
+      const parsed = JSON.parse(raw) as PageFile;
+      pages.push({
+        slug: parsed.slug,
+        kind: parsed.kind,
+        category: parsed.category,
+        metaTitle: parsed.metaTitle,
+        metaDescription: parsed.metaDescription,
+        h1: parsed.h1,
+        tagline: parsed.tagline,
+        intro: parsed.intro,
+        sections: bodyToSections(parsed.body),
+        faq: parsed.faq,
+        related: parsed.related,
+        ctaHeading: parsed.ctaHeading,
+        body: parsed.body,
+      });
+    } catch {
+      // skip malformed files
+    }
+  }
+
+  return pages;
+}
