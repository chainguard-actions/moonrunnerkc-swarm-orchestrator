+    backgroundColor: 'FFFFFF',
+    primaryColor: '4663C9',
+    email: email || undefined,
+    accountReference: orderId,
+    orderId,
+  });
+  return `https://${BANXA_PARTNER_SUBDOMAIN}.banxa.com/?${query}`;
+}
