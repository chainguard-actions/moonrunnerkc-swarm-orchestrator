diff --git a/public/styles.css b/public/styles.css
index 9358b90..4a0be43 100644
--- a/public/styles.css
+++ b/public/styles.css
@@ -478,3 +478,85 @@ body {
     z-index: 1000;
 }
 .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
+
+/* Numbered step list inside notice blocks (Pay with card / Pay direct flows) */
+.notice .steps {
+    list-style: none;
+    margin: 10px 0 0;
+    padding: 0;
+    display: grid;
+    gap: 8px;
+}
+.notice .steps li {
+    display: flex;
+    align-items: flex-start;
+    gap: 10px;
+    font-size: 13.5px;
+    color: var(--navy);
+    line-height: 1.45;
+}
+.notice .steps .step-num {
+    flex-shrink: 0;
+    width: 22px;
+    height: 22px;
+    border-radius: 50%;
+    background: var(--navy);
+    color: #fff;
+    font-size: 12px;
+    font-weight: 800;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    line-height: 1;
+    margin-top: 1px;
+}
+.notice .steps .step-text { display: block; }
+.notice .steps .step-text strong { color: var(--navy); font-weight: 700; }
+
+/* Inline card-form iframe panel (ChangeNOW / Guardarian widgets) */
+.embed-panel {
+    margin: 14px 28px 0;
+    border: 1.5px solid var(--line);
+    border-radius: 14px;
+    overflow: hidden;
+    background: #fff;
+}
+.embed-panel .embed-head {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    padding: 10px 14px;
+    border-bottom: 1px solid var(--line);
+    background: #f7fafd;
+}
+.embed-panel .embed-title {
+    font-size: 13.5px;
+    font-weight: 700;
+    color: var(--navy);
+}
+.embed-panel .embed-newtab {
+    font-size: 12.5px;
+    font-weight: 600;
+    color: var(--navy);
+    text-decoration: none;
+    border-bottom: 1px dashed currentColor;
+}
+.embed-panel .embed-newtab:hover { opacity: 0.85; }
+.embed-panel iframe {
+    width: 100%;
+    height: 640px;
+    border: 0;
+    display: block;
+    background: #fff;
+}
+@media (max-width: 720px) {
+    .embed-panel iframe { height: 720px; }
+}
+.embed-panel .embed-foot {
+    padding: 8px 14px;
+    font-size: 12px;
+    color: var(--muted);
+    background: #f7fafd;
+    border-top: 1px solid var(--line);
+    text-align: center;
+}
