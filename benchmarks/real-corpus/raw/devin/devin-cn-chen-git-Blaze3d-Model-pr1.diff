 package cn.chen.blaze3d.render.npr
+import cn.chen.blaze3d.material.Material
+import cn.chen.blaze3d.render.Pipelines
+import com.mojang.blaze3d.pipeline.RenderPipeline
+enum class ToonKind { BODY, HAIR, FACE, EYE, SSS, IRIDESCENT, OUTLINE }
+enum class Tonemapper(val id: Int) { REINHARD(0), ACES_FITTED(1), AGX(2) }
+data class BloomConfig(var enabled: Boolean = true, var threshold: Float = 1.05f, var knee: Float = 0.25f, var intensity: Float = 0.55f, var mipLevels: Int = 6, var dirtIntensity: Float = 0.0f, var scatter: Float = 0.7f)
+data class TonemapConfig(var exposure: Float = 1.0f, var saturation: Float = 1.05f, var invGamma: Float = 1.0f / 2.2f, var tonemapper: Tonemapper = Tonemapper.ACES_FITTED)
+class PostFx {
+    val bloom = BloomConfig()
+    val tonemap = TonemapConfig()
+    var enabled = true
+    var dofFocusDistance = 0f
+    var dofAperture = 0f
+    var vignetteStrength = 0f
+    fun snapshotBloom(): FloatArray = floatArrayOf(bloom.threshold, bloom.knee, bloom.intensity, bloom.scatter)
+    fun snapshotTonemap(): FloatArray = floatArrayOf(tonemap.exposure, tonemap.saturation, tonemap.invGamma, tonemap.tonemapper.id.toFloat())
+    fun summary() = "postfx exposure=${tonemap.exposure} bloom=${bloom.enabled}:${bloom.intensity} tonemap=${tonemap.tonemapper.name}"
+}
+class ToonProfile {
+    private val bodyKeys = listOf("body", "skin", "肌", "肌色", "顔", "face", "neck", "ear")
+    private val hairKeys = listOf("hair", "髪", "髮", "前髪", "横髪", "後髪", "毛")
+    private val faceKeys = listOf("face", "顔", "口", "鼻", "頬", "skin", "肌")
+    private val eyeKeys = listOf("eye", "瞳", "目", "iris", "pupil")
+    fun classify(material: Material): ToonKind {
+        val n = material.name.lowercase()
+        return when {
+            eyeKeys.any { n.contains(it.lowercase()) } -> ToonKind.EYE
+            hairKeys.any { n.contains(it.lowercase()) } -> ToonKind.HAIR
+            faceKeys.any { n.contains(it.lowercase()) } -> ToonKind.FACE
+            (material.khrExtensions.iridescence?.factor ?: 0f) > 0.05f -> ToonKind.IRIDESCENT
+            (material.khrExtensions.transmission?.factor ?: 0f) > 0.05f || (material.khrExtensions.volume?.thicknessFactor ?: 0f) > 0.001f -> ToonKind.SSS
+            bodyKeys.any { n.contains(it.lowercase()) } -> ToonKind.BODY
+            else -> ToonKind.BODY
+        }
+    }
+    fun pipelineFor(kind: ToonKind): RenderPipeline = when (kind) {
+        ToonKind.BODY -> Pipelines.AI_TOON_BODY
+        ToonKind.HAIR -> Pipelines.AI_TOON_HAIR
+        ToonKind.FACE -> Pipelines.AI_TOON_FACE
+        ToonKind.EYE -> Pipelines.AI_TOON_EYE
+        ToonKind.SSS -> Pipelines.AI_SSS_OPAQUE
+        ToonKind.IRIDESCENT -> Pipelines.AI_IRIDESCENT
+        ToonKind.OUTLINE -> Pipelines.AI_OUTLINE_PURE
+    }
+}
