--- /dev/null
+++ b/src/main/kotlin/cn/chen/blaze3d/vehicle/VehicleSystem.kt
@@ -0,0 +1,162 @@
+package cn.chen.blaze3d.vehicle
+import cn.chen.blaze3d.api.ModelFormatRegistry
+import cn.chen.blaze3d.api.ModelLoadResult
+import cn.chen.blaze3d.math.Vec3
+import com.mojang.blaze3d.vertex.PoseStack
+import net.minecraft.client.Minecraft
+import net.minecraft.client.renderer.SubmitNodeCollector
+import net.minecraft.client.renderer.entity.state.EntityRenderState
+import net.minecraft.client.renderer.state.level.CameraRenderState
+import net.minecraft.core.BlockPos
+import net.minecraft.world.entity.Entity
+import net.minecraft.world.level.ClipContext
+import net.minecraft.world.phys.HitResult
+import net.minecraft.world.phys.Vec3 as MinecraftVec3
+import java.io.File
+import java.util.UUID
+import java.util.concurrent.atomic.AtomicLong
+import kotlin.math.PI
+import kotlin.math.atan2
+import kotlin.math.cos
+import kotlin.math.sin
+data class VehicleBinding(val modelPath: String, val scale: Float = 1f, val frontOffset: Float = 0.55f, val sideOffset: Float = 0.4f, val restLength: Float = 0.45f, val stiffness: Float = 14f, val damping: Float = 4.5f, val rideHeight: Float = 0.0f) {
+    val key: UUID = UUID.randomUUID()
+}
+data class WheelSample(val position: Vec3, val groundHeight: Float, val hit: Boolean, val slopeX: Float, val slopeZ: Float)
+class WheelRaycaster {
+    private val downRange = 1.6f
+    fun sampleWheel(entity: Entity, localOffset: Vec3): WheelSample {
+        val world = entity.level()
+        val origin = MinecraftVec3(entity.x + localOffset.x.toDouble(), entity.y + 0.5 + localOffset.y.toDouble(), entity.z + localOffset.z.toDouble())
+        val target = MinecraftVec3(origin.x, origin.y - downRange.toDouble(), origin.z)
+        val ctx = ClipContext(origin, target, ClipContext.Block.COLLIDER, ClipContext.Fluid.NONE, entity)
+        val hit = world.clip(ctx)
+        if (hit.type != HitResult.Type.BLOCK) return WheelSample(Vec3(origin.x.toFloat(), entity.y.toFloat(), origin.z.toFloat()), entity.y.toFloat(), false, 0f, 0f)
+        val pos = hit.location
+        val slope = estimateSlope(world, BlockPos.containing(pos))
+        return WheelSample(Vec3(pos.x.toFloat(), pos.y.toFloat(), pos.z.toFloat()), pos.y.toFloat(), true, slope[0], slope[1])
+    }
+    private fun estimateSlope(world: net.minecraft.world.level.Level, pos: BlockPos): FloatArray {
+        val east = topY(world, pos.east()); val west = topY(world, pos.west())
+        val north = topY(world, pos.north()); val south = topY(world, pos.south())
+        return floatArrayOf((east - west) * 0.5f, (south - north) * 0.5f)
+    }
+    private fun topY(world: net.minecraft.world.level.Level, pos: BlockPos): Float {
+        val state = world.getBlockState(pos)
+        val box = state.getCollisionShape(world, pos)
+        return if (box.isEmpty) pos.y.toFloat() else (pos.y + box.max(net.minecraft.core.Direction.Axis.Y)).toFloat()
+    }
+    fun sampleFour(entity: Entity, frontOffset: Float, sideOffset: Float, axleY: Float): Array<WheelSample> {
+        val yaw = Math.toRadians(entity.yRot.toDouble())
+        val cy = Math.cos(yaw).toFloat(); val sy = Math.sin(yaw).toFloat()
+        fun local(x: Float, z: Float) = Vec3(x * cy - z * sy, axleY, x * sy + z * cy)
+        return arrayOf(
+            sampleWheel(entity, local(sideOffset, frontOffset)),
+            sampleWheel(entity, local(-sideOffset, frontOffset)),
+            sampleWheel(entity, local(sideOffset, -frontOffset)),
+            sampleWheel(entity, local(-sideOffset, -frontOffset))
+        )
+    }
+    companion object {
+        val shared = WheelRaycaster()
+        fun atCamera(): Boolean = Minecraft.getInstance().level != null
+    }
+}
+class VehicleSuspension(val frontOffset: Float = 0.55f, val sideOffset: Float = 0.4f, val restLength: Float = 0.45f, val stiffness: Float = 14f, val damping: Float = 4.5f) {
+    private val compression = FloatArray(4)
+    private val compressionVel = FloatArray(4)
+    private val cached = arrayOf(Vec3(), Vec3(), Vec3(), Vec3())
+    var pitch = 0f; private set
+    var roll = 0f; private set
+    var height = 0f; private set
+    fun update(dt: Float, samples: Array<WheelSample>) {
+        if (samples.size < 4) return
+        val clampedDt = dt.coerceIn(0f, 0.05f)
+        for (i in 0..3) {
+            val sample = samples[i]
+            val target = if (sample.hit) (restLength - (sample.position.y - (sample.position.y + restLength))).coerceIn(0.0f, restLength) else restLength
+            val err = target - compression[i]
+            val acc = err * stiffness - compressionVel[i] * damping
+            compressionVel[i] += acc * clampedDt
+            compression[i] += compressionVel[i] * clampedDt
+            compression[i] = compression[i].coerceIn(0f, restLength)
+            cached[i] = Vec3(sample.position.x, sample.position.y + (restLength - compression[i]), sample.position.z)
+        }
+        val front = (cached[0].y + cached[1].y) * 0.5f
+        val rear = (cached[2].y + cached[3].y) * 0.5f
+        val left = (cached[1].y + cached[3].y) * 0.5f
+        val right = (cached[0].y + cached[2].y) * 0.5f
+        pitch = atan2((front - rear).toDouble(), frontOffset * 2.0).toFloat()
+        roll = atan2((right - left).toDouble(), sideOffset * 2.0).toFloat()
+        height = (front + rear + left + right) * 0.25f
+    }
+    fun wheels(): Array<Vec3> = cached
+    fun chassisRotation(): FloatArray {
+        val cp = cos(pitch.toDouble()).toFloat(); val sp = sin(pitch.toDouble()).toFloat()
+        val cr = cos(roll.toDouble()).toFloat(); val sr = sin(roll.toDouble()).toFloat()
+        return floatArrayOf(cr, 0f, sr, 0f, sr * sp, cp, -cr * sp, 0f, -sr * cp, sp, cr * cp, 0f, 0f, 0f, 0f, 1f)
+    }
+    fun status() = "vehicle-suspension pitch=${(pitch * 180.0 / PI).toFloat()} roll=${(roll * 180.0 / PI).toFloat()} h=$height"
+}
+class VehicleRuntime {
+    private val suspensions = HashMap<UUID, VehicleSuspension>()
+    private val raycaster = WheelRaycaster.shared
+    fun update(entity: Entity, binding: VehicleBinding, dt: Float): VehicleSuspension {
+        val suspension = suspensions.getOrPut(entity.uuid) { VehicleSuspension(binding.frontOffset, binding.sideOffset, binding.restLength, binding.stiffness, binding.damping) }
+        val samples = raycaster.sampleFour(entity, binding.frontOffset, binding.sideOffset, binding.rideHeight)
+        suspension.update(dt, samples)
+        return suspension
+    }
+    fun remove(entity: Entity) { suspensions.remove(entity.uuid) }
+    fun clear() { suspensions.clear() }
+    fun status() = "vehicle-runtime active=${suspensions.size}"
+}
+object VehicleRenderRegistry {
+    private val boats = LinkedHashMap<String, VehicleBinding>()
+    private val minecarts = LinkedHashMap<String, VehicleBinding>()
+    private val loaded = HashMap<UUID, ModelLoadResult>()
+    fun registerBoat(variant: String, binding: VehicleBinding) { boats[variant] = binding }
+    fun registerMinecart(variant: String, binding: VehicleBinding) { minecarts[variant] = binding }
+    fun boatBinding(variant: String): VehicleBinding? = boats[variant] ?: boats.values.firstOrNull()
+    fun minecartBinding(variant: String): VehicleBinding? = minecarts[variant] ?: minecarts.values.firstOrNull()
+    fun resolve(binding: VehicleBinding): ModelLoadResult? {
+        val cached = loaded[binding.key]
+        if (cached != null) return cached
+        return runCatching { ModelFormatRegistry.load(binding.modelPath) }.getOrNull()?.also { loaded[binding.key] = it }
+    }
+    fun status() = "vehicle-registry boats=${boats.size} minecarts=${minecarts.size} loaded=${loaded.size}"
+    fun reset() { boats.clear(); minecarts.clear(); loaded.clear() }
+    fun loadDefaults(configDir: File) {
+        val boatsDir = File(configDir, "vehicles/boats")
+        val minecartsDir = File(configDir, "vehicles/minecarts")
+        if (boatsDir.isDirectory) boatsDir.listFiles()?.forEach { f -> if (f.isFile) registerBoat(f.nameWithoutExtension, VehicleBinding(modelPath = f.absolutePath)) }
+        if (minecartsDir.isDirectory) minecartsDir.listFiles()?.forEach { f -> if (f.isFile) registerMinecart(f.nameWithoutExtension, VehicleBinding(modelPath = f.absolutePath)) }
+    }
+}
+object VehicleRenderHook {
+    val runtime = VehicleRuntime()
+    val raycaster = WheelRaycaster.shared
+    var enabled = true
+    val rendered: AtomicLong = AtomicLong()
+    val cancelled: AtomicLong = AtomicLong()
+    fun tryRenderBoat(state: EntityRenderState, pose: PoseStack, collector: SubmitNodeCollector, camera: CameraRenderState?): Boolean {
+        if (!enabled) return false
+        val binding = VehicleRenderRegistry.boatBinding("default") ?: return false
+        return renderVehicle(binding, state, pose, collector)
+    }
+    fun tryRenderMinecart(state: EntityRenderState, pose: PoseStack, collector: SubmitNodeCollector, camera: CameraRenderState?): Boolean {
+        if (!enabled) return false
+        val binding = VehicleRenderRegistry.minecartBinding("default") ?: return false
+        return renderVehicle(binding, state, pose, collector)
+    }
+    private fun renderVehicle(binding: VehicleBinding, state: EntityRenderState, pose: PoseStack, collector: SubmitNodeCollector): Boolean {
+        val resolved = VehicleRenderRegistry.resolve(binding) ?: return false
+        rendered.incrementAndGet()
+        pose.pushPose()
+        pose.scale(binding.scale, binding.scale, binding.scale)
+        pose.popPose()
+        cancelled.incrementAndGet()
+        return resolved.support.id.isNotEmpty()
+    }
+    fun status() = "vehicle-hook enabled=$enabled rendered=${rendered.get()} cancelled=${cancelled.get()} ${runtime.status()}"
+}
