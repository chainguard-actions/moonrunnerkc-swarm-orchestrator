+	// Cannot add turn after ending
+	err = svc.AddTurn(context.Background(), sess, "late", "msg", 3)
+	if err != ErrSessionAlreadyEnded {
+		t.Fatalf("expected ErrSessionAlreadyEnded, got %v", err)
+	}
