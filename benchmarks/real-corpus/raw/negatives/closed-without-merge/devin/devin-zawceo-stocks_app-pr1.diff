diff --git a/manage_api_keys.py b/manage_api_keys.py
new file mode 100644
index 0000000..08b2635
--- /dev/null
+++ b/manage_api_keys.py
@@ -0,0 +1,30 @@
+import sys
+
+from models import ApiKey, db, set_api_key
+
+
+def list_api_keys():
+    for api_key in ApiKey.query.order_by(ApiKey.provider).all():
+        print(api_key.provider)
+
+
+def main():
+    db.create_all()
+
+    if len(sys.argv) == 2 and sys.argv[1] == 'list':
+        list_api_keys()
+        return
+
+    if len(sys.argv) == 4 and sys.argv[1] == 'set':
+        set_api_key(sys.argv[2], sys.argv[3])
+        print(f"Saved API key for {sys.argv[2]}")
+        return
+
+    print('Usage:')
+    print('  python manage_api_keys.py set PROVIDER API_KEY')
+    print('  python manage_api_keys.py list')
+    sys.exit(1)
+
+
+if __name__ == '__main__':
+    main()
