@@ -90,3 +91,28 @@ class Friends(db.Model):
     name = db.Column(db.String, nullable=False)
     last = db.Column(db.String(30), nullable=False)
     email = db.Column(db.String(60), nullable=False)
+
+
+class ApiKey(db.Model):
+    provider = db.Column(db.String(50), primary_key=True)
+    key = db.Column(db.String(255), nullable=False)
+
+
+def get_api_key(provider, env_var=None):
+    stored_key = ApiKey.query.get(provider)
+    if stored_key:
+        return stored_key.key
+
+    if env_var:
+        return os.environ.get(env_var)
+
+    return os.environ.get(f"{provider.upper()}_API_KEY")
+
+
+def set_api_key(provider, key):
+    stored_key = ApiKey.query.get(provider)
+    if stored_key:
+        stored_key.key = key
+    else:
+        db.session.add(ApiKey(provider=provider, key=key))
+    db.session.commit()
