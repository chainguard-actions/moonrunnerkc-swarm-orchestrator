diff --git a/.github/workflows/link-check.yml b/.github/workflows/link-check.yml
new file mode 100644
index 0000000..bc18a69
--- /dev/null
+++ b/.github/workflows/link-check.yml
@@ -0,0 +1,102 @@
+# ═══════════════════════════════════════════════════════════════════════════════
+# Link Check · Detección de enlaces rotos en documentación
+#
+# Propósito: Escanea archivos Markdown buscando enlaces HTTP rotos o
+# referencias internas inválidas. Ayuda a mantener la documentación actualizada.
+#
+# Se ejecuta en:
+#   - Semanalmente (lunes 08:00 UTC)
+#   - Manualmente (workflow_dispatch)
+#
+# ROADMAP: 4.2.1
+# ═══════════════════════════════════════════════════════════════════════════════
+
+name: Link Check
+
+on:
+  schedule:
+    - cron: "0 8 * * 1"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+  issues: write
+
+jobs:
+  check-links:
+    name: Verificar enlaces
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Instalar lychee
+        run: |
+          LYCHEE_VERSION="v0.18.0"
+          curl -sSfL "https://github.com/lycheeverse/lychee/releases/download/${LYCHEE_VERSION}/lychee-${LYCHEE_VERSION}-x86_64-unknown-linux-gnu.tar.gz" \
+            | tar xz -C /usr/local/bin
+
+      - name: Ejecutar lychee
+        id: lychee
+        run: |
+          EXIT_CODE=0
+          lychee \
+            --exclude-path '.git' \
+            --exclude-path 'artefactos' \
+            --exclude-path 'node_modules' \
+            --exclude 'localhost' \
+            --exclude '127\.0\.0\.1' \
+            --exclude 'example\.com' \
+            --exclude 'tu-.*\.com' \
+            --accept '200..=299,403,429' \
+            --max-retries 3 \
+            --timeout 30 \
+            --no-progress \
+            --format markdown \
+            --output /tmp/lychee-report.md \
+            '**/*.md' || EXIT_CODE=$?
+
+          if [ "$EXIT_CODE" -ne 0 ] && [ -s /tmp/lychee-report.md ]; then
+            echo "has_broken=true" >> "$GITHUB_OUTPUT"
+          else
+            echo "has_broken=false" >> "$GITHUB_OUTPUT"
+          fi
+
+      - name: Crear issue si hay enlaces rotos
+        if: steps.lychee.outputs.has_broken == 'true' && github.event_name == 'schedule'
+        uses: actions/github-script@v7
+        with:
+          script: |
+            const fs = require('fs');
+            const report = fs.readFileSync('/tmp/lychee-report.md', 'utf8');
+
+            const title = `🔗 Enlaces rotos detectados (${new Date().toISOString().split('T')[0]})`;
+
+            // Buscar issue existente para no duplicar
+            const existing = await github.rest.issues.listForRepo({
+              owner: context.repo.owner,
+              repo: context.repo.repo,
+              state: 'open',
+              labels: 'links-rotos',
+              per_page: 1,
+            });
+
+            const body = `## Reporte automático de enlaces rotos\n\n${report}\n\n---\n*Generado por \`.github/workflows/link-check.yml\`*`;
+
+            if (existing.data.length > 0) {
+              await github.rest.issues.update({
+                owner: context.repo.owner,
+                repo: context.repo.repo,
+                issue_number: existing.data[0].number,
+                body: body,
+              });
+              console.log(`Actualizado issue #${existing.data[0].number}`);
+            } else {
+              await github.rest.issues.create({
+                owner: context.repo.owner,
+                repo: context.repo.repo,
+                title: title,
+                body: body,
+                labels: ['links-rotos'],
+              });
+              console.log('Nuevo issue creado');
+            }
