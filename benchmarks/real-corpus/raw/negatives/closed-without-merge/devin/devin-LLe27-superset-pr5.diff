+test('"Select all" excludes null options from count', async () => {
+  const optionsWithNull = [
+    { label: 'Alice', value: 100, gender: 'Female' },
+    { label: 'Bob', value: 101, gender: 'Male' },
+    NULL_OPTION,
+  ];
+  render(
+    <Select {...defaultProps} options={optionsWithNull} mode="multiple" />,
+  );
+  await open();
+  expect(await screen.findByText(selectAllButtonText(2))).toBeInTheDocument();
+});
+
+test('"Select all" does not select null options', async () => {
+  const optionsWithNull = [
+    { label: 'Alice', value: 100, gender: 'Female' },
+    { label: 'Bob', value: 101, gender: 'Male' },
+    NULL_OPTION,
+  ];
+  render(
+    <Select {...defaultProps} options={optionsWithNull} mode="multiple" />,
+  );
+  await open();
+  await userEvent.click(await screen.findByText(selectAllButtonText(2)));
+  const values = await findAllSelectValues();
+  expect(values.length).toBe(2);
+  expect(values.some(v => v.textContent === NULL_OPTION.label)).toBe(false);
+});
