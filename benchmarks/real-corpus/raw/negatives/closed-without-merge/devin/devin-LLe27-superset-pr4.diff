+test('"Select all" does not count null options', async () => {
+  const cleanOptions = [
+    { label: 'Alice', value: 1 },
+    { label: 'Bob', value: 2 },
+    { label: 'Carol', value: 3 },
+  ];
+  const optionsWithNull = [...cleanOptions, NULL_OPTION];
+  render(
+    <Select {...defaultProps} options={optionsWithNull} mode="multiple" />,
+  );
+  await open();
+  expect(
+    await screen.findByText(selectAllButtonText(cleanOptions.length)),
+  ).toBeInTheDocument();
+});
+
+test('"Select all" does not select null options', async () => {
+  const cleanOptions = [
+    { label: 'Alice', value: 1 },
+    { label: 'Bob', value: 2 },
+    { label: 'Carol', value: 3 },
+  ];
+  const optionsWithNull = [...cleanOptions, NULL_OPTION];
+  render(
+    <Select {...defaultProps} options={optionsWithNull} mode="multiple" />,
+  );
+  await open();
+  await userEvent.click(
+    await screen.findByText(selectAllButtonText(cleanOptions.length)),
+  );
+  const values = await findAllSelectValues();
+  expect(values).toHaveLength(cleanOptions.length);
+  expect(values.every(v => v.textContent !== NULL_OPTION.label)).toBe(true);
+});
+
