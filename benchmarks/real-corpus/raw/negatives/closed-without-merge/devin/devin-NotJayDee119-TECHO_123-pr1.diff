+}
+
+function SeverityBadge({ severity }: { severity: HotspotCluster["severity"] }) {
+  if (severity === "high") return <Badge tone="danger">High</Badge>;
+  if (severity === "medium") return <Badge tone="warning">Medium</Badge>;
