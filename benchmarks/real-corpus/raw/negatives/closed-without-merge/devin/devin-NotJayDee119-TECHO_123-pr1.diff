+# Supabase (client-safe values for the Vite frontend)
+VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
+VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
+
+# Shared invite code required to create a health-worker account at /register/staff.
+# Rotate this and share with TB coordinators only. If unset, the staff registration
+# form will be disabled.
+VITE_STAFF_INVITE_CODE=change-me-bantay-tb-staff
+
+# Local Supabase development defaults (when using `supabase start`)
+# VITE_SUPABASE_URL=http://127.0.0.1:54321
+# VITE_SUPABASE_ANON_KEY=eyJhbGci... (printed by `supabase start`)
+
+# Server-only secrets (used by Edge Functions, never expose to the client)
+# Configure these in the Supabase dashboard under Project Settings > Edge Functions:
+# OPENAI_API_KEY=sk-...
+# SMS_PROVIDER=mock          # one of: mock, twilio, semaphore, philsms
+# SMS_API_KEY=
+# SMS_FROM_NUMBER=
