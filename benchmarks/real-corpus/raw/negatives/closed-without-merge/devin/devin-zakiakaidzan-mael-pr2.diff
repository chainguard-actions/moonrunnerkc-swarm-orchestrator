+  function attachImagePickers(rootEl) {
+    rootEl.querySelectorAll('.image-picker').forEach(box => {
+      const name = box.dataset.name;
+      const category = box.dataset.category || 'general';
+      const tabUrl = box.querySelector('.ip-tab-url');
+      const tabUp = box.querySelector('.ip-tab-upload');
+      const paneUrl = box.querySelector('.ip-url');
+      const paneUp = box.querySelector('.ip-upload');
+      const preview = box.querySelector('.ip-preview');
+      const previewImg = box.querySelector('.ip-preview-img');
+      const previewName = box.querySelector('.ip-preview-name');
+      const previewStatus = box.querySelector('.ip-preview-status');
+      const fileInput = box.querySelector('.ip-file');
+      const urlInput = box.querySelector(`input[name="${name}"]`);
+      const removeBtn = box.querySelector('.ip-remove');
+
+      const activate = (mode) => {
+        if (mode === 'url') {
+          paneUrl.classList.remove('hidden'); paneUp.classList.add('hidden');
+          tabUrl.classList.add('bg-primary','text-white'); tabUrl.classList.remove('bg-white','border-border-soft');
+          tabUp.classList.remove('bg-primary','text-white'); tabUp.classList.add('bg-white','border-border-soft');
+        } else {
+          paneUp.classList.remove('hidden'); paneUrl.classList.add('hidden');
+          tabUp.classList.add('bg-primary','text-white'); tabUp.classList.remove('bg-white','border-border-soft');
+          tabUrl.classList.remove('bg-primary','text-white'); tabUrl.classList.add('bg-white','border-border-soft');
+        }
+      };
+      tabUrl.addEventListener('click', () => activate('url'));
+      tabUp.addEventListener('click', () => activate('upload'));
+      activate('url');
+
+      fileInput.addEventListener('change', async (e) => {
+        const file = e.target.files && e.target.files[0];
+        if (!file) return;
+        if (!/^image\//.test(file.type)) { showToast('File harus berupa gambar', 'error'); return; }
+        if (file.size > 2 * 1024 * 1024) { showToast('Ukuran maksimal 2MB', 'error'); return; }
+        const localUrl = URL.createObjectURL(file);
+        previewImg.src = localUrl;
+        previewName.textContent = file.name;
+        previewStatus.textContent = 'Mengupload...';
+        preview.classList.remove('hidden');
+        try {
+          const data = await uploadImageToGallery(file, file.name.replace(/\.[^/.]+$/, ''), category);
+          urlInput.value = data.image_url || '';
+          previewStatus.textContent = 'Berhasil diupload';
+          previewStatus.classList.add('text-success');
+          showToast('Foto berhasil diupload', 'success');
+        } catch (err) {
+          previewStatus.textContent = err.message || 'Gagal upload';
+          previewStatus.classList.add('text-danger');
+          showToast(err.message || 'Gagal upload', 'error');
+        }
+        refreshIcons();
+      });
+
+      removeBtn.addEventListener('click', () => {
+        fileInput.value = '';
+        urlInput.value = '';
+        preview.classList.add('hidden');
+        previewStatus.classList.remove('text-success','text-danger');
+      });
+    });
+    refreshIcons();
+  }
