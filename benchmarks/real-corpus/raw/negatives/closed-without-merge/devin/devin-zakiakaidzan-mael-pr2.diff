+  }
+
+  function modalFooter(isEdit, label) {
+    return `
+      <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-end gap-2 pt-3 border-t border-border-soft">
+        <button type="button" onclick="closeModal()" class="px-5 py-2.5 rounded-xl border border-border-soft font-bold hover:bg-gray-50">Batal</button>
+        <button type="submit" class="btn-primary px-5 py-2.5 rounded-xl font-bold inline-flex items-center justify-center gap-2">
+          <i data-lucide="check" class="w-4 h-4"></i>${label || (isEdit ? 'Simpan Perubahan' : 'Simpan')}
+        </button>
+      </div>`;
+  }
+
+  function renderErrorBlock(message, retryFn) {
+    const id = 'retry-' + Math.random().toString(36).slice(2,8);
+    setTimeout(() => { const b = document.getElementById(id); if (b) b.onclick = retryFn; }, 0);
+    return `
+      <div class="bg-white border border-danger/20 rounded-2xl p-8 text-center">
+        <div class="w-14 h-14 rounded-2xl bg-danger/10 text-danger flex items-center justify-center mx-auto mb-3"><i data-lucide="alert-circle" class="w-7 h-7"></i></div>
+        <h4 class="font-bold text-text-main">Gagal memuat data</h4>
+        <p class="text-sm text-text-muted mt-1">${escapeHtml(message||'Terjadi kesalahan saat memuat.')}</p>
+        <button id="${id}" class="mt-4 btn-primary px-5 py-2 rounded-xl font-bold text-sm">Coba lagi</button>
+      </div>`;
+  }
+
+  /* =========================================================
+   *  DATE UTILS
+   * ========================================================= */
+  function toDateTimeLocal(val) {
+    if (!val) return '';
+    const d = new Date(val);
+    if (isNaN(d)) return '';
+    const pad = (n) => String(n).padStart(2,'0');
+    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
+  }
+  function toDateInput(val) {
+    if (!val) return '';
+    const d = new Date(val);
+    if (isNaN(d)) return String(val).slice(0,10);
+    const pad = (n) => String(n).padStart(2,'0');
+    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
+  }
+  function toISOString(val) {
+    if (!val) return null;
+    const d = new Date(val);
+    if (isNaN(d)) return null;
+    return d.toISOString();
+  }
+
+  /* =========================================================
+   *  INIT
+   * ========================================================= */
+  function init() {
+    refreshIcons();
+    STATE.token = localStorage.getItem('fspp_token');
+    try { STATE.admin = JSON.parse(localStorage.getItem('fspp_admin') || 'null'); }
+    catch(e) { STATE.admin = null; }
+
+    // Login form
+    $('#form-login').addEventListener('submit', handleLogin);
+    $('#toggle-password').addEventListener('click', () => {
+      const inp = $('#login-password');
+      inp.type = inp.type === 'password' ? 'text' : 'password';
+    });
+
+    // Top search
+    $('#global-search').addEventListener('input', (e) => {
+      STATE.search = e.target.value || '';
+      const fn = ({
+        berita: renderBeritaList, dakwah: renderDakwahList, agenda: renderAgendaList,
+        pesantren: renderPesantrenList, pengurus: renderPengurusList, donasi: renderDonasiList,
+        transparansi: renderTransparansiList, gallery: renderGalleryList, notifikasi: renderNotifikasiList,
+      })[STATE.currentView];
+      if (fn) fn();
+    });
+
+    // Drawer / mobile
+    $('#btn-open-drawer').addEventListener('click', openDrawer);
+    $('#btn-close-drawer').addEventListener('click', closeDrawer);
+    $('#drawer-overlay').addEventListener('click', closeDrawer);
+
+    // Bottom nav
+    $$('#bottom-nav .bn').forEach(b => {
+      b.addEventListener('click', () => {
+        if (b.id === 'btn-more-menu') {
+          openMobileMenu();
+        } else if (b.dataset.view) {
+          navigate(b.dataset.view);
+        }
+      });
+    });
+
+    // Close modal with Escape
+    document.addEventListener('keydown', (e) => {
+      if (e.key === 'Escape') {
+        if (!$('#modal-root').classList.contains('hidden')) closeModal();
+      }
+    });
+
+    if (STATE.token && STATE.admin) {
+      enterApp();
+    } else {
+      showScreen('login');
+    }
+  }
+
+  function openMobileMenu() {
+    const items = MENU.map(m => `
+      <button onclick="navigate('${m.key}'); closeModal();" class="flex items-center gap-3 p-3 rounded-2xl border border-border-soft hover:bg-primary-soft hover:border-primary transition text-left">
+        <div class="w-10 h-10 rounded-xl bg-primary-soft text-primary flex items-center justify-center">
+          <i data-lucide="${m.icon}" class="w-5 h-5"></i>
+        </div>
+        <div class="min-w-0 flex-1">
+          <p class="font-bold text-text-main truncate">${m.label}</p>
+          <p class="text-xs text-text-muted truncate">${m.subtitle}</p>
+        </div>
+      </button>
+    `).join('');
+    openModal('Menu Lengkap', `<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">${items}</div>`);
+  }
+
+  document.addEventListener('DOMContentLoaded', init);
+  </script>
+</body>
+</html>
