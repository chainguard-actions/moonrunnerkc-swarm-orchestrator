+    if (file.size > 2 * 1024 * 1024) throw new Error('Ukuran file maksimal 2MB');
+    const image_base64 = await fileToBase64(file);
+    const safeName = (file.name || 'foto.jpg').replace(/[^\w.\-]+/g, '-').toLowerCase();
+    const body = {
+      title: sanitizeInput(title) || safeName,
+      description: '',
+      file_name: safeName,
