+    { key: 'gallery',      label: 'Gallery Foto',           icon: 'image',            subtitle: 'Koleksi foto kegiatan' },
+    { key: 'notifikasi',   label: 'Notifikasi',             icon: 'bell',             subtitle: 'Pemberitahuan sistem' },
+    { key: 'settings',     label: 'Settings',               icon: 'settings',         subtitle: 'Pengaturan website FSPP' },
+  ];
+
+  /* =========================================================
+   *  TINY DOM HELPERS
+   * ========================================================= */
+  const $ = (sel, ctx=document) => ctx.querySelector(sel);
+  const $$ = (sel, ctx=document) => Array.from(ctx.querySelectorAll(sel));
+  const escapeHtml = (str) => String(str ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
+  const refreshIcons = () => { try { if (window.lucide) lucide.createIcons(); } catch(e){} };
+
+  /* =========================================================
+   *  HELPERS REQUIRED BY SPEC
+   * ========================================================= */
+  function getInitials(name) {
+    if (!name) return 'AF';
+    const parts = String(name).trim().split(/\s+/).slice(0, 2);
+    return parts.map(p => p[0] || '').join('').toUpperCase() || 'AF';
+  }
+
+  function sanitizeInput(value) {
+    if (value === null || value === undefined) return '';
+    return String(value).replace(/[\u0000-\u001F\u007F]/g, '').trim();
+  }
+
+  function formatRupiah(number) {
+    const n = Number(number);
+    if (!isFinite(n)) return 'Rp 0';
+    return 'Rp ' + n.toLocaleString('id-ID', { maximumFractionDigits: 0 });
+  }
+
+  function formatDate(date) {
+    if (!date) return '-';
+    const d = new Date(date);
+    if (isNaN(d)) return String(date);
+    return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' });
+  }
+
+  function formatDateTime(date) {
+    if (!date) return '-';
+    const d = new Date(date);
+    if (isNaN(d)) return String(date);
+    return d.toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
+  }
+
+  function relativeTime(date) {
+    if (!date) return '';
+    const d = new Date(date);
+    if (isNaN(d)) return '';
+    const diff = (Date.now() - d.getTime()) / 1000;
+    if (diff < 60) return 'baru saja';
+    if (diff < 3600) return Math.floor(diff/60) + ' menit lalu';
+    if (diff < 86400) return Math.floor(diff/3600) + ' jam lalu';
+    if (diff < 604800) return Math.floor(diff/86400) + ' hari lalu';
+    return formatDate(date);
+  }
+
+  function showToast(message, type='info') {
+    const root = $('#toast-root');
+    if (!root) return;
+    const map = {
+      success: { cls: 'bg-success text-white', icon: 'check-circle' },
+      error:   { cls: 'bg-danger text-white',  icon: 'alert-circle' },
+      warning: { cls: 'bg-warning text-white', icon: 'alert-triangle' },
+      info:    { cls: 'bg-text-main text-white', icon: 'info' },
+    };
+    const m = map[type] || map.info;
+    const el = document.createElement('div');
+    el.className = `${m.cls} px-4 py-3 rounded-xl shadow-pop flex items-center gap-3 toast-enter`;
+    el.innerHTML = `<i data-lucide="${m.icon}" class="w-5 h-5 shrink-0"></i><span class="text-sm font-semibold">${escapeHtml(message)}</span>`;
+    root.appendChild(el);
+    refreshIcons();
+    setTimeout(() => {
+      el.style.transition = 'opacity .3s, transform .3s';
+      el.style.opacity = '0';
+      el.style.transform = 'translateX(20px)';
+      setTimeout(() => el.remove(), 300);
+    }, 3000);
+  }
+
+  function showLoading(target) {
+    const html = `
+      <div class="space-y-3">
+        <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
+          ${Array(4).fill('<div class="skeleton h-24"></div>').join('')}
+        </div>
+        <div class="skeleton h-64"></div>
+      </div>`;
+    if (target instanceof HTMLElement) target.innerHTML = html;
+    else if (typeof target === 'string') { const el = $(target); if (el) el.innerHTML = html; }
+    else $('#main-content').innerHTML = html;
+  }
+
+  function hideLoading(target) {
+    if (target instanceof HTMLElement) { target.innerHTML = ''; return; }
+    if (typeof target === 'string') { const el = $(target); if (el) el.innerHTML = ''; return; }
+  }
+
+  function showEmptyState(message, opts={}) {
+    const icon = opts.icon || 'inbox';
+    const action = opts.action ? `<button class="mt-4 btn-primary px-5 py-2 rounded-xl font-bold text-sm" onclick="${opts.action.onclick}">${escapeHtml(opts.action.label)}</button>` : '';
+    return `
+      <div class="bg-white border border-border-soft rounded-3xl p-10 flex flex-col items-center text-center">
+        <div class="w-16 h-16 rounded-2xl bg-primary-soft text-primary flex items-center justify-center mb-4">
+          <i data-lucide="${icon}" class="w-8 h-8"></i>
+        </div>
+        <p class="text-text-main font-bold">${escapeHtml(message || 'Belum ada data')}</p>
+        <p class="text-text-muted text-sm mt-1">${escapeHtml(opts.hint || 'Data akan muncul di sini ketika tersedia.')}</p>
+        ${action}
+      </div>`;
+  }
+
+  function openModal(title, content) {
+    $('#modal-title').textContent = title || '';
+    $('#modal-body').innerHTML = content || '';
+    $('#modal-root').classList.remove('hidden');
+    document.body.style.overflow = 'hidden';
+    refreshIcons();
+  }
+
+  function closeModal() {
+    $('#modal-root').classList.add('hidden');
+    $('#modal-body').innerHTML = '';
+    document.body.style.overflow = '';
