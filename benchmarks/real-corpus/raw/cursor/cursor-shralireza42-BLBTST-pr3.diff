+  @@index([roundId])
+  @@index([status])
+  @@index([vrfRequestId])
+  @@index([blockNumber])
+}
+
+model JackpotCycle {
+  id                    BigInt             @id
+  chainId               Int                @default(56)
+  contractAddress       String?
+  status                JackpotCycleStatus @default(OPEN)
+  startedAt             DateTime           @default(now())
+  thresholdMetAt        DateTime?
+  randomnessRequestedAt DateTime?
+  endedAt               DateTime?
+  thresholdUsdE18       Decimal            @default(100000000000000000000000) @db.Decimal(78, 0)
+  thresholdBlobbie      Decimal            @default(0) @db.Decimal(78, 0)
+  reserveBalance        Decimal            @default(0) @db.Decimal(78, 0)
+  totalContributed      Decimal            @default(0) @db.Decimal(78, 0)
+  eligibleTicketCount   Int                @default(0)
+  vrfRequestId          Decimal?           @db.Decimal(78, 0)
+  randomness            Decimal?           @db.Decimal(78, 0)
+  winnerWalletAddress   String?
+  paidAmount            Decimal            @default(0) @db.Decimal(78, 0)
+  txHash                String?
+  settlementTxHash      String?
+  blockNumber           BigInt?
+  createdAt             DateTime           @default(now())
+  updatedAt             DateTime           @updatedAt
+
+  entries       JackpotEntry[]
+  contributions JackpotContribution[]
+  winner        JackpotWinner?
+
+  @@unique([chainId, contractAddress, id])
+  @@index([status])
+  @@index([startedAt])
+  @@index([vrfRequestId])
+  @@index([blockNumber])
+}
+
+model JackpotEntry {
