+model User {
+  id              String       @id @default(cuid())
+  email           String?      @unique
+  username        String?      @unique
+  status          UserStatus   @default(ACTIVE)
+  reviewStatus    ReviewStatus @default(NONE)
+  fraudExcluded   Boolean      @default(false)
+  bannedAt        DateTime?
+  fraudRejectedAt DateTime?
+  lastLoginAt     DateTime?
+  createdAt       DateTime     @default(now())
+  updatedAt       DateTime     @updatedAt
+  deletedAt       DateTime?
+
+  wallets                    Wallet[]
+  profile                    Profile?
+  referralCodes              ReferralCode[]
+  referralBindingsAsUser     ReferralBinding[]     @relation("ReferralBindingUser")
+  referralBindingsAsReferrer ReferralBinding[]     @relation("ReferralBindingReferrer")
