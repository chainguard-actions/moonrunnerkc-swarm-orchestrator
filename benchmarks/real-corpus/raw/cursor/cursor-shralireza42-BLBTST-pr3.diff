+  txHash          String?
+  logIndex        Int?
+  blockNumber     BigInt?
+  createdAt       DateTime        @default(now())
+  updatedAt       DateTime        @updatedAt
+
+  cycle  JackpotCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
+  wallet Wallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)
+
+  @@unique([txHash, logIndex])
+  @@index([cycleId])
+  @@index([walletId])
+  @@index([walletAddress])
+  @@index([source])
+  @@index([eligible])
+}
+
+model JackpotContribution {
