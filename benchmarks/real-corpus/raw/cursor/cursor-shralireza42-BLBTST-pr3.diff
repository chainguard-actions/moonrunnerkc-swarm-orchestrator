+
+  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
+}
+
+model DrawRound {
+  id                    BigInt          @id
+  chainId               Int             @default(56)
+  contractAddress       String?
+  status                DrawRoundStatus @default(OPEN)
+  openedAt              DateTime
+  expiresAt             DateTime
+  closedAt              DateTime?
+  finalizedAt           DateTime?
+  eligibleTicketCount   Int             @default(0)
+  totalEntryCount       Int             @default(0)
+  uniqueWalletCount     Int             @default(0)
+  grossTicketRevenue    Decimal         @default(0) @db.Decimal(78, 0)
+  prizePool             Decimal         @default(0) @db.Decimal(78, 0)
+  jackpotContribution   Decimal         @default(0) @db.Decimal(78, 0)
+  operationalTopUp      Decimal         @default(0) @db.Decimal(78, 0)
+  topUpRequired         Decimal         @default(0) @db.Decimal(78, 0)
+  dailyPrizePaid        Decimal         @default(0) @db.Decimal(78, 0)
+  jackpotPaid           Decimal         @default(0) @db.Decimal(78, 0)
+  freeEntryReserve      Decimal         @default(0) @db.Decimal(78, 0)
+  burnTreasuryReserve   Decimal         @default(0) @db.Decimal(78, 0)
+  dailyWinner           String?
+  jackpotWinner         String?
+  vrfRequestId          Decimal?        @db.Decimal(78, 0)
+  randomness            Decimal?        @db.Decimal(78, 0)
+  jackpotEligible       Boolean         @default(false)
+  reviewStatus          ReviewStatus    @default(NONE)
+  reviewReason          String?
+  txHash                String?
+  closeTxHash           String?
+  settlementTxHash      String?
+  blockNumber           BigInt?
+  closeBlockNumber      BigInt?
+  settlementBlockNumber BigInt?
+  createdAt             DateTime        @default(now())
+  updatedAt             DateTime        @updatedAt
+
+  entries        DrawEntry[]
+  winners        DrawWinner[]
+  settlements    DrawSettlement[]
+  priceSnapshots PriceSnapshot[]
+  purchases      TicketPurchase[]
+  topUps         DrawTopUp[]
+
+  @@unique([chainId, contractAddress, id])
+  @@index([status])
+  @@index([openedAt])
+  @@index([expiresAt])
+  @@index([txHash])
+  @@index([blockNumber])
+}
+
+model DrawEntry {
+  id                  String          @id @default(cuid())
+  roundId             BigInt
+  walletId            String?
+  userId              String?
+  walletAddress       String
+  chainId             Int             @default(56)
+  contractAddress     String?
+  source              DrawEntrySource @default(PAID)
+  status              DrawEntryStatus @default(ELIGIBLE)
+  quantity            Int
+  eligibleQuantity    Int             @default(0)
+  startInclusive      Int?
+  endExclusive        Int?
+  blobbyPaid          Decimal         @default(0) @db.Decimal(78, 0)
+  usdValueE18         Decimal         @default(0) @db.Decimal(78, 0)
+  jackpotContribution Decimal         @default(0) @db.Decimal(78, 0)
+  excludedReason      String?
+  fraudExcluded       Boolean         @default(false)
+  txHash              String?
+  logIndex            Int?
+  blockNumber         BigInt?
+  createdAt           DateTime        @default(now())
+  updatedAt           DateTime        @updatedAt
+
+  round  DrawRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
+  wallet Wallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)
+
+  @@unique([chainId, txHash, logIndex])
+  @@index([roundId])
+  @@index([walletId])
+  @@index([walletAddress])
+  @@index([source])
+  @@index([status])
+  @@index([blockNumber])
+}
+
+model DrawWinner {
+  id            String         @id @default(cuid())
+  roundId       BigInt
+  walletId      String?
+  walletAddress String?
+  winner        String?
+  slot          Int?
+  tier          DrawPrizeTier?
+  prizeType     String         @default("DAILY")
+  amount        Decimal        @db.Decimal(78, 0)
+  usdValueE18   Decimal        @default(0) @db.Decimal(78, 0)
+  paid          Boolean        @default(false)
+  txHash        String?
+  logIndex      Int?
+  blockNumber   BigInt?
+  createdAt     DateTime       @default(now())
+  updatedAt     DateTime       @updatedAt
+
+  round  DrawRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
+  wallet Wallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)
+
+  @@unique([roundId, slot])
+  @@unique([roundId, walletAddress])
+  @@unique([txHash, logIndex, prizeType])
+  @@unique([txHash, logIndex, tier])
+  @@index([walletId])
+  @@index([walletAddress])
+  @@index([winner])
+  @@index([tier])
+  @@index([prizeType])
+  @@index([blockNumber])
+}
+
+model DrawPrizeConfig {
