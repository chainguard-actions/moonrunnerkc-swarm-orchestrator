+  txHash          String?
+  logIndex        Int?
+  blockNumber     BigInt?
+  createdAt       DateTime @default(now())
+
+  cycle JackpotCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
+
+  @@unique([chainId, txHash, logIndex])
+  @@index([cycleId])
+  @@index([drawRoundId])
+  @@index([blockNumber])
