+  fraudExcluded   Boolean      @default(false)
+  bannedAt        DateTime?
+  fraudRejectedAt DateTime?
+  firstSeenAt     DateTime     @default(now())
+  lastSeenAt      DateTime?
+  createdAt       DateTime     @default(now())
+  updatedAt       DateTime     @updatedAt
+  deletedAt       DateTime?
+
+  user                User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
+  drawEntries         DrawEntry[]
+  drawWinners         DrawWinner[]
+  jackpotEntries      JackpotEntry[]
+  jackpotWinners      JackpotWinner[]
+  rewardLedgerEntries RewardLedgerEntry[]
+  referralCodes       ReferralCode[]
+  referralRewards     ReferralReward[]
+  taskClaims          TaskClaim[]
+  fraudSignals        FraudSignal[]
+  fraudCases          FraudCase[]
+  supportTickets      SupportTicket[]
+  bugReports          BugReport[]
+
+  @@unique([chainId, address])
+  @@index([userId])
+  @@index([status])
+  @@index([fraudExcluded])
+  @@index([address])
