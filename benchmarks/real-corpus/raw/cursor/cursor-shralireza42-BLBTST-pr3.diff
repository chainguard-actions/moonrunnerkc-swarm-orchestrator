+FROM node:22-alpine AS base
+WORKDIR /app
+RUN corepack enable
+
+FROM base AS deps
+COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
+COPY apps/web/package.json apps/web/package.json
+RUN pnpm install --filter @blobby/web --frozen-lockfile
+
+FROM deps AS build
+ARG NEXT_PUBLIC_API_BASE_URL
+ARG NEXT_PUBLIC_REOWN_PROJECT_ID
+ARG NEXT_PUBLIC_CHAIN_ID
+ARG NEXT_PUBLIC_BLOBBIE_TOKEN_ADDRESS
+ARG NEXT_PUBLIC_DAILY_DRAW_CONTRACT_ADDRESS
+ARG NEXT_PUBLIC_JACKPOT_VAULT_CONTRACT_ADDRESS
+ARG NEXT_PUBLIC_PRICE_ADAPTER_CONTRACT_ADDRESS
+ARG NEXT_PUBLIC_EXPLORER_BASE_URL
+ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
+ENV NEXT_PUBLIC_REOWN_PROJECT_ID=$NEXT_PUBLIC_REOWN_PROJECT_ID
+ENV NEXT_PUBLIC_CHAIN_ID=$NEXT_PUBLIC_CHAIN_ID
+ENV NEXT_PUBLIC_BLOBBIE_TOKEN_ADDRESS=$NEXT_PUBLIC_BLOBBIE_TOKEN_ADDRESS
+ENV NEXT_PUBLIC_DAILY_DRAW_CONTRACT_ADDRESS=$NEXT_PUBLIC_DAILY_DRAW_CONTRACT_ADDRESS
+ENV NEXT_PUBLIC_JACKPOT_VAULT_CONTRACT_ADDRESS=$NEXT_PUBLIC_JACKPOT_VAULT_CONTRACT_ADDRESS
+ENV NEXT_PUBLIC_PRICE_ADAPTER_CONTRACT_ADDRESS=$NEXT_PUBLIC_PRICE_ADAPTER_CONTRACT_ADDRESS
+ENV NEXT_PUBLIC_EXPLORER_BASE_URL=$NEXT_PUBLIC_EXPLORER_BASE_URL
+COPY tsconfig.base.json ./
+COPY apps/web apps/web
+RUN pnpm --filter @blobby/web build
+
+FROM node:22-alpine AS runner
+WORKDIR /app
+ENV NODE_ENV=production
+RUN corepack enable
+COPY --from=build /app/package.json /app/pnpm-workspace.yaml ./
+COPY --from=build /app/node_modules ./node_modules
+COPY --from=build /app/apps/web ./apps/web
+EXPOSE 3000
+CMD ["pnpm", "--filter", "@blobby/web", "start"]
