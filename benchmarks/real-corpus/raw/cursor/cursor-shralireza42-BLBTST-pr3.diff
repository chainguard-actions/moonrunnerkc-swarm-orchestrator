diff --git a/apps/web/app/globals.css b/apps/web/app/globals.css
new file mode 100644
index 0000000..b22be37
--- /dev/null
+++ b/apps/web/app/globals.css
@@ -0,0 +1,30 @@
+@import "tailwindcss";
+
+:root {
+  --blobbie-bg: #f7f8df;
+  --blobbie-ink: #020202;
+  --blobbie-cream: #fff8df;
+  --blobbie-red: #bc352a;
+  --blobbie-peach: #ffc4ad;
+  --blobbie-line: #020202;
+}
+
+* { box-sizing: border-box; }
+html { scroll-behavior: smooth; }
+body {
+  min-height: 100vh;
+  background:
+    radial-gradient(circle at 20% 10%, rgba(255,196,173,.55), transparent 28rem),
+    radial-gradient(circle at 80% 0%, rgba(255,248,223,.95), transparent 24rem),
+    var(--blobbie-bg);
+  color: var(--blobbie-ink);
+  overflow-x: hidden;
+}
+button, input, select, textarea { font: inherit; }
+::selection { background: var(--blobbie-red); color: var(--blobbie-cream); }
+.blobbie-outline { border: 4px solid var(--blobbie-line); box-shadow: 8px 8px 0 var(--blobbie-line); }
+.blobbie-soft { border: 3px solid var(--blobbie-line); box-shadow: 5px 5px 0 var(--blobbie-line); }
+.display-text { font-family: var(--font-dela); color: var(--blobbie-ink); letter-spacing: -0.04em; }
+.body-text { font-family: var(--font-bricolage); font-style: italic; font-weight: 700; color: var(--blobbie-ink); }
+.no-scrollbar::-webkit-scrollbar { display: none; }
+.no-scrollbar { scrollbar-width: none; }
