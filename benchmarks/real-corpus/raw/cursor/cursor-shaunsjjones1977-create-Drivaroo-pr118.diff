diff --git a/src/app/compare/[slug]/page.tsx b/src/app/compare/[slug]/page.tsx
new file mode 100644
index 00000000..4e679714
--- /dev/null
+++ b/src/app/compare/[slug]/page.tsx
@@ -0,0 +1,146 @@
+import type { Metadata } from "next";
+import Link from "next/link";
+import { notFound } from "next/navigation";
+
+type Comparison = {
+  title: string;
+  description: string;
+  left: {
+    label: string;
+    searchHref: string;
+    strengths: string[];
+  };
+  right: {
+    label: string;
+    searchHref: string;
+    strengths: string[];
+  };
+};
+
+const comparisons: Record<string, Comparison> = {
+  "cx-5-vs-rav4": {
+    title: "Mazda CX-5 vs Toyota RAV4",
+    description:
+      "Compare two popular family SUVs, then browse matching Drivaroo listings.",
+    left: {
+      label: "Mazda CX-5",
+      searchHref: "/cars?search=Mazda+CX-5&bodyType=SUV",
+      strengths: ["Premium-feeling cabin", "Family SUV practicality", "Strong used-market choice"],
+    },
+    right: {
+      label: "Toyota RAV4",
+      searchHref: "/cars?search=Toyota+RAV4&bodyType=SUV",
+      strengths: ["Toyota reliability reputation", "Family-friendly space", "Popular hybrid options"],
+    },
+  },
+  "hilux-vs-ranger": {
+    title: "Toyota Hilux vs Ford Ranger",
+    description:
+      "Compare two of Australia's best-known utes, then browse matching Drivaroo listings.",
+    left: {
+      label: "Toyota Hilux",
+      searchHref: "/cars?search=Toyota+Hilux&bodyType=Ute",
+      strengths: ["Proven workhorse reputation", "Strong 4x4 demand", "Popular trade and touring ute"],
+    },
+    right: {
+      label: "Ford Ranger",
+      searchHref: "/cars?search=Ford+Ranger&bodyType=Ute",
+      strengths: ["Strong towing appeal", "Comfortable dual-cab options", "Popular family/work ute"],
+    },
+  },
+};
+
+type Props = {
+  params: Promise<{
+    slug: string;
+  }>;
+};
+
+export async function generateMetadata({ params }: Props): Promise<Metadata> {
+  const { slug } = await params;
+  const comparison = comparisons[slug];
+
+  if (!comparison) {
+    return {};
+  }
+
+  return {
+    title: `${comparison.title} | Drivaroo`,
+    description: comparison.description,
+    alternates: {
+      canonical: `/compare/${slug}`,
+    },
+  };
+}
+
+function ComparisonColumn({
+  href,
+  label,
+  strengths,
+}: {
+  href: string;
+  label: string;
+  strengths: string[];
+}) {
+  return (
+    <article className="rounded-[1.5rem] border border-white/10 bg-[#15161a] p-6 shadow-xl shadow-black/20">
+      <h2 className="text-2xl font-black text-white">{label}</h2>
+      <ul className="mt-5 space-y-3 text-sm text-white/60">
+        {strengths.map((strength) => (
+          <li key={strength} className="flex gap-2">
+            <span className="text-[#d4af37]">✓</span>
+            <span>{strength}</span>
+          </li>
+        ))}
+      </ul>
+      <Link
+        href={href}
+        className="mt-6 inline-flex rounded-xl bg-[#d4af37] px-5 py-3 text-sm font-bold text-black hover:bg-[#e6c65c]"
+      >
+        Browse {label}
+      </Link>
+    </article>
+  );
+}
+
+export default async function ComparePage({ params }: Props) {
+  const { slug } = await params;
+  const comparison = comparisons[slug];
+
+  if (!comparison) {
+    notFound();
+  }
+
+  return (
+    <main className="min-h-screen bg-[#0d0d0f] px-6 py-16 text-white">
+      <div className="mx-auto max-w-6xl">
+        <section className="rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_85%_20%,rgba(212,175,55,0.18),transparent_30rem),#15161a] p-8 shadow-2xl shadow-black/30">
+          <p className="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-[#d4af37]">
+            Vehicle comparison
+          </p>
+          <h1 className="text-4xl font-black text-white sm:text-5xl">
+            {comparison.title}
+          </h1>
+          <p className="mt-5 max-w-3xl leading-8 text-white/60">
+            {comparison.description} Use this as a guide only; inspect each
+            vehicle, compare history, condition, kilometres, features and price
+            before enquiring.
+          </p>
+        </section>
+
+        <section className="mt-8 grid gap-5 md:grid-cols-2">
+          <ComparisonColumn
+            href={comparison.left.searchHref}
+            label={comparison.left.label}
+            strengths={comparison.left.strengths}
+          />
+          <ComparisonColumn
+            href={comparison.right.searchHref}
+            label={comparison.right.label}
+            strengths={comparison.right.strengths}
+          />
+        </section>
+      </div>
+    </main>
+  );
+}
