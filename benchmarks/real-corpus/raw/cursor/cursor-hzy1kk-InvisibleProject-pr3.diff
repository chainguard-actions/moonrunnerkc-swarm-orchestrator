diff --git a/style.css b/style.css
index 2844165..b37560b 100644
--- a/style.css
+++ b/style.css
@@ -1062,3 +1062,230 @@ body.tema-escuro .tech-tags span {
     justify-content: center;
   }
 }
+
+
+/* ——— Colégio Paulo de Tarso (imagens oficiais) ——— */
+.marca-logo {
+  object-fit: contain;
+  border-radius: 10px;
+  filter: drop-shadow(0 4px 12px rgba(30, 136, 229, 0.25));
+}
+
+.hero-visual-duplo {
+  position: relative;
+  min-height: 320px;
+}
+
+.hero-card-ia {
+  position: absolute;
+  bottom: -12px;
+  left: -24px;
+  width: 42%;
+  max-width: 200px;
+  margin: 0;
+  padding: 0.5rem;
+  border-radius: var(--raio-sm);
+  overflow: hidden;
+  transform: translateZ(60px) rotate(-4deg);
+  z-index: 3;
+}
+
+.hero-card-ia img {
+  border-radius: 8px;
+  width: 100%;
+  aspect-ratio: 4/3;
+  object-fit: cover;
+}
+
+.hero-card-ia figcaption {
+  font-family: var(--mono);
+  font-size: 0.6rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  color: var(--text-muted);
+  margin-top: 0.35rem;
+  text-align: center;
+}
+
+.hero-imagem-escola img {
+  width: 100%;
+  aspect-ratio: 16/10;
+  object-fit: cover;
+}
+
+/* Seção escola */
+.secao-escola {
+  padding-top: 0;
+  padding-left: 0;
+  padding-right: 0;
+}
+
+.escola-banner-wrap {
+  position: relative;
+  max-height: 320px;
+  overflow: hidden;
+  margin-bottom: 3rem;
+}
+
+.escola-banner-wide {
+  width: 100%;
+  height: 320px;
+  object-fit: cover;
+  object-position: center;
+}
+
+.escola-banner-overlay {
+  position: absolute;
+  bottom: 1.5rem;
+  left: 50%;
+  transform: translateX(-50%);
+  padding: 0.75rem 1.5rem;
+  border-radius: var(--raio);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.escola-logo-grande {
+  height: 72px;
+  width: auto;
+  object-fit: contain;
+}
+
+.escola-conteudo {
+  padding: 0 1.5rem 2rem;
+}
+
+.diferenciais-escola {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 1.25rem;
+  margin: 2.5rem 0;
+}
+
+.dif-item {
+  padding: 1.25rem;
+  text-align: center;
+}
+
+.dif-item img:not(.dif-banner-mini) {
+  margin: 0 auto 0.75rem;
+  object-fit: contain;
+}
+
+.dif-banner-mini {
+  width: 100%;
+  height: 100px;
+  object-fit: cover;
+  border-radius: var(--raio-sm);
+  margin-bottom: 0.75rem;
+}
+
+.dif-item h3 {
+  margin: 0 0 0.35rem;
+  font-size: 1rem;
+  color: var(--azul-deep);
+}
+
+body.tema-escuro .dif-item h3 {
+  color: #90caf9;
+}
+
+.dif-item p {
+  margin: 0;
+  font-size: 0.88rem;
+  color: var(--text-muted);
+}
+
+.galeria-escola {
+  display: grid;
+  grid-template-columns: repeat(3, 1fr);
+  gap: 1rem;
+  margin: 1.25rem 0 2rem;
+}
+
+.galeria-item {
+  margin: 0;
+  overflow: hidden;
+  border-radius: var(--raio);
+  padding: 0;
+}
+
+.galeria-item img {
+  width: 100%;
+  aspect-ratio: 1;
+  object-fit: cover;
+  transition: transform 0.5s var(--ease-out);
+}
+
+.galeria-item:hover img {
+  transform: scale(1.06);
+}
+
+.galeria-item figcaption {
+  font-family: var(--mono);
+  font-size: 0.72rem;
+  text-align: center;
+  padding: 0.6rem;
+  color: var(--text-muted);
+  text-transform: uppercase;
+  letter-spacing: 0.06em;
+}
+
+.escola-cta {
+  padding: 1.75rem 2rem;
+  text-align: center;
+  margin-top: 1rem;
+}
+
+.escola-cta p {
+  margin: 0 0 1rem;
+  color: var(--text-muted);
+}
+
+.credito-imagens {
+  font-size: 0.75rem !important;
+  opacity: 0.7;
+  margin-top: 1rem !important;
+  margin-bottom: 0 !important;
+}
+
+.projeto-local-banner {
+  margin: 0 0 2rem;
+  border-radius: var(--raio);
+  overflow: hidden;
+  box-shadow: var(--sombra-3d);
+}
+
+.projeto-local-banner img {
+  width: 100%;
+  max-height: 220px;
+  object-fit: cover;
+}
+
+.rodape-logo {
+  margin: 0 auto 1rem;
+  height: 64px;
+  width: auto;
+  object-fit: contain;
+  opacity: 0.95;
+}
+
+@media (max-width: 900px) {
+  .diferenciais-escola,
+  .galeria-escola {
+    grid-template-columns: 1fr;
+  }
+
+  .hero-card-ia {
+    position: relative;
+    left: auto;
+    bottom: auto;
+    width: 60%;
+    margin: -2rem auto 0;
+  }
+
+  .escola-logo-grande {
+    height: 48px;
+  }
+}
