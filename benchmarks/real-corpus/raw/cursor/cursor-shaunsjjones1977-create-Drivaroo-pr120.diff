+import { buildDealerCalendarIcs } from "@/lib/dealer-calendar-events";
+
+export async function GET(request: Request) {
+  const origin = new URL(request.url).origin;
+  const body = buildDealerCalendarIcs(origin);
+
+  return new Response(body, {
+    headers: {
+      "Cache-Control": "no-store",
+      "Content-Disposition": 'attachment; filename="drivaroo-dealer-calendar.ics"',
+      "Content-Type": "text/calendar; charset=utf-8",
+    },
+  });
+}
