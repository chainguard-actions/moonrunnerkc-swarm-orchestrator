@@ -0,0 +1,54 @@
+"use client";
+
+import { useState } from "react";
+
+export default function DealerCalendarReminderButton() {
+  const [isSending, setIsSending] = useState(false);
+  const [status, setStatus] = useState("");
+
+  async function sendReminder() {
+    setIsSending(true);
+    setStatus("");
+
+    try {
+      const response = await fetch("/api/dealers/calendar/reminders", {
+        method: "POST",
+      });
+      const data = (await response.json().catch(() => null)) as {
+        error?: string;
+        push?: { sent?: number; skipped?: boolean };
+      } | null;
+
+      if (!response.ok) {
+        setStatus(data?.error ?? "Could not send calendar reminder.");
+        return;
+      }
+
+      if (data?.push?.sent) {
+        setStatus("Push reminder sent for the next calendar item.");
+      } else if (data?.push?.skipped) {
+        setStatus("Push reminders are not configured yet.");
+      } else {
+        setStatus("No push subscription found. Enable notifications first.");
+      }
+    } catch {
+      setStatus("Could not send calendar reminder.");
+    } finally {
+      setIsSending(false);
+    }
+  }
+
+  return (
+    <div>
+      <button
+        type="button"
+        onClick={sendReminder}
+        disabled={isSending}
+        className="rounded-xl border border-[#d4af37]/45 px-4 py-2 text-sm font-bold text-[#f4d77c] hover:bg-[#d4af37]/10 disabled:cursor-not-allowed disabled:opacity-60"
+      >
+        {isSending ? "Sending..." : "Send push reminder"}
+      </button>
+      {status ? <p className="mt-2 text-xs text-white/45">{status}</p> : null}
+    </div>
+  );
+}
diff --git a/src/lib/dealer-calendar-events.ts b/src/lib/dealer-calendar-events.ts
new file mode 100644
index 0000000..ac9a7b0
--- /dev/null
+++ b/src/lib/dealer-calendar-events.ts
@@ -0,0 +1,128 @@
+import { sampleDealerCrmLeads } from "@/lib/dealer-crm-sample-leads";
+
+export type DealerCalendarEvent = {
+  customerName: string;
+  day: string;
+  label: string;
+  leadId: string;
+  time: string;
+  vehicleTitle: string;
+};
+
+const dayIndexes: Record<string, number> = {
+  Sunday: 0,
+  Monday: 1,
+  Tuesday: 2,
+  Wednesday: 3,
+  Thursday: 4,
+  Friday: 5,
+  Saturday: 6,
+};
+
+function pad(value: number) {
+  return String(value).padStart(2, "0");
+}
+
+export function getDealerCalendarEvents(): DealerCalendarEvent[] {
+  return sampleDealerCrmLeads.flatMap((lead) =>
+    (lead.schedule ?? []).flatMap((day) =>
+      day.items.map((item) => ({
+        ...item,
+        day: day.day,
+        leadId: lead.id,
+        customerName: lead.buyer.name,
+        vehicleTitle: lead.vehicle.title,
+      })),
+    ),
+  );
+}
+
+export function getNextEventDate(day: string, time: string, from = new Date()) {
+  const targetDay = dayIndexes[day] ?? 1;
+  const [hours = "9", minutes = "0"] = time.split(":");
+  const next = new Date(from);
+  const daysUntil = (targetDay - next.getDay() + 7) % 7;
+  next.setDate(next.getDate() + daysUntil);
+  next.setHours(Number(hours), Number(minutes), 0, 0);
+
+  if (next <= from) {
+    next.setDate(next.getDate() + 7);
+  }
+
+  return next;
+}
+
+export function formatIcsDate(date: Date) {
+  return `${date.getUTCFullYear()}${pad(date.getUTCMonth() + 1)}${pad(date.getUTCDate())}T${pad(date.getUTCHours())}${pad(date.getUTCMinutes())}${pad(date.getUTCSeconds())}Z`;
+}
+
+function escapeIcsText(value: string) {
+  return value
+    .replace(/\\/g, "\\\\")
+    .replace(/;/g, "\\;")
+    .replace(/,/g, "\\,")
+    .replace(/\n/g, "\\n");
+}
+
+export function buildDealerCalendarIcs(origin: string) {
+  const now = new Date();
+  const events = getDealerCalendarEvents();
+  const lines = [
+    "BEGIN:VCALENDAR",
+    "VERSION:2.0",
+    "PRODID:-//Drivaroo//Dealer Calendar//EN",
+    "CALSCALE:GREGORIAN",
+    "METHOD:PUBLISH",
+  ];
+
+  for (const event of events) {
+    const start = getNextEventDate(event.day, event.time, now);
+    const end = new Date(start.getTime() + 60 * 60 * 1000);
+    const summary = `${event.label} - ${event.customerName}`;
+    const description = `${event.vehicleTitle} via Drivaroo dealer calendar`;
+
+    lines.push(
+      "BEGIN:VEVENT",
+      `UID:${event.leadId}-${event.day}-${event.time}@drivaroo.com`,
+      `DTSTAMP:${formatIcsDate(now)}`,
+      `DTSTART:${formatIcsDate(start)}`,
+      `DTEND:${formatIcsDate(end)}`,
+      `SUMMARY:${escapeIcsText(summary)}`,
+      `DESCRIPTION:${escapeIcsText(description)}`,
+      `URL:${origin}/dealers/crm/${encodeURIComponent(event.leadId)}`,
+      "BEGIN:VALARM",
+      "TRIGGER:-PT30M",
+      "ACTION:DISPLAY",
+      `DESCRIPTION:${escapeIcsText(summary)}`,
+      "END:VALARM",
+      "END:VEVENT",
+    );
+  }
+
+  lines.push("END:VCALENDAR");
+  return `${lines.join("\r\n")}\r\n`;
+}
+
+export function buildGoogleCalendarUrl(event: DealerCalendarEvent, origin: string) {
+  const start = getNextEventDate(event.day, event.time);
+  const end = new Date(start.getTime() + 60 * 60 * 1000);
+  const params = new URLSearchParams({
+    action: "TEMPLATE",
+    text: `${event.label} - ${event.customerName}`,
+    dates: `${formatIcsDate(start).replace(/Z$/, "Z")}/${formatIcsDate(end).replace(/Z$/, "Z")}`,
+    details: `${event.vehicleTitle} via Drivaroo dealer calendar`,
+    location: `${origin}/dealers/crm/${event.leadId}`,
+  });
+
+  return `https://calendar.google.com/calendar/render?${params.toString()}`;
+}
+
+export function getNextDealerCalendarEvent() {
+  const now = new Date();
+  return getDealerCalendarEvents()
+    .map((event) => ({
+      event,
+      start: getNextEventDate(event.day, event.time, now),
+    }))
+    .sort((first, second) => first.start.getTime() - second.start.getTime())[0];
+}
