@@ -0,0 +1,54 @@
+import { cookies } from "next/headers";
+import { NextResponse } from "next/server";
+import { getNextDealerCalendarEvent } from "@/lib/dealer-calendar-events";
+import { insertNotification } from "@/lib/notification-events";
+import { getSupabaseAdmin } from "@/lib/supabase-admin";
+import { sendPushToUser } from "@/lib/web-push-server";
+import { createClient } from "@/utils/supabase/server";
+
+export async function POST() {
+  const authClient = createClient(await cookies());
+  const {
+    data: { user },
+  } = await authClient.auth.getUser();
+
+  if (!user) {
+    return NextResponse.json({ error: "Please sign in." }, { status: 401 });
+  }
+
+  const next = getNextDealerCalendarEvent();
+  if (!next) {
+    return NextResponse.json({ error: "No calendar items found." }, { status: 404 });
+  }
+
+  const title = `Upcoming: ${next.event.label}`;
+  const body = `${next.event.time} ${next.event.customerName} - ${next.event.vehicleTitle}`;
+
+  try {
+    await insertNotification(getSupabaseAdmin(), {
+      body,
+      title,
+      type: "dealer_calendar_reminder",
+      userId: user.id,
+    });
+  } catch {
+    // Push is the primary action for this endpoint; in-app notification is best effort.
+  }
+
+  const pushResult = await sendPushToUser(user.id, {
+    body,
+    title,
+    url: `/dealers/crm/${next.event.leadId}`,
+  });
+
+  return NextResponse.json({
+    nextEvent: {
+      customerName: next.event.customerName,
+      label: next.event.label,
+      time: next.event.time,
+      vehicleTitle: next.event.vehicleTitle,
+    },
+    push: pushResult,
+    success: true,
+  });
+}
