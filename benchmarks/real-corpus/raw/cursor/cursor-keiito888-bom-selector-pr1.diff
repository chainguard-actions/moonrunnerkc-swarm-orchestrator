+
+type FormFieldsProps = {
+  initialName?: string;
+  initialClient?: string;
+  initialFolder?: string;
+  existingFolders: string[];
+  isEdit: boolean;
+  onSubmit: (name: string, client: string, folder: string) => void;
+  onOpenChange: (open: boolean) => void;
+};
+
+function FormFields({
+  initialName,
+  initialClient,
+  initialFolder,
+  existingFolders,
+  isEdit,
+  onSubmit,
+  onOpenChange,
+}: FormFieldsProps) {
+  const [name, setName] = useState(initialName ?? "");
+  const [client, setClient] = useState(initialClient ?? "");
+  const [folder, setFolder] = useState(initialFolder ?? "");
+
+  const handleSubmit = () => {
+    const trimmedName = name.trim();
+    if (!trimmedName) return;
+    onSubmit(trimmedName, client.trim(), folder.trim());
+    onOpenChange(false);
+  };
+
+  const datalistId = "folder-suggestions";
+
+  return (
+    <>
+      <FieldGroup>
+        <Field>
+          <FieldLabel htmlFor="project-name">盤名</FieldLabel>
+          <Input
+            id="project-name"
+            autoFocus
+            value={name}
+            onChange={(e) => setName(e.target.value)}
+            onKeyDown={(e) => {
+              if (e.key === "Enter") handleSubmit();
+            }}
+            placeholder="例: 第2ライン動力盤"
+          />
+        </Field>
+        <Field>
+          <FieldLabel htmlFor="project-client">客先名</FieldLabel>
+          <Input
+            id="project-client"
+            value={client}
+            onChange={(e) => setClient(e.target.value)}
+            onKeyDown={(e) => {
+              if (e.key === "Enter") handleSubmit();
+            }}
+            placeholder="例: 〇〇工場"
+          />
+        </Field>
+        <Field>
+          <FieldLabel htmlFor="project-folder">フォルダ</FieldLabel>
+          <Input
+            id="project-folder"
+            value={folder}
+            onChange={(e) => setFolder(e.target.value)}
+            onKeyDown={(e) => {
+              if (e.key === "Enter") handleSubmit();
+            }}
+            placeholder="例: 第1工場（空白でフォルダなし）"
+            list={datalistId}
+          />
+          {existingFolders.length > 0 && (
+            <datalist id={datalistId}>
+              {existingFolders.map((f) => (
+                <option key={f} value={f} />
+              ))}
+            </datalist>
+          )}
+        </Field>
+      </FieldGroup>
+      <AlertDialogFooter>
+        <AlertDialogCancel>キャンセル</AlertDialogCancel>
+        <AlertDialogAction
+          onClick={handleSubmit}
+          disabled={!name.trim()}
+        >
+          {isEdit ? "保存" : "追加"}
+        </AlertDialogAction>
+      </AlertDialogFooter>
+    </>
+  );
+}
