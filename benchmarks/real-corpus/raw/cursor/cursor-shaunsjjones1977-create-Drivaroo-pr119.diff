@@ -0,0 +1,99 @@
+export type DealerCrmPipelineStatus = "booked" | "contacted" | "negotiating" | "new";
+
+export type DealerCrmLead = {
+  assignedTo: string;
+  buyer: {
+    email: string;
+    name: string;
+    phone: string;
+  };
+  createdAt: string | null;
+  enquiryType: string;
+  id: string;
+  insights: string[];
+  message: string;
+  notes?: string[];
+  pipelineStatus?: DealerCrmPipelineStatus;
+  vehicle: {
+    id: string;
+    price: number | null;
+    title: string;
+  };
+};
+
+export const dealerCrmPipelineColumns = [
+  { label: "NEW", status: "new" },
+  { label: "CONTACTED", status: "contacted" },
+  { label: "BOOKED", status: "booked" },
+  { label: "NEGOTIATING", status: "negotiating" },
+] as const;
+
+export const sampleDealerCrmLeads: DealerCrmLead[] = [
+  {
+    assignedTo: "Sales Team",
+    buyer: { email: "", name: "John Smith", phone: "" },
+    createdAt: null,
+    enquiryType: "General Enquiry",
+    id: "sample-john-smith",
+    insights: [],
+    message: "Interested in the Toyota Hilux.",
+    notes: [
+      "Customer wants finance.",
+      "Returning Saturday.",
+      "Interested in tow package.",
+    ],
+    pipelineStatus: "new",
+    vehicle: { id: "sample-toyota-hilux-sr5", price: 34500, title: "Toyota Hilux" },
+  },
+  {
+    assignedTo: "Sales Team",
+    buyer: { email: "", name: "Sarah Jones", phone: "" },
+    createdAt: null,
+    enquiryType: "General Enquiry",
+    id: "sample-sarah-jones",
+    insights: ["Lead requires follow-up"],
+    message: "Followed up on finance and inspection questions.",
+    pipelineStatus: "contacted",
+    vehicle: { id: "", price: null, title: "Vehicle enquiry" },
+  },
+  {
+    assignedTo: "Sales Team",
+    buyer: { email: "", name: "Michael Brown", phone: "" },
+    createdAt: null,
+    enquiryType: "General Enquiry",
+    id: "sample-michael-brown",
+    insights: ["Customer likely to purchase"],
+    message: "Inspection booked.",
+    pipelineStatus: "booked",
+    vehicle: { id: "", price: null, title: "Vehicle enquiry" },
+  },
+  {
+    assignedTo: "Sales Team",
+    buyer: { email: "", name: "David Lee", phone: "" },
+    createdAt: null,
+    enquiryType: "General Enquiry",
+    id: "sample-david-lee",
+    insights: [],
+    message: "Negotiating final price.",
+    pipelineStatus: "negotiating",
+    vehicle: { id: "", price: null, title: "Vehicle enquiry" },
+  },
+];
+
+export function inferDealerCrmPipelineStatus(
+  lead: DealerCrmLead,
+): DealerCrmPipelineStatus {
+  if (lead.pipelineStatus) {
+    return lead.pipelineStatus;
+  }
+
+  if (lead.insights.includes("Customer likely to purchase")) {
+    return "negotiating";
+  }
+
+  if (lead.insights.includes("Lead requires follow-up")) {
+    return "contacted";
+  }
+
+  return "new";
+}
