+  }
+
+  return (
+    <div className="mt-4 space-y-2">
+      {items.map(([label, count]) => (
+        <div
+          key={label}
+          className="flex items-center justify-between gap-3 rounded-xl border border-white/10 bg-white/[0.03] p-3"
+        >
+          <span className="truncate text-sm font-semibold text-white">{label}</span>
+          <span className="rounded-full bg-[#d4af37] px-3 py-1 text-xs font-black text-black">
+            {count.toLocaleString("en-AU")}
+          </span>
+        </div>
+      ))}
+    </div>
+  );
+}
