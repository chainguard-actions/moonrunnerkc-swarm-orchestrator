+"use client";
+
+import Link from "next/link";
+import { useEffect, useMemo, useState } from "react";
+import {
+  dealerCrmPipelineColumns,
+  inferDealerCrmPipelineStatus,
+  sampleDealerCrmLeads,
+  type DealerCrmLead,
+} from "@/lib/dealer-crm-sample-leads";
+
+type CrmResponse = {
+  error?: string;
+  leads?: DealerCrmLead[];
+  totals?: {
+    leads: number;
+    vehicles: number;
+  };
+};
+
+const emptyLeads: DealerCrmLead[] = [];
+
+function formatMoney(value: number | null) {
+  return value ? `$${value.toLocaleString("en-AU")}` : "POA";
+}
+
+export default function DealerCrmPage() {
+  const [data, setData] = useState<CrmResponse | null>(null);
+  const [isLoading, setIsLoading] = useState(true);
+  const [statusFilter, setStatusFilter] = useState("all");
+  const [search, setSearch] = useState("");
+
+  useEffect(() => {
+    const controller = new AbortController();
+
+    async function loadCrm() {
+      try {
+        const response = await fetch("/api/dealers/leads", {
+          signal: controller.signal,
+        });
+        const json = (await response.json().catch(() => null)) as CrmResponse | null;
+        setData(
+          response.ok
+            ? json
+            : {
+                error: json?.error ?? "Could not load CRM leads.",
+              },
+        );
+      } catch (error) {
+        if (error instanceof DOMException && error.name === "AbortError") {
+          return;
+        }
+        setData({ error: "Could not load CRM leads." });
+      } finally {
+        if (!controller.signal.aborted) {
+          setIsLoading(false);
+        }
+      }
+    }
+
+    loadCrm();
+
+    return () => controller.abort();
+  }, []);
+
+  const liveLeads = data?.leads ?? emptyLeads;
+  const leads = liveLeads.length > 0 ? liveLeads : sampleDealerCrmLeads;
+  const filteredLeads = useMemo(() => {
+    const query = search.trim().toLowerCase();
+
+    return leads.filter((lead) => {
+      const matchesStatus =
+        statusFilter === "all" ||
+        (statusFilter === "follow-up"
+          ? lead.insights.includes("Lead requires follow-up")
+          : lead.enquiryType.toLowerCase().includes(statusFilter));
+      const matchesSearch =
+        !query ||
+        [
+          lead.buyer.name,
+          lead.buyer.email,
+          lead.buyer.phone,
+          lead.vehicle.title,
+          lead.message,
+          lead.assignedTo,
+          lead.enquiryType,
+        ]
+          .join(" ")
+          .toLowerCase()
+          .includes(query);
+
+      return matchesStatus && matchesSearch;
+    });
+  }, [leads, search, statusFilter]);
+
+  return (
+    <main className="min-h-screen bg-[#0d0d0f] px-6 py-16 text-white">
+      <div className="mx-auto max-w-6xl">
+        <section className="mb-8 rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_85%_20%,rgba(212,175,55,0.18),transparent_30%),#15161a] p-8 shadow-2xl shadow-black/30">
+          <p className="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-[#d4af37]">
+            Dealer CRM
+          </p>
+          <h1 className="text-4xl font-black text-white sm:text-5xl">
+            Manage buyer leads and follow-up.
+          </h1>
+          <p className="mt-4 max-w-3xl text-white/55">
+            Track enquiries, assigned specialists, follow-up flags and vehicle
+            context from one dealer CRM view.
+          </p>
+          <div className="mt-6 flex flex-wrap gap-3">
+            <Link
+              href="/dealers/dashboard"
+              className="rounded-xl border border-white/15 px-4 py-2 text-sm font-semibold text-white hover:border-[#d4af37]/50 hover:text-[#d4af37]"
+            >
+              Dealer dashboard
+            </Link>
+            <Link
+              href="/dealers/leads"
+              className="rounded-xl bg-[#d4af37] px-4 py-2 text-sm font-bold text-black hover:bg-[#e6c65c]"
+            >
+              Lead inbox
+            </Link>
+          </div>
+        </section>
+
+        {isLoading ? (
+          <div className="rounded-[2rem] border border-white/10 bg-[#15161a] p-8 text-center text-white/55">
+            Loading CRM...
+          </div>
+        ) : data?.error ? (
+          <div className="rounded-[2rem] border border-[#d4af37]/30 bg-[#d4af37]/10 p-8 text-[#f4d77c]">
+            {data.error}
+          </div>
+        ) : (
+          <>
+            <div className="mb-6 grid gap-4 md:grid-cols-3">
+              <div className="rounded-2xl border border-white/10 bg-[#15161a] p-5">
+                <p className="text-xs uppercase tracking-[0.2em] text-white/35">
+                  Leads
+                </p>
+                <p className="mt-2 text-3xl font-black text-[#d4af37]">
+                  {(data?.totals?.leads ?? leads.length).toLocaleString("en-AU")}
+                </p>
+              </div>
+              <div className="rounded-2xl border border-white/10 bg-[#15161a] p-5">
+                <p className="text-xs uppercase tracking-[0.2em] text-white/35">
+                  Vehicles
+                </p>
+                <p className="mt-2 text-3xl font-black text-[#d4af37]">
+                  {(data?.totals?.vehicles ?? 0).toLocaleString("en-AU")}
+                </p>
+              </div>
+              <div className="rounded-2xl border border-white/10 bg-[#15161a] p-5">
+                <p className="text-xs uppercase tracking-[0.2em] text-white/35">
+                  Follow-up
+                </p>
+                <p className="mt-2 text-3xl font-black text-[#d4af37]">
+                  {leads
+                    .filter((lead) => lead.insights.includes("Lead requires follow-up"))
+                    .length.toLocaleString("en-AU")}
+                </p>
+              </div>
+            </div>
+
+            <div className="mb-6 grid gap-3 md:grid-cols-[1fr_14rem]">
+              <input
+                type="search"
+                value={search}
+                onChange={(event) => setSearch(event.target.value)}
+                placeholder="Search buyer, vehicle, phone, email or note"
+                className="rounded-2xl border border-white/10 bg-black/30 p-4 text-white outline-none placeholder:text-white/35 focus:border-[#d4af37]/60"
+              />
+              <select
+                value={statusFilter}
+                onChange={(event) => setStatusFilter(event.target.value)}
+                className="rounded-2xl border border-white/10 bg-black/30 p-4 text-white outline-none focus:border-[#d4af37]/60"
+              >
+                <option value="all">All leads</option>
+                <option value="4wd">4WD enquiries</option>
+                <option value="follow-up">Needs follow-up</option>
+                <option value="general">General enquiries</option>
+              </select>
+            </div>
+
+            {liveLeads.length === 0 ? (
+              <p className="mb-4 rounded-2xl border border-[#d4af37]/30 bg-[#d4af37]/10 p-4 text-sm text-[#f4d77c]">
+                Showing sample CRM pipeline cards until live dealer leads arrive.
+              </p>
+            ) : null}
+
+            <div className="grid gap-4 xl:grid-cols-4">
+              {dealerCrmPipelineColumns.map((column) => {
+                const columnLeads = filteredLeads.filter(
+                  (lead) => inferDealerCrmPipelineStatus(lead) === column.status,
+                );
+
+                return (
+                  <section
+                    key={column.status}
+                    className="rounded-[1.5rem] border border-white/10 bg-[#15161a] p-4 shadow-xl shadow-black/20"
+                  >
+                    <h2 className="border-b border-white/10 pb-3 text-sm font-black tracking-[0.22em] text-[#d4af37]">
+                      {column.label}
+                    </h2>
+                    <div className="mt-4 space-y-3">
+                      {columnLeads.map((lead) => (
+                        <Link
+                          key={lead.id}
+                          href={`/dealers/crm/${encodeURIComponent(lead.id)}`}
+                          className="rounded-2xl border border-white/10 bg-black/25 p-4"
+                        >
+                          <p className="text-lg font-bold text-white">
+                            {lead.buyer.name}
+                          </p>
+                          <p className="mt-1 text-sm font-semibold text-[#f4d77c]">
+                            {lead.vehicle.title}
+                          </p>
+                          <p className="mt-1 text-xs text-white/45">
+                            {formatMoney(lead.vehicle.price)}
+                          </p>
+                          <p className="mt-3 line-clamp-3 text-sm leading-6 text-white/55">
+                            {lead.message || "No message provided."}
+                          </p>
+                          {lead.insights.length > 0 ? (
+                            <div className="mt-3 flex flex-wrap gap-2">
+                              {lead.insights.map((insight) => (
+                                <span
+                                  key={insight}
+                                  className="rounded-full border border-emerald-400/25 bg-emerald-500/10 px-2 py-1 text-[11px] font-semibold text-emerald-100"
+                                >
+                                  {insight}
+                                </span>
+                              ))}
+                            </div>
+                          ) : null}
+                        </Link>
+                      ))}
+                      {columnLeads.length === 0 ? (
+                        <p className="rounded-2xl border border-dashed border-white/15 p-4 text-center text-sm text-white/35">
+                          No leads
+                        </p>
+                      ) : null}
+                    </div>
+                  </section>
+                );
+              })}
+            </div>
+          </>
+        )}
+      </div>
+    </main>
+  );
+}
