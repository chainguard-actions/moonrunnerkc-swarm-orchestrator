# Swarm Orchestrator – Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Agent API Keys ──
# Required depending on which agent tool you use (--tool flag).
# copilot: no key required (uses GitHub Copilot session)
# claude-code: requires ANTHROPIC_API_KEY
# codex: requires OPENAI_API_KEY
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── GitHub ──
# Used for PR automation and GitHub Actions integration.
GITHUB_TOKEN=

# ── Optional ──
# COPILOT_TOKEN=
# GOOGLE_APPLICATION_CREDENTIALS=

# ── Health Service ──
# DATABASE_URL for the FastAPI health service.
# For local development with docker-compose, the Postgres DSN is:
DATABASE_URL=postgresql://health:health@db:5432/health_service
CORS_ORIGINS=
PORT=8000

# ── Database (docker-compose) ──
POSTGRES_USER=health
POSTGRES_PASSWORD=health
POSTGRES_DB=health_service
POSTGRES_PORT=5432

# ── Calculations API ──
CALC_API_PORT=3001

# ── Notes API ──
NOTES_API_PORT=3002

# ── Web (Inkwell) ──
WEB_PORT=5173
