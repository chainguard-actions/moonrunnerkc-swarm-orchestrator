{
  "name": "swarm-orchestrator",
  "version": "9.0.0",
  "description": "Contract-first AI coding swarm with hash-chained evidence. Compiles a goal into typed obligations, races persona candidates per obligation in a single cached inference session, verifies before commit, and logs every action in an append-only ledger.",
  "main": "dist/src/index.js",
  "bin": {
    "swarm": "dist/src/cli.js",
    "swarm-orchestrator": "dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "config/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-non-ts-assets.js && node -e \"require('fs').chmodSync('dist/src/cli.js', 0o755)\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test",
    "test": "npm run build && mocha --recursive 'dist/test/**/*.test.js'",
    "test:ci": "mocha --recursive 'dist/test/**/*.test.js'",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'test/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'test/**/*.ts'",
    "start": "node dist/src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonrunnerkc/swarm-orchestrator.git"
  },
  "keywords": [
    "cli",
    "falsification",
    "attestation",
    "verification",
    "quality-gates",
    "orchestrator",
    "agent-orchestrator",
    "swarm",
    "ai",
    "swe-bench",
    "copilot",
    "copilot-cli",
    "claude-code",
    "codex"
  ],
  "author": "Bradley R. Kinnard",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/moonrunnerkc/swarm-orchestrator/issues"
  },
  "homepage": "https://github.com/moonrunnerkc/swarm-orchestrator#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.10",
    "eslint": "^10.2.1",
    "madge": "^8.0.0",
    "mocha": "^11.7.5",
    "msw": "^2.14.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@octokit/rest": "^20",
    "ajv": "^8.20.0",
    "js-yaml": "^4.1.1",
    "parse-diff": "^0.12.0",
    "typescript": "^5.9.3"
  }
}
